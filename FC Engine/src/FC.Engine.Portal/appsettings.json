{
  "EngineApi": {
    "BaseUrl": "https://localhost:5001"
  },
  "ConnectionStrings": {
    "FcEngine": "Server=localhost,1433;Database=FcEngine;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=true"
  },
  "DataResidency": {
    "DefaultRegion": "SouthAfricaNorth",
    "MultiJurisdictionRegion": "WestEurope",
    "RegionConnectionStrings": {
      "SouthAfricaNorth": "FcEngine",
      "WestEurope": "FcEngine",
      "UAE North": "FcEngine",
      "UAENorth": "FcEngine"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/portal-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "FileStorage": {
    "Provider": "Local",
    "Local": {
      "BasePath": "wwwroot/uploads",
      "BaseUrl": "/uploads"
    }
  },
  "Notifications": {
    "Email": {
      "Provider": "SendGrid",
      "SendGrid": {
        "ApiKey": "",
        "DefaultFromEmail": "noreply@regos.app",
        "DefaultFromName": "RegOS"
      },
      "AwsSes": {
        "Region": "eu-west-1",
        "AccessKeyId": "",
        "SecretAccessKey": "",
        "DefaultFromEmail": "noreply@regos.app",
        "DefaultFromName": "RegOS",
        "ConfigurationSetName": ""
      }
    },
    "Sms": {
      "Provider": "AfricasTalking",
      "AfricasTalking": {
        "Username": "",
        "ApiKey": "",
        "SenderId": "RegOS",
        "BaseUrl": "https://api.africastalking.com"
      }
    },
    "SignalR": {
      "RedisBackplane": false
    }
  },
  "PrivacyCompliance": {
    "PolicyVersion": "2.1",
    "DsarDueDays": 30,
    "RetentionYears": 7
  },
  "AllowedHosts": "*"
}
