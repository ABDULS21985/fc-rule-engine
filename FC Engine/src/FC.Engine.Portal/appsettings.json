{
  "ConnectionStrings": {
    "FcEngine": "Server=localhost,1433;Database=FcEngine;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=true"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/portal-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "FileStorage": {
    "Provider": "Local",
    "Local": {
      "BasePath": "wwwroot/uploads",
      "BaseUrl": "/uploads"
    }
  },
  "Notifications": {
    "Email": {
      "Provider": "SendGrid",
      "SendGrid": {
        "ApiKey": "",
        "DefaultFromEmail": "noreply@regos.app",
        "DefaultFromName": "RegOS"
      }
    },
    "Sms": {
      "Provider": "AfricasTalking",
      "AfricasTalking": {
        "Username": "",
        "ApiKey": "",
        "SenderId": "RegOS",
        "BaseUrl": "https://api.africastalking.com"
      }
    },
    "SignalR": {
      "RedisBackplane": false
    }
  },
  "AllowedHosts": "*"
}
