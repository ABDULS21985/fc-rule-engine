@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@using System.Security.Claims
@using FC.Engine.Domain.Enums
@inject NotificationService NotificationSvc
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="portal-notif-bell-wrapper" @onkeydown="HandleKeyDown">
    <button class="portal-topbar-notification"
            @onclick="ToggleDropdown"
            aria-label="Notifications (@unreadCount unread)"
            aria-expanded="@isOpen"
            aria-haspopup="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
            <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
            <path d="M13.73 21a2 2 0 01-3.46 0"/>
        </svg>
        @if (hasUrgent && unreadCount > 0)
        {
            <span class="portal-notif-bell-badge portal-notif-bell-badge-urgent" aria-hidden="true">
                @(unreadCount > 99 ? "99+" : unreadCount.ToString())
            </span>
        }
        else if (unreadCount > 0)
        {
            <span class="portal-notif-bell-badge" aria-hidden="true">
                @(unreadCount > 99 ? "99+" : unreadCount.ToString())
            </span>
        }
    </button>

    @if (isOpen)
    {
        <div class="portal-notif-backdrop" @onclick="CloseDropdown" role="presentation" aria-hidden="true"></div>
        <div class="portal-notif-dropdown" role="region" aria-label="Recent notifications">
            <div class="portal-notif-dropdown-header">
                <span class="portal-notif-dropdown-title">Notifications</span>
                <div class="portal-notif-dropdown-header-actions">
                    <button class="portal-notif-sound-toggle"
                            @onclick="ToggleSound"
                            @onclick:stopPropagation="true"
                            title="@(soundEnabled ? "Mute notification sounds" : "Enable notification sounds")"
                            aria-label="@(soundEnabled ? "Mute sounds" : "Enable sounds")">
                        @if (soundEnabled)
                        {
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
                                <path d="M19.07 4.93a10 10 0 010 14.14"/>
                                <path d="M15.54 8.46a5 5 0 010 7.07"/>
                            </svg>
                        }
                        else
                        {
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
                                <line x1="23" y1="9" x2="17" y2="15"/>
                                <line x1="17" y1="9" x2="23" y2="15"/>
                            </svg>
                        }
                    </button>
                    @if (unreadCount > 0)
                    {
                        <button class="portal-notif-dropdown-action" @onclick="MarkAllRead">
                            Mark all read
                        </button>
                    }
                </div>
            </div>

            <!-- Dropdown Tabs -->
            <div class="portal-notif-dropdown-tabs" role="tablist">
                <button class="portal-notif-dropdown-tab @(dropdownTab == DropdownTab.All ? "active" : "")"
                        @onclick="() => SetDropdownTab(DropdownTab.All)" role="tab">
                    All
                </button>
                <button class="portal-notif-dropdown-tab @(dropdownTab == DropdownTab.Alerts ? "active" : "")"
                        @onclick="() => SetDropdownTab(DropdownTab.Alerts)" role="tab">
                    Alerts
                </button>
                <button class="portal-notif-dropdown-tab @(dropdownTab == DropdownTab.System ? "active" : "")"
                        @onclick="() => SetDropdownTab(DropdownTab.System)" role="tab">
                    System
                </button>
                <button class="portal-notif-dropdown-tab @(dropdownTab == DropdownTab.Audit ? "active" : "")"
                        @onclick="() => SetDropdownTab(DropdownTab.Audit)" role="tab">
                    Audit
                </button>
            </div>

            @if (isLoadingDropdown)
            {
                <div class="portal-notif-dropdown-loading">
                    <div class="portal-skeleton portal-skeleton-block" style="height: 60px; margin: 0.5rem;"></div>
                    <div class="portal-skeleton portal-skeleton-block" style="height: 60px; margin: 0.5rem;"></div>
                </div>
            }
            else if (filteredDropdownNotifications.Count == 0)
            {
                <div class="portal-notif-dropdown-empty">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#22c55e"
                         stroke-width="1.5" aria-hidden="true">
                        <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                        <polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                    <span class="portal-notif-dropdown-empty-title">You're all caught up!</span>
                    <span class="portal-notif-dropdown-empty-desc">
                        @if (dropdownTab != DropdownTab.All)
                        {
                            @:No notifications in this category.
                        }
                        else
                        {
                            @:No new notifications right now.
                        }
                    </span>
                </div>
            }
            else
            {
                <div class="portal-notif-dropdown-list">
                    @foreach (var notif in filteredDropdownNotifications)
                    {
                        <a href="@(notif.Link ?? "/notifications")"
                           class="portal-notif-dropdown-item @(notif.IsRead ? "" : "portal-notif-dropdown-item-unread")"
                           @onclick="() => HandleNotifClick(notif)">
                            <div class="portal-notif-dropdown-item-icon @GetNotifTypeIconClass(notif.Type)">
                                @GetNotifTypeIcon(notif.Type)
                            </div>
                            <div class="portal-notif-dropdown-item-content">
                                <span class="portal-notif-dropdown-item-title">@notif.Title</span>
                                <span class="portal-notif-dropdown-item-msg">@TruncateMessage(notif.Message, 80)</span>
                                <span class="portal-notif-dropdown-item-time">@notif.TimeAgo</span>
                            </div>
                            @if (!notif.IsRead)
                            {
                                <span class="portal-notif-dropdown-item-dot @GetPriorityDotClass(notif.Priority)" aria-hidden="true"></span>
                            }
                        </a>
                    }
                </div>
            }

            <a href="/notifications" class="portal-notif-dropdown-footer" @onclick="CloseDropdown">
                View all notifications
            </a>
        </div>
    }
</div>

@code {
    private bool isOpen;
    private bool isLoadingDropdown;
    private int unreadCount;
    private bool hasUrgent;
    private bool soundEnabled;
    private DropdownTab dropdownTab = DropdownTab.All;
    private List<NotificationModel> recentNotifications = new();
    private List<NotificationModel> filteredDropdownNotifications = new();
    private HubConnection? _hubConnection;

    private int userId;
    private int institutionId;

    private enum DropdownTab { All, Alerts, System, Audit }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var state = await AuthState!;
            var userIdStr = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            var instIdStr = state.User.FindFirst("InstitutionId")?.Value;
            int.TryParse(userIdStr, out userId);
            int.TryParse(instIdStr, out institutionId);

            if (userId > 0 && institutionId > 0)
            {
                unreadCount = await NotificationSvc.GetUnreadCount(userId, institutionId);
                var recent = await NotificationSvc.GetRecentUnread(userId, institutionId, 3);
                hasUrgent = recent.Any(n => n.Priority >= NotificationPriority.High);
            }

            await EnsureSignalRConnected();
        }
        catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                soundEnabled = await JS.InvokeAsync<bool>("portalNotifGetSoundPref");
            }
            catch { soundEnabled = false; }
        }
    }

    private async Task EnsureSignalRConnected()
    {
        if (_hubConnection is not null) return;

        try
        {
            var hubUrl = Navigation.ToAbsoluteUri("/hubs/notifications");
            var authCookie = HttpContextAccessor.HttpContext?.Request.Cookies["FC.Portal.Auth"];

            _hubConnection = new HubConnectionBuilder()
                .WithUrl(hubUrl, options =>
                {
                    if (!string.IsNullOrWhiteSpace(authCookie))
                    {
                        options.Cookies = new System.Net.CookieContainer();
                        options.Cookies.Add(hubUrl, new System.Net.Cookie("FC.Portal.Auth", authCookie));
                    }
                })
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<NotificationPayload>("ReceiveNotification", async payload =>
            {
                var updated = ApplyRealtimePayload(unreadCount, recentNotifications, payload);
                unreadCount = updated.UnreadCount;
                recentNotifications = updated.RecentNotifications;
                hasUrgent = recentNotifications.Any(n => n.Priority >= NotificationPriority.High);
                ApplyDropdownFilter();

                await InvokeAsync(StateHasChanged);

                if (soundEnabled)
                {
                    try { await JS.InvokeVoidAsync("portalNotifPlaySound"); }
                    catch { /* non-fatal */ }
                }
            });

            await _hubConnection.StartAsync();
        }
        catch
        {
            // Non-fatal fallback: UI still works with normal refresh/loading flow.
        }
    }

    private async Task ToggleDropdown()
    {
        if (isOpen)
        {
            isOpen = false;
            return;
        }

        isOpen = true;
        isLoadingDropdown = true;
        dropdownTab = DropdownTab.All;
        StateHasChanged();

        try
        {
            if (userId > 0 && institutionId > 0)
            {
                recentNotifications = await NotificationSvc.GetRecentUnread(userId, institutionId, 5);

                // If fewer than 7 unread, pad with recent ones
                if (recentNotifications.Count < 7)
                {
                    var all = await NotificationSvc.GetNotifications(userId, institutionId, 1, 7);
                    foreach (var n in all.Notifications)
                    {
                        if (recentNotifications.All(r => r.Id != n.Id))
                        {
                            recentNotifications.Add(n);
                            if (recentNotifications.Count >= 7) break;
                        }
                    }
                }

                ApplyDropdownFilter();
            }
        }
        catch { }
        finally
        {
            isLoadingDropdown = false;
            StateHasChanged();
        }
    }

    private void SetDropdownTab(DropdownTab tab)
    {
        dropdownTab = tab;
        ApplyDropdownFilter();
    }

    private void ApplyDropdownFilter()
    {
        filteredDropdownNotifications = dropdownTab switch
        {
            DropdownTab.Alerts => recentNotifications
                .Where(n => n.Type is NotificationType.SubmissionResult
                    or NotificationType.DeadlineApproaching
                    or NotificationType.ApprovalRequest
                    or NotificationType.ApprovalResult)
                .ToList(),
            DropdownTab.System => recentNotifications
                .Where(n => n.Type is NotificationType.SystemAnnouncement or NotificationType.TeamUpdate)
                .ToList(),
            DropdownTab.Audit => recentNotifications
                .Where(n => n.Type == NotificationType.AuditEvent)
                .ToList(),
            _ => recentNotifications.ToList()
        };
    }

    private void CloseDropdown() => isOpen = false;

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" && isOpen)
            isOpen = false;
    }

    private async Task HandleNotifClick(NotificationModel notif)
    {
        if (!notif.IsRead)
        {
            await NotificationSvc.MarkAsRead(notif.Id);
            notif.IsRead = true;
            unreadCount = Math.Max(0, unreadCount - 1);
        }
        isOpen = false;
    }

    private async Task MarkAllRead()
    {
        try
        {
            await NotificationSvc.MarkAllAsRead(userId, institutionId);
            unreadCount = 0;
            hasUrgent = false;
            foreach (var n in recentNotifications) n.IsRead = true;
            StateHasChanged();
        }
        catch { }
    }

    private async Task ToggleSound()
    {
        soundEnabled = !soundEnabled;
        try { await JS.InvokeVoidAsync("portalNotifSetSoundPref", soundEnabled); }
        catch { }
    }

    private static string TruncateMessage(string msg, int maxLen)
    {
        if (string.IsNullOrEmpty(msg) || msg.Length <= maxLen) return msg;
        return msg[..maxLen] + "...";
    }

    private static string GetNotifTypeIconClass(NotificationType type) => type switch
    {
        NotificationType.SubmissionResult => "portal-notif-icon-submission",
        NotificationType.DeadlineApproaching => "portal-notif-icon-deadline",
        NotificationType.ApprovalRequest or NotificationType.ApprovalResult => "portal-notif-icon-approval",
        NotificationType.SystemAnnouncement => "portal-notif-icon-system",
        NotificationType.TeamUpdate => "portal-notif-icon-team",
        NotificationType.AuditEvent => "portal-notif-icon-audit",
        _ => "portal-notif-icon-system"
    };

    private static string GetPriorityDotClass(NotificationPriority priority) => priority switch
    {
        NotificationPriority.Critical or NotificationPriority.High => "portal-notif-dot-urgent",
        _ => ""
    };

    private static MarkupString GetNotifTypeIcon(NotificationType type) => type switch
    {
        NotificationType.SubmissionResult => new(
            "<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"/><polyline points=\"14 2 14 8 20 8\"/></svg>"),
        NotificationType.DeadlineApproaching => new(
            "<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/></svg>"),
        NotificationType.ApprovalRequest or NotificationType.ApprovalResult => new(
            "<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>"),
        NotificationType.SystemAnnouncement => new(
            "<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><line x1=\"12\" y1=\"16\" x2=\"12\" y2=\"12\"/><line x1=\"12\" y1=\"8\" x2=\"12.01\" y2=\"8\"/></svg>"),
        NotificationType.TeamUpdate => new(
            "<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/></svg>"),
        NotificationType.AuditEvent => new(
            "<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 20h9\"/><path d=\"M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z\"/></svg>"),
        _ => new("")
    };

    private static NotificationType MapPayloadType(string eventType)
    {
        if (eventType.StartsWith("deadline.", StringComparison.OrdinalIgnoreCase))
            return NotificationType.DeadlineApproaching;

        if (string.Equals(eventType, "return.submitted_for_review", StringComparison.OrdinalIgnoreCase))
            return NotificationType.ApprovalRequest;

        if (string.Equals(eventType, "return.approved", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(eventType, "return.rejected", StringComparison.OrdinalIgnoreCase))
            return NotificationType.ApprovalResult;

        if (eventType.StartsWith("subscription.", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(eventType, "system.announcement", StringComparison.OrdinalIgnoreCase))
            return NotificationType.SystemAnnouncement;

        if (eventType.StartsWith("breach.", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(eventType, "user.provisioned", StringComparison.OrdinalIgnoreCase))
            return NotificationType.AuditEvent;

        return NotificationType.SubmissionResult;
    }

    private static (int UnreadCount, List<NotificationModel> RecentNotifications) ApplyRealtimePayload(
        int currentUnreadCount,
        IReadOnlyList<NotificationModel> currentNotifications,
        NotificationPayload payload)
    {
        var notifications = currentNotifications.ToList();
        notifications.Insert(0, new NotificationModel
        {
            Id = 0,
            Type = MapPayloadType(payload.EventType),
            EventType = payload.EventType,
            Priority = payload.Priority,
            Title = payload.Title,
            Message = payload.Message,
            Link = payload.ActionUrl,
            IsRead = false,
            CreatedAt = payload.Timestamp,
            TimeAgo = "Just now"
        });

        if (notifications.Count > 10)
            notifications.RemoveAt(10);

        return (currentUnreadCount + 1, notifications);
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
            _hubConnection = null;
        }
    }
}
