@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@using System.Security.Claims
@using FC.Engine.Domain.Enums
@inject NotificationService NotificationSvc
@inject FC.Engine.Portal.Services.OverdueAlertService OverdueAlertSvc
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="portal-notif-bell-wrapper" @onkeydown="HandleKeyDown">
    <button class="portal-topbar-notification"
            @onclick="ToggleDrawer"
            aria-label="Notifications (@unreadCount unread)"
            aria-expanded="@isOpen"
            aria-haspopup="dialog">
        <span class="portal-notif-bell-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                <path d="M13.73 21a2 2 0 01-3.46 0"/>
            </svg>
        </span>
        @if (hasUrgent && unreadCount > 0)
        {
            <span class="portal-notif-bell-badge portal-notif-bell-badge-urgent" aria-hidden="true">
                @(unreadCount > 99 ? "99+" : unreadCount.ToString())
            </span>
        }
        else if (unreadCount > 0)
        {
            <span class="portal-notif-bell-badge" aria-hidden="true">
                @(unreadCount > 99 ? "99+" : unreadCount.ToString())
            </span>
        }
    </button>

    @if (isOpen)
    {
        <div class="portal-notif-drawer-overlay"
             @onclick="CloseDrawer"
             role="presentation"
             aria-hidden="true">
        </div>

        <div class="portal-notif-drawer" role="dialog" aria-label="Notification center" aria-modal="true">

            <div class="portal-notif-drawer-header">
                <div class="portal-notif-drawer-title-row">
                    <span class="portal-notif-drawer-title">Notifications</span>
                    @if (unreadCount > 0)
                    {
                        <span class="portal-notif-drawer-badge">@(unreadCount > 99 ? "99+" : unreadCount.ToString())</span>
                    }
                    <span class="portal-notif-poll-dot" title="Auto-refreshing every 30 s"></span>
                </div>
                <div class="portal-notif-drawer-header-actions">
                    <button class="portal-notif-sound-toggle"
                            @onclick="ToggleSound"
                            @onclick:stopPropagation="true"
                            title="@(soundEnabled ? "Mute notification sounds" : "Enable notification sounds")"
                            aria-label="@(soundEnabled ? "Mute sounds" : "Enable sounds")">
                        @if (soundEnabled)
                        {
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
                                <path d="M19.07 4.93a10 10 0 010 14.14"/>
                                <path d="M15.54 8.46a5 5 0 010 7.07"/>
                            </svg>
                        }
                        else
                        {
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
                                <line x1="23" y1="9" x2="17" y2="15"/>
                                <line x1="17" y1="9" x2="23" y2="15"/>
                            </svg>
                        }
                    </button>
                    <button class="portal-notif-drawer-close"
                            @onclick="CloseDrawer"
                            aria-label="Close notification panel">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="6" x2="6" y2="18"/>
                            <line x1="6" y1="6" x2="18" y2="18"/>
                        </svg>
                    </button>
                </div>
            </div>

            <div class="portal-notif-drawer-tabs" role="tablist">
                <button class="portal-notif-drawer-tab @(drawerTab == DrawerTab.All ? "active" : "")"
                        @onclick="() => SetDrawerTab(DrawerTab.All)" role="tab">All</button>
                <button class="portal-notif-drawer-tab @(drawerTab == DrawerTab.Alerts ? "active" : "")"
                        @onclick="() => SetDrawerTab(DrawerTab.Alerts)" role="tab">Alerts</button>
                <button class="portal-notif-drawer-tab @(drawerTab == DrawerTab.System ? "active" : "")"
                        @onclick="() => SetDrawerTab(DrawerTab.System)" role="tab">System</button>
                <button class="portal-notif-drawer-tab @(drawerTab == DrawerTab.Audit ? "active" : "")"
                        @onclick="() => SetDrawerTab(DrawerTab.Audit)" role="tab">Audit</button>
            </div>

            <div class="portal-notif-drawer-toolbar">
                <span style="font-size:0.75rem;color:var(--cbn-text-muted);">
                    @if (isLoadingDrawer)
                    {
                        <span>Loading…</span>
                    }
                    else
                    {
                        <span>Showing @Math.Min(filteredDrawerNotifs.Count, 10) of @filteredDrawerNotifs.Count</span>
                    }
                </span>
                @if (unreadCount > 0)
                {
                    <button class="portal-notif-dropdown-action" @onclick="MarkAllRead">Mark all read</button>
                }
            </div>

            <div class="portal-notif-drawer-body">
                @if (isLoadingDrawer)
                {
                    <div class="portal-notif-drawer-loading">
                        @for (int s = 0; s < 4; s++)
                        {
                            <div class="portal-skeleton portal-skeleton-block" style="height:72px;border-radius:10px;"></div>
                        }
                    </div>
                }
                else if (drawerGroups.Count == 0)
                {
                    <div class="portal-notif-drawer-empty">
                        <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="#22c55e"
                             stroke-width="1.5" aria-hidden="true">
                            <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                            <polyline points="22 4 12 14.01 9 11.01"/>
                        </svg>
                        <span class="portal-notif-drawer-empty-title">You're all caught up!</span>
                        <span class="portal-notif-drawer-empty-desc">
                            @if (drawerTab != DrawerTab.All)
                            {
                                @:No notifications in this category.
                            }
                            else
                            {
                                @:No new notifications right now.
                            }
                        </span>
                    </div>
                }
                else
                {
                    @foreach (var group in drawerGroups)
                    {
                        @if (group.IsGroupCard)
                        {
                            <div class="portal-notif-group">
                                <div class="portal-notif-group-header"
                                     @onclick="() => ToggleGroup(group.Key)"
                                     @oncontextmenu="(e) => OpenSnoozeMenu(group.Items[0].Id, e)"
                                     @oncontextmenu:preventDefault="true">
                                    <div class="portal-notif-group-avatar"
                                         style="background:@group.AvatarColor;">
                                        @group.Initials
                                    </div>
                                    <div class="portal-notif-group-info">
                                        <div class="portal-notif-group-summary">@group.Summary</div>
                                        <div class="portal-notif-group-meta">@group.MetaLine</div>
                                    </div>
                                    <button class="portal-notif-group-expand-btn" type="button"
                                            aria-expanded="@group.IsExpanded">
                                        @if (group.IsExpanded)
                                        {
                                            <span>Collapse</span>
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15"/></svg>
                                        }
                                        else
                                        {
                                            <span>@group.Items.Count items</span>
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                                        }
                                    </button>
                                </div>
                                @if (group.IsExpanded)
                                {
                                    <div class="portal-notif-group-items">
                                        @foreach (var n in group.Items)
                                        {
                                            @RichCard(n, inGroup: true)
                                        }
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            @RichCard(group.Items[0], inGroup: false)
                        }
                    }
                }
            </div>

            <a href="/notifications" class="portal-notif-drawer-footer" @onclick="CloseDrawer">
                View all notifications
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                </svg>
            </a>
        </div>
    }
</div>

@code {

    // ── Render Fragment: Rich Notification Card ───────────────────────────

    private RenderFragment RichCard(NotificationModel n, bool inGroup) => __builder =>
    {
        var isSnoozed = _snoozedIds.Contains(n.Id);
        var ctaLabel = GetCtaLabel(n.Type);
        var avatarColor = GetTypeColor(n.Type);
        var initials = GetInitials(n.Title);

        __builder.OpenElement(0, "div");
        __builder.AddAttribute(1, "class",
            "portal-notif-rich-card" +
            (n.IsRead ? " portal-notif-rich-card--read" : "") +
            (isSnoozed ? " portal-notif-rich-card--snoozed" : ""));
        __builder.AddAttribute(2, "data-notif-id", n.Id.ToString());
        __builder.AddAttribute(3, "data-is-read", n.IsRead ? "true" : "false");
        __builder.AddAttribute(4, "oncontextmenu",
            EventCallback.Factory.Create<MouseEventArgs>(this, (MouseEventArgs e) => OpenSnoozeMenu(n.Id, e)));
        __builder.AddAttribute(5, "oncontextmenu:preventDefault", true);

        // Avatar
        __builder.OpenElement(10, "div");
        __builder.AddAttribute(11, "class", "portal-notif-avatar");
        __builder.AddAttribute(12, "style", $"background:{avatarColor};");
        __builder.AddContent(13, initials);
        __builder.CloseElement();

        // Body
        __builder.OpenElement(20, "div");
        __builder.AddAttribute(21, "class", "portal-notif-rich-body");

        // Header row: title + time
        __builder.OpenElement(30, "div");
        __builder.AddAttribute(31, "class", "portal-notif-rich-header");

        __builder.OpenElement(32, "span");
        __builder.AddAttribute(33, "class", "portal-notif-rich-title");
        __builder.AddContent(34, n.Title);
        __builder.CloseElement();

        __builder.OpenElement(35, "span");
        __builder.AddAttribute(36, "class", "portal-notif-rich-time");
        __builder.AddAttribute(37, "title", n.CreatedAt.ToString("ddd d MMM yyyy HH:mm"));
        __builder.AddContent(38, n.TimeAgo);
        __builder.CloseElement();

        __builder.CloseElement(); // header row

        // Message
        __builder.OpenElement(40, "p");
        __builder.AddAttribute(41, "class", "portal-notif-rich-msg");
        __builder.AddContent(42, TruncateMessage(n.Message, 120));
        __builder.CloseElement();

        // Actions row
        __builder.OpenElement(50, "div");
        __builder.AddAttribute(51, "class", "portal-notif-rich-actions");

        if (!string.IsNullOrEmpty(n.Link))
        {
            __builder.OpenElement(52, "a");
            __builder.AddAttribute(53, "href", n.Link);
            __builder.AddAttribute(54, "class", "portal-notif-rich-cta");
            __builder.AddAttribute(55, "onclick",
                EventCallback.Factory.Create<MouseEventArgs>(this, (MouseEventArgs _) => HandleDrawerNotifClick(n)));
            __builder.AddContent(56, ctaLabel);
            __builder.CloseElement();
        }

        // Unread dot
        if (!n.IsRead)
        {
            __builder.OpenElement(60, "span");
            __builder.AddAttribute(61, "class",
                "portal-notif-unread-dot" +
                (n.Priority >= NotificationPriority.High ? " portal-notif-unread-dot--urgent" : ""));
            __builder.AddAttribute(62, "aria-label", "Unread");
            __builder.CloseElement();
        }

        // Dismiss ×
        __builder.OpenElement(70, "button");
        __builder.AddAttribute(71, "class", "portal-notif-dismiss-btn");
        __builder.AddAttribute(72, "title", "Dismiss");
        __builder.AddAttribute(73, "aria-label", "Dismiss notification");
        __builder.AddAttribute(74, "type", "button");
        __builder.AddAttribute(75, "onclick",
            EventCallback.Factory.Create<MouseEventArgs>(this, (MouseEventArgs _) => DismissNotif(n.Id)));
        __builder.AddAttribute(76, "onclick:stopPropagation", true);
        __builder.AddMarkupContent(77,
            "<svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\">" +
            "<line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg>");
        __builder.CloseElement();

        __builder.CloseElement(); // actions
        __builder.CloseElement(); // body
        __builder.CloseElement(); // card
    };

    // ── State ─────────────────────────────────────────────────────────────

    private bool isOpen;
    private bool isLoadingDrawer;
    private int unreadCount;
    private bool hasUrgent;
    private bool soundEnabled;
    private DrawerTab drawerTab = DrawerTab.All;
    private List<NotificationModel> drawerNotifs = new();
    private List<NotificationModel> filteredDrawerNotifs = new();
    private List<NotifGroup> drawerGroups = new();
    private HashSet<int> _snoozedIds = new();
    private HashSet<string> _expandedGroupKeys = new();
    private HubConnection? _hubConnection;
    private PeriodicTimer? _pollTimer;
    private CancellationTokenSource? _pollCts;
    private DotNetObjectReference<NotificationBell>? _selfRef;

    private int userId;
    private int institutionId;

    private enum DrawerTab { All, Alerts, System, Audit }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    // ── Notification Group model ─────────────────────────────────────────

    private class NotifGroup
    {
        public string Key { get; set; } = "";
        public string Summary { get; set; } = "";
        public string MetaLine { get; set; } = "";
        public string Initials { get; set; } = "";
        public string AvatarColor { get; set; } = "#1a6b3c";
        public List<NotificationModel> Items { get; set; } = new();
        public bool IsGroupCard { get; set; }
        public bool IsExpanded { get; set; }
    }

    // ── Lifecycle ─────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var state = await AuthState!;
            var userIdStr = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            var instIdStr = state.User.FindFirst("InstitutionId")?.Value;
            int.TryParse(userIdStr, out userId);
            int.TryParse(instIdStr, out institutionId);

            if (userId > 0 && institutionId > 0)
            {
                unreadCount = await NotificationSvc.GetUnreadCount(userId, institutionId);
                var recent = await NotificationSvc.GetRecentUnread(userId, institutionId, 3);
                hasUrgent = OverdueAlertSvc.OverdueCount > 0 || recent.Any(n => n.Priority >= NotificationPriority.High);
            }

            OverdueAlertSvc.OnChange += OnOverdueCountChanged;
            await EnsureSignalRConnected();
        }
        catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { soundEnabled = await JS.InvokeAsync<bool>("portalNotifGetSoundPref"); }
            catch { soundEnabled = false; }

            _selfRef = DotNetObjectReference.Create(this);
            StartBackgroundPolling();
        }

        if (isOpen)
        {
            try
            {
                await JS.InvokeVoidAsync("portalNotifHub.positionDrawer");
            }
            catch
            {
                // Drawer positioning is progressive enhancement only.
            }
        }
    }

    // ── 30-second background polling ─────────────────────────────────────

    private void StartBackgroundPolling()
    {
        _pollCts = new CancellationTokenSource();
        _pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(30));
        _ = PollLoop(_pollCts.Token);
    }

    private async Task PollLoop(CancellationToken ct)
    {
        try
        {
            while (await _pollTimer!.WaitForNextTickAsync(ct))
                await PollSilently();
        }
        catch (OperationCanceledException) { }
        catch { }
    }

    [JSInvokable]
    public async Task PollForUpdates() => await PollSilently();

    private async Task PollSilently()
    {
        try
        {
            if (userId <= 0 || institutionId <= 0) return;
            var newCount = await NotificationSvc.GetUnreadCount(userId, institutionId);
            if (newCount != unreadCount)
            {
                var prev = unreadCount;
                unreadCount = newCount;
                hasUrgent = newCount > 0;
                if (newCount > prev)
                {
                    // Animate bell + badge on new notifications
                    await InvokeAsync(async () =>
                    {
                        StateHasChanged();
                        try
                        {
                            await JS.InvokeVoidAsync("portalNotifHub.animateBell");
                            await JS.InvokeVoidAsync("portalNotifHub.animateBadge");
                            if (soundEnabled) await JS.InvokeVoidAsync("portalNotifPlaySound");
                        }
                        catch { }
                    });
                }
                else
                {
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch { }
    }

    // ── SignalR ──────────────────────────────────────────────────────────

    private async Task EnsureSignalRConnected()
    {
        if (_hubConnection is not null) return;
        try
        {
            var hubUrl = Navigation.ToAbsoluteUri("/hubs/notifications");
            var authCookie = HttpContextAccessor.HttpContext?.Request.Cookies["FC.Portal.Auth"];
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(hubUrl, options =>
                {
                    if (!string.IsNullOrWhiteSpace(authCookie))
                    {
                        options.Cookies = new System.Net.CookieContainer();
                        options.Cookies.Add(hubUrl, new System.Net.Cookie("FC.Portal.Auth", authCookie));
                    }
                })
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<NotificationPayload>("ReceiveNotification", async payload =>
            {
                var updated = ApplyRealtimePayload(unreadCount, drawerNotifs, payload);
                unreadCount = updated.UnreadCount;
                drawerNotifs = updated.Recent;
                hasUrgent = drawerNotifs.Any(n => n.Priority >= NotificationPriority.High);
                ApplyDrawerFilter();
                BuildDrawerGroups();

                await InvokeAsync(async () =>
                {
                    StateHasChanged();
                    try
                    {
                        await JS.InvokeVoidAsync("portalNotifHub.animateBell");
                        await JS.InvokeVoidAsync("portalNotifHub.animateBadge");
                        if (soundEnabled) await JS.InvokeVoidAsync("portalNotifPlaySound");
                    }
                    catch { }
                });
            });

            await _hubConnection.StartAsync();
        }
        catch { }
    }

    // ── Drawer ───────────────────────────────────────────────────────────

    private async Task ToggleDrawer()
    {
        if (isOpen) { isOpen = false; return; }

        isOpen = true;
        isLoadingDrawer = true;
        drawerTab = DrawerTab.All;
        StateHasChanged();

        try
        {
            if (userId > 0 && institutionId > 0)
            {
                var recent = await NotificationSvc.GetRecentUnread(userId, institutionId, 5);
                if (recent.Count < 10)
                {
                    var all = await NotificationSvc.GetNotifications(userId, institutionId, 1, 10);
                    foreach (var n in all.Notifications)
                    {
                        if (recent.All(r => r.Id != n.Id))
                        {
                            recent.Add(n);
                            if (recent.Count >= 10) break;
                        }
                    }
                }
                drawerNotifs = recent;
                // Load snooze state
                await RefreshSnoozeState();
                ApplyDrawerFilter();
                BuildDrawerGroups();
            }
        }
        catch { }
        finally
        {
            isLoadingDrawer = false;
            StateHasChanged();
        }
    }

    private void CloseDrawer() { isOpen = false; }

    private void SetDrawerTab(DrawerTab tab)
    {
        drawerTab = tab;
        ApplyDrawerFilter();
        BuildDrawerGroups();
    }

    private void ApplyDrawerFilter()
    {
        filteredDrawerNotifs = drawerTab switch
        {
            DrawerTab.Alerts => drawerNotifs
                .Where(n => n.Type is NotificationType.SubmissionResult
                    or NotificationType.DeadlineApproaching
                    or NotificationType.ApprovalRequest
                    or NotificationType.ApprovalResult)
                .ToList(),
            DrawerTab.System => drawerNotifs
                .Where(n => n.Type is NotificationType.SystemAnnouncement or NotificationType.TeamUpdate)
                .ToList(),
            DrawerTab.Audit => drawerNotifs
                .Where(n => n.Type == NotificationType.AuditEvent)
                .ToList(),
            _ => drawerNotifs.ToList()
        };
    }

    private void BuildDrawerGroups()
    {
        var list = filteredDrawerNotifs.Take(10).ToList();
        drawerGroups = new List<NotifGroup>();
        var processed = new HashSet<int>();

        for (int i = 0; i < list.Count; i++)
        {
            if (processed.Contains(list[i].Id)) continue;

            var n = list[i];
            var similar = new List<NotificationModel> { n };

            for (int j = i + 1; j < list.Count && similar.Count < 6; j++)
            {
                if (!processed.Contains(list[j].Id) && list[j].Type == n.Type)
                {
                    similar.Add(list[j]);
                    processed.Add(list[j].Id);
                }
            }
            processed.Add(n.Id);

            var groupKey = $"{n.Type}_{i}";
            var isExpanded = _expandedGroupKeys.Contains(groupKey);

            if (similar.Count >= 3)
            {
                drawerGroups.Add(new NotifGroup
                {
                    Key = groupKey,
                    Summary = $"{similar.Count} {GetTypePluralLabel(n.Type)}",
                    MetaLine = $"Latest: {similar[0].TimeAgo}",
                    Initials = GetTypeInitials(n.Type),
                    AvatarColor = GetTypeColor(n.Type),
                    Items = similar,
                    IsGroupCard = true,
                    IsExpanded = isExpanded
                });
            }
            else
            {
                foreach (var s in similar)
                {
                    drawerGroups.Add(new NotifGroup
                    {
                        Key = $"{s.Type}_{s.Id}",
                        Summary = s.Title,
                        Initials = GetInitials(s.Title),
                        AvatarColor = GetTypeColor(s.Type),
                        Items = new List<NotificationModel> { s },
                        IsGroupCard = false,
                        IsExpanded = false
                    });
                }
            }
        }
    }

    private void ToggleGroup(string key)
    {
        var group = drawerGroups.Find(g => g.Key == key);
        if (group == null) return;
        group.IsExpanded = !group.IsExpanded;
        if (group.IsExpanded) _expandedGroupKeys.Add(key);
        else _expandedGroupKeys.Remove(key);
    }

    // ── Snooze ───────────────────────────────────────────────────────────

    private async Task RefreshSnoozeState()
    {
        _snoozedIds.Clear();
        foreach (var n in drawerNotifs)
        {
            try
            {
                var snoozed = await JS.InvokeAsync<bool>("portalNotifHub.isSnoozed", n.Id);
                if (snoozed) _snoozedIds.Add(n.Id);
            }
            catch { }
        }
    }

    private async Task OpenSnoozeMenu(int notifId, MouseEventArgs e)
    {
        try { await JS.InvokeVoidAsync("portalNotifHub.showSnoozeMenu", notifId, e.ClientX, e.ClientY, _selfRef); }
        catch { }
    }

    [JSInvokable]
    public async Task OnSnoozeAction(int notifId, string action)
    {
        switch (action)
        {
            case "snooze_1h":
                var until1h = DateTimeOffset.UtcNow.AddHours(1).ToString("O");
                await JS.InvokeVoidAsync("portalNotifHub.setSnooze", notifId, until1h);
                _snoozedIds.Add(notifId);
                break;

            case "snooze_tomorrow":
                var tomorrow = DateTimeOffset.UtcNow.Date.AddDays(1).ToString("O");
                await JS.InvokeVoidAsync("portalNotifHub.setSnooze", notifId, tomorrow);
                _snoozedIds.Add(notifId);
                break;

            case "mute_type":
                var type = drawerNotifs.FirstOrDefault(n => n.Id == notifId)?.Type.ToString() ?? "";
                if (!string.IsNullOrEmpty(type))
                    await JS.InvokeVoidAsync("portalNotifHub.muteType", type);
                drawerNotifs.RemoveAll(n => n.Type.ToString() == type);
                ApplyDrawerFilter();
                BuildDrawerGroups();
                break;

            case "mark_read":
                await HandleDrawerNotifClickById(notifId);
                break;

            case "dismiss":
                await DismissNotif(notifId);
                break;
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task DismissNotif(int notifId)
    {
        try
        {
            if (notifId > 0) await NotificationSvc.MarkAsRead(notifId);
            drawerNotifs.RemoveAll(n => n.Id == notifId);
            _snoozedIds.Remove(notifId);
            ApplyDrawerFilter();
            BuildDrawerGroups();
        }
        catch { }
    }

    // ── Notification Interactions ─────────────────────────────────────────

    private async Task HandleDrawerNotifClick(NotificationModel notif)
    {
        if (!notif.IsRead)
        {
            try
            {
                await NotificationSvc.MarkAsRead(notif.Id);
                notif.IsRead = true;
                unreadCount = Math.Max(0, unreadCount - 1);
            }
            catch { }
        }
        isOpen = false;
    }

    private async Task HandleDrawerNotifClickById(int notifId)
    {
        var notif = drawerNotifs.FirstOrDefault(n => n.Id == notifId);
        if (notif != null) await HandleDrawerNotifClick(notif);
    }

    private async Task MarkAllRead()
    {
        try
        {
            await NotificationSvc.MarkAllAsRead(userId, institutionId);
            unreadCount = 0;
            hasUrgent = false;
            foreach (var n in drawerNotifs) n.IsRead = true;
            StateHasChanged();
        }
        catch { }
    }

    private async Task ToggleSound()
    {
        soundEnabled = !soundEnabled;
        try { await JS.InvokeVoidAsync("portalNotifSetSoundPref", soundEnabled); }
        catch { }
    }

    private void OnOverdueCountChanged()
    {
        if (OverdueAlertSvc.OverdueCount > 0) hasUrgent = true;
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" && isOpen) isOpen = false;
    }

    // ── Disposal ─────────────────────────────────────────────────────────

    public async ValueTask DisposeAsync()
    {
        OverdueAlertSvc.OnChange -= OnOverdueCountChanged;
        _selfRef?.Dispose();
        try { _pollCts?.Cancel(); } catch { }
        _pollTimer?.Dispose();

        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
            _hubConnection = null;
        }
    }

