    private static string GetInitials(string title)
    {
        if (string.IsNullOrWhiteSpace(title)) return "N";
        var words = title.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (words.Length == 1) return words[0][..Math.Min(2, words[0].Length)].ToUpperInvariant();
        return (words[0][0].ToString() + words[1][0].ToString()).ToUpperInvariant();
    }

    private static NotificationType MapPayloadType(string eventType)
    {
        if (eventType.StartsWith("deadline.", StringComparison.OrdinalIgnoreCase))
            return NotificationType.DeadlineApproaching;
        if (eventType.Equals("return.submitted_for_review", StringComparison.OrdinalIgnoreCase))
            return NotificationType.ApprovalRequest;
        if (eventType.Equals("return.approved", StringComparison.OrdinalIgnoreCase) ||
            eventType.Equals("return.rejected", StringComparison.OrdinalIgnoreCase))
            return NotificationType.ApprovalResult;
        if (eventType.StartsWith("subscription.", StringComparison.OrdinalIgnoreCase) ||
            eventType.Equals("system.announcement", StringComparison.OrdinalIgnoreCase))
            return NotificationType.SystemAnnouncement;
        if (eventType.StartsWith("breach.", StringComparison.OrdinalIgnoreCase) ||
            eventType.Equals("user.provisioned", StringComparison.OrdinalIgnoreCase))
            return NotificationType.AuditEvent;
        return NotificationType.SubmissionResult;
    }

    private static (int UnreadCount, List<NotificationModel> Recent) ApplyRealtimePayload(
        int currentCount, IReadOnlyList<NotificationModel> current, NotificationPayload payload)
    {
        var list = current.ToList();
        list.Insert(0, new NotificationModel
        {
            Id = 0,
            Type = MapPayloadType(payload.EventType),
            EventType = payload.EventType,
            Priority = payload.Priority,
            Title = payload.Title,
            Message = payload.Message,
            Link = payload.ActionUrl,
            IsRead = false,
            CreatedAt = payload.Timestamp,
            TimeAgo = "Just now"
        });
        if (list.Count > 10) list.RemoveAt(10);
        return (currentCount + 1, list);
    }
