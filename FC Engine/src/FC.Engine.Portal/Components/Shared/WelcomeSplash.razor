@implements IAsyncDisposable
@inject OnboardingStateService OnboardingState
@inject NavigationManager Navigation

@if (_show)
{
    <div class="portal-welcome-backdrop" @onclick="JumpIn" role="presentation" aria-hidden="true"></div>

    <div class="portal-welcome-modal @(_animatingOut ? "portal-welcome-modal--out" : "")"
         role="dialog" aria-modal="true" aria-labelledby="portal-welcome-title"
         @onclick:stopPropagation="true">

        <div class="portal-welcome-deco" aria-hidden="true">
            <div class="portal-welcome-deco-ring portal-welcome-deco-ring--1"></div>
            <div class="portal-welcome-deco-ring portal-welcome-deco-ring--2"></div>
        </div>

        <div class="portal-welcome-logo" aria-hidden="true">
            <svg viewBox="0 0 56 56" fill="none" width="56" height="56">
                <circle cx="28" cy="28" r="28" fill="#006B3F" fill-opacity=".1"/>
                <circle cx="28" cy="28" r="20" fill="#006B3F" fill-opacity=".08"/>
                <path d="M16 28l8 8 16-16" stroke="#006B3F" stroke-width="3.5"
                      stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>

        <h2 class="portal-welcome-title" id="portal-welcome-title">Welcome to FC Engine</h2>
        <p class="portal-welcome-subtitle">
            Your regulatory returns portal. Submit, track, and manage compliance returns — all in one place.
        </p>

        <div class="portal-welcome-options">
            <button class="portal-welcome-option portal-welcome-option--primary"
                    @onclick="StartTour" type="button">
                <span class="portal-welcome-option-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                        <circle cx="12" cy="12" r="10"/>
                        <polygon points="10 8 16 12 10 16 10 8"/>
                    </svg>
                </span>
                <div class="portal-welcome-option-text">
                    <strong>Take the tour</strong>
                    <span>2-minute guided walkthrough</span>
                </div>
                <svg class="portal-welcome-option-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
            </button>

            <button class="portal-welcome-option" @onclick="JumpIn" type="button">
                <span class="portal-welcome-option-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                    </svg>
                </span>
                <div class="portal-welcome-option-text">
                    <strong>Jump straight in</strong>
                    <span>Start working right away</span>
                </div>
                <svg class="portal-welcome-option-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
            </button>

            <button class="portal-welcome-option" @onclick="WatchVideo" type="button">
                <span class="portal-welcome-option-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                        <polyline points="8 21 12 17 16 21"/>
                        <line x1="12" y1="17" x2="12" y2="21"/>
                    </svg>
                </span>
                <div class="portal-welcome-option-text">
                    <strong>Watch intro video</strong>
                    <span>5-minute overview</span>
                </div>
                <svg class="portal-welcome-option-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
            </button>
        </div>

        <p class="portal-welcome-skip">
            <button class="portal-welcome-skip-btn" @onclick="JumpIn" type="button">
                Skip — I'll explore on my own
            </button>
        </p>
    </div>
}

@code {
    private bool _show;
    private bool _animatingOut;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!await OnboardingState.HasSeenWelcomeAsync())
        {
            _show = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task Dismiss()
    {
        _animatingOut = true;
        StateHasChanged();
        await Task.Delay(380);
        _show = false;
        await OnboardingState.MarkWelcomeSeenAsync();
        StateHasChanged();
    }

    private async Task StartTour()
    {
        await Dismiss();
        Navigation.NavigateTo("/onboarding/wizard");
    }

    private async Task JumpIn() => await Dismiss();

    private async Task WatchVideo()
    {
        await Dismiss();
        Navigation.NavigateTo("/help/getting-started");
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
