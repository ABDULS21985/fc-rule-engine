@* Reusable confirmation dialog for sensitive actions *@
@using FC.Engine.Portal.Services
@inject DialogService DialogService
@implements IDisposable

@if (DialogService.IsOpen && DialogService.CurrentRequest is not null)
{
    var req = DialogService.CurrentRequest;

    <div class="portal-modal-backdrop portal-modal-backdrop-active"
         @onclick="() => DialogService.Complete(false)"
         role="presentation">
        <div class="portal-modal portal-modal-sm portal-modal-active portal-confirm-dialog"
             role="alertdialog"
             aria-modal="true"
             aria-labelledby="confirm-dialog-title"
             aria-describedby="confirm-dialog-desc"
             @onclick:stopPropagation="true"
             @onkeydown="HandleKeyDown"
             tabindex="-1">
            <div class="portal-confirm-body">
                <!-- Icon -->
                <div class="portal-confirm-icon @(req.IsDestructive ? "portal-confirm-icon-danger" : "portal-confirm-icon-primary")" aria-hidden="true">
                    @if (req.Icon == "delete")
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                            <polyline points="3 6 5 6 21 6"/>
                            <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                            <line x1="10" y1="11" x2="10" y2="17"/>
                            <line x1="14" y1="11" x2="14" y2="17"/>
                        </svg>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                            <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                            <line x1="12" y1="9" x2="12" y2="13"/>
                            <line x1="12" y1="17" x2="12.01" y2="17"/>
                        </svg>
                    }
                </div>

                <h3 id="confirm-dialog-title" class="portal-confirm-title">@req.Title</h3>
                <p id="confirm-dialog-desc" class="portal-confirm-message">@req.Message</p>

                <div class="portal-confirm-actions">
                    <button class="portal-btn portal-btn-outline" @onclick="() => DialogService.Complete(false)" type="button">
                        @req.CancelText
                    </button>
                    <button class="portal-btn @(req.IsDestructive ? "portal-btn-danger" : "portal-btn-primary")"
                            @onclick="() => DialogService.Complete(true)" type="button">
                        @req.ConfirmText
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        DialogService.OnChange += HandleStateChanged;
    }

    private void HandleStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            DialogService.Complete(false);
        }
    }

    public void Dispose()
    {
        DialogService.OnChange -= HandleStateChanged;
    }
}
