@* Skeleton loading placeholder with shimmer wave animation *@

@switch (Variant)
{
    case SkeletonVariant.Text:
        <div class="fc-skel fc-skel-text" style="width: @Width;" aria-hidden="true"></div>
        break;

    case SkeletonVariant.TextLarge:
        <div class="fc-skel fc-skel-text-lg" style="width: @Width;" aria-hidden="true"></div>
        break;

    case SkeletonVariant.Heading:
        <div class="fc-skel fc-skel-text-xl" style="width: @Width;" aria-hidden="true"></div>
        break;

    case SkeletonVariant.Circle:
        <div class="fc-skel fc-skel-circle" style="width: @Size; height: @Size;" aria-hidden="true"></div>
        break;

    case SkeletonVariant.Block:
        <div class="fc-skel fc-skel-block" style="width: @Width; height: @Height;" aria-hidden="true"></div>
        break;

    case SkeletonVariant.Card:
        <div class="fc-skel-card" aria-hidden="true">
            <div class="fc-skel fc-skel-block" style="height: 140px;"></div>
            <div style="padding: var(--space-4); display: flex; flex-direction: column; gap: var(--space-2);">
                <div class="fc-skel fc-skel-text-lg" style="width: 70%;"></div>
                <div class="fc-skel fc-skel-text" style="width: 90%;"></div>
                <div class="fc-skel fc-skel-text" style="width: 50%;"></div>
            </div>
        </div>
        break;

    case SkeletonVariant.TableRows:
        <div aria-hidden="true">
            @for (int i = 0; i < RowCount; i++)
            {
                <div class="fc-skel-row" style="display: flex; gap: var(--space-4); padding: var(--space-3) 0; border-bottom: 1px solid var(--cbn-border-subtle);">
                    <div class="fc-skel fc-skel-text" style="width: 15%;"></div>
                    <div class="fc-skel fc-skel-text" style="width: 25%;"></div>
                    <div class="fc-skel fc-skel-text" style="width: 20%;"></div>
                    <div class="fc-skel fc-skel-text" style="width: 15%;"></div>
                    <div class="fc-skel fc-skel-text" style="width: 10%;"></div>
                </div>
            }
        </div>
        break;
}

@code {
    [Parameter] public SkeletonVariant Variant { get; set; } = SkeletonVariant.Text;
    [Parameter] public string Width { get; set; } = "100%";
    [Parameter] public string Height { get; set; } = "100px";
    [Parameter] public string Size { get; set; } = "40px";
    [Parameter] public int RowCount { get; set; } = 5;

    public enum SkeletonVariant
    {
        Text,
        TextLarge,
        Heading,
        Circle,
        Block,
        Card,
        TableRows
    }
}
