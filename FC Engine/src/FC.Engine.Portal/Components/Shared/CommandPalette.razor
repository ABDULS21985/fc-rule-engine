@* RegOS™ Portal — Command Palette *@
@* Trigger: Ctrl+K / Cmd+K → [JSInvokable] OpenPalette() *@
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthProvider
@inject ISubmissionRepository SubmissionRepo

@if (_isOpen)
{
    <div class="portal-cmd-backdrop" @onclick="Close" aria-hidden="true"></div>

    <div class="portal-cmd-dialog"
         role="dialog"
         aria-label="Command palette"
         aria-modal="true">

        <div class="portal-cmd-header">
            <span class="portal-cmd-search-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
            </span>
            <input id="portal-cmd-input"
                   type="text"
                   class="portal-cmd-input"
                   placeholder="Search pages, submissions, actions..."
                   autocomplete="off"
                   spellcheck="false"
                   @bind="_query"
                   @bind:event="oninput"
                   @bind:after="OnQueryChanged"
                   @onkeydown="HandleKeyDown"
                   aria-label="Command palette search"
                   aria-autocomplete="list"
                   aria-controls="portal-cmd-results"
                   aria-activedescendant="@(_selectedIndex >= 0 && TotalItems > 0 ? $"cmd-item-{_selectedIndex}" : null)" />
            <button class="portal-cmd-esc-key" @onclick="Close" type="button" aria-label="Close palette">
                Esc
            </button>
        </div>

        <div id="portal-cmd-results"
             class="portal-cmd-results"
             role="listbox"
             aria-label="Results">

            @if (_loading)
            {
                <div class="portal-cmd-loading" role="status" aria-label="Loading results">
                    <svg class="portal-cmd-spinner" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                         width="24" height="24" aria-hidden="true">
                        <circle cx="12" cy="12" r="10" stroke-dasharray="50.27"
                                stroke-dashoffset="37.7" opacity="0.25"/>
                        <path d="M12 2a10 10 0 0 1 10 10"/>
                    </svg>
                </div>
            }
            else if (_filteredGroups.Count == 0)
            {
                <div class="portal-cmd-empty" role="status">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                         stroke-linejoin="round" aria-hidden="true">
                        <circle cx="11" cy="11" r="8"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <p class="portal-cmd-empty-text">Nothing found for '<strong>@_query</strong>'</p>
                    <p class="portal-cmd-empty-hint">Try searching by return code or period</p>
                </div>
            }
            else
            {
                var flatIdx = 0;
                @foreach (var group in _filteredGroups)
                {
                    <div class="portal-cmd-group" role="group" aria-label="@GetGroupLabel(group.Key)">
                        <div class="portal-cmd-group-label" aria-hidden="true">
                            @GetGroupIconSvg(group.Key)
                            <span>@GetGroupLabel(group.Key)</span>
                        </div>
                        @foreach (var item in group.Items)
                        {
                            var capturedIdx = flatIdx; flatIdx++;
                            <button id="cmd-item-@capturedIdx"
                                    class="portal-cmd-item @(capturedIdx == _selectedIndex ? "portal-cmd-item--active" : "")"
                                    role="option"
                                    aria-selected="@(capturedIdx == _selectedIndex)"
                                    @onclick="() => Navigate(item.Route)"
                                    @onmouseenter="() => _selectedIndex = capturedIdx"
                                    type="button"
                                    tabindex="-1">
                                <span class="portal-cmd-item-icon" aria-hidden="true">
                                    @GetItemIconSvg(group.Key)
                                </span>
                                <span class="portal-cmd-item-body">
                                    <span class="portal-cmd-item-label">@Highlight(item.Label)</span>
                                    @if (!string.IsNullOrEmpty(item.Secondary))
                                    {
                                        <span class="portal-cmd-item-secondary">@item.Secondary</span>
                                    }
                                </span>
                                <span class="portal-cmd-item-hint" aria-hidden="true">↵</span>
                            </button>
                        }
                    </div>
                }
            }
        </div>

        @if (!_loading && _filteredGroups.Any())
        {
            <div class="portal-cmd-footer" aria-hidden="true">
                <span><kbd>↑</kbd><kbd>↓</kbd> Navigate</span>
                <span><kbd>↵</kbd> Open</span>
                <span><kbd>Tab</kbd> Switch group</span>
                <span><kbd>Esc</kbd> Close</span>
            </div>
        }
    </div>
}

@code {
    // ── Types ─────────────────────────────────────────────────────────
