    private static readonly CmdItem[] QuickActions =
    [
        new("action-submit",      "Submit New Return",          "Start a new regulatory return",              "/submit",       CmdGroup.Actions, ["submit","new","return","file"]),
        new("action-bulk",        "Bulk Upload Returns",        "Upload multiple returns at once",            "/submit/bulk",  CmdGroup.Actions, ["bulk","upload","multiple"]),
        new("action-validate",    "Quick Validate",             "Validate data before submitting",            "/validate",     CmdGroup.Actions, ["validate","check","verify"]),
        new("action-certificate", "Download Certificate",       "Download your submission certificate",       "/submissions",  CmdGroup.Actions, ["download","certificate"]),
        new("action-extension",   "Request Extension",          "Request a reporting deadline extension",     "/submissions",  CmdGroup.Actions, ["extension","deadline","request"]),
        new("action-settings",    "Account Settings",           "Manage your profile and preferences",        "/settings",     CmdGroup.Actions, ["settings","account","profile"]),
    ];

    private static readonly CmdItem[] HelpItems =
    [
        new("help-start",   "Getting Started Guide",        "New to RegOS™ Portal?",                   "/help/getting-started",   CmdGroup.Help, ["getting","started","guide","new"]),
        new("help-submit",  "Submission Guide",              "Step-by-step return submission walkthrough", "/help/submission-guide",  CmdGroup.Help, ["submission","guide","how"]),
        new("help-val",     "Validation Errors Reference",   "Understanding and fixing validation errors", "/help/validation-errors", CmdGroup.Help, ["validation","errors","codes","fix"]),
        new("help-faq",     "FAQ",                           "Frequently asked questions",                 "/help/faq",               CmdGroup.Help, ["faq","questions","answers"]),
        new("help-support", "Contact Support",               "Get help from our support team",             "/help/support",           CmdGroup.Help, ["support","contact","ticket"]),
        new("help-kb",      "Knowledge Base",                "Browse articles and tutorials",              "/help/knowledge-base",    CmdGroup.Help, ["knowledge","base","articles"]),
    ];

    // ── Lifecycle ─────────────────────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _dotNetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("portalCommandPalette.init", _dotNetRef);
        Navigation.LocationChanged += OnLocationChanged;
        // Seed initial page in recent routes
        _recentRoutes.Add(new Uri(Navigation.Uri).AbsolutePath);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var route = new Uri(e.Location).AbsolutePath;
        _recentRoutes.Remove(route);
        _recentRoutes.Insert(0, route);
        if (_recentRoutes.Count > 10) _recentRoutes.RemoveAt(_recentRoutes.Count - 1);
        if (_isOpen) Close();
    }

    // ── Public API (JS-invokable) ─────────────────────────────────────
    [JSInvokable]
    public async Task OpenPalette()
    {
        _isOpen = true;
        _query = "";
        _selectedIndex = 0;
        _loading = !_subsLoaded;
        BuildResults();
        await InvokeAsync(StateHasChanged);
        await JS.InvokeVoidAsync("portalCommandPalette.focusInput", "portal-cmd-input");
        if (!_subsLoaded)
        {
            await LoadSubmissionsAsync();
            _subsLoaded = true;
            _loading = false;
            BuildResults();
            await InvokeAsync(StateHasChanged);
        }
    }

    // ── Data Loading ──────────────────────────────────────────────────
    private async Task LoadSubmissionsAsync()
    {
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var instIdStr = authState.User.FindFirst("InstitutionId")?.Value;
            if (!int.TryParse(instIdStr, out var institutionId)) return;

            var raw = await SubmissionRepo.GetByInstitution(institutionId);
            _submissions = raw
                .OrderByDescending(s => s.SubmittedAt)
                .Take(10)
                .Select(s => new CmdItem(
                    Id: $"sub-{s.Id}",
                    Label: $"{s.ReturnCode} — {(s.ReturnPeriod is not null ? new DateTime(s.ReturnPeriod.Year, s.ReturnPeriod.Month, 1).ToString("MMM yyyy") : "—")}",
                    Secondary: $"Submission · {s.Status}",
                    Route: $"/submissions/{s.Id}",
                    Group: CmdGroup.Submissions,
                    Keywords: [s.ReturnCode, s.Status.ToString(), "submission"]
                ))
                .ToList();
        }
        catch
        {
            // Silently handle — submissions section omitted
        }
    }

    // ── Filtering & Search ────────────────────────────────────────────
    private void OnQueryChanged()
    {
        _selectedIndex = 0;
        BuildResults();
    }

    private void BuildResults()
    {
        _filteredGroups.Clear();

        if (string.IsNullOrWhiteSpace(_query))
        {
            var recentItems = _recentRoutes
                .Select(r => AllPages.FirstOrDefault(p => p.Route == r))
                .OfType<CmdItem>()
                .Take(5)
                .ToList();
            if (recentItems.Count > 0)
                _filteredGroups.Add(new DisplayGroup(CmdGroup.Recent, recentItems));

            if (_submissions.Count > 0)
                _filteredGroups.Add(new DisplayGroup(CmdGroup.Submissions, _submissions.Take(5).ToList()));

            _filteredGroups.Add(new DisplayGroup(CmdGroup.Actions, [.. QuickActions]));
            _filteredGroups.Add(new DisplayGroup(CmdGroup.Help, HelpItems.Take(3).ToList()));
        }
        else
        {
            var q = _query.Trim();
            var pageHits = AllPages.Where(p => Matches(p, q)).Take(8).ToList();
            if (pageHits.Count > 0) _filteredGroups.Add(new DisplayGroup(CmdGroup.Pages, pageHits));

            var subHits = _submissions.Where(p => Matches(p, q)).Take(5).ToList();
            if (subHits.Count > 0) _filteredGroups.Add(new DisplayGroup(CmdGroup.Submissions, subHits));

            var actionHits = QuickActions.Where(p => Matches(p, q)).ToList();
            if (actionHits.Count > 0) _filteredGroups.Add(new DisplayGroup(CmdGroup.Actions, actionHits));

            var helpHits = HelpItems.Where(p => Matches(p, q)).ToList();
            if (helpHits.Count > 0) _filteredGroups.Add(new DisplayGroup(CmdGroup.Help, helpHits));
        }

        _selectedIndex = TotalItems > 0 ? 0 : -1;
    }

    private static bool Matches(CmdItem item, string q) =>
        item.Label.Contains(q, StringComparison.OrdinalIgnoreCase) ||
        (item.Secondary?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false) ||
        item.Keywords.Any(k => k.Contains(q, StringComparison.OrdinalIgnoreCase)) ||
        item.Route.Contains(q, StringComparison.OrdinalIgnoreCase);

    // ── Highlighting ──────────────────────────────────────────────────
    private MarkupString Highlight(string text)
    {
        if (string.IsNullOrWhiteSpace(_query))
            return (MarkupString)System.Text.Encodings.Web.HtmlEncoder.Default.Encode(text);

        var q = _query.Trim();
        var sb = new System.Text.StringBuilder();
        var enc = System.Text.Encodings.Web.HtmlEncoder.Default;
        var pos = 0;

        while (pos < text.Length)
        {
            var idx = text.IndexOf(q, pos, StringComparison.OrdinalIgnoreCase);
            if (idx < 0) { sb.Append(enc.Encode(text[pos..])); break; }
            sb.Append(enc.Encode(text[pos..idx]));
            sb.Append("<mark class=\"portal-cmd-match\">");
            sb.Append(enc.Encode(text[idx..(idx + q.Length)]));
            sb.Append("</mark>");
            pos = idx + q.Length;
        }
        return (MarkupString)sb.ToString();
    }

    // ── Keyboard Navigation ───────────────────────────────────────────
    private int TotalItems => _filteredGroups.Sum(g => g.Items.Count);

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "ArrowDown":
                MoveSelection(+1);
                await ScrollSelectedIntoView();
                break;
            case "ArrowUp":
                MoveSelection(-1);
                await ScrollSelectedIntoView();
                break;
            case "Tab":
                MoveToGroup(e.ShiftKey ? -1 : +1);
                await ScrollSelectedIntoView();
                break;
            case "Enter":
                SelectCurrent();
                break;
            case "Escape":
                Close();
                break;
        }
    }

    private void MoveSelection(int delta)
    {
        var total = TotalItems;
        if (total == 0) return;
        _selectedIndex = (_selectedIndex + delta + total) % total;
    }

    private void MoveToGroup(int direction)
    {
        if (_filteredGroups.Count == 0) return;
        var flat = GetFlatList();
        if (_selectedIndex < 0 || _selectedIndex >= flat.Count) return;
        var currentGroup = flat[_selectedIndex].Group;
        var groups = _filteredGroups.Select(g => g.Key).ToList();
        var gIdx = groups.IndexOf(currentGroup);
        var nextIdx = (gIdx + direction + groups.Count) % groups.Count;
        var firstOfNext = flat.FindIndex(f => f.Group == groups[nextIdx]);
        if (firstOfNext >= 0) _selectedIndex = firstOfNext;
    }

    private void SelectCurrent()
    {
        var flat = GetFlatList();
        if (_selectedIndex >= 0 && _selectedIndex < flat.Count)
            Navigate(flat[_selectedIndex].Route);
    }

    private List<CmdItem> GetFlatList() => [.. _filteredGroups.SelectMany(g => g.Items)];

    private async Task ScrollSelectedIntoView() =>
        await JS.InvokeVoidAsync("portalCommandPalette.scrollItemIntoView", $"cmd-item-{_selectedIndex}");

    // ── Actions ───────────────────────────────────────────────────────
    private void Navigate(string route)
    {
        Close();
        Navigation.NavigateTo(route);
    }

    private void Close()
    {
        _isOpen = false;
        _query = "";
        _selectedIndex = 0;
        StateHasChanged();
    }

    // ── Icons ─────────────────────────────────────────────────────────
    private static string GetGroupLabel(CmdGroup group) => group switch
    {
        CmdGroup.Recent      => "Recent",
        CmdGroup.Pages       => "Pages",
        CmdGroup.Submissions => "Submissions",
        CmdGroup.Actions     => "Quick Actions",
        CmdGroup.Help        => "Help",
        _                    => group.ToString()
    };

    private static MarkupString GetGroupIconSvg(CmdGroup group)
    {
        var d = group switch
        {
            CmdGroup.Recent      => "<circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/>",
            CmdGroup.Pages       => "<rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\"/><line x1=\"3\" y1=\"9\" x2=\"21\" y2=\"9\"/><line x1=\"9\" y1=\"21\" x2=\"9\" y2=\"9\"/>",
            CmdGroup.Submissions => "<path d=\"M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z\"/><polyline points=\"14 2 14 8 20 8\"/>",
            CmdGroup.Actions     => "<polygon points=\"13 2 3 14 12 14 11 22 21 10 12 10 13 2\"/>",
            CmdGroup.Help        => "<circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3\"/><line x1=\"12\" y1=\"17\" x2=\"12.01\" y2=\"17\"/>",
            _                    => ""
        };
        return (MarkupString)$"<svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">{d}</svg>";
    }

    private static MarkupString GetItemIconSvg(CmdGroup group)
    {
        var d = group switch
        {
            CmdGroup.Recent      => "<circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/>",
            CmdGroup.Pages       => "<rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\"/><line x1=\"3\" y1=\"9\" x2=\"21\" y2=\"9\"/><line x1=\"9\" y1=\"21\" x2=\"9\" y2=\"9\"/>",
            CmdGroup.Submissions => "<path d=\"M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z\"/><polyline points=\"14 2 14 8 20 8\"/>",
            CmdGroup.Actions     => "<polygon points=\"13 2 3 14 12 14 11 22 21 10 12 10 13 2\"/>",
            CmdGroup.Help        => "<circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3\"/><line x1=\"12\" y1=\"17\" x2=\"12.01\" y2=\"17\"/>",
            _                    => ""
        };
        return (MarkupString)$"<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">{d}</svg>";
    }

    // ── Dispose ───────────────────────────────────────────────────────
    public async ValueTask DisposeAsync()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        if (_dotNetRef is not null)
        {
            try { await JS.InvokeVoidAsync("portalCommandPalette.dispose"); } catch { }
            _dotNetRef.Dispose();
        }
    }
}
