                        @onclick='() => ToggleSectionAsync("Resources")'
                        aria-expanded="@(!_collapsedSections.Contains("Resources"))">
                    <span>Resources</span>
                    <svg class="portal-nav-collapse-icon @(_collapsedSections.Contains("Resources") ? "is-collapsed" : "")"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="12" height="12" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </button>
                <ul class="portal-nav-group-items @(_collapsedSections.Contains("Resources") ? "portal-nav-group-items--collapsed" : "")">
