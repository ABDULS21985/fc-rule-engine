                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                                <path d="M8 9h8"/>
                                <path d="M8 13h5"/>
                            </svg>
                            <span class="portal-nav-label">ComplianceIQ</span>
                        </NavLink>
                    </li>
                    <li>
                        <NavLink href="/dashboard/consolidation" class="portal-nav-item">
                            <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                <path d="M3 6h18"/><path d="M3 12h18"/><path d="M3 18h18"/><circle cx="8" cy="6" r="1"/><circle cx="16" cy="12" r="1"/><circle cx="12" cy="18" r="1"/>
                            </svg>
                            <span class="portal-nav-label">Consolidation</span>
                        </NavLink>
                    </li>
                    <AuthorizeView Roles="Admin">
                        <Authorized>
                            <li>
                                <NavLink href="/dashboard/admin" class="portal-nav-item">
                                    <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                        <line x1="12" y1="20" x2="12" y2="10"/>
                                        <line x1="18" y1="20" x2="18" y2="4"/>
                                        <line x1="6" y1="20" x2="6" y2="14"/>
                                    </svg>
                                    <span class="portal-nav-label">Admin Dashboard</span>
                                </NavLink>
                            </li>
                        </Authorized>
                    </AuthorizeView>
                    @if (HasAnyModuleAccess())
                    {
                        <li>
                            <NavLink href="@_primarySubmitHref" class="portal-nav-item portal-nav-primary-submit">
                                <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                                    <polyline points="17 8 12 3 7 8"/>
                                    <line x1="12" y1="3" x2="12" y2="15"/>
                                </svg>
                                <span class="portal-nav-label">Submit Return</span>
                            </NavLink>
                        </li>
                        <li>
                            <NavLink href="@_primaryBulkSubmitHref" class="portal-nav-item">
                                <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                    <path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/>
                                    <path d="M15 2H9a1 1 0 00-1 1v2a1 1 0 001 1h6a1 1 0 001-1V3a1 1 0 00-1-1z"/>
                                    <line x1="12" y1="11" x2="12" y2="17"/>
                                    <line x1="9" y1="14" x2="15" y2="14"/>
                                </svg>
                                <span class="portal-nav-label">Bulk Upload</span>
                            </NavLink>
                        </li>
                        <AuthorizeView Roles="Admin">
                            <Authorized>
                                <li>
                                    <NavLink href="/migration" class="portal-nav-item">
                                        <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                            <path d="M3 3h18v4H3z"/><path d="M5 7v14h14V7"/><path d="M8 12h8"/><path d="M8 16h6"/>
                                        </svg>
                                        <span class="portal-nav-label">Historical Migration</span>
                                    </NavLink>
                                </li>
                                <li>
                                    <NavLink href="/migration/tracker" class="portal-nav-item">
                                        <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                                        </svg>
                                        <span class="portal-nav-label">Migration Tracker</span>
                                    </NavLink>
                                </li>
                            </Authorized>
                        </AuthorizeView>
                        <li>
                            <NavLink href="/submissions" Match="NavLinkMatch.All" class="portal-nav-item">
                                <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                    <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
                                    <path d="M5.45 5.11L2 12v6a2 2 0 002 2h16a2 2 0 002-2v-6l-3.45-6.89A2 2 0 0016.76 4H7.24a2 2 0 00-1.79 1.11z"/>
                                </svg>
                                <span class="portal-nav-label">My Submissions</span>
                                @if (_navBadges.OverdueCount > 0)
                                {
                                    <span class="portal-nav-badge" title="@_navBadges.OverdueCount overdue submission(s)">@(_navBadges.OverdueCount > 9 ? "9+" : _navBadges.OverdueCount)</span>
                                }
                            </NavLink>
                        </li>
                        <li>
                            <NavLink href="/submissions/batches" class="portal-nav-item">
                                <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                    <polyline points="22 4 12 14.01 9 11.01"/>
                                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                                </svg>
                                <span class="portal-nav-label">Batch Submissions</span>
                            </NavLink>
                        </li>
                        @if (isCheckerOrAdmin)
                        {
                            <li>
                                <NavLink href="/approvals" class="portal-nav-item">
                                    <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                        <path d="M9 11l3 3L22 4"/>
                                        <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
                                    </svg>
                                    <span class="portal-nav-label">Pending Approvals</span>
                                    @if (_navBadges.PendingApprovalCount > 0)
                                    {
                                        <span class="portal-nav-badge" title="@_navBadges.PendingApprovalCount pending approval(s)">@(_navBadges.PendingApprovalCount > 9 ? "9+" : _navBadges.PendingApprovalCount)</span>
                                    }
                                </NavLink>
                            </li>
                        }
                    }
                    <li>
                        <NavLink href="/calendar" class="portal-nav-item">
                            <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                <line x1="16" y1="2" x2="16" y2="6"/>
                                <line x1="8" y1="2" x2="8" y2="6"/>
                                <line x1="3" y1="10" x2="21" y2="10"/>
                            </svg>
                            <span class="portal-nav-label">Reporting Calendar</span>
                            @if (_navBadges.CalendarDue7Days > 0)
                            {
                                <span class="portal-nav-badge portal-nav-badge--warning" title="@_navBadges.CalendarDue7Days return(s) due within 7 days">@_navBadges.CalendarDue7Days</span>
                            }
                        </NavLink>
                    </li>
                </ul>
            </div>

            <!-- VALIDATION -->
            @if (HasAnyModuleAccess())
            {
                <div class="portal-nav-group">
                    <button class="portal-nav-group-label portal-nav-group-toggle"
                            @onclick='() => ToggleSectionAsync("Validation")'
                            aria-expanded="@(!_collapsedSections.Contains("Validation"))">
                        <span>Validation</span>
                        <svg class="portal-nav-collapse-icon @(_collapsedSections.Contains("Validation") ? "is-collapsed" : "")"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="12" height="12" aria-hidden="true">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    </button>
                    <ul class="portal-nav-group-items @(_collapsedSections.Contains("Validation") ? "portal-nav-group-items--collapsed" : "")">
                        <li>
                            <NavLink href="/validation/hub" class="portal-nav-item" Match="NavLinkMatch.Prefix">
                                <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                    <circle cx="12" cy="12" r="10"/>
                                    <path d="M9 12l2 2 4-4"/>
                                    <path d="M12 2v2M12 20v2M2 12h2M20 12h2"/>
                                </svg>
                                <span class="portal-nav-label">Validation Hub</span>
                            </NavLink>
                        </li>
                        <li>
                            <NavLink href="/validation/cross-sheet" class="portal-nav-item">
                                <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                    <path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/>
                                    <path d="M15 2H9a1 1 0 00-1 1v2a1 1 0 001 1h6a1 1 0 001-1V3a1 1 0 00-1-1z"/>
                                    <path d="M9 14l2 2 4-4"/>
                                </svg>
                                <span class="portal-nav-label">Cross-Sheet Rules</span>
                            </NavLink>
                        </li>
                        <li>
                            <NavLink href="/validate" class="portal-nav-item">
                                <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                                    <polyline points="22 4 12 14.01 9 11.01"/>
                                </svg>
                                <span class="portal-nav-label">Quick Validate</span>
                            </NavLink>
                        </li>
                    </ul>
                </div>
            }

            <!-- REPORTS -->
            <div class="portal-nav-group">
                <button class="portal-nav-group-label portal-nav-group-toggle"
                        @onclick='() => ToggleSectionAsync("Reports")'
                        aria-expanded="@(!_collapsedSections.Contains("Reports"))">
                    <span>Reports</span>
                    <svg class="portal-nav-collapse-icon @(_collapsedSections.Contains("Reports") ? "is-collapsed" : "")"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="12" height="12" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </button>
                <ul class="portal-nav-group-items @(_collapsedSections.Contains("Reports") ? "portal-nav-group-items--collapsed" : "")">
                    <li>
                        <NavLink href="/reports/compliance" class="portal-nav-item">
                            <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                                <line x1="16" y1="13" x2="8" y2="13"/>
                                <line x1="16" y1="17" x2="8" y2="17"/>
                            </svg>
                            <span class="portal-nav-label">Compliance Report</span>
                        </NavLink>
