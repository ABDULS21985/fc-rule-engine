@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.ValueObjects
@inject FC.Engine.Portal.Services.ApprovalService ApprovalSvc
@inject FC.Engine.Portal.Services.DashboardService DashboardSvc
@inject IEntitlementService EntitlementSvc
@inject ITenantContext TenantContext
@inject ITenantBrandingService BrandingService
@inject FC.Engine.Portal.Services.PartnerPortalService PartnerPortalService
@inject PortalSubmissionLaunchService SubmissionLaunchService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IDisposable

<AuthorizeView>
    <Authorized Context="navAuth">
        <nav class="portal-nav" aria-label="Portal navigation">
            <div class="portal-nav-tenant-logo-wrap">
                <img src="@_branding.LogoSmallUrl" alt="@_branding.CompanyName" class="portal-nav-tenant-logo" />
            </div>

            <!-- RECENT PAGES -->
            @if (_recentPages.Count > 0)
            {
                <div class="portal-nav-recent">
                    <span class="portal-nav-recent-label">Recent</span>
                    <ul class="portal-nav-recent-list">
                        @foreach (var page in _recentPages)
                        {
                            var pageRef = page;
                            <li class="portal-nav-recent-item">
                                <a href="@pageRef.Href" class="portal-nav-recent-link">
                                    <svg class="portal-nav-recent-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="12" height="12" aria-hidden="true">
                                        <polyline points="9 14 4 9 9 4"/><path d="M20 20v-7a4 4 0 00-4-4H4"/>
                                    </svg>
                                    @pageRef.Label
                                </a>
                                <button class="portal-nav-recent-remove" @onclick="() => RemoveRecentPageAsync(pageRef.Href)" aria-label="Remove @pageRef.Label from recent">×</button>
                            </li>
                        }
                    </ul>
                </div>
            }

            <!-- SUBMISSIONS -->
            <div class="portal-nav-group">
                <button class="portal-nav-group-label portal-nav-group-toggle"
                        @onclick='() => ToggleSectionAsync("Submissions")'
                        aria-expanded="@(!_collapsedSections.Contains("Submissions"))">
                    <span>Submissions</span>
                    <svg class="portal-nav-collapse-icon @(_collapsedSections.Contains("Submissions") ? "is-collapsed" : "")"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="12" height="12" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </button>
                <ul class="portal-nav-group-items @(_collapsedSections.Contains("Submissions") ? "portal-nav-group-items--collapsed" : "")">
                    <li>
                        <NavLink href="/" Match="NavLinkMatch.All" class="portal-nav-item">
                            <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                <rect x="3" y="3" width="7" height="7"/>
                                <rect x="14" y="3" width="7" height="7"/>
                                <rect x="14" y="14" width="7" height="7"/>
                                <rect x="3" y="14" width="7" height="7"/>
                            </svg>
                            <span class="portal-nav-label">Dashboard</span>
                        </NavLink>
                    </li>
                    <li>
                        <NavLink href="/dashboard/compliance" class="portal-nav-item">
                            <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                <path d="M3 3h18v18H3z"/>
                                <path d="M9 9h6v6H9z"/>
                            </svg>
                            <span class="portal-nav-label">Compliance Summary</span>
                        </NavLink>
                    </li>
                    <li>
                        <NavLink href="/dashboard/health" class="portal-nav-item">
                            <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                            </svg>
                            <span class="portal-nav-label">Health Score</span>
                        </NavLink>
                    </li>
                    <li>
                        <NavLink href="/analytics/anomalies" class="portal-nav-item">
                            <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                <path d="M12 3l8 4v5c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V7l8-4z"/>
                                <path d="M12 8v5"/>
                                <circle cx="12" cy="16" r="1"/>
                            </svg>
                            <span class="portal-nav-label">Anomaly Review</span>
                        </NavLink>
                    </li>
                    <li>
                        <NavLink href="/analytics/foresight" class="portal-nav-item">
                            <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                <path d="M3 12s3-6 9-6 9 6 9 6-3 6-9 6-9-6-9-6z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                            <span class="portal-nav-label">ForeSight</span>
                        </NavLink>
                    </li>
                    <li>
                        <NavLink href="/analytics/chat" class="portal-nav-item">
