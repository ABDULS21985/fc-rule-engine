@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject FC.Engine.Portal.Services.ApprovalService ApprovalSvc

<AuthorizeView>
    <Authorized Context="navAuth">
        <nav class="portal-nav" aria-label="Portal navigation">

            <!-- SUBMISSIONS -->
            <div class="portal-nav-group">
                <h3 class="portal-nav-group-label">Submissions</h3>
                <ul class="portal-nav-group-items">
                    <li>
                        <NavLink href="/" Match="NavLinkMatch.All" class="portal-nav-item">
                            <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                <rect x="3" y="3" width="7" height="7"/>
                                <rect x="14" y="3" width="7" height="7"/>
                                <rect x="14" y="14" width="7" height="7"/>
                                <rect x="3" y="14" width="7" height="7"/>
                            </svg>
                            <span class="portal-nav-label">Dashboard</span>
                        </NavLink>
                    </li>
                    <li>
                        <NavLink href="/submit" class="portal-nav-item">
                            <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                                <polyline points="17 8 12 3 7 8"/>
                                <line x1="12" y1="3" x2="12" y2="15"/>
                            </svg>
                            <span class="portal-nav-label">Submit Return</span>
                        </NavLink>
                    </li>
                    <li>
                        <NavLink href="/submit/bulk" class="portal-nav-item">
                            <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                <path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/>
                                <path d="M15 2H9a1 1 0 00-1 1v2a1 1 0 001 1h6a1 1 0 001-1V3a1 1 0 00-1-1z"/>
                                <line x1="12" y1="11" x2="12" y2="17"/>
                                <line x1="9" y1="14" x2="15" y2="14"/>
                            </svg>
                            <span class="portal-nav-label">Bulk Upload</span>
                        </NavLink>
                    </li>
                    <li>
                        <NavLink href="/submissions" class="portal-nav-item">
                            <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
                                <path d="M5.45 5.11L2 12v6a2 2 0 002 2h16a2 2 0 002-2v-6l-3.45-6.89A2 2 0 0016.76 4H7.24a2 2 0 00-1.79 1.11z"/>
                            </svg>
                            <span class="portal-nav-label">My Submissions</span>
                        </NavLink>
                    </li>
                    @if (isCheckerOrAdmin)
                    {
                        <li>
                            <NavLink href="/approvals" class="portal-nav-item">
                                <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                    <path d="M9 11l3 3L22 4"/>
                                    <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
                                </svg>
                                <span class="portal-nav-label">Pending Approvals</span>
                                @if (pendingApprovalCount > 0)
                                {
                                    <span class="portal-nav-badge">@pendingApprovalCount</span>
                                }
                            </NavLink>
                        </li>
                    }
                    <li>
                        <NavLink href="/calendar" class="portal-nav-item">
                            <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                <line x1="16" y1="2" x2="16" y2="6"/>
                                <line x1="8" y1="2" x2="8" y2="6"/>
                                <line x1="3" y1="10" x2="21" y2="10"/>
                            </svg>
                            <span class="portal-nav-label">Reporting Calendar</span>
                        </NavLink>
                    </li>
                </ul>
            </div>

            <!-- VALIDATION -->
            <div class="portal-nav-group">
                <h3 class="portal-nav-group-label">Validation</h3>
                <ul class="portal-nav-group-items">
                    <li>
                        <NavLink href="/validation/cross-sheet" class="portal-nav-item">
                            <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                <path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/>
                                <path d="M15 2H9a1 1 0 00-1 1v2a1 1 0 001 1h6a1 1 0 001-1V3a1 1 0 00-1-1z"/>
                                <path d="M9 14l2 2 4-4"/>
                            </svg>
                            <span class="portal-nav-label">Cross-Sheet Rules</span>
                        </NavLink>
                    </li>
                </ul>
            </div>

            <!-- RESOURCES -->
            <div class="portal-nav-group">
                <h3 class="portal-nav-group-label">Resources</h3>
                <ul class="portal-nav-group-items">
                    <li>
                        <NavLink href="/templates" class="portal-nav-item">
                            <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                                <line x1="16" y1="13" x2="8" y2="13"/>
                                <line x1="16" y1="17" x2="8" y2="17"/>
                                <polyline points="10 9 9 9 8 9"/>
                            </svg>
                            <span class="portal-nav-label">Template Browser</span>
                        </NavLink>
                    </li>
                    <li>
                        <NavLink href="/schemas" class="portal-nav-item">
                            <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                                <polyline points="7 10 12 15 17 10"/>
                                <line x1="12" y1="15" x2="12" y2="3"/>
                            </svg>
                            <span class="portal-nav-label">Download Schemas</span>
                        </NavLink>
                    </li>
                    <li>
                        <NavLink href="/help" class="portal-nav-item">
                            <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                <circle cx="12" cy="12" r="10"/>
                                <path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/>
                                <line x1="12" y1="17" x2="12.01" y2="17"/>
                            </svg>
                            <span class="portal-nav-label">Help Center</span>
                        </NavLink>
                    </li>
                </ul>
            </div>

            <!-- ACCOUNT — Institution Admin only -->
            <AuthorizeView Roles="Admin">
                <Authorized Context="adminAuth">
                    <div class="portal-nav-group">
                        <h3 class="portal-nav-group-label">Account</h3>
                        <ul class="portal-nav-group-items">
                            <li>
                                <NavLink href="/institution" class="portal-nav-item">
                                    <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                                        <polyline points="9 22 9 12 15 12 15 22"/>
                                    </svg>
                                    <span class="portal-nav-label">My Institution</span>
                                </NavLink>
                            </li>
                            <li>
                                <NavLink href="/institution/team" class="portal-nav-item">
                                    <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                                        <circle cx="9" cy="7" r="4"/>
                                        <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                                        <path d="M16 3.13a4 4 0 010 7.75"/>
                                    </svg>
                                    <span class="portal-nav-label">Team Members</span>
                                </NavLink>
                            </li>
                            <li>
                                <NavLink href="/institution/settings" class="portal-nav-item">
                                    <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                        <circle cx="12" cy="12" r="3"/>
                                        <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/>
                                    </svg>
                                    <span class="portal-nav-label">Settings</span>
                                </NavLink>
                            </li>
                        </ul>
                    </div>
                </Authorized>
            </AuthorizeView>

        </nav>
    </Authorized>
</AuthorizeView>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool isCheckerOrAdmin;
    private int pendingApprovalCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var state = await AuthState!;
            var role = state.User.FindFirst(ClaimTypes.Role)?.Value ?? "";
            isCheckerOrAdmin = role == "Checker" || role == "Admin";

            if (isCheckerOrAdmin)
            {
                var instIdStr = state.User.FindFirst("InstitutionId")?.Value;
                if (int.TryParse(instIdStr, out var institutionId) && institutionId > 0)
                {
                    pendingApprovalCount = await ApprovalSvc.GetPendingCount(institutionId);
                }
            }
        }
        catch
        {
            // Silently handle — badge just won't show
        }
    }
}
