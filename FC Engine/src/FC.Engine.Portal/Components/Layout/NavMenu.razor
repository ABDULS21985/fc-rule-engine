@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool isCheckerOrAdmin;
    private bool _isPartnerTenant;
    private HashSet<string> _activeModules = new(StringComparer.OrdinalIgnoreCase);
    private BrandingConfig _branding = BrandingConfig.WithDefaults();

    private NavBadgeCounts _navBadges = NavBadgeCounts.Empty;
    private int _institutionId;
    private Timer? _refreshTimer;

    private HashSet<string> _collapsedSections = new(StringComparer.OrdinalIgnoreCase);
    private List<(string Href, string Label)> _recentPages = new();
    private bool _quickSubmitOpen;
    private bool _afterRenderInit;
    private string _primarySubmitHref = "/submit";
    private string _primaryBulkSubmitHref = "/submit/bulk";

    // ── Lifecycle ────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var state = await AuthState!;
            var role = state.User.FindFirst(ClaimTypes.Role)?.Value ?? "";
            isCheckerOrAdmin = role == "Checker" || role == "Admin";

            var instIdStr = state.User.FindFirst("InstitutionId")?.Value;
            if (int.TryParse(instIdStr, out var institutionId) && institutionId > 0)
            {
                _institutionId = institutionId;
                _navBadges = await DashboardSvc.GetNavBadgeCountsAsync(institutionId);
            }

            var tenantId = TenantContext.CurrentTenantId;
            if (tenantId.HasValue)
            {
                _branding = await BrandingService.GetBrandingConfig(tenantId.Value);
                _isPartnerTenant = await PartnerPortalService.IsPartnerTenant(tenantId.Value);
                var entitlement = await EntitlementSvc.ResolveEntitlements(tenantId.Value);
                _activeModules = entitlement.ActiveModules
                    .Select(m => m.ModuleCode)
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);
                _primarySubmitHref = (await SubmissionLaunchService.ResolvePrimarySubmitAsync(tenantId.Value)).Href;
                _primaryBulkSubmitHref = (await SubmissionLaunchService.ResolvePrimaryBulkSubmitAsync(tenantId.Value)).Href;
            }

            // 5-minute auto-refresh timer
            _refreshTimer = new Timer(async _ =>
            {
                if (_institutionId > 0)
                {
                    _navBadges = await DashboardSvc.GetNavBadgeCountsAsync(_institutionId);
                    await InvokeAsync(StateHasChanged);
                }
            }, null, TimeSpan.FromMinutes(5), TimeSpan.FromMinutes(5));
        }
        catch
        {
            // Keep nav safe-by-default when entitlement / badge lookup fails.
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _afterRenderInit) return;
        _afterRenderInit = true;

        try
        {
            // Load persisted section collapse state from localStorage
            var collapsed = await JS.InvokeAsync<string[]>("portalNavGetCollapsed");
            if (collapsed?.Length > 0)
            {
                _collapsedSections = new HashSet<string>(collapsed, StringComparer.OrdinalIgnoreCase);
            }

            // Load recent pages history from localStorage
            var pages = await JS.InvokeAsync<RecentPageDto[]>("portalNavGetRecentPages");
            if (pages?.Length > 0)
            {
                _recentPages = pages.Select(p => (p.Href, p.Label)).ToList();
            }

            // Track current page and subscribe to future navigations
            await TrackCurrentPageAsync(Navigation.Uri);
            Navigation.LocationChanged += OnLocationChanged;

            StateHasChanged();
        }
        catch
        {
            // Non-fatal — recent pages / collapse state just won't persist.
        }
    }

    // ── Navigation tracking ──────────────────────────────────────────────────

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _quickSubmitOpen = false;
        await TrackCurrentPageAsync(e.Location);
        await InvokeAsync(StateHasChanged);
    }

    private async Task TrackCurrentPageAsync(string uri)
    {
        try
        {
            var path = new Uri(uri).AbsolutePath;
            var label = GetPageLabel(path);
            if (string.IsNullOrEmpty(label)) return;

            await JS.InvokeVoidAsync("portalNavAddRecentPage", path, label);

            // Refresh in-memory list
            var pages = await JS.InvokeAsync<RecentPageDto[]>("portalNavGetRecentPages");
            _recentPages = pages?.Select(p => (p.Href, p.Label)).ToList() ?? _recentPages;
        }
        catch { /* non-fatal */ }
    }

    private static string GetPageLabel(string path) => path.TrimStart('/').ToLowerInvariant() switch
    {
        "" or "/" => "",   // Don't track dashboard root
        "dashboard/compliance" => "Compliance Summary",
        "dashboard/health" => "Health Score",
        "analytics/foresight" => "ForeSight",
        "analytics/foresight/filing-risks" => "ForeSight Filing Risks",
        "analytics/foresight/capital-forecast" => "ForeSight Capital Forecast",
        "analytics/foresight/compliance-trend" => "ForeSight Compliance Trend",
        "analytics/chat" => "ComplianceIQ",
        "analytics/chat/history" => "ComplianceIQ Query History",
        "dashboard/admin" => "Admin Dashboard",
        "dashboard/consolidation" => "Consolidation",
        "submit" => "Submit Return",
        "submit/bulk" => "Bulk Upload",
        "submissions" => "My Submissions",
        "approvals" => "Pending Approvals",
        "calendar" => "Reporting Calendar",
        "validation/hub" => "Validation Hub",
        "validation/cross-sheet" => "Cross-Sheet Rules",
        "validate" => "Quick Validate",
        "reports/compliance" => "Compliance Report",
        "reports/audit" => "Audit Trail",
        "reports/builder" => "Report Builder",
        "reports/saved" => "Saved Reports",
        "reports/board-pack" => "Board Pack",
        "modules" => "Modules",
        "templates" => "Template Browser",
        "help" => "Help Center",
        "institution" => "My Institution",
        "institution/team" => "Team Members",
        _ => ""
    };

    // ── Section collapse ─────────────────────────────────────────────────────

    private async Task ToggleSectionAsync(string section)
    {
        if (_collapsedSections.Contains(section))
            _collapsedSections.Remove(section);
        else
            _collapsedSections.Add(section);

        try
        {
            await JS.InvokeVoidAsync("portalNavSetCollapsed", section, _collapsedSections.Contains(section));
        }
        catch { /* non-fatal */ }
    }

    // ── Recent pages ─────────────────────────────────────────────────────────

    private async Task RemoveRecentPageAsync(string href)
    {
        _recentPages.RemoveAll(p => p.Href == href);
        try
        {
            await JS.InvokeVoidAsync("portalNavRemovePage", href);
        }
        catch { /* non-fatal */ }
    }

    // ── Quick Submit ─────────────────────────────────────────────────────────

    private void ToggleQuickSubmit() => _quickSubmitOpen = !_quickSubmitOpen;
    private void CloseQuickSubmit() => _quickSubmitOpen = false;

    // ── Module access ────────────────────────────────────────────────────────

    private bool HasAnyModuleAccess() => _activeModules.Count > 0;
    private bool HasModule(string moduleCode) => _activeModules.Contains(moduleCode);
    private static string GetModuleWorkspaceHref(string moduleCode) => PortalModuleWorkspaceCatalog.GetWorkspaceHref(moduleCode);

    // ── IDisposable ──────────────────────────────────────────────────────────

    public void Dispose()
    {
        _refreshTimer?.Dispose();
        Navigation.LocationChanged -= OnLocationChanged;
    }

    // ── JS interop DTOs ──────────────────────────────────────────────────────

    private class RecentPageDto
    {
        public string Href { get; set; } = "";
        public string Label { get; set; } = "";
    }
}
