                                </svg>
                                <span class="portal-nav-label">Capital Supervision</span>
                            </NavLink>
                        </li>
                    }
                    @if (HasModule("OPS_RESILIENCE"))
                    {
                        <li>
                            <NavLink href="@GetModuleWorkspaceHref("OPS_RESILIENCE")" class="portal-nav-item">
                                <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                    <path d="M12 3l7 4v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V7l7-4z"/>
                                </svg>
                                <span class="portal-nav-label">Operational Resilience</span>
                            </NavLink>
                        </li>
                    }
                    @if (HasModule("MODEL_RISK"))
                    {
                        <li>
                            <NavLink href="@GetModuleWorkspaceHref("MODEL_RISK")" class="portal-nav-item">
                                <svg class="portal-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                    <path d="M9 2h6"/><path d="M12 14V6"/><path d="M7 14l5 8 5-8"/><circle cx="12" cy="14" r="2"/>
                                </svg>
                                <span class="portal-nav-label">Model Risk</span>
                            </NavLink>
                        </li>
                    }
