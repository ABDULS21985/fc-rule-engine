@* Minimal layout for public-facing pages (no auth required, no sidebar). *@
@inherits LayoutComponentBase

<div class="portal-public-shell">

    <header class="portal-public-header" role="banner">
        <div class="portal-public-header-inner">
            <div class="portal-public-header-brand">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#006B3F" stroke-width="2" aria-hidden="true">
                    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                <span class="portal-public-header-name">RegOS™ Portal</span>
                <span class="portal-public-header-divider" aria-hidden="true">·</span>
                <span class="portal-public-header-sub">Certificate Verification</span>
            </div>
            <div class="portal-public-header-badge">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                Secure Verification
            </div>
        </div>
    </header>

    <main class="portal-public-main" id="main-content" role="main">
        @Body
    </main>

    <footer class="portal-public-footer" role="contentinfo">
        <p>Central Bank of Nigeria &mdash; Financial Conditions Division &mdash; RegOS™ &copy; @DateTime.UtcNow.Year</p>
    </footer>

</div>
