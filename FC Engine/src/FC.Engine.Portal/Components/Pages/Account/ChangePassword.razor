@page "/change-password"
@attribute [Authorize]
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject UserSettingsService SettingsSvc
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Change Password — RegOS™ Portal</PageTitle>

<div class="portal-page-shell">
    <div class="portal-page-card" style="max-width:460px;">
        <h2>Change Your Password</h2>
        <p class="portal-text-muted">Your account requires a password change before you can continue.</p>

        @if (!string.IsNullOrWhiteSpace(_successMsg))
        {
            <div class="portal-alert portal-alert-success">@_successMsg</div>
        }

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="portal-alert portal-alert-error">@_error</div>
        }

        <div class="portal-form-group">
            <label for="currentPassword" class="portal-form-label">Current Password</label>
            <input id="currentPassword"
                   type="password"
                   class="portal-form-input"
                   @bind="_currentPassword"
                   placeholder="Enter your current password" />
        </div>

        <div class="portal-form-group">
            <label for="newPassword" class="portal-form-label">New Password</label>
            <input id="newPassword"
                   type="password"
                   class="portal-form-input"
                   @bind="_newPassword"
                   placeholder="Enter a new password" />
            @if (!string.IsNullOrWhiteSpace(_newPasswordError))
            {
                <span class="portal-form-error">@_newPasswordError</span>
            }
        </div>

        <div class="portal-form-group">
            <label for="confirmPassword" class="portal-form-label">Confirm New Password</label>
            <input id="confirmPassword"
                   type="password"
                   class="portal-form-input"
                   @bind="_confirmPassword"
                   placeholder="Confirm your new password" />
            @if (!string.IsNullOrWhiteSpace(_confirmPasswordError))
            {
                <span class="portal-form-error">@_confirmPasswordError</span>
            }
        </div>

        <button class="portal-btn portal-btn-primary" style="width:100%;margin-top:8px;" @onclick="HandleSubmit" disabled="@_saving">
            @if (_saving)
            {
                <span class="portal-btn-spinner" aria-hidden="true"></span>
                <span>Changing...</span>
            }
            else
            {
                <span>Change Password</span>
            }
        </button>
    </div>
</div>

@code {
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private string? _error;
    private string? _successMsg;
    private string? _newPasswordError;
    private string? _confirmPasswordError;
    private bool _saving;
    private int _userId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated != true)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (!int.TryParse(userIdClaim, out _userId))
        {
            _error = "Unable to resolve your user identity.";
        }
    }

    private async Task HandleSubmit()
    {
        _error = null;
        _successMsg = null;
        _newPasswordError = null;
        _confirmPasswordError = null;

        if (string.IsNullOrWhiteSpace(_currentPassword))
        {
            _error = "Please enter your current password.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            _newPasswordError = "New password is required.";
            return;
        }

        if (_newPassword.Length < 8)
        {
            _newPasswordError = "Password must be at least 8 characters.";
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            _confirmPasswordError = "Passwords do not match.";
            return;
        }

        if (_newPassword == _currentPassword)
        {
            _newPasswordError = "New password must be different from your current password.";
            return;
        }

        _saving = true;
        StateHasChanged();

        try
        {
            var success = await SettingsSvc.ChangePassword(_userId, _currentPassword, _newPassword);

            if (success)
            {
                _successMsg = "Password changed successfully. Redirecting...";
                StateHasChanged();
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/", forceLoad: true);
            }
            else
            {
                _error = "Current password is incorrect.";
            }
        }
        catch (Exception ex)
        {
            _error = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }
}
