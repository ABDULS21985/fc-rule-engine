@page "/migration/mapping/{ImportJobId:int}"
@attribute [Authorize(Policy = "InstitutionAdmin")]
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Enums
@using System.Text.RegularExpressions
@implements IAsyncDisposable
@inject IHistoricalMigrationService MigrationService
@inject ITenantContext TenantContext
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Migration Mapping — RegOS™ Portal</PageTitle>

<!-- Commit Progress Overlay -->
<div id="mig-commit-overlay" class="portal-mig-commit-overlay">
    <div class="portal-mig-commit-modal">
        <div class="portal-mig-commit-title">Importing Historical Data</div>
        <div class="portal-mig-commit-sub">Committing records to read-only historical submissions…</div>
        <div class="portal-mig-commit-track">
            <div class="portal-mig-commit-fill"></div>
        </div>
        <div class="portal-mig-commit-label">Preparing…</div>
        <div class="portal-mig-commit-stats">
            <div class="portal-mig-commit-stat portal-mig-commit-stat--ok">
                <span class="portal-mig-commit-dot portal-mig-commit-dot--ok"></span>
                <span id="mig-ok-count">0</span> succeeded
            </div>
            <div class="portal-mig-commit-stat portal-mig-commit-stat--err">
                <span class="portal-mig-commit-dot portal-mig-commit-dot--err"></span>
                <span id="mig-err-count">0</span> failed
            </div>
        </div>
    </div>
</div>

<div class="portal-page">
    <div class="portal-breadcrumb">
        <a href="/migration" class="portal-breadcrumb-link">Historical Migration</a>
        <span class="portal-breadcrumb-sep">/</span>
        <span class="portal-breadcrumb-current">Job #@ImportJobId — @(mappingEditor?.ReturnCode ?? "…")</span>
    </div>

    <div class="portal-detail-hero">
        <div class="portal-detail-hero-main">
            <h1 class="portal-detail-hero-title">Field Mapping Editor</h1>
            <p class="portal-detail-hero-subtitle">Connect legacy source columns to RegOS™ schema fields, validate, preview, then commit.</p>
        </div>
        <div class="portal-detail-hero-actions">
            @if (job is not null)
            {
                <span class="portal-badge @GetStatusBadge(job.Status)">@job.Status</span>
            }
            <a class="portal-btn portal-btn-ghost portal-btn-sm" href="/migration">← Back</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="portal-validation-banner portal-validation-banner-error">@errorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="portal-validation-banner portal-validation-banner-success">@successMessage</div>
    }

    @if (mappingEditor is null)
    {
        <div class="portal-card" style="padding:1.5rem;">
            <p class="portal-text-muted">Loading mapping editor…</p>
        </div>
    }
    else
    {
        <!-- Completeness Meter -->
        var mappedCount = mappingEditor.Mappings.Count(m => !m.Ignored && !string.IsNullOrEmpty(m.TargetFieldName));
        var totalMappable = mappingEditor.Mappings.Count(m => !m.Ignored);
        var mappedPct = totalMappable > 0 ? (int)Math.Round((double)mappedCount / totalMappable * 100) : 0;
        var requiredUnmapped = mappingEditor.UnmappedFields.Count;
        <div class="portal-mig-meter">
            <div class="portal-mig-meter-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 10h14M3 5h9M3 15h11" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/><circle cx="16" cy="10" r="3" fill="currentColor" opacity="0.2"/></svg>
            </div>
            <div class="portal-mig-meter-body">
                <div class="portal-mig-meter-label">
                    <span>Field Mapping Completeness — <strong>@mappedCount of @totalMappable columns mapped</strong></span>
                    <span class="portal-mig-meter-pct">@mappedPct%</span>
                </div>
                <div class="portal-mig-meter-track">
                    <div class="portal-mig-meter-fill @(mappedPct < 60 ? "portal-mig-meter-fill--warn" : "")"
                         style="width:@mappedPct%"></div>
                </div>
                @if (requiredUnmapped > 0)
                {
                    <div class="portal-mig-meter-unmapped">
                        ⚠ @requiredUnmapped required field@(requiredUnmapped == 1 ? "" : "s") still unmapped: @string.Join(", ", mappingEditor.UnmappedFields.Take(5))@(requiredUnmapped > 5 ? "…" : "")
                    </div>
                }
            </div>
        </div>

        <!-- Mode toggle + Action row -->
        <div class="portal-mig-mode-bar">
            <div class="portal-mig-mode-toggle">
                <button class="portal-mig-mode-btn @(_visualMode ? "" : "portal-mig-mode-btn--active")" @onclick='() => SetMode(false)'>
                    <svg width="13" height="13" viewBox="0 0 14 14" fill="none" style="margin-right:0.25rem;"><rect x="1" y="2" width="12" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M1 5h12" stroke="currentColor" stroke-width="1.2"/></svg>
                    Table Mode
                </button>
                <button class="portal-mig-mode-btn @(_visualMode ? "portal-mig-mode-btn--active" : "")" @onclick='() => SetMode(true)'>
                    <svg width="13" height="13" viewBox="0 0 14 14" fill="none" style="margin-right:0.25rem;"><circle cx="3" cy="7" r="1.5" fill="currentColor"/><circle cx="11" cy="7" r="1.5" fill="currentColor"/><path d="M4.5 7 C6 4, 8 10, 9.5 7" stroke="currentColor" stroke-width="1.3" fill="none"/></svg>
                    Visual Mode
                </button>
            </div>
            <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
                <button class="portal-btn portal-btn-primary portal-btn-sm" @onclick="SaveMapping" disabled="@isBusy">Save Mapping</button>
                <button class="portal-btn portal-btn-outline portal-btn-sm" @onclick="ValidateJob" disabled="@isBusy">Validate</button>
                <button class="portal-btn portal-btn-outline portal-btn-sm" @onclick="StageJob" disabled="@isBusy">Stage</button>
                <button class="portal-btn portal-btn-outline portal-btn-sm" @onclick="LoadStagedPreview" disabled="@isBusy">Load Preview</button>
                <button class="portal-btn portal-btn-success portal-btn-sm" @onclick="CommitJob" disabled="@isBusy">Commit Historical</button>
            </div>
        </div>

        @if (!_visualMode)
        {
            <!-- TABLE MODE: mapping table + suggestions sidebar -->
            var suggestions = GetSuggestions();
            <div class="portal-mig-two-col">
                <div class="portal-card" style="padding:1rem 1.25rem;">
                    <h3 class="portal-detail-section-title" style="margin-top:0; margin-bottom:0.75rem;">Mapping Table</h3>
                    <div class="portal-table-responsive">
                        <table class="portal-table">
                            <thead>
                                <tr>
                                    <th>Source Column</th>
                                    <th>Sample Values</th>
                                    <th>Mapped Field</th>
                                    <th>Confidence</th>
                                    <th>Ignore</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var map in mappingEditor.Mappings)
                                {
                                    var rowClass = GetConfidenceRowClass(map.Confidence);
                                    <tr class="@rowClass">
                                        <td style="font-family:monospace; font-size:0.8125rem; font-weight:600;">@map.SourceHeader</td>
                                        <td style="font-size:0.75rem; color:var(--cbn-text-secondary); max-width:140px;">
                                            @string.Join(", ", map.SampleValues.Take(3))
                                        </td>
                                        <td>
                                            <select class="portal-form-select portal-form-select-sm"
                                                    value="@map.TargetFieldName"
                                                    @onchange="e => SetMappedField(map, e.Value?.ToString())">
                                                <option value="">— Unmapped —</option>
                                                @foreach (var field in mappingEditor.AvailableFields)
                                                {
                                                    <option value="@field.FieldName">@field.FieldLabel (@field.FieldName)</option>
                                                }
                                            </select>
                                        </td>
                                        <td>
                                            <div class="portal-mig-conf-bar">
                                                <div class="portal-mig-conf-track">
                                                    <div class="portal-mig-conf-fill @GetConfClass(map.Confidence)"
                                                         style="width:@((int)(map.Confidence * 100))%"></div>
                                                </div>
                                                <span class="portal-mig-conf-text" style="color:@GetConfColor(map.Confidence)">@($"{map.Confidence:P0}")</span>
                                            </div>
                                        </td>
                                        <td>
                                            <input type="checkbox"
                                                   checked="@map.Ignored"
                                                   @onchange="e => map.Ignored = (bool)e.Value!" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Suggestions Sidebar -->
                <div>
                    <div class="portal-mig-suggestions">
                        <div class="portal-mig-suggestions-header">
                            <span class="portal-mig-suggestions-title">
                                <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M7 1.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM7 4v4M7 9.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                                Smart Suggestions
                                @if (suggestions.Count > 0)
                                {
                                    <span class="portal-mig-suggestions-badge">@suggestions.Count</span>
                                }
                            </span>
                        </div>
                        @if (suggestions.Count == 0)
                        {
                            <div class="portal-mig-suggestions-empty">
                                @if (mappedPct >= 100)
                                {
                                    <span>✓ All columns mapped</span>
                                }
                                else
                                {
                                    <span>No suggestions available for remaining unmapped columns.</span>
                                }
                            </div>
                        }
                        else
                        {
                            @foreach (var sg in suggestions)
                            {
                                var s = sg;
                                <div class="portal-mig-suggestion">
                                    <div class="portal-mig-suggestion-row">
                                        <span class="portal-mig-suggestion-src">@s.Source.SourceHeader</span>
                                        <span class="portal-mig-suggestion-arrow">→</span>
                                        <span class="portal-mig-suggestion-tgt">@s.Target.FieldName</span>
                                        <span class="portal-mig-suggestion-match">@((int)(s.Score * 100))% match</span>
                                    </div>
                                    <div style="font-size:0.7rem; color:var(--cbn-text-muted); margin-bottom:0.3rem;">
                                        @s.Target.FieldLabel • @s.Target.DataType
                                    </div>
                                    <button class="portal-mig-suggestion-accept"
                                            @onclick="() => AcceptSuggestion(s.Source, s.Target.FieldName)">
                                        ✓ Accept Suggestion
                                    </button>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- VISUAL MODE: bezier curve mapper -->
            <div class="portal-card" style="padding:1rem 1.25rem;">
                <div style="font-size:0.75rem; color:var(--cbn-text-muted); margin-bottom:0.75rem;">
                    Click a <strong>source field</strong> on the left to select it, then click a <strong>target field</strong> on the right to draw a connection.
                </div>
                <div class="portal-mig-mapper" id="mig-mapper-root">
                    <!-- Source panel -->
                    <div class="portal-mig-mapper-panel portal-mig-mapper-panel--source">
                        <div class="portal-mig-mapper-panel-header">
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><rect x="1" y="1" width="10" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5"/></svg>
                            Source Columns
                        </div>
                        @foreach (var map in mappingEditor.Mappings.Where(m => !m.Ignored))
                        {
                            var m = map;
                            var isMapped = !string.IsNullOrEmpty(m.TargetFieldName);
                            <div class="portal-mig-field-row @(isMapped ? "portal-mig-field-row--mapped" : "") @(_selectedSourceIdx == m.SourceIndex ? "portal-mig-field-row--selected" : "")"
                                 data-src-idx="@m.SourceIndex"
                                 data-mapped-to="@(m.TargetFieldName ?? "")"
                                 @onclick="() => SelectSource(m.SourceIndex)">
                                <div class="portal-mig-field-name">@m.SourceHeader</div>
                                @if (!string.IsNullOrEmpty(m.TargetFieldName))
                                {
                                    <span style="font-size:0.65rem; color:var(--cbn-primary); font-weight:600; flex-shrink:0;">↔</span>
                                }
                                <div class="portal-mig-dot--right"></div>
                            </div>
                        }
                    </div>

                    <!-- SVG Canvas -->
                    <div class="portal-mig-mapper-canvas" id="mig-mapper-canvas">
                        <svg id="mig-mapper-svg" style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;"></svg>
                        @if (_selectedSourceIdx.HasValue)
                        {
                            <div class="portal-mig-canvas-hint" style="position:relative;z-index:1;">
                                <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M4 14h20M14 4l10 10-10 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                <span>Now click a target field →</span>
                            </div>
                        }
                        else
                        {
                            <div class="portal-mig-canvas-hint">
                                <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="6" cy="14" r="4" stroke="currentColor" stroke-width="1.5"/><circle cx="22" cy="14" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M10 14 C13 8, 15 20, 18 14" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
                                <span>Select a source field<br/>to begin mapping</span>
                            </div>
                        }
                    </div>

                    <!-- Target panel -->
                    <div class="portal-mig-mapper-panel portal-mig-mapper-panel--target">
                        <div class="portal-mig-mapper-panel-header">
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 1.5a4.5 4.5 0 100 9 4.5 4.5 0 000-9zM6 4v4M6 9h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                            RegOS™ Fields
                        </div>
                        @foreach (var field in mappingEditor.AvailableFields)
                        {
                            var f = field;
                            var isConnected = mappingEditor.Mappings.Any(m => m.TargetFieldName == f.FieldName && !m.Ignored);
                            <div class="portal-mig-field-row @(isConnected ? "portal-mig-field-row--mapped" : "")"
                                 data-tgt-name="@f.FieldName"
                                 @onclick="() => AcceptTargetClick(f.FieldName)">
                                <div class="portal-mig-dot--left"></div>
                                <div>
                                    <div class="portal-mig-field-label">@f.FieldLabel</div>
                                    <div class="portal-mig-field-name" style="font-size:0.7rem; color:var(--cbn-text-muted);">@f.FieldName</div>
                                </div>
                                <div class="portal-mig-field-type">@f.DataType</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Validation Preview (10 rows after staging) -->
        @if (stagedReview is not null)
        {
            <div class="portal-card" style="padding:1rem 1.25rem; margin-top:1rem;">
                <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:0.5rem; margin-bottom:0.75rem;">
                    <div>
                        <h3 class="portal-detail-section-title" style="margin:0;">Validation Preview</h3>
                        <p class="portal-text-muted" style="margin:0.25rem 0 0; font-size:0.8125rem;">
                            Showing @Math.Min(stagedReview.Records.Count, 10) of @stagedReview.TotalRecords record(s).
                            Cells highlighted in <span style="background:#fef3c7;color:#92400e;padding:0.1rem 0.3rem;border-radius:3px;font-size:0.72rem;font-weight:600;">amber</span> have type mismatches.
                        </p>
                    </div>
                    <div style="display:flex; gap:0.5rem;">
                        <button class="portal-btn portal-btn-primary portal-btn-sm" @onclick="SaveStagedPreview" disabled="@isBusy">Save Edits</button>
                        <button class="portal-btn portal-btn-outline portal-btn-sm" @onclick="ValidateJob" disabled="@isBusy">Re-Validate</button>
                        <button class="portal-btn portal-btn-success portal-btn-sm" @onclick="CommitJob" disabled="@isBusy">Commit Historical</button>
                    </div>
                </div>

                <div class="portal-table-responsive">
                    <table class="portal-table">
                        <thead>
                            <tr>
                                <th style="width:40px;">Row</th>
                                @foreach (var column in stagedReview.Columns)
                                {
                                    var colField = mappingEditor.AvailableFields.FirstOrDefault(f => f.FieldName == column);
                                    <th>
                                        @column
                                        @if (colField is not null)
                                        {
                                            <span style="font-size:0.6rem; color:var(--cbn-text-muted); font-weight:400; margin-left:0.25rem;">@colField.DataType</span>
                                        }
                                    </th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var record in stagedReview.Records.Take(10))
                            {
                                var rec = record;
                                <tr>
                                    <td style="color:var(--cbn-text-muted); font-size:0.75rem;">@rec.RowNumber</td>
                                    @foreach (var column in stagedReview.Columns)
                                    {
                                        var col = column;
                                        var cellValue = GetRecordValue(rec, col);
                                        var isMismatch = IsTypeMismatch(col, cellValue);
                                        <td class="@(isMismatch ? "portal-mig-preview-cell--mismatch" : "")">
                                            <input class="portal-form-input portal-form-input-sm"
                                                   style="@(isMismatch ? "background:transparent;border:none;color:#92400e;" : "background:transparent;border:none;")"
                                                   value="@cellValue"
                                                   @onchange="e => SetRecordValue(rec, col, e.Value?.ToString())" />
                                            @if (isMismatch)
                                            {
                                                <div class="portal-mig-preview-type-warn">
                                                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M5 1L9 9H1L5 1z" stroke="currentColor" stroke-width="1.2" fill="none"/><path d="M5 5V6.5M5 7.5h.01" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>
                                                    Type mismatch
                                                </div>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int ImportJobId { get; set; }

    private ImportJobDto? job;
    private ImportMappingEditorDto? mappingEditor;
    private ImportStagedReviewDto? stagedReview;
    private bool isBusy;
    private bool _visualMode;
    private int? _selectedSourceIdx;
    private string? errorMessage;
    private string? successMessage;
    private DotNetObjectReference<MappingEditor>? _dotNetRef;

    protected override async Task OnInitializedAsync() => await LoadAll();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_visualMode && mappingEditor is not null)
        {
            if (_dotNetRef is null)
            {
                _dotNetRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("portalMigration.initMapper", _dotNetRef);
            }
            await JS.InvokeVoidAsync("portalMigration.observeMapperResize");
            await JS.InvokeVoidAsync("portalMigration.redrawCurves");
        }
    }

    private async Task LoadAll()
    {
        if (!TenantContext.CurrentTenantId.HasValue) { errorMessage = "Tenant context is missing."; return; }
        errorMessage = null; successMessage = null;
        var tenantId = TenantContext.CurrentTenantId.Value;
        job = await MigrationService.GetJob(tenantId, ImportJobId);
        mappingEditor = await MigrationService.GetMappingEditor(tenantId, ImportJobId);
    }

    private async Task SetMode(bool visual)
    {
        _visualMode = visual;
        _selectedSourceIdx = null;
        if (!visual) { await JS.InvokeVoidAsync("portalMigration.disposeMapper"); _dotNetRef?.Dispose(); _dotNetRef = null; }
    }

    private void SelectSource(int idx)
    {
        _selectedSourceIdx = idx;
        _ = JS.InvokeVoidAsync("portalMigration.selectSource", idx);
    }

    private void AcceptTargetClick(string fieldName)
    {
        if (!_selectedSourceIdx.HasValue) return;
        var src = mappingEditor?.Mappings.FirstOrDefault(m => m.SourceIndex == _selectedSourceIdx.Value);
        if (src is null) return;
        SetMappedField(src, fieldName);
        _selectedSourceIdx = null;
        _ = JS.InvokeVoidAsync("portalMigration.redrawCurves");
        StateHasChanged();
    }

    [JSInvokable]
    public void AcceptVisualMapping(int srcIdx, string fieldName)
    {
        var src = mappingEditor?.Mappings.FirstOrDefault(m => m.SourceIndex == srcIdx);
        if (src is null) return;
        SetMappedField(src, fieldName);
        _selectedSourceIdx = null;
        StateHasChanged();
    }

    private void SetMappedField(ImportColumnMapping map, string? value)
    {
        map.TargetFieldName = string.IsNullOrWhiteSpace(value) ? null : value.Trim();
        if (!string.IsNullOrWhiteSpace(map.TargetFieldName)) map.Ignored = false;
    }

    private void AcceptSuggestion(ImportColumnMapping map, string fieldName)
    {
        SetMappedField(map, fieldName);
        StateHasChanged();
    }

    private async Task SaveMapping()
    {
        if (!TenantContext.CurrentTenantId.HasValue || mappingEditor is null) return;
        isBusy = true; errorMessage = null; successMessage = null;
        try
        {
            var updates = mappingEditor.Mappings.Select(x => new ImportMappingUpdate
            {
                SourceIndex = x.SourceIndex,
                SourceHeader = x.SourceHeader,
                TargetFieldName = string.IsNullOrWhiteSpace(x.TargetFieldName) ? null : x.TargetFieldName,
                Ignored = x.Ignored
            }).ToList();
            await MigrationService.SaveMapping(TenantContext.CurrentTenantId.Value, ImportJobId, updates, null);
            mappingEditor = await MigrationService.GetMappingEditor(TenantContext.CurrentTenantId.Value, ImportJobId);
            job = await MigrationService.GetJob(TenantContext.CurrentTenantId.Value, ImportJobId);
            successMessage = "Mapping saved.";
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isBusy = false; }
    }

    private async Task ValidateJob()
    {
        if (!TenantContext.CurrentTenantId.HasValue) return;
        isBusy = true; errorMessage = null; successMessage = null;
        try
        {
            job = await MigrationService.ValidateJob(TenantContext.CurrentTenantId.Value, ImportJobId);
            successMessage = $"Validation complete. Warnings: {job.WarningCount}, Errors: {job.ErrorCount}.";
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isBusy = false; }
    }

    private async Task StageJob()
    {
        if (!TenantContext.CurrentTenantId.HasValue) return;
        isBusy = true; errorMessage = null; successMessage = null;
        try
        {
            job = await MigrationService.StageJob(TenantContext.CurrentTenantId.Value, ImportJobId);
            successMessage = "Job staged — load preview to inspect records.";
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isBusy = false; }
    }

    private async Task LoadStagedPreview()
    {
        if (!TenantContext.CurrentTenantId.HasValue) return;
        isBusy = true; errorMessage = null; successMessage = null;
        try
        {
            stagedReview = await MigrationService.GetStagedReview(TenantContext.CurrentTenantId.Value, ImportJobId, 30);
            successMessage = "Staged preview loaded — review rows and fix any type mismatches before committing.";
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isBusy = false; }
    }

    private async Task SaveStagedPreview()
    {
        if (!TenantContext.CurrentTenantId.HasValue || stagedReview is null) return;
        isBusy = true; errorMessage = null; successMessage = null;
        try
        {
            await MigrationService.SaveStagedReview(TenantContext.CurrentTenantId.Value, ImportJobId, stagedReview.Records);
            successMessage = "Staged edits saved.";
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isBusy = false; }
    }

    private async Task CommitJob()
    {
        if (!TenantContext.CurrentTenantId.HasValue) return;
        isBusy = true; errorMessage = null; successMessage = null;
        var totalRows = job?.RecordCount ?? 0;
        try
        {
            await JS.InvokeVoidAsync("portalMigration.showCommitProgress", totalRows);
            job = await MigrationService.CommitJob(TenantContext.CurrentTenantId.Value, ImportJobId);
            await JS.InvokeVoidAsync("portalMigration.hideCommitProgress");
            successMessage = $"Historical submission committed — {job.RecordCount:N0} rows imported, {job.WarningCount} warnings, {job.ErrorCount} errors.";
            stagedReview = await MigrationService.GetStagedReview(TenantContext.CurrentTenantId.Value, ImportJobId, 30);
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("portalMigration.hideCommitProgress");
            errorMessage = ex.Message;
        }
        finally { isBusy = false; }
    }

    // ── Smart Suggestions ────────────────────────────────────────────

    private record SuggestionItem(ImportColumnMapping Source, ImportFieldOption Target, double Score);

    private List<SuggestionItem> GetSuggestions()
    {
        if (mappingEditor is null) return [];
        var results = new List<SuggestionItem>();
        foreach (var map in mappingEditor.Mappings.Where(m => !m.Ignored && string.IsNullOrEmpty(m.TargetFieldName)))
        {
            ImportFieldOption? best = null;
            double bestScore = 0.55;
            foreach (var field in mappingEditor.AvailableFields)
            {
                var score = ComputeSimilarity(map.SourceHeader, field.FieldName);
                if (score > bestScore) { best = field; bestScore = score; }
            }
            if (best is not null) results.Add(new SuggestionItem(map, best, bestScore));
        }
        return [.. results.OrderByDescending(x => x.Score).Take(8)];
    }

    private static double ComputeSimilarity(string a, string b)
    {
        a = Regex.Replace(a.ToLowerInvariant(), @"[_\s\-.]", "");
        b = Regex.Replace(b.ToLowerInvariant(), @"[_\s\-.]", "");
        if (a == b) return 1.0;
        if (a.Contains(b, StringComparison.Ordinal) || b.Contains(a, StringComparison.Ordinal)) return 0.88;
        var dist = LevenshteinDistance(a, b);
        var maxLen = Math.Max(a.Length, b.Length);
        return maxLen == 0 ? 1.0 : 1.0 - (double)dist / maxLen;
    }

    private static int LevenshteinDistance(string s, string t)
    {
        if (s.Length == 0) return t.Length;
        if (t.Length == 0) return s.Length;
        var d = new int[s.Length + 1, t.Length + 1];
        for (int i = 0; i <= s.Length; i++) d[i, 0] = i;
        for (int j = 0; j <= t.Length; j++) d[0, j] = j;
        for (int i = 1; i <= s.Length; i++)
            for (int j = 1; j <= t.Length; j++)
                d[i, j] = s[i - 1] == t[j - 1]
                    ? d[i - 1, j - 1]
                    : 1 + Math.Min(d[i - 1, j - 1], Math.Min(d[i - 1, j], d[i, j - 1]));
        return d[s.Length, t.Length];
    }

    // ── Type Mismatch Detection ──────────────────────────────────────

    private bool IsTypeMismatch(string column, string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return false;
        var field = mappingEditor?.AvailableFields.FirstOrDefault(f => f.FieldName == column);
        if (field is null) return false;
        return field.DataType?.ToLowerInvariant() switch
        {
            "decimal" or "number" or "numeric" or "currency" => !decimal.TryParse(value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out _),
            "integer" or "int" => !int.TryParse(value, out _),
            "date" or "datetime" => !DateTime.TryParse(value, out _),
            "boolean" or "bool" => !bool.TryParse(value, out _),
            _ => false
        };
    }

    // ── Helpers ──────────────────────────────────────────────────────

    private static string GetRecordValue(ImportStagedRecordDto record, string column)
        => record.Values.TryGetValue(column, out var v) ? v ?? string.Empty : string.Empty;

    private static void SetRecordValue(ImportStagedRecordDto record, string column, string? value)
        => record.Values[column] = string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static string GetStatusBadge(ImportJobStatus status) => status switch
    {
        ImportJobStatus.Committed => "portal-badge-success",
        ImportJobStatus.Failed => "portal-badge-danger",
        ImportJobStatus.MappingReview => "portal-badge-warning",
        ImportJobStatus.Validated or ImportJobStatus.Staged => "portal-badge-info",
        _ => "portal-badge-neutral"
    };

    private static string GetConfidenceRowClass(double confidence)
    {
        if (confidence >= 0.8) return "portal-table-row-success";
        if (confidence >= 0.6) return "portal-table-row-warning";
        return string.Empty;
    }

    private static string GetConfClass(double conf)
        => conf >= 0.8 ? "portal-mig-conf-fill--high" : conf >= 0.6 ? "portal-mig-conf-fill--mid" : "portal-mig-conf-fill--low";

    private static string GetConfColor(double conf)
        => conf >= 0.8 ? "#16a34a" : conf >= 0.6 ? "#d97706" : "#dc2626";

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("portalMigration.disposeMapper"); } catch { }
        _dotNetRef?.Dispose();
    }
}
