@page "/migration/tracker"
@attribute [Authorize(Policy = "InstitutionAdmin")]
@using System.Security.Claims
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Enums
@implements IAsyncDisposable
@inject IHistoricalMigrationService MigrationService
@inject ITenantContext TenantContext
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Migration Tracker — RegOS™ Portal</PageTitle>

<div class="portal-page">
    <div class="portal-detail-hero">
        <div class="portal-detail-hero-main">
            <h1 class="portal-detail-hero-title">Migration Progress Tracker</h1>
            <p class="portal-detail-hero-subtitle">Track module coverage, warning quality, compliance sign-off, and rollback recent imports.</p>
        </div>
        <div class="portal-detail-hero-actions">
            <button class="portal-btn portal-btn-outline portal-btn-sm" @onclick="LoadAll" disabled="@isBusy">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:0.25rem;"><path d="M12 7A5 5 0 112 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M12 3v4h-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Refresh
            </button>
            <a class="portal-btn portal-btn-outline portal-btn-sm" href="/migration">← Back to Migration</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="portal-validation-banner portal-validation-banner-error">@errorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="portal-validation-banner portal-validation-banner-success">@successMessage</div>
    }

    @if (tracker is null)
    {
        <div class="portal-card" style="padding:1.5rem;">
            <p class="portal-text-muted">Loading tracker…</p>
        </div>
    }
    else
    {
        <!-- Stats row -->
        var signedOffCount = tracker.Modules.Count(x => x.SignOff);
        var totalWarnings = tracker.Modules.Sum(x => x.WarningCount);
        var totalErrors = tracker.Modules.Sum(x => x.ErrorCount);
        var overallPct = tracker.TotalModules > 0 ? (int)Math.Round((double)tracker.ModulesMigrated / tracker.TotalModules * 100) : 0;
        <div class="portal-form-grid portal-form-grid-3" style="margin-bottom:1rem;">
            <div class="portal-card" style="padding:1rem;">
                <div class="portal-text-muted" style="font-size:0.78rem; margin-bottom:0.25rem;">Modules Migrated</div>
                <div style="font-size:1.5rem; font-weight:800; color:var(--cbn-text);">@tracker.ModulesMigrated <span style="font-size:1rem; font-weight:400; color:var(--cbn-text-muted);">/ @tracker.TotalModules</span></div>
                <div style="margin-top:0.5rem; height:5px; background:var(--cbn-gray-100); border-radius:99px; overflow:hidden;">
                    <div style="height:100%; width:@overallPct%; background:var(--cbn-primary); border-radius:99px; transition:width 0.5s ease;"></div>
                </div>
                <div style="font-size:0.7rem; color:var(--cbn-text-muted); margin-top:0.25rem;">@overallPct% complete</div>
            </div>
            <div class="portal-card" style="padding:1rem;">
                <div class="portal-text-muted" style="font-size:0.78rem; margin-bottom:0.25rem;">Modules Signed Off</div>
                <div style="font-size:1.5rem; font-weight:800; color:var(--cbn-text);">@signedOffCount <span style="font-size:1rem; font-weight:400; color:var(--cbn-text-muted);">/ @tracker.TotalModules</span></div>
                @if (signedOffCount == tracker.TotalModules && tracker.TotalModules > 0)
                {
                    <div style="margin-top:0.5rem; font-size:0.75rem; color:#16a34a; font-weight:600; display:flex; align-items:center; gap:0.3rem;">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        All modules signed off
                    </div>
                }
            </div>
            <div class="portal-card" style="padding:1rem;">
                <div class="portal-text-muted" style="font-size:0.78rem; margin-bottom:0.25rem;">Quality Summary</div>
                <div style="display:flex; gap:1rem; align-items:baseline; margin-top:0.25rem;">
                    <div>
                        <div style="font-size:1.1rem; font-weight:800; color:@(totalWarnings > 0 ? "#d97706" : "var(--cbn-text)");">@totalWarnings</div>
                        <div style="font-size:0.7rem; color:var(--cbn-text-muted);">warnings</div>
                    </div>
                    <div style="color:var(--cbn-gray-300);">|</div>
                    <div>
                        <div style="font-size:1.1rem; font-weight:800; color:@(totalErrors > 0 ? "#dc2626" : "var(--cbn-text)");">@totalErrors</div>
                        <div style="font-size:0.7rem; color:var(--cbn-text-muted);">errors</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Active Job Progress Cards -->
        @if (activeJobs.Count > 0)
        {
            <div style="margin-bottom:1rem;">
                <h3 class="portal-detail-section-title" style="margin-top:0; margin-bottom:0.5rem;">Active Import Jobs</h3>
                @foreach (var job in activeJobs)
                {
                    var j = job;
                    var progPct = j.RecordCount > 0 ? 100 : 0;
                    var errPct = j.RecordCount > 0 ? (int)((double)j.ErrorCount / Math.Max(j.RecordCount, 1) * 100) : 0;
                    <div class="portal-mig-prog-card">
                        <div class="portal-mig-prog-header">
                            <div class="portal-mig-prog-info">
                                <div class="portal-mig-prog-name">Job #@j.Id — @j.ReturnCode</div>
                                <div class="portal-mig-prog-meta">@j.SourceFileName • Updated @j.UpdatedAt.ToString("dd MMM HH:mm")</div>
                            </div>
                            <span class="portal-badge @GetStatusBadge(j.Status)">@j.Status</span>
                            <a class="portal-btn portal-btn-sm portal-btn-outline" href="/migration/mapping/@j.Id">Open →</a>
                        </div>
                        <div class="portal-mig-prog-body">
                            <div class="portal-mig-prog-bar">
                                <div class="portal-mig-prog-fill-ok" style="width:@(progPct - errPct)%"></div>
                                <div class="portal-mig-prog-fill-err" style="width:@errPct%"></div>
                            </div>
                            <div class="portal-mig-prog-row-stats">
                                <span class="portal-mig-prog-stat portal-mig-prog-stat--ok">
                                    <span class="portal-mig-prog-dot portal-mig-prog-dot--ok"></span>
                                    @(j.RecordCount - j.ErrorCount) succeeded
                                </span>
                                @if (j.ErrorCount > 0)
                                {
                                    <span class="portal-mig-prog-stat portal-mig-prog-stat--err">
                                        <span class="portal-mig-prog-dot portal-mig-prog-dot--err"></span>
                                        @j.ErrorCount failed
                                    </span>
                                }
                                <span class="portal-mig-prog-stat portal-mig-prog-stat--total">@j.RecordCount total rows</span>
                                @if (j.WarningCount > 0)
                                {
                                    <span class="portal-mig-prog-stat" style="color:#d97706;">@j.WarningCount warnings</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Rollback Section (committed jobs < 24h) -->
        @if (rollbackableJobs.Count > 0)
        {
            <div class="portal-mig-rollback-section">
                <div class="portal-mig-rollback-heading">
                    <svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M12.5 7.5A5 5 0 112.5 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M12.5 3v4.5h-4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Undo Available — Recent Imports (within 24 hours)
                </div>
                @foreach (var job in rollbackableJobs)
                {
                    var j = job;
                    var hoursLeft = (int)Math.Ceiling(24 - (DateTime.UtcNow - j.UpdatedAt).TotalHours);
                    var minsLeft = (int)Math.Ceiling((DateTime.UtcNow.AddHours(24) - j.UpdatedAt).TotalMinutes - (hoursLeft - 1) * 60);
                    var rolledBack = _rolledBackJobIds.Contains(j.Id);
                    <div class="portal-mig-rollback-job">
                        <div class="portal-mig-rollback-info">
                            <div class="portal-mig-rollback-jobname">Job #@j.Id — @j.ReturnCode</div>
                            <div class="portal-mig-rollback-meta">@j.SourceFileName • @j.RecordCount rows committed • @j.UpdatedAt.ToString("dd MMM yyyy HH:mm")</div>
                        </div>
                        <span class="portal-mig-rollback-countdown">
                            <svg width="11" height="11" viewBox="0 0 11 11" fill="none" style="margin-right:0.2rem;"><circle cx="5.5" cy="5.5" r="4.5" stroke="currentColor" stroke-width="1.2"/><path d="M5.5 3v3l1.5 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            @hoursLeft h remaining
                        </span>
                        @if (rolledBack)
                        {
                            <span class="portal-mig-rollback-done">
                                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                Rolled back
                            </span>
                        }
                        else
                        {
                            <button class="portal-mig-undo-btn" @onclick="() => UndoImport(j)" disabled="@isBusy">
                                <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M10 6.5A3.5 3.5 0 103 6.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M10 3.5v3h-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                Undo Import
                            </button>
                        }
                    </div>
                }
            </div>
        }

        <!-- Module Progress Table -->
        <div class="portal-card" style="padding:1rem 1.25rem;">
            <h3 class="portal-detail-section-title" style="margin-top:0; margin-bottom:0.75rem;">Module Progress</h3>

            <div class="portal-table-responsive">
                <table class="portal-table">
                    <thead>
                        <tr>
                            <th>Module</th>
                            <th>Periods Imported</th>
                            <th style="text-align:right;">Warn</th>
                            <th style="text-align:right;">Err</th>
                            <th>Eligible</th>
                            <th>Sign-Off</th>
                            <th>Compliance Notes</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var module in tracker.Modules.OrderBy(x => x.ModuleCode))
                        {
                            var mod = module;
                            var periodPct = mod.TotalPeriods > 0 ? (int)Math.Round((double)mod.ImportedPeriods / mod.TotalPeriods * 100) : 0;
                            <tr>
                                <td>
                                    <div style="font-weight:600; font-size:0.8125rem;">@mod.ModuleCode</div>
                                    <div class="portal-text-muted" style="font-size:0.72rem;">@mod.ModuleName</div>
                                </td>
                                <td>
                                    <div style="display:flex; align-items:center; gap:0.5rem;">
                                        <div class="portal-mig-period-bar">
                                            <div class="portal-mig-period-fill" style="width:@periodPct%"></div>
                                        </div>
                                        <span style="font-size:0.78rem; font-variant-numeric:tabular-nums;">@mod.ImportedPeriods / @mod.TotalPeriods</span>
                                    </div>
                                </td>
                                <td style="text-align:right; font-variant-numeric:tabular-nums; @(mod.WarningCount > 0 ? "color:#d97706;font-weight:600;" : "")">@mod.WarningCount</td>
                                <td style="text-align:right; font-variant-numeric:tabular-nums; @(mod.ErrorCount > 0 ? "color:#dc2626;font-weight:600;" : "")">@mod.ErrorCount</td>
                                <td>
                                    <span class="portal-badge @(mod.AutoSignOffEligible ? "portal-badge-success" : "portal-badge-warning")">
                                        @(mod.AutoSignOffEligible ? "Ready" : "Not Ready")
                                    </span>
                                </td>
                                <td>
                                    <div style="display:flex; align-items:center; gap:0.5rem;">
                                        <input type="checkbox"
                                               checked="@mod.SignOff"
                                               @onchange="e => mod.SignOff = (bool)e.Value!"
                                               disabled="@(!mod.AutoSignOffEligible && !mod.SignOff)" />
                                        @if (mod.SignOff)
                                        {
                                            <span style="font-size:0.7rem; color:#16a34a; font-weight:600;">✓ Signed</span>
                                        }
                                    </div>
                                    @if (mod.SignedOffAt.HasValue)
                                    {
                                        <div class="portal-text-muted" style="font-size:0.68rem; margin-top:0.125rem;">
                                            @mod.SignedOffAt.Value.ToString("dd MMM yyyy HH:mm")
                                        </div>
                                    }
                                </td>
                                <td>
                                    <input class="portal-form-input portal-form-input-sm"
                                           value="@GetSignOffNote(mod.ModuleId, mod.SignOffNotes)"
                                           @onchange="e => SetSignOffNote(mod.ModuleId, e.Value?.ToString())"
                                           placeholder="Compliance notes…" />
                                </td>
                                <td>
                                    <button class="portal-btn portal-btn-sm portal-btn-primary"
                                            @onclick="() => SaveSignOff(mod)"
                                            disabled="@isBusy">
                                        Save
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private MigrationTrackerDto? tracker;
    private List<ImportJobDto> activeJobs = [];
    private List<ImportJobDto> rollbackableJobs = [];
    private HashSet<int> _rolledBackJobIds = [];
    private Dictionary<int, string> signOffNotes = new();
    private bool isBusy;
    private string? errorMessage;
    private string? successMessage;
    private int userId;
    private Guid? _tenantId;

    protected override async Task OnInitializedAsync()
    {
        await LoadUser();
        await LoadAll();
    }

    private async Task LoadUser()
    {
        if (AuthState is null) return;
        var state = await AuthState;
        var raw = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? state.User.FindFirst("sub")?.Value;
        _ = int.TryParse(raw, out userId);
        _tenantId = TenantContext.CurrentTenantId;
    }

    private async Task LoadAll()
    {
        if (!TenantContext.CurrentTenantId.HasValue) { errorMessage = "Tenant context is missing."; return; }
        isBusy = true; errorMessage = null;
        try
        {
            var tenantId = TenantContext.CurrentTenantId.Value;
            tracker = await MigrationService.GetTracker(tenantId);
            signOffNotes = tracker.Modules.ToDictionary(x => x.ModuleId, x => x.SignOffNotes ?? string.Empty);

            var allJobs = (await MigrationService.GetJobs(tenantId)).OrderByDescending(j => j.UpdatedAt).ToList();
            activeJobs = allJobs
                .Where(j => j.Status is ImportJobStatus.Staged or ImportJobStatus.Validated or ImportJobStatus.Parsed or ImportJobStatus.Uploaded or ImportJobStatus.MappingReview)
                .Take(5)
                .ToList();
            rollbackableJobs = allJobs
                .Where(j => j.Status == ImportJobStatus.Committed && (DateTime.UtcNow - j.UpdatedAt).TotalHours < 24)
                .OrderByDescending(j => j.UpdatedAt)
                .ToList();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isBusy = false; }
    }

    private async Task LoadTracker()
    {
        if (!TenantContext.CurrentTenantId.HasValue) { errorMessage = "Tenant context is missing."; return; }
        isBusy = true; errorMessage = null; successMessage = null;
        try
        {
            tracker = await MigrationService.GetTracker(TenantContext.CurrentTenantId.Value);
            signOffNotes = tracker.Modules.ToDictionary(x => x.ModuleId, x => x.SignOffNotes ?? string.Empty);
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isBusy = false; }
    }

    private async Task UndoImport(ImportJobDto job)
    {
        if (!TenantContext.CurrentTenantId.HasValue) return;
        if (userId <= 0) { errorMessage = "User context missing."; return; }
        if ((DateTime.UtcNow - job.UpdatedAt).TotalHours >= 24)
        {
            errorMessage = "Rollback window (24 hours) has expired for this job.";
            return;
        }

        isBusy = true; errorMessage = null; successMessage = null;
        try
        {
            var updatedJob = await MigrationService.RollbackJob(TenantContext.CurrentTenantId.Value, job.Id, userId);
            _rolledBackJobIds.Add(job.Id);
            successMessage = $"Job #{job.Id} rolled back — {job.RecordCount:N0} historical records removed.";
            await LoadAll();
        }
        catch (NotImplementedException)
        {
            errorMessage = "Rollback is not yet implemented in the current environment. A snapshot of this import has been flagged for manual review.";
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isBusy = false; }
    }

    private async Task SaveSignOff(MigrationModuleProgressDto module)
    {
        if (!TenantContext.CurrentTenantId.HasValue) return;
        if (userId <= 0) { errorMessage = "User context missing."; return; }
        isBusy = true; errorMessage = null; successMessage = null;
        try
        {
            await MigrationService.SetModuleSignOff(
                TenantContext.CurrentTenantId.Value,
                module.ModuleId,
                module.SignOff,
                userId,
                GetSignOffNote(module.ModuleId, module.SignOffNotes));
            successMessage = $"Saved sign-off for {module.ModuleCode}.";
            await LoadTracker();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isBusy = false; }
    }

    private string GetSignOffNote(int moduleId, string? fallback)
        => signOffNotes.TryGetValue(moduleId, out var note) ? note : fallback ?? string.Empty;

    private void SetSignOffNote(int moduleId, string? value)
        => signOffNotes[moduleId] = value?.Trim() ?? string.Empty;

    private static string GetStatusBadge(ImportJobStatus status) => status switch
    {
        ImportJobStatus.Committed => "portal-badge-success",
        ImportJobStatus.Failed => "portal-badge-danger",
        ImportJobStatus.MappingReview => "portal-badge-warning",
        ImportJobStatus.Validated or ImportJobStatus.Staged => "portal-badge-info",
        _ => "portal-badge-neutral"
    };

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
