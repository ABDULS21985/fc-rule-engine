    {
        file.BufferedContent?.Dispose();
        _files.Remove(file);
    }

    private void ToggleFileDetails(BulkFileEntry file)
    {
        file.ShowDetails = !file.ShowDetails;
    }

    // ── Batch Processing ──────────────────────────────────────────
    private async Task ValidateAll()
    {
        if (_selectedPeriodId == 0 || _files.Count == 0)
            return;

        _isProcessing = true;
        _batchComplete = false;
        _processedCount = 0;
        _passedCount = 0;
        _warningCount = 0;
        _stageIndex = 0;
        _currentStageLabel = "Uploading";
        _failedCount = 0;
        _skippedCount = 0;
        StateHasChanged();

        foreach (var file in _files)
        {
            if (!file.TemplateFound || string.IsNullOrEmpty(file.DetectedReturnCode))
            {
                file.Status = BulkFileStatus.Skipped;
                file.ErrorMessage = "No matching template found for this file.";
                _skippedCount++;
            }
            else
            {
                await ProcessSingleFile(file);
                switch (file.Status)
                {
                    case BulkFileStatus.Passed:             _passedCount++;   break;
                    case BulkFileStatus.PassedWithWarnings: _warningCount++;  break;
                    case BulkFileStatus.Failed:             _failedCount++;   break;
                    case BulkFileStatus.Skipped:            _skippedCount++;  break;
                }
            }

            _processedCount++;
            StateHasChanged();
        }

        _isProcessing = false;
        _batchComplete = true;

        // Store hashes of successfully uploaded files so future sessions detect duplicates
        foreach (var f in _files.Where(f => f.Status is BulkFileStatus.Passed or BulkFileStatus.PassedWithWarnings
                                         && !string.IsNullOrEmpty(f.PreValidation?.FileHash)))
        {
            await JS.InvokeVoidAsync("portalBulkStoreHash", f.PreValidation!.FileHash, f.FileName);
        }

        if (_passedCount > 0)
            Toast.Success($"{_passedCount} of {_files.Count} returns processed successfully.");
        else if (_failedCount == _files.Count)
            Toast.Error("All files failed validation. Please review the errors.");

        StateHasChanged();
    }

    private async Task ProcessSingleFile(BulkFileEntry file)
    {
        file.Status = BulkFileStatus.Processing;
        file.Result = null;
        file.ErrorMessage = null;

        file.ProcessingStage = "Parsing";
        _stageIndex = 1; _currentStageLabel = "Parsing";
        StateHasChanged();
        await Task.Delay(1); // yield so UI updates

        file.ProcessingStage = "Validating";
        _stageIndex = 2; _currentStageLabel = "Validating";
        StateHasChanged();
        await Task.Delay(1);

        file.ProcessingStage = "Submitting";
        _stageIndex = 3; _currentStageLabel = "Submitting";
        StateHasChanged();

        try
        {
            file.BufferedContent!.Position = 0;

            if (string.Equals(file.FileExtension, ".xml", StringComparison.OrdinalIgnoreCase))
            {
                var xmlResult = await SubmissionService.ProcessSubmission(
                    file.BufferedContent,
                    file.DetectedReturnCode,
                    _institutionId,
                    _selectedPeriodId,
                    submittedByUserId: _userId);

                file.Result = xmlResult;
                file.Status = xmlResult.Status switch
                {
                    "Accepted" or "PendingApproval" => BulkFileStatus.Passed,
                    "AcceptedWithWarnings"           => BulkFileStatus.PassedWithWarnings,
                    _                               => BulkFileStatus.Failed
                };
            }
            else
            {
                if (!_tenantId.HasValue)
                    throw new InvalidOperationException("Tenant context is required for bulk data upload.");

                BulkUploadResult bulkResult = string.Equals(file.FileExtension, ".xlsx", StringComparison.OrdinalIgnoreCase)
                    ? await BulkUploadService.ProcessExcelUpload(file.BufferedContent, _tenantId.Value, file.DetectedReturnCode, _institutionId, _selectedPeriodId, _userId)
                    : await BulkUploadService.ProcessCsvUpload(file.BufferedContent, _tenantId.Value, file.DetectedReturnCode, _institutionId, _selectedPeriodId, _userId);

                file.Result = BuildSubmissionResultFromBulk(file.DetectedReturnCode, bulkResult);
                file.ErrorFileBytes = bulkResult.ErrorFile;
                file.ErrorFileName = bulkResult.ErrorFileName;

                if (bulkResult.Success && bulkResult.Status is "Accepted" or "PendingApproval")
                    file.Status = BulkFileStatus.Passed;
                else if (bulkResult.Success && bulkResult.Status == "AcceptedWithWarnings")
                    file.Status = BulkFileStatus.PassedWithWarnings;
                else
                {
                    file.Status = BulkFileStatus.Failed;
                    file.ErrorMessage = bulkResult.Message;
                }
            }
        }
        catch (Exception ex)
        {
            file.Status = BulkFileStatus.Failed;
            file.ErrorMessage = ex.Message;
        }
    }

    private async Task RetryFile(BulkFileEntry file)
    {
        if (file.Status != BulkFileStatus.Failed || file.BufferedContent is null)
            return;

        file.ErrorFileBytes = null;
        file.ErrorFileName = null;
        await ProcessSingleFile(file);

        // Recompute all counters from current file states
        _passedCount   = _files.Count(f => f.Status == BulkFileStatus.Passed);
        _warningCount  = _files.Count(f => f.Status == BulkFileStatus.PassedWithWarnings);
        _failedCount   = _files.Count(f => f.Status == BulkFileStatus.Failed);
        _skippedCount  = _files.Count(f => f.Status == BulkFileStatus.Skipped);
        StateHasChanged();
    }

    private async Task DownloadAllErrorsCsv()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("File,ReturnCode,Row,Severity,Category,Rule,Field,Message,ExpectedFormat");

        foreach (var file in _files.Where(f => f.Result?.ValidationReport?.Errors.Any() == true))
        {
            int rowNum = 1;
            foreach (var err in file.Result!.ValidationReport!.Errors)
            {
                var msg      = (err.Message  ?? "").Replace("\"", "\"\"");
                var field    = (err.Field    ?? "").Replace("\"", "\"\"");
                var category = (err.Category ?? "").Replace("\"", "\"\"");
                var expected = err.Category switch
                {
                    "TypeRange" => "Numeric value within allowed range",
                    "Required"  => "Non-empty value required",
                    "Format"    => "Expected date/code format per schema",
                    _           => err.Category ?? ""
                };
                sb.AppendLine($"\"{file.FileName}\",\"{file.DetectedReturnCode}\",\"{rowNum}\",\"{err.Severity}\",\"{category}\",\"{err.RuleId}\",\"{field}\",\"{msg}\",\"{expected}\"");
                rowNum++;
            }
        }

        await JS.InvokeVoidAsync("portalDownloadFile", sb.ToString(), "bulk_error_report.csv", "text/csv");
    }

    private static SubmissionResultDto BuildSubmissionResultFromBulk(string returnCode, BulkUploadResult bulkResult)
    {
        return new SubmissionResultDto
        {
            SubmissionId = bulkResult.SubmissionId,
            ReturnCode = returnCode,
            Status = bulkResult.Status,
            ValidationReport = new ValidationReportDto
            {
                IsValid = bulkResult.Success,
                ErrorCount = bulkResult.Errors.Count(x => string.Equals(x.Severity, "Error", StringComparison.OrdinalIgnoreCase)),
                WarningCount = bulkResult.Errors.Count(x => string.Equals(x.Severity, "Warning", StringComparison.OrdinalIgnoreCase)),
                Errors = bulkResult.Errors.Select(x => new ValidationErrorDto
                {
                    RuleId = "BULK",
                    Field = x.FieldCode,
                    Message = x.Message,
                    Severity = x.Severity,
                    Category = "TypeRange"
                }).ToList()
            }
        };
    }

    private async Task DownloadErrorFile(BulkFileEntry file)
    {
        if (file.ErrorFileBytes is null || file.ErrorFileBytes.Length == 0)
        {
            return;
        }

        var fileName = string.IsNullOrWhiteSpace(file.ErrorFileName)
            ? $"{file.DetectedReturnCode}_upload_errors.xlsx"
            : file.ErrorFileName;

        await JS.InvokeVoidAsync(
            "portalDownloadBase64File",
            Convert.ToBase64String(file.ErrorFileBytes),
            fileName,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private void ResetBatch()
    {
        foreach (var file in _files)
            file.BufferedContent?.Dispose();

        _files.Clear();
        _batchComplete = false;
        _processedCount = 0;
        _passedCount = 0;
        _warningCount = 0;
        _failedCount = 0;
        _skippedCount = 0;
        _uploadError = null;
    }

    private void ClearAll()
    {
        ResetBatch();
    }

    // ── Helpers ────────────────────────────────────────────────────
    private static string GetFileTypeIconClass(string ext) => ext.ToLowerInvariant() switch
    {
        ".xml"  => "portal-bulk-filetype-xml",
        ".xlsx" => "portal-bulk-filetype-xlsx",
        ".csv"  => "portal-bulk-filetype-csv",
        _       => ""
    };

    private static string GetFileCardClass(BulkFileEntry file) => file.Status switch
    {
        BulkFileStatus.Passed             => "portal-bulk-card-passed",
        BulkFileStatus.PassedWithWarnings => "portal-bulk-card-warnings",
        BulkFileStatus.Failed             => "portal-bulk-card-failed",
        BulkFileStatus.Processing         => "portal-bulk-card-processing",
        BulkFileStatus.Skipped            => "portal-bulk-card-skipped",
        _                                 => ""
    };

    private static string FormatFileSize(long bytes)
    {
        if (bytes >= 1048576) return $"{bytes / 1048576.0:F1} MB";
        if (bytes >= 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes} bytes";
    }

    private static string GetFileRowClass(BulkFileEntry file) => file.Status switch
    {
        BulkFileStatus.Passed => "portal-bulk-filerow-passed",
        BulkFileStatus.PassedWithWarnings => "portal-bulk-filerow-warnings",
        BulkFileStatus.Failed => "portal-bulk-filerow-failed",
        BulkFileStatus.Processing => "portal-bulk-filerow-processing",
        BulkFileStatus.Skipped => "portal-bulk-filerow-skipped",
        _ => ""
    };

    // ── Models ─────────────────────────────────────────────────────
    private enum BulkFileStatus
    {
        Pending,
        Processing,
        Passed,
        PassedWithWarnings,
        Failed,
        Skipped
    }

    private class BulkFileEntry
    {
        public string FileName { get; set; } = "";
        public long FileSize { get; set; }
        public MemoryStream? BufferedContent { get; set; }
        public string FileExtension { get; set; } = string.Empty;
        public string DetectedReturnCode { get; set; } = "";
        public bool TemplateFound { get; set; }
        public BulkFileStatus Status { get; set; }
        public SubmissionResultDto? Result { get; set; }
        public string? ErrorMessage { get; set; }
        public byte[]? ErrorFileBytes { get; set; }
        public string? ErrorFileName { get; set; }
        public bool ShowDetails { get; set; }
        public bool ShowErrors { get; set; } = true;
        public bool IsUploading { get; set; }
        public int UploadProgress { get; set; }
        public double UploadSpeedMbps { get; set; }
        public string ProcessingStage { get; set; } = "";
        // Pre-validation
        public PreValidationResult? PreValidation { get; set; }
        public bool UserAcknowledgedWarnings { get; set; }
        public bool ShowInlineEditor { get; set; }
        public List<List<string>> EditableRows { get; set; } = new();
    }

    private class PreValidationResult
    {
        public int DataRowCount { get; set; }
        public int ColumnCount { get; set; }
        public List<string> Headers { get; set; } = new();
        public string? DetectedPeriod { get; set; }
        public bool IsDuplicate { get; set; }
        public string? DuplicatePreviousDate { get; set; }
        public string? DuplicatePreviousFile { get; set; }
        public string? SuggestedTemplateCode { get; set; }
        public List<PreValidationIssue> Issues { get; set; } = new();
        public string FileHash { get; set; } = "";
        public List<string[]> AllRows { get; set; } = new();
    }

    private class PreValidationIssue
    {
        public int? Row { get; set; }
        public string? Column { get; set; }
        public string Type { get; set; } = "";
        public string Description { get; set; } = "";
        public string? Expected { get; set; }
        public string? Found { get; set; }
    }

    private class DuplicateCheckResult
    {
        public bool IsDuplicate { get; set; }
        public string? Date { get; set; }
        public string? FileName { get; set; }
    }
