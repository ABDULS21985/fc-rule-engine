    private async Task RequestExport(ExportFormat format)
    {
        if (submission is null || tenantId == Guid.Empty || !currentUserId.HasValue)
        { exportStatusMessage = "Unable to queue export for this session."; return; }
        isRequestingExport = true;
        exportStatusMessage = null;
        try
        {
            await ExportEngine.QueueExport(tenantId, submission.Id, format, currentUserId.Value);
            exportStatusMessage = $"{format} export queued. You will be notified when it is ready.";
            await LoadExportHistory();
        }
        catch (Exception ex) { exportStatusMessage = $"Export request failed: {ex.Message}"; }
        finally { isRequestingExport = false; StateHasChanged(); }
    }

