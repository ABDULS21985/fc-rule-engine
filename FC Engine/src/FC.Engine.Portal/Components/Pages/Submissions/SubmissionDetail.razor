    private static string FormatFileSize(long? bytes)
    {
        if (!bytes.HasValue || bytes.Value <= 0) return "0 B";
        const long kb = 1024, mb = 1024 * 1024;
        if (bytes.Value >= mb) return $"{bytes.Value / (double)mb:0.00} MB";
        if (bytes.Value >= kb) return $"{bytes.Value / (double)kb:0.00} KB";
        return $"{bytes.Value} B";
    }

