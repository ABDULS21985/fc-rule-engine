    private string GetQueryDraft(int queryId) =>
        queryDraftResponses.TryGetValue(queryId, out var value) ? value : string.Empty;

    private void SetQueryDraft(int queryId, string? value) => queryDraftResponses[queryId] = value ?? string.Empty;

    private async Task RespondToExaminerQuery(int queryId)
    {
        if (!currentUserId.HasValue) { queryActionMessage = "Unable to identify current user."; return; }
        var response = GetQueryDraft(queryId);
        if (string.IsNullOrWhiteSpace(response)) { queryActionMessage = "Response text is required."; return; }
        isRespondingQuery = true;
        queryActionMessage = null;
        try
        {
            await RegulatorInboxService.RespondToQueryAsInstitution(queryId, currentUserId.Value, response.Trim());
            queryDraftResponses.Remove(queryId);
            queryActionMessage = "Response sent successfully.";
            await LoadExaminerQueries();
        }
        catch (Exception ex) { queryActionMessage = $"Failed to send response: {ex.Message}"; }
        finally { isRespondingQuery = false; StateHasChanged(); }
    }

    private List<StepInfo> GetLifecycleSteps()
    {
        var currentIdx = GetCurrentLifecycleIndex();
        (string label, string? performer, DateTime? time)[] defs =
        [
            ("Draft",          null,                    null),
            ("Submitted",      submitterName,           submission?.SubmittedAt),
            ("Validating",     "System",                submission?.SubmittedAt),
            ("Checker Review", approval != null ? submitterName : null, approval?.RequestedAt),
            ("Approved",       approval?.Status is ApprovalStatus.Approved or ApprovalStatus.Rejected ? reviewerName : null, approval?.ReviewedAt),
            ("Published",      null,                    null),
        ];
        return defs.Select((d, i) =>
        {
            var state = i < currentIdx ? "done" : i == currentIdx ? "active" : "future";
            var initials = !string.IsNullOrEmpty(d.performer) ? GetInitials(d.performer) : null;
            return new StepInfo(d.label, state, d.performer, initials, d.time);
        }).ToList();
    }

    private int GetCurrentLifecycleIndex() => submission?.Status switch
    {
        SubmissionStatus.Parsing                => 2,
        SubmissionStatus.Validating             => 2,
        SubmissionStatus.Rejected               => 2,
        SubmissionStatus.PendingApproval        => 3,
        SubmissionStatus.ApprovalRejected       => 3,
        SubmissionStatus.Accepted               => 4,
        SubmissionStatus.AcceptedWithWarnings   => 4,
        SubmissionStatus.SubmittedToRegulator   => 5,
        SubmissionStatus.RegulatorAcknowledged  => 5,
        SubmissionStatus.RegulatorAccepted      => 5,
        SubmissionStatus.RegulatorQueriesRaised => 5,
        SubmissionStatus.Historical             => 5,
        _                                       => 1,
    };

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1 ? parts[0][0].ToString().ToUpper() : $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }

    private static string RelativeTime(DateTime? dt)
    {
        if (!dt.HasValue) return "";
        var diff = DateTime.UtcNow - dt.Value.ToUniversalTime();
        if (diff.TotalSeconds < 60) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 30) return $"{(int)diff.TotalDays}d ago";
        return dt.Value.ToString("d MMM yyyy");
    }

