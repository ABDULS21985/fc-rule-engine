@page "/submissions/{SubmissionId:int}"
@attribute [Authorize(Policy = "InstitutionUser")]
@inject ISubmissionRepository SubmissionRepo
@inject ITemplateMetadataCache TemplateCache
@inject IGenericDataRepository DataRepo
@inject IInstitutionUserRepository UserRepo
@inject ISubmissionApprovalRepository ApprovalRepo
@inject ApprovalService ApprovalSvc
@inject ExportService ExportSvc
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Submission #@SubmissionId — FC Engine Portal</PageTitle>

<div class="portal-page">

    @if (isLoading)
    {
        <div class="portal-detail-skeleton">
            <div class="portal-skeleton portal-skeleton-block" style="height: 180px; margin-bottom: 1.5rem;"></div>
            <div class="portal-skeleton portal-skeleton-block" style="height: 80px; margin-bottom: 1.5rem;"></div>
            <div class="portal-skeleton portal-skeleton-block" style="height: 400px;"></div>
        </div>
    }
    else if (submission is null)
    {
        <div class="portal-empty-state portal-card" style="padding: 3rem;">
            <div class="portal-empty-state-icon" aria-hidden="true">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5">
                    <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
            </div>
            <h3 class="portal-empty-state-title">Submission Not Found</h3>
            <p class="portal-empty-state-desc">This submission doesn't exist or you don't have access to it.</p>
            <a href="/submissions" class="portal-btn portal-btn-primary">Back to Submissions</a>
        </div>
    }
    else
    {
        <!-- ═══════════════════════════════════════════════════════
             BREADCRUMB
             ═══════════════════════════════════════════════════════ -->
        <nav class="portal-breadcrumb" aria-label="Breadcrumb">
            <a href="/" class="portal-breadcrumb-link">Dashboard</a>
            <span class="portal-breadcrumb-sep" aria-hidden="true">/</span>
            <a href="/submissions" class="portal-breadcrumb-link">Submissions</a>
            <span class="portal-breadcrumb-sep" aria-hidden="true">/</span>
            <span class="portal-breadcrumb-current">@submission.ReturnCode — @periodLabel</span>
        </nav>

        <!-- ═══════════════════════════════════════════════════════
             HERO SECTION
             ═══════════════════════════════════════════════════════ -->
        <div class="portal-detail-hero">
            <div class="portal-detail-hero-main">
                <div class="portal-detail-hero-title-row">
                    <h1 class="portal-detail-hero-title">@submission.ReturnCode</h1>
                    <span class="portal-badge portal-badge-lg @GetStatusBadgeClass(submission.Status.ToString())">
                        @GetStatusIcon(submission.Status.ToString()) @GetStatusLabel(submission.Status.ToString())
                    </span>
                </div>
                <p class="portal-detail-hero-subtitle">@templateName</p>
                <div class="portal-detail-hero-meta">
                    <span class="portal-detail-meta-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                        Period: <strong>@periodLabel</strong>
                    </span>
                    <span class="portal-detail-meta-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                        </svg>
                        Submitted: <strong>@submission.SubmittedAt.ToString("d MMM yyyy 'at' HH:mm")</strong>
                    </span>
                    @if (submission.ProcessingDurationMs is not null)
                    {
                        <span class="portal-detail-meta-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                            </svg>
                            Processed in: <strong>@FormatDuration(submission.ProcessingDurationMs)</strong>
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(submitterName))
                    {
                        <span class="portal-detail-meta-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                            </svg>
                            Submitted by: <strong>@submitterName</strong>
                        </span>
                    }
                </div>
            </div>
            <div class="portal-detail-hero-actions">
                <a href="/submissions/@SubmissionId/report" class="portal-btn portal-btn-outline portal-btn-sm">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/>
                    </svg>
                    Report
                </a>
                @if (submission!.Status is SubmissionStatus.Accepted or SubmissionStatus.AcceptedWithWarnings)
                {
                    <a href="/submissions/@SubmissionId/certificate" class="portal-btn portal-btn-outline portal-btn-sm">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>
                        </svg>
                        Certificate
                    </a>
                }
                <div class="portal-export-dropdown-wrap" @onkeydown="HandleExportKeyDown">
                    <button class="portal-btn portal-btn-outline portal-btn-sm"
                            @onclick="ToggleExportMenu"
                            aria-expanded="@showExportMenu"
                            aria-haspopup="true">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                        </svg>
                        Export
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="margin-left:2px;"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    @if (showExportMenu)
                    {
                        <div class="portal-export-backdrop" @onclick="() => showExportMenu = false" role="presentation" aria-hidden="true"></div>
                        <div class="portal-export-dropdown" role="menu">
                            <button class="portal-export-dropdown-item" role="menuitem" @onclick="ExportErrorsCsv">Export Errors CSV</button>
                            @if (!string.IsNullOrEmpty(submission.RawXml))
                            {
                                <button class="portal-export-dropdown-item" role="menuitem" @onclick="DownloadXml">Download Original XML</button>
                            }
                        </div>
                    }
                </div>
                <a href="/submit" class="portal-btn portal-btn-ghost portal-btn-sm">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
                    </svg>
                    Re-submit
                </a>
                <a href="/submissions" class="portal-btn portal-btn-ghost portal-btn-sm">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <polyline points="15 18 9 12 15 6"/>
                    </svg>
                    Back
                </a>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════
             VALIDATION SUMMARY CARDS
             ═══════════════════════════════════════════════════════ -->
        <div class="portal-validation-summary portal-detail-summary">
            <div class="portal-validation-summary-card portal-validation-summary-errors">
                <span class="portal-validation-summary-count">@errorCount</span>
                <span class="portal-validation-summary-label">Errors</span>
            </div>
            <div class="portal-validation-summary-card portal-validation-summary-warnings">
                <span class="portal-validation-summary-count">@warningCount</span>
                <span class="portal-validation-summary-label">Warnings</span>
            </div>
            <div class="portal-validation-summary-card portal-validation-summary-duration">
                <span class="portal-validation-summary-count">@FormatDuration(submission.ProcessingDurationMs)</span>
                <span class="portal-validation-summary-label">Processing Time</span>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════
             APPROVAL SECTION
             ═══════════════════════════════════════════════════════ -->
        @if (approval is not null)
        {
            <div class="portal-card portal-detail-approval">
                <div class="portal-approval-panel-header">
                    <h3 class="portal-detail-section-title" style="margin: 0;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="vertical-align: text-bottom;">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        </svg>
                        Approval Workflow
                    </h3>
                    <span class="portal-badge portal-badge-lg @GetApprovalStatusBadgeClass()">
                        @GetApprovalStatusLabel()
                    </span>
                </div>

                <div class="portal-approval-timeline">
                    <!-- Step 1: Submitted for Review -->
                    <div class="portal-approval-step portal-approval-step-done">
                        <div class="portal-approval-step-dot"></div>
                        <div class="portal-approval-step-content">
                            <span class="portal-approval-step-title">Submitted for Review</span>
                            <span class="portal-approval-step-meta">by @submitterName · @approval.RequestedAt.ToString("d MMM yyyy HH:mm")</span>
                            @if (!string.IsNullOrEmpty(approval.SubmitterNotes))
                            {
                                <div class="portal-approval-comments" style="margin-top: 0.5rem;">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="vertical-align: text-bottom;">
                                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                                    </svg>
                                    <em>@approval.SubmitterNotes</em>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Step 2: Review Status -->
                    <div class="portal-approval-step @GetApprovalStepClass()">
                        <div class="portal-approval-step-dot"></div>
                        <div class="portal-approval-step-content">
                            @if (approval.Status == ApprovalStatus.Pending)
                            {
                                <span class="portal-approval-step-title">Awaiting Checker Review</span>
                                <span class="portal-approval-step-meta">Pending review</span>

                                @if (isChecker && !isSelfSubmission)
                                {
                                    <div class="portal-approval-actions">
                                        <div class="portal-form-group">
                                            <label for="reviewComments" class="portal-form-label">Review Comments</label>
                                            <textarea id="reviewComments"
                                                      @bind="approvalComments"
                                                      class="portal-form-textarea"
                                                      rows="3"
                                                      placeholder="Add comments (required for rejection)..."></textarea>
                                        </div>
                                        @if (!string.IsNullOrEmpty(approvalError))
                                        {
                                            <div class="portal-alert portal-alert-error" style="margin-bottom: 0.75rem;" role="alert">@approvalError</div>
                                        }
                                        <div class="portal-approval-action-buttons">
                                            <button class="portal-btn portal-btn-success portal-btn-sm" @onclick="ApproveSubmission" disabled="@isProcessingApproval">
                                                @if (isProcessingApproval && processingApprovalAction == "approve")
                                                {
                                                    <span class="portal-btn-spinner" aria-hidden="true"></span>
                                                }
                                                Approve
                                            </button>
                                            <button class="portal-btn portal-btn-danger portal-btn-sm"
                                                    @onclick="RejectSubmission"
                                                    disabled="@(isProcessingApproval || string.IsNullOrWhiteSpace(approvalComments))">
                                                @if (isProcessingApproval && processingApprovalAction == "reject")
                                                {
                                                    <span class="portal-btn-spinner" aria-hidden="true"></span>
                                                }
                                                Reject
                                            </button>
                                        </div>
                                    </div>
                                }
                                else if (isSelfSubmission)
                                {
                                    <div class="portal-alert portal-alert-info" style="margin-top: 0.75rem;">
                                        You submitted this return. A different Checker must review it.
                                    </div>
                                }
                            }
                            else
                            {
                                <span class="portal-approval-step-title">
                                    @(approval.Status == ApprovalStatus.Approved ? "Approved" : "Rejected")
                                </span>
                                <span class="portal-approval-step-meta">
                                    by @reviewerName · @approval.ReviewedAt?.ToString("d MMM yyyy HH:mm")
                                </span>
                                @if (!string.IsNullOrEmpty(approval.ReviewerComments))
                                {
                                    <div class="portal-approval-comments">
                                        <strong>Comments:</strong> @approval.ReviewerComments
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- ═══════════════════════════════════════════════════════
             TABBED CONTENT AREA
             ═══════════════════════════════════════════════════════ -->
        <div class="portal-detail-tabs" role="tablist" aria-label="Submission details">
            <button class="portal-detail-tab @(activeTab == "all" ? "portal-detail-tab-active" : "")"
                    role="tab" aria-selected="@(activeTab == "all")"
                    @onclick='() => SwitchTab("all")'>
                All Issues
                @if (totalIssues > 0)
                {
                    <span class="portal-tab-count">@totalIssues</span>
                }
            </button>
            <button class="portal-detail-tab @(activeTab == "category" ? "portal-detail-tab-active" : "")"
                    role="tab" aria-selected="@(activeTab == "category")"
                    @onclick='() => SwitchTab("category")'>
                By Category
            </button>
            <button class="portal-detail-tab @(activeTab == "data" ? "portal-detail-tab-active" : "")"
                    role="tab" aria-selected="@(activeTab == "data")"
                    @onclick='() => SwitchTab("data")'>
                Data Preview
            </button>
            <button class="portal-detail-tab @(activeTab == "xml" ? "portal-detail-tab-active" : "")"
                    role="tab" aria-selected="@(activeTab == "xml")"
                    @onclick='() => SwitchTab("xml")'>
                Raw XML
            </button>
        </div>

        <div class="portal-detail-tab-content">
            <!-- ── TAB: All Issues ──────────────────────────────── -->
            @if (activeTab == "all")
            {
                @if (allErrors.Any())
                {
                    <div class="portal-card portal-card-flush">
                        <div class="portal-table-container">
                            <table class="portal-table" aria-label="All validation issues">
                                <thead>
                                    <tr>
                                        <th>Severity</th>
                                        <th>Rule ID</th>
                                        <th>Category</th>
                                        <th>Field</th>
                                        <th>Message</th>
                                        <th>Expected</th>
                                        <th>Actual</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var err in allErrors)
                                    {
                                        <tr>
                                            <td>
                                                <span class="portal-badge @GetSeverityBadgeClass(err.Severity)">
                                                    @GetSeverityIcon(err.Severity) @err.Severity
                                                </span>
                                            </td>
                                            <td class="portal-td-mono">@err.RuleId</td>
                                            <td>
                                                <span class="portal-badge portal-badge-neutral">@GetCategoryLabel(err.Category)</span>
                                            </td>
                                            <td class="portal-td-mono">@err.Field</td>
                                            <td>@err.Message</td>
                                            <td class="portal-td-mono">@(err.ExpectedValue ?? "—")</td>
                                            <td class="portal-td-mono">@(err.ActualValue ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div class="portal-card portal-empty-state">
                        <div class="portal-empty-state-icon" aria-hidden="true">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="1.5">
                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                            </svg>
                        </div>
                        <h3 class="portal-empty-state-title">No Validation Issues</h3>
                        <p class="portal-empty-state-desc">This submission passed all validation checks.</p>
                    </div>
                }
            }

            <!-- ── TAB: By Category ─────────────────────────────── -->
            @if (activeTab == "category")
            {
                @if (errorsByCategory.Any())
                {
                    @foreach (var cat in errorsByCategory.OrderBy(c => c.Key))
                    {
                        var catKey = cat.Key;
                        var catErrors = cat.Value;
                        var isExpanded = expandedCategories.Contains(catKey);

                        <div class="portal-category-panel">
                            <button class="portal-category-header" @onclick="() => ToggleCategory(catKey)" aria-expanded="@isExpanded">
                                <div class="portal-category-header-left">
                                    <span class="portal-category-chevron @(isExpanded ? "portal-category-chevron-open" : "")" aria-hidden="true">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <polyline points="9 18 15 12 9 6"/>
                                        </svg>
                                    </span>
                                    <span class="portal-category-name">@GetCategoryLabel(catKey)</span>
                                </div>
                                <div class="portal-category-header-right">
                                    @{ var catErrorCount = catErrors.Count(e => e.Severity == ValidationSeverity.Error); }
                                    @{ var catWarnCount = catErrors.Count(e => e.Severity == ValidationSeverity.Warning); }
                                    @if (catErrorCount > 0)
                                    {
                                        <span class="portal-badge portal-badge-danger">@catErrorCount errors</span>
                                    }
                                    @if (catWarnCount > 0)
                                    {
                                        <span class="portal-badge portal-badge-warning">@catWarnCount warnings</span>
                                    }
                                </div>
                            </button>
                            @if (isExpanded)
                            {
                                <div class="portal-category-body">
                                    <div class="portal-table-container">
                                        <table class="portal-table" aria-label="@GetCategoryLabel(catKey) validation issues">
                                            <thead>
                                                <tr>
                                                    <th>Severity</th>
                                                    <th>Rule ID</th>
                                                    <th>Field</th>
                                                    <th>Message</th>
                                                    <th>Expected</th>
                                                    <th>Actual</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var err in catErrors)
                                                {
                                                    <tr>
                                                        <td>
                                                            <span class="portal-badge @GetSeverityBadgeClass(err.Severity)">
                                                                @GetSeverityIcon(err.Severity) @err.Severity
                                                            </span>
                                                        </td>
                                                        <td class="portal-td-mono">@err.RuleId</td>
                                                        <td class="portal-td-mono">@err.Field</td>
                                                        <td>@err.Message</td>
                                                        <td class="portal-td-mono">@(err.ExpectedValue ?? "—")</td>
                                                        <td class="portal-td-mono">@(err.ActualValue ?? "—")</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="portal-card portal-empty-state">
                        <h3 class="portal-empty-state-title">No Validation Issues</h3>
                        <p class="portal-empty-state-desc">This submission passed all validation checks.</p>
                    </div>
                }
            }

            <!-- ── TAB: Data Preview ────────────────────────────── -->
            @if (activeTab == "data")
            {
                @if (!dataLoaded)
                {
                    <div class="portal-card" style="padding: 2rem; text-align: center;">
                        <div class="portal-spinner" aria-hidden="true"></div>
                        <p class="portal-text-muted" style="margin-top: 1rem;">Loading data preview...</p>
                    </div>
                }
                else if (dataRecord is null || !dataRecord.Rows.Any())
                {
                    <div class="portal-card portal-empty-state">
                        <h3 class="portal-empty-state-title">No Data Available</h3>
                        <p class="portal-empty-state-desc">Parsed data is not available for this submission.</p>
                    </div>
                }
                else
                {
                    <div class="portal-card portal-card-flush">
                        <div class="portal-table-container">
                            <table class="portal-table portal-data-preview-table" aria-label="Parsed submission data">
                                <thead>
                                    <tr>
                                        @if (dataRecord.Rows.Any(r => r.RowKey is not null))
                                        {
                                            <th>Row Key</th>
                                        }
                                        @foreach (var field in fieldNames)
                                        {
                                            <th>@field</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in dataRecord.Rows)
                                    {
                                        <tr>
                                            @if (dataRecord.Rows.Any(r => r.RowKey is not null))
                                            {
                                                <td class="portal-td-mono">@(row.RowKey ?? "—")</td>
                                            }
                                            @foreach (var field in fieldNames)
                                            {
                                                <td class="portal-td-mono">@(row.GetValue(field)?.ToString() ?? "")</td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            }

            <!-- ── TAB: Raw XML ─────────────────────────────────── -->
            @if (activeTab == "xml")
            {
                @if (!string.IsNullOrEmpty(submission.RawXml))
                {
                    <div class="portal-card portal-raw-xml-container">
                        <pre class="portal-raw-xml"><code>@submission.RawXml</code></pre>
                    </div>
                }
                else
                {
                    <div class="portal-card portal-empty-state">
                        <h3 class="portal-empty-state-title">Raw XML Not Available</h3>
                        <p class="portal-empty-state-desc">The original XML content is not stored for this submission.</p>
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    [Parameter] public int SubmissionId { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool isLoading = true;
    private Submission? submission;
    private string templateName = "";
    private string periodLabel = "";
    private string submitterName = "";
    private SubmissionApproval? approval;
    private string reviewerName = "";
    private bool isChecker;
    private int institutionId;
    private int? currentUserId;

    private string activeTab = "all";

    private bool dataLoaded;
    private ReturnDataRecord? dataRecord;
    private List<string> fieldNames = new();

    private string approvalComments = "";
    private bool isProcessingApproval;
    private string? processingApprovalAction;
    private string? approvalError;
    private bool isSelfSubmission;

    private List<ValidationError> allErrors = new();
    private Dictionary<string, List<ValidationError>> errorsByCategory = new();
    private HashSet<string> expandedCategories = new();
    private int errorCount;
    private int warningCount;
    private int totalIssues;
    private bool showExportMenu;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState!;
        var instIdStr = state.User.FindFirst("InstitutionId")?.Value;
        int.TryParse(instIdStr, out institutionId);
        var userIdStr = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(userIdStr, out var uid)) currentUserId = uid;
        var role = state.User.FindFirst(ClaimTypes.Role)?.Value ?? "";
        isChecker = role == "Checker" || role == "Admin";

        await LoadSubmission();
    }

    private async Task LoadSubmission()
    {
        isLoading = true;

        submission = await SubmissionRepo.GetByIdWithReport(SubmissionId);

        if (submission is null || submission.InstitutionId != institutionId)
        {
            submission = null;
            isLoading = false;
            return;
        }

        // Template name
        try
        {
            var template = await TemplateCache.GetPublishedTemplate(submission.ReturnCode);
            templateName = template.Name;
        }
        catch
        {
            templateName = submission.ReturnCode;
        }

        // Period label
        if (submission.ReturnPeriod is not null)
        {
            periodLabel = new DateTime(submission.ReturnPeriod.Year, submission.ReturnPeriod.Month, 1).ToString("MMM yyyy");
        }
        else
        {
            periodLabel = "—";
        }

        // Submitter name
        if (submission.SubmittedByUserId.HasValue)
        {
            var user = await UserRepo.GetById(submission.SubmittedByUserId.Value);
            submitterName = user?.DisplayName ?? "Unknown";
        }

        // Approval info
        if (submission.ApprovalRequired ||
            submission.Status == SubmissionStatus.PendingApproval ||
            submission.Status == SubmissionStatus.ApprovalRejected)
        {
            approval = await ApprovalRepo.GetBySubmission(submission.Id);
            if (approval is not null)
            {
                isSelfSubmission = currentUserId.HasValue &&
                    approval.RequestedByUserId == currentUserId.Value;

                if (approval.ReviewedByUserId.HasValue)
                {
                    var reviewer = await UserRepo.GetById(approval.ReviewedByUserId.Value);
                    reviewerName = reviewer?.DisplayName ?? "Unknown";
                }
            }
        }

        // Validation data
        if (submission.ValidationReport is not null)
        {
            allErrors = submission.ValidationReport.Errors
                .OrderByDescending(e => e.Severity)
                .ToList();
            errorsByCategory = allErrors
                .GroupBy(e => e.Category.ToString())
                .ToDictionary(g => g.Key, g => g.ToList());
            errorCount = submission.ValidationReport.ErrorCount;
            warningCount = submission.ValidationReport.WarningCount;
            totalIssues = allErrors.Count;

            // Auto-expand first category
            if (errorsByCategory.Any())
            {
                expandedCategories.Add(errorsByCategory.Keys.First());
            }
        }

        isLoading = false;
    }

    private void SwitchTab(string tab)
    {
        activeTab = tab;
        if (tab == "data" && !dataLoaded)
        {
            _ = LoadDataPreview();
        }
    }

    private async Task LoadDataPreview()
    {
        try
        {
            dataRecord = await DataRepo.GetBySubmission(submission!.ReturnCode, submission.Id);
            if (dataRecord is not null && dataRecord.Rows.Any())
            {
                fieldNames = dataRecord.Rows[0].AllFields.Keys.ToList();
            }
        }
        catch
        {
            // Data preview unavailable
        }
        finally
        {
            dataLoaded = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ToggleCategory(string category)
    {
        if (!expandedCategories.Remove(category))
        {
            expandedCategories.Add(category);
        }
    }

    private async Task ApproveSubmission()
    {
        if (approval is null || isProcessingApproval || !currentUserId.HasValue) return;
        isProcessingApproval = true;
        processingApprovalAction = "approve";
        approvalError = null;
        StateHasChanged();

        try
        {
            var comments = string.IsNullOrWhiteSpace(approvalComments) ? null : approvalComments;
            var result = await ApprovalSvc.Approve(SubmissionId, currentUserId.Value, comments);

            if (result == ApprovalActionResult.Success)
            {
                // Reload to reflect new state
                await LoadSubmission();
            }
            else
            {
                approvalError = result switch
                {
                    ApprovalActionResult.SelfApprovalNotAllowed => "You cannot approve your own submission.",
                    ApprovalActionResult.AlreadyProcessed => "This submission has already been reviewed.",
                    _ => "Failed to approve. Please try again."
                };
            }
        }
        catch (Exception ex)
        {
            approvalError = $"Error: {ex.Message}";
        }
        finally
        {
            isProcessingApproval = false;
            processingApprovalAction = null;
            StateHasChanged();
        }
    }

    private async Task RejectSubmission()
    {
        if (approval is null || isProcessingApproval || !currentUserId.HasValue
            || string.IsNullOrWhiteSpace(approvalComments)) return;
        isProcessingApproval = true;
        processingApprovalAction = "reject";
        approvalError = null;
        StateHasChanged();

        try
        {
            var result = await ApprovalSvc.Reject(SubmissionId, currentUserId.Value, approvalComments);

            if (result == ApprovalActionResult.Success)
            {
                await LoadSubmission();
            }
            else
            {
                approvalError = result switch
                {
                    ApprovalActionResult.SelfApprovalNotAllowed => "You cannot reject your own submission.",
                    ApprovalActionResult.AlreadyProcessed => "This submission has already been reviewed.",
                    ApprovalActionResult.CommentsRequired => "Comments are required when rejecting.",
                    _ => "Failed to reject. Please try again."
                };
            }
        }
        catch (Exception ex)
        {
            approvalError = $"Error: {ex.Message}";
        }
        finally
        {
            isProcessingApproval = false;
            processingApprovalAction = null;
            StateHasChanged();
        }
    }

    // ── Export Helpers ──────────────────────────────────────

    private void ToggleExportMenu() => showExportMenu = !showExportMenu;

    private void HandleExportKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" && showExportMenu)
            showExportMenu = false;
    }

    private async Task ExportErrorsCsv()
    {
        showExportMenu = false;
        var csv = await ExportSvc.ExportValidationErrorsCsvAsync(SubmissionId, institutionId);
        if (!string.IsNullOrEmpty(csv))
            await JS.InvokeVoidAsync("portalDownloadFile", csv, $"validation-errors-{SubmissionId}.csv", "text/csv");
    }

    private async Task DownloadXml()
    {
        showExportMenu = false;
        var xml = await ExportSvc.GetSubmissionXmlAsync(SubmissionId, institutionId);
        if (!string.IsNullOrEmpty(xml))
            await JS.InvokeVoidAsync("portalDownloadFile", xml, $"submission-{SubmissionId}.xml", "application/xml");
    }

    // ── Display Helpers ─────────────────────────────────────

    private static string GetStatusBadgeClass(string status)
    {
        if (status == "Accepted") return "portal-badge-success";
        if (status == "AcceptedWithWarnings") return "portal-badge-warning";
        if (status == "Rejected") return "portal-badge-danger";
        if (status == "PendingApproval") return "portal-badge-info";
        if (status == "ApprovalRejected") return "portal-badge-danger";
        return "portal-badge-neutral";
    }

    private static string GetStatusIcon(string status)
    {
        if (status == "Accepted") return "✓";
        if (status == "AcceptedWithWarnings") return "⚠";
        if (status == "Rejected") return "✗";
        if (status == "PendingApproval") return "◷";
        if (status == "ApprovalRejected") return "↩";
        return "";
    }

    private static string GetStatusLabel(string status)
    {
        if (status == "AcceptedWithWarnings") return "Accepted (Warnings)";
        if (status == "PendingApproval") return "Pending Approval";
        if (status == "ApprovalRejected") return "Approval Rejected";
        return status;
    }

    private static string FormatDuration(int? durationMs)
    {
        if (durationMs is null) return "—";
        if (durationMs.Value < 1000) return $"{durationMs}ms";
        if (durationMs.Value < 60000) return $"{durationMs.Value / 1000.0:F1}s";
        return $"{durationMs.Value / 60000.0:F1}m";
    }

    private static string GetSeverityBadgeClass(ValidationSeverity severity)
    {
        if (severity == ValidationSeverity.Error) return "portal-badge-danger";
        if (severity == ValidationSeverity.Warning) return "portal-badge-warning";
        return "portal-badge-info";
    }

    private static string GetSeverityIcon(ValidationSeverity severity)
    {
        if (severity == ValidationSeverity.Error) return "✗";
        if (severity == ValidationSeverity.Warning) return "⚠";
        return "ℹ";
    }

    private static string GetCategoryLabel(ValidationCategory category)
    {
        if (category == ValidationCategory.TypeRange) return "Type & Range";
        if (category == ValidationCategory.IntraSheet) return "Intra-Sheet";
        if (category == ValidationCategory.CrossSheet) return "Cross-Sheet";
        return category.ToString();
    }

    private static string GetCategoryLabel(string category)
    {
        if (category == "TypeRange") return "Type & Range";
        if (category == "IntraSheet") return "Intra-Sheet";
        if (category == "CrossSheet") return "Cross-Sheet";
        return category;
    }

    private string GetApprovalStepClass()
    {
        if (approval is null) return "";
        if (approval.Status == ApprovalStatus.Pending) return "portal-approval-step-active";
        return "portal-approval-step-done";
    }

    private string GetApprovalStatusBadgeClass()
    {
        if (approval is null) return "portal-badge-neutral";
        return approval.Status switch
        {
            ApprovalStatus.Pending => "portal-badge-info",
            ApprovalStatus.Approved => "portal-badge-success",
            ApprovalStatus.Rejected => "portal-badge-danger",
            _ => "portal-badge-neutral"
        };
    }

    private string GetApprovalStatusLabel()
    {
        if (approval is null) return "";
        return approval.Status switch
        {
            ApprovalStatus.Pending => "Pending Review",
            ApprovalStatus.Approved => "Approved",
            ApprovalStatus.Rejected => "Rejected",
            _ => approval.Status.ToString()
        };
    }
