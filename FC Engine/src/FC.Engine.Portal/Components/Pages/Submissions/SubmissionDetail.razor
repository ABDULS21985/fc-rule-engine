@page "/submissions/{SubmissionId:int}"
@attribute [Authorize(Policy = "InstitutionUser")]
@inject ISubmissionRepository SubmissionRepo
@inject ITemplateMetadataCache TemplateCache
@inject IGenericDataRepository DataRepo
@inject IInstitutionUserRepository UserRepo
@inject ISubmissionApprovalRepository ApprovalRepo
@inject ApprovalService ApprovalSvc
@inject ExportService ExportSvc
@inject IExportEngine ExportEngine
@inject IRegulatorInboxService RegulatorInboxService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IRegulatorySubmissionService DirectSubmissionService
@inject IDirectSubmissionRepository DirectSubmissionRepo

<PageTitle>Submission #@SubmissionId — RegOS™ Portal</PageTitle>

<div class="portal-page">

    @if (isLoading)
    {
        <div class="portal-detail-skeleton">
            <div class="portal-skeleton portal-skeleton-block" style="height: 180px; margin-bottom: 1.5rem;"></div>
            <div class="portal-skeleton portal-skeleton-block" style="height: 72px; margin-bottom: 1.25rem;"></div>
            <div class="portal-skeleton portal-skeleton-block" style="height: 400px;"></div>
        </div>
    }
    else if (submission is null)
    {
        <div class="portal-empty-state portal-card" style="padding: 3rem;">
            <div class="portal-empty-state-icon" aria-hidden="true">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5">
                    <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
            </div>
            <h3 class="portal-empty-state-title">Submission Not Found</h3>
            <p class="portal-empty-state-desc">This submission doesn't exist or you don't have access to it.</p>
            <a href="@submissionsHref" class="portal-btn portal-btn-primary">Back to Submissions</a>
        </div>
    }
    else
    {
        <nav class="portal-breadcrumb" aria-label="Breadcrumb">
            <a href="/" class="portal-breadcrumb-link">Dashboard</a>
            <span class="portal-breadcrumb-sep" aria-hidden="true">/</span>
            <a href="@submissionsHref" class="portal-breadcrumb-link">Submissions</a>
            <span class="portal-breadcrumb-sep" aria-hidden="true">/</span>
            <span class="portal-breadcrumb-current">@submission.ReturnCode — @periodLabel</span>
        </nav>

        <div class="portal-detail-hero">
            <div class="portal-detail-hero-main">
                <div class="portal-detail-hero-title-row">
                    <h1 class="portal-detail-hero-title">@submission.ReturnCode</h1>
                    <span class="portal-badge portal-badge-lg @GetStatusBadgeClass(submission.Status.ToString())">
                        @GetStatusIcon(submission.Status.ToString()) @GetStatusLabel(submission.Status.ToString())
                    </span>
                    @if (!string.IsNullOrWhiteSpace(moduleCode))
                    {
                        <span class="portal-badge portal-badge-neutral">@moduleCode</span>
                    }
                </div>
                <p class="portal-detail-hero-subtitle">@templateName</p>
                <div class="portal-detail-hero-meta">
                    <span class="portal-detail-meta-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        Period: <strong>@periodLabel</strong>
                    </span>
                    <span class="portal-detail-meta-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        Submitted: <strong>@submission.SubmittedAt.ToString("d MMM yyyy 'at' HH:mm")</strong>
                    </span>
                    @if (submission.ProcessingDurationMs is not null)
                    {
                        <span class="portal-detail-meta-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                            Processed in: <strong>@FormatDuration(submission.ProcessingDurationMs)</strong>
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(submitterName))
                    {
                        <span class="portal-detail-meta-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            Submitted by: <strong>@submitterName</strong>
                        </span>
                    }
                </div>
                @if (currentUserId.HasValue)
                {
                    <div class="portal-detail-hero-presence">
                        <PresenceAvatars ResourceKey="@($"sub:{SubmissionId}")"
                                         CurrentUserId="@currentUserId.Value"
                                         CurrentUserName="@_presUserName"
                                         CurrentUserRole="@_userRole" />
                    </div>
                }
            </div>
            <div class="portal-detail-hero-actions">
                @if (!string.IsNullOrWhiteSpace(moduleWorkspaceHref))
                {
                    <a href="@moduleWorkspaceHref" class="portal-btn portal-btn-outline portal-btn-sm">
                        Module Workspace
                    </a>
                }
                @if (!string.IsNullOrWhiteSpace(moduleSubmitHref))
                {
                    <a href="@moduleSubmitHref" class="portal-btn portal-btn-outline portal-btn-sm">
                        File Another
                    </a>
                }
                <div class="portal-download-wrap" @onkeydown="HandleDownloadKeyDown">
                    <button class="portal-btn portal-btn-primary portal-btn-sm"
                            @onclick="ToggleDownloadMenu"
                            disabled="@isRequestingExport"
                            aria-expanded="@_downloadMenuOpen"
                            aria-haspopup="true">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        @(isRequestingExport ? "Queueing..." : "Download")
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="margin-left:2px;"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    @if (_downloadMenuOpen)
                    {
                        <div class="portal-download-backdrop" @onclick="() => _downloadMenuOpen = false" role="presentation" aria-hidden="true"></div>
                        <div class="portal-download-dropdown" role="menu">
                            <button class="portal-download-item" role="menuitem" @onclick="DownloadReceiptPdf">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                Download Receipt PDF
                            </button>
                            @if (!string.IsNullOrEmpty(submission.RawXml))
                            {
                                <button class="portal-download-item" role="menuitem" @onclick="DownloadReturnDataXml">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                                    Download Return Data (XML)
                                </button>
                            }
                            @if (allErrors.Any())
                            {
                                <button class="portal-download-item" role="menuitem" @onclick="DownloadValidationReport">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                                    Download Validation Report
                                </button>
                            }
                        </div>
                    }
                </div>
                @if (submission.Status is SubmissionStatus.Accepted or SubmissionStatus.AcceptedWithWarnings)
                {
                    <a href="/submissions/@SubmissionId/certificate" class="portal-btn portal-btn-outline portal-btn-sm portal-cert-badge-btn">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                        View Certificate
                    </a>
                }
                <a href="@submissionsHref" class="portal-btn portal-btn-ghost portal-btn-sm">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                    Back
                </a>
            </div>
        </div>

        <div class="portal-validation-summary portal-detail-summary">
            <div class="portal-validation-summary-card portal-validation-summary-errors">
                <span class="portal-validation-summary-count">@errorCount</span>
                <span class="portal-validation-summary-label">Errors</span>
            </div>
            <div class="portal-validation-summary-card portal-validation-summary-warnings">
                <span class="portal-validation-summary-count">@warningCount</span>
                <span class="portal-validation-summary-label">Warnings</span>
            </div>
            <div class="portal-validation-summary-card portal-validation-summary-duration">
                <span class="portal-validation-summary-count">@FormatDuration(submission.ProcessingDurationMs)</span>
                <span class="portal-validation-summary-label">Processing Time</span>
            </div>
        </div>

        <div class="portal-lifecycle-stepper" role="list" aria-label="Submission lifecycle">
            @{ var lcSteps = GetLifecycleSteps(); }
            @for (int si = 0; si < lcSteps.Count; si++)
            {
                var step = lcSteps[si];
                var isLastStep = si == lcSteps.Count - 1;
                <div class="portal-lifecycle-step portal-lifecycle-step--@step.State" role="listitem">
                    <div class="portal-lifecycle-step-track">
                        <div class="portal-lifecycle-step-icon" aria-hidden="true">
                            @if (step.State == "done")
                            {
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                            }
                            else
                            {
                                <span>@(si + 1)</span>
                            }
                        </div>
                        @if (!isLastStep)
                        {
                            <div class="portal-lifecycle-connector @(step.State == "done" ? "portal-lifecycle-connector--done" : "")"></div>
                        }
                    </div>
                    <div class="portal-lifecycle-step-body">
                        <span class="portal-lifecycle-step-label">@step.Label</span>
                        @if (!string.IsNullOrEmpty(step.PerformerName))
                        {
                            <div class="portal-lifecycle-step-meta">
                                <span class="portal-step-avatar" aria-hidden="true">@step.PerformerInitials</span>
                                <span class="portal-lifecycle-performer">@step.PerformerName</span>
                                @if (step.StepTime.HasValue)
                                {
                                    <span class="portal-lifecycle-time" title="@step.StepTime.Value.ToString("dd MMM yyyy HH:mm")">@RelativeTime(step.StepTime)</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="portal-detail-layout">

            <div class="portal-detail-main">

                @if (examinerQueries.Any())
                {
                    <div class="portal-card portal-examiner-card">
                        <button class="portal-examiner-header"
                                @onclick="() => _examinerExpanded = !_examinerExpanded"
                                aria-expanded="@_examinerExpanded">
                            <div class="portal-examiner-header-left">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                <span>Examiner Queries</span>
                                @{ var unanswered = examinerQueries.Count(q => string.IsNullOrEmpty(q.ResponseText)); }
                                @if (unanswered > 0)
                                {
                                    <span class="portal-badge portal-badge-warning">@unanswered pending</span>
                                }
                            </div>
                            <svg class="portal-examiner-chevron @(_examinerExpanded ? "portal-examiner-chevron--open" : "")"
                                 width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <polyline points="6 9 12 15 18 9"/>
                            </svg>
                        </button>
                        @if (_examinerExpanded)
                        {
                            <div class="portal-examiner-body">
                                @if (!string.IsNullOrWhiteSpace(queryActionMessage))
                                {
                                    <div class="portal-alert portal-alert-info" style="margin-bottom:0.75rem;">@queryActionMessage</div>
                                }
                                <div class="portal-examiner-list">
                                    @foreach (var query in examinerQueries.OrderByDescending(x => x.RaisedAt))
                                    {
                                        <div class="portal-examiner-item">
                                            <div class="portal-examiner-item-header">
                                                <span class="portal-badge portal-badge-neutral">@(string.IsNullOrWhiteSpace(query.FieldCode) ? "General" : query.FieldCode)</span>
                                                <span class="portal-badge portal-badge-warning">@query.Priority</span>
                                                <span class="portal-badge portal-badge-info">@query.Status</span>
                                                <span class="portal-examiner-date">@query.RaisedAt.ToString("dd MMM yyyy HH:mm")</span>
                                            </div>
                                            <p class="portal-examiner-text">@query.QueryText</p>
                                            @if (string.IsNullOrWhiteSpace(query.ResponseText))
                                            {
                                                <div class="portal-examiner-response-form">
                                                    <textarea class="portal-input" style="min-height: 72px;"
                                                              placeholder="Enter your response to this examiner query"
                                                              value="@GetQueryDraft(query.Id)"
                                                              @oninput="e => SetQueryDraft(query.Id, e.Value?.ToString())"></textarea>
                                                    <div style="display:flex;justify-content:flex-end;margin-top:0.4rem;">
                                                        <button class="portal-btn portal-btn-primary portal-btn-sm"
                                                                disabled="@isRespondingQuery"
                                                                @onclick="() => RespondToExaminerQuery(query.Id)">Respond</button>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="portal-examiner-response-view">
                                                    <div class="portal-examiner-response-meta">Response@(query.RespondedAt.HasValue ? $" on {query.RespondedAt.Value:dd MMM yyyy HH:mm}" : "")</div>
                                                    <p style="margin:0;font-size:0.875rem;">@query.ResponseText</p>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }

                <div class="portal-detail-tabs" role="tablist" aria-label="Submission detail sections">
                    <button class="portal-detail-tab @(activeTab == "data" ? "portal-detail-tab-active" : "")"
                            role="tab" aria-selected="@(activeTab == "data")"
                            @onclick='() => SwitchTab("data")'>Return Data</button>
                    <button class="portal-detail-tab @(activeTab == "validation" ? "portal-detail-tab-active" : "")"
                            role="tab" aria-selected="@(activeTab == "validation")"
                            @onclick='() => SwitchTab("validation")'>
                        Validation Report
                        @if (totalIssues > 0)
                        {
                            <span class="portal-tab-count">@totalIssues</span>
                        }
                    </button>
                    <button class="portal-detail-tab @(activeTab == "audit" ? "portal-detail-tab-active" : "")"
                            role="tab" aria-selected="@(activeTab == "audit")"
                            @onclick='() => SwitchTab("audit")'>Audit Trail</button>
                    <button class="portal-detail-tab @(activeTab == "directSubmission" ? "portal-detail-tab-active" : "")"
                            role="tab" aria-selected="@(activeTab == "directSubmission")"
                            @onclick='() => SwitchTab("directSubmission")'>
                        Direct Submission
                        @if (directSubmissions?.Count > 0)
                        {
                            <span class="portal-tab-count">@directSubmissions.Count</span>
                        }
                    </button>
                </div>

                <div class="portal-detail-tab-content">

                    @if (activeTab == "data")
                    {
                        @if (!dataLoaded)
                        {
                            <div class="portal-card" style="padding: 2rem; text-align: center;">
                                <div class="portal-spinner" aria-hidden="true"></div>
                                <p class="portal-text-muted" style="margin-top: 1rem;">Loading data preview...</p>
                            </div>
                        }
                        else if (dataRecord is null || !dataRecord.Rows.Any())
                        {
                            <div class="portal-card portal-empty-state">
                                <div class="portal-empty-state-icon" aria-hidden="true">
                                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                                </div>
                                <h3 class="portal-empty-state-title">No Data Available</h3>
                                <p class="portal-empty-state-desc">Parsed data is not available for this submission.</p>
                            </div>
                        }
                        else
                        {
                            <div class="portal-card portal-card-flush">
                                <div class="portal-table-container">
                                    <table class="portal-table portal-data-preview-table" aria-label="Parsed submission data">
                                        <thead>
                                            <tr>
                                                @if (dataRecord.Rows.Any(r => r.RowKey is not null))
                                                {
                                                    <th>Row Key</th>
                                                }
                                                @foreach (var field in fieldNames)
                                                {
                                                    <th>@field</th>
                                                }
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in dataRecord.Rows)
                                            {
                                                <tr>
                                                    @if (dataRecord.Rows.Any(r => r.RowKey is not null))
                                                    {
                                                        <td class="portal-td-mono">@(row.RowKey ?? "—")</td>
                                                    }
                                                    @foreach (var field in fieldNames)
                                                    {
                                                        <td class="portal-td-mono">@(row.GetValue(field)?.ToString() ?? "")</td>
                                                    }
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(submission.RawXml))
                        {
                            <div class="portal-card portal-raw-xml-container" style="margin-top: 1rem;">
                                <div style="display:flex;align-items:center;justify-content:space-between;padding:0.65rem 1rem;border-bottom:1px solid #e5e7eb;">
                                    <span style="font-weight:600;font-size:0.875rem;color:#374151;">Raw XML</span>
                                    <button class="portal-btn portal-btn-ghost portal-btn-sm" @onclick="DownloadReturnDataXml">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                        Download
                                    </button>
                                </div>
                                <pre class="portal-raw-xml"><code>@submission.RawXml</code></pre>
                            </div>
                        }
                    }

                    @if (activeTab == "validation")
                    {
                        @if (!allErrors.Any())
                        {
                            <div class="portal-card portal-empty-state">
                                <div class="portal-empty-state-icon" aria-hidden="true">
                                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                </div>
                                <h3 class="portal-empty-state-title">No Validation Issues</h3>
                                <p class="portal-empty-state-desc">This submission passed all validation checks.</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var section in errorsByCategory.OrderBy(c => c.Key))
                            {
                                var sectionIssues = section.Value
                                    .OrderBy(e => e.Severity == ValidationSeverity.Error ? 0
                                               : e.Severity == ValidationSeverity.Warning ? 1 : 2)
                                    .ToList();
                                var secErrCnt = sectionIssues.Count(e => e.Severity == ValidationSeverity.Error);
                                var secWarnCnt = sectionIssues.Count(e => e.Severity == ValidationSeverity.Warning);
                                <div class="portal-vr-section">
                                    <div class="portal-vr-section-header">
                                        <span class="portal-vr-section-name">@GetCategoryLabel(section.Key)</span>
                                        <div class="portal-vr-section-counts">
                                            @if (secErrCnt > 0)
                                            {
                                                <span class="portal-badge portal-badge-danger">@secErrCnt error@(secErrCnt != 1 ? "s" : "")</span>
                                            }
                                            @if (secWarnCnt > 0)
                                            {
                                                <span class="portal-badge portal-badge-warning">@secWarnCnt warning@(secWarnCnt != 1 ? "s" : "")</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="portal-vr-issue-list">
                                        @foreach (var issue in sectionIssues)
                                        {
                                            <div class="portal-vr-issue portal-vr-issue--@(issue.Severity.ToString().ToLowerInvariant())">
                                                <div class="portal-vr-severity" aria-label="@issue.Severity">
                                                    @if (issue.Severity == ValidationSeverity.Error)
                                                    {
                                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                                    }
                                                    else if (issue.Severity == ValidationSeverity.Warning)
                                                    {
                                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2.5" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                                                    }
                                                    else
                                                    {
                                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                                                    }
                                                </div>
                                                <div class="portal-vr-body">
                                                    <div class="portal-vr-field-row">
                                                        <code class="portal-vr-field-code">@issue.Field</code>
                                                        <span class="portal-vr-rule-id">@issue.RuleId</span>
                                                    </div>
                                                    <p class="portal-vr-message">@issue.Message</p>
                                                    @if (!string.IsNullOrEmpty(issue.ExpectedValue) || !string.IsNullOrEmpty(issue.ActualValue))
                                                    {
                                                        <div class="portal-vr-values">
                                                            <span class="portal-vr-value-chip portal-vr-value-chip--expected">Expected: <code>@(issue.ExpectedValue ?? "—")</code></span>
                                                            <span class="portal-vr-value-chip portal-vr-value-chip--actual">Actual: <code>@(issue.ActualValue ?? "—")</code></span>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    }

                    @if (activeTab == "audit")
                    {
                        <div class="portal-card at-card-wrap">
                            <SubmissionAuditTimeline SubmissionId="@SubmissionId"
                                                     InstitutionId="@institutionId"
                                                     CurrentUserId="@currentUserId"
                                                     CurrentUserName="@(string.IsNullOrEmpty(submitterName) ? _presUserName : submitterName)"
                                                     Approval="@approval" />
                        </div>
                    }

                    @if (activeTab == "directSubmission")
                    {
                        <div class="portal-card" style="padding: 1.5rem;">
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.25rem;">
                                <h3 style="margin:0; font-size:1rem; font-weight:600;">Regulatory Direct Submission</h3>
                                @if (CanTriggerDirectSubmission())
                                {
                                    <div style="display:flex; gap:0.5rem; align-items:center;">
                                        <select class="portal-form-select" style="min-width:120px; font-size:0.85rem;" @bind="selectedRegulatorCode">
                                            <option value="">Select Regulator</option>
                                            <option value="CBN">CBN (eFASS)</option>
                                            <option value="NFIU">NFIU (goAML)</option>
                                            <option value="NDIC">NDIC</option>
                                            <option value="SEC">SEC</option>
                                            <option value="NAICOM">NAICOM</option>
                                            <option value="PENCOM">PenCom</option>
                                        </select>
                                        <button class="portal-btn portal-btn-gold portal-btn-sm"
                                                disabled="@(isSubmittingToRegulator || string.IsNullOrEmpty(selectedRegulatorCode))"
                                                @onclick="SubmitToRegulatorAsync">
                                            @if (isSubmittingToRegulator)
                                            {
                                                <span class="portal-btn-spinner" aria-hidden="true"></span>
                                            }
                                            else
                                            {
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                                            }
                                            Submit
                                        </button>
                                    </div>
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(directSubmissionMessage))
                            {
                                <div class="portal-alert @(directSubmissionSuccess ? "portal-alert-success" : "portal-alert-error")" role="alert" style="margin-bottom:1rem;">
                                    @directSubmissionMessage
                                </div>
                            }

                            @if (directSubmissions is null || directSubmissions.Count == 0)
                            {
                                <div class="portal-empty-state" style="padding:2rem; text-align:center;">
                                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                                    <p class="portal-text-muted" style="margin-top:0.75rem;">No direct submissions yet. Select a regulator and click Submit to send this return directly via API.</p>
                                </div>
                            }
                            else
                            {
                                <div class="portal-table-wrap">
                                    <table class="portal-table">
                                        <thead>
                                            <tr>
                                                <th>Regulator</th>
                                                <th>Status</th>
                                                <th>Reference</th>
                                                <th>Attempts</th>
                                                <th>Submitted</th>
                                                <th>Acknowledged</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var ds in directSubmissions)
                                            {
                                                <tr>
                                                    <td><strong>@ds.RegulatorCode</strong></td>
                                                    <td>
                                                        <span class="portal-badge @GetDirectSubmissionBadgeClass(ds.Status)">
                                                            @ds.Status
                                                        </span>
                                                    </td>
                                                    <td style="font-family:monospace; font-size:0.82rem;">@(ds.RegulatorReference ?? "—")</td>
                                                    <td>@ds.AttemptCount / @ds.MaxAttempts</td>
                                                    <td>@(ds.SubmittedAt?.ToString("dd MMM yyyy HH:mm") ?? "—")</td>
                                                    <td>@(ds.AcknowledgedAt?.ToString("dd MMM yyyy HH:mm") ?? "—")</td>
                                                    <td>
                                                        @if (ds.Status == DirectSubmissionStatus.Failed
                                                            || ds.Status == DirectSubmissionStatus.RetryScheduled
                                                            || ds.Status == DirectSubmissionStatus.Exhausted)
                                                        {
                                                            <button class="portal-btn portal-btn-outline portal-btn-xs"
                                                                    @onclick="() => RetryDirectSubmissionAsync(ds.Id)">
                                                                Retry
                                                            </button>
                                                        }
                                                    </td>
                                                </tr>
                                                @if (!string.IsNullOrEmpty(ds.ErrorMessage))
                                                {
                                                    <tr>
                                                        <td colspan="7" style="background:#fef3c7; color:#92400e; font-size:0.82rem; padding:0.5rem 1rem;">
                                                            @ds.ErrorMessage
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }

                            @if (directSubmissions is not null)
                            {
                                <div style="margin-top:0.75rem; font-size:0.8rem; color:#6b7280;">
                                    @if (submission?.Status == SubmissionStatus.RegulatorAccepted)
                                    {
                                        <span style="color:#059669; font-weight:600;">Regulator has accepted this return.</span>
                                    }
                                    else if (submission?.Status == SubmissionStatus.RegulatorAcknowledged)
                                    {
                                        <span style="color:#2563eb;">Awaiting regulator processing.</span>
                                    }
                                    else if (submission?.Status == SubmissionStatus.RegulatorQueriesRaised)
                                    {
                                        <span style="color:#dc2626; font-weight:600;">Regulator has raised queries. Check your inbox.</span>
                                    }
                                </div>
                            }
                        </div>
                    }

                </div>
            </div>

            <aside class="portal-detail-actions-panel" aria-label="Submission actions">
                <div class="portal-actions-card">
                    <h3 class="portal-actions-card-title">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        Actions
                    </h3>

                    @if (!string.IsNullOrEmpty(approvalError))
                    {
                        <div class="portal-alert portal-alert-error" role="alert">@approvalError</div>
                    }
                    @if (!string.IsNullOrEmpty(_adminActionError))
                    {
                        <div class="portal-alert portal-alert-error" role="alert">@_adminActionError</div>
                    }
                    @if (!string.IsNullOrEmpty(_adminActionSuccess))
                    {
                        <div class="portal-alert portal-alert-success" role="status">@_adminActionSuccess</div>
                    }

                    @if (_isAdminRole)
                    {
                        <div class="portal-actions-group">
                            <button class="portal-btn portal-btn-outline portal-btn-sm portal-btn-full" @onclick="OverrideStatus">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                                Override Status
                            </button>
                            <button class="portal-btn portal-btn-outline portal-btn-sm portal-btn-full" @onclick="UnlockForEdit">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
                                Unlock for Edit
                            </button>
                            @if (_showOverridePanel)
                            {
                                <div class="portal-action-comment-form">
                                    <label class="portal-form-label" for="override-status-select" style="font-size:0.8rem;">New status</label>
                                    <select id="override-status-select" class="portal-form-select" @bind="_overrideStatus">
                                        <option value="@nameof(SubmissionStatus.Draft)">Draft</option>
                                        <option value="@nameof(SubmissionStatus.Accepted)">Accepted</option>
                                        <option value="@nameof(SubmissionStatus.AcceptedWithWarnings)">Accepted With Warnings</option>
                                        <option value="@nameof(SubmissionStatus.Rejected)">Rejected</option>
                                        <option value="@nameof(SubmissionStatus.Historical)">Historical</option>
                                    </select>
                                    <div style="display:flex; gap:0.5rem; margin-top:0.5rem;">
                                        <button class="portal-btn portal-btn-primary portal-btn-sm portal-btn-full" @onclick="ApplyOverrideStatus">Apply Override</button>
                                        <button class="portal-btn portal-btn-ghost portal-btn-sm portal-btn-full" @onclick="() => _showOverridePanel = false">Cancel</button>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    @if (isChecker && !_isAdminRole && approval?.Status == ApprovalStatus.Pending && !isSelfSubmission)
                    {
                        <div class="portal-actions-group">
                            <button class="portal-btn portal-btn-gold portal-btn-sm portal-btn-full"
                                    disabled="@isProcessingApproval"
                                    @onclick="ApproveSubmission">
                                @if (isProcessingApproval && processingApprovalAction == "approve")
                                {
                                    <span class="portal-btn-spinner" aria-hidden="true"></span>
                                }
                                else
                                {
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                                }
                                Approve
                            </button>
                            <button class="portal-btn portal-btn-outline portal-btn-danger-tint portal-btn-sm portal-btn-full"
                                    disabled="@isProcessingApproval"
                                    @onclick="ToggleCommentForm">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                @(_showCommentForm ? "Cancel" : "Reject with Comment")
                            </button>
                            @if (_showCommentForm)
                            {
                                <div class="portal-action-comment-form">
                                    <label class="portal-form-label" for="inline-reject-comment" style="font-size:0.8rem;">
                                        Reason for Rejection <span style="color:#dc2626;">*</span>
                                    </label>
                                    <textarea id="inline-reject-comment"
                                              class="portal-form-textarea portal-action-textarea"
                                              rows="4"
                                              placeholder="Provide feedback to the submitter..."
                                              @bind="approvalComments"></textarea>
                                    <button class="portal-btn portal-btn-danger portal-btn-sm portal-btn-full"
                                            style="margin-top:0.35rem;"
                                            disabled="@(isProcessingApproval || string.IsNullOrWhiteSpace(approvalComments))"
                                            @onclick="RejectAndCloseForm">
                                        @if (isProcessingApproval && processingApprovalAction == "reject")
                                        {
                                            <span class="portal-btn-spinner" aria-hidden="true"></span>
                                        }
                                        Submit Decision
                                    </button>
                                </div>
                            }
                        </div>
                    }

                    @if (isSelfSubmission && approval?.Status == ApprovalStatus.Pending)
                    {
                        <div class="portal-alert portal-alert-info" style="font-size:0.82rem;">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="flex-shrink:0;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            You submitted this return. A different Checker must review it.
                        </div>
                    }

                    @if (approval?.Status == ApprovalStatus.Approved)
                    {
                        <div class="portal-actions-status portal-actions-status--approved">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" style="flex-shrink:0;margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>
                            <div>
                                <span class="portal-actions-status-label">Approved</span>
                                @if (!string.IsNullOrEmpty(reviewerName))
                                {
                                    <span class="portal-actions-status-meta">by @reviewerName · @approval.ReviewedAt?.ToString("d MMM yyyy")</span>
                                }
                                @if (!string.IsNullOrEmpty(approval.ReviewerComments))
                                {
                                    <div class="portal-actions-comment">"@approval.ReviewerComments"</div>
                                }
                            </div>
                        </div>
                    }
                    @if (approval?.Status == ApprovalStatus.Rejected)
                    {
                        <div class="portal-actions-status portal-actions-status--rejected">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" style="flex-shrink:0;margin-top:2px;"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                            <div>
                                <span class="portal-actions-status-label">Rejected</span>
                                @if (!string.IsNullOrEmpty(reviewerName))
                                {
                                    <span class="portal-actions-status-meta">by @reviewerName · @approval.ReviewedAt?.ToString("d MMM yyyy")</span>
                                }
                                @if (!string.IsNullOrEmpty(approval.ReviewerComments))
                                {
                                    <div class="portal-actions-comment">"@approval.ReviewerComments"</div>
                                }
                            </div>
                        </div>
                    }

                    @if (!isChecker && submission!.Status == SubmissionStatus.PendingApproval)
                    {
                        <div class="portal-actions-group">
                            <button class="portal-btn portal-btn-outline portal-btn-sm portal-btn-full" @onclick="WithdrawSubmission">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
                                Withdraw Submission
                            </button>
                        </div>
                    }

                    @if (approval is null && !_isAdminRole && submission!.Status != SubmissionStatus.PendingApproval && !(isChecker && !_isAdminRole))
                    {
                        <p class="portal-actions-empty">No actions available for this submission.</p>
                    }
                </div>
            </aside>

        </div>
    }
</div>

@code {
    [Parameter] public int SubmissionId { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool isLoading = true;
    private Submission? submission;
    private string templateName = "";
    private string? moduleCode;
    private string? moduleWorkspaceHref;
    private string moduleSubmitHref = "/submit";
    private string submissionsHref = "/submissions";
    private string periodLabel = "";
    private string submitterName = "";
    private SubmissionApproval? approval;
    private string reviewerName = "";
    private bool isChecker;
    private int institutionId;
    private int? currentUserId;
    private Guid tenantId;

    private string activeTab = "data";

    // Direct Submission (RG-34)
    private List<DirectSubmission>? directSubmissions;
    private string selectedRegulatorCode = "";
    private bool isSubmittingToRegulator;
    private string? directSubmissionMessage;
    private bool directSubmissionSuccess;

    private bool dataLoaded;
    private ReturnDataRecord? dataRecord;
    private List<string> fieldNames = new();

    private string approvalComments = "";
    private bool isProcessingApproval;
    private string? processingApprovalAction;
    private string? approvalError;
    private bool isSelfSubmission;

    private List<ValidationError> allErrors = new();
    private Dictionary<string, List<ValidationError>> errorsByCategory = new();
    private HashSet<string> expandedCategories = new();
    private int errorCount;
    private int warningCount;
    private int totalIssues;

    private bool showExportMenu;
    private List<ExportRequest> exports = new();
    private bool isRequestingExport;
    private string? exportStatusMessage;

    private List<ExaminerQuery> examinerQueries = new();
    private Dictionary<int, string> queryDraftResponses = new();
    private bool isRespondingQuery;
    private string? queryActionMessage;

    private string _userRole = "Maker";
    private bool _isAdminRole;
    private bool _downloadMenuOpen;
    private bool _showCommentForm;
    private bool _examinerExpanded = true;
    private string _presUserName = "";
    private bool _showOverridePanel;
    private string _overrideStatus = nameof(SubmissionStatus.Draft);
    private string? _adminActionError;
    private string? _adminActionSuccess;

    private record StepInfo(string Label, string State, string? PerformerName, string? PerformerInitials, DateTime? StepTime);

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState!;
        var instIdStr = state.User.FindFirst("InstitutionId")?.Value;
        int.TryParse(instIdStr, out institutionId);
        var userIdStr = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(userIdStr, out var uid)) currentUserId = uid;
        var tenantIdStr = state.User.FindFirst("TenantId")?.Value;
        if (Guid.TryParse(tenantIdStr, out var parsedTenantId)) tenantId = parsedTenantId;

        _userRole = state.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Maker";
        _isAdminRole = _userRole == "Admin";
        isChecker = _userRole == "Checker" || _userRole == "Admin";
        _presUserName = state.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? _userRole;

        await LoadSubmission();
    }

    private async Task LoadSubmission()
    {
        isLoading = true;
        submission = await SubmissionRepo.GetByIdWithReport(SubmissionId);

        if (submission is null || submission.InstitutionId != institutionId)
        {
            submission = null;
            exports.Clear();
            isLoading = false;
            return;
        }

        try
        {
            var template = await TemplateCache.GetPublishedTemplate(submission.ReturnCode);
            templateName = template.Name;
            moduleCode = template.ModuleCode;
            submissionsHref = PortalSubmissionLinkBuilder.BuildSubmissionListHref(moduleCode);
            moduleWorkspaceHref = PortalSubmissionLinkBuilder.ResolveWorkspaceHref(moduleCode);
            moduleSubmitHref = PortalSubmissionLinkBuilder.BuildSubmitHref(submission.ReturnCode, moduleCode, submission.ReturnPeriodId);
        }
        catch
        {
            templateName = submission.ReturnCode;
            moduleCode = null;
            submissionsHref = PortalSubmissionLinkBuilder.BuildSubmissionListHref(null);
            moduleWorkspaceHref = null;
            moduleSubmitHref = PortalSubmissionLinkBuilder.BuildSubmitHref(submission.ReturnCode, null, submission.ReturnPeriodId);
        }

        periodLabel = submission.ReturnPeriod is not null
            ? new DateTime(submission.ReturnPeriod.Year, submission.ReturnPeriod.Month, 1).ToString("MMM yyyy")
            : "—";

        if (submission.SubmittedByUserId.HasValue)
        {
            var user = await UserRepo.GetById(submission.SubmittedByUserId.Value);
            submitterName = user?.DisplayName ?? "Unknown";
        }

        if (submission.ApprovalRequired ||
            submission.Status == SubmissionStatus.PendingApproval ||
            submission.Status == SubmissionStatus.ApprovalRejected)
        {
            approval = await ApprovalRepo.GetBySubmission(submission.Id);
            if (approval is not null)
            {
                isSelfSubmission = currentUserId.HasValue && approval.RequestedByUserId == currentUserId.Value;
                if (approval.ReviewedByUserId.HasValue)
                {
                    var reviewer = await UserRepo.GetById(approval.ReviewedByUserId.Value);
                    reviewerName = reviewer?.DisplayName ?? "Unknown";
                }
            }
        }

        if (submission.ValidationReport is not null)
        {
            allErrors = submission.ValidationReport.Errors.OrderByDescending(e => e.Severity).ToList();
            errorsByCategory = allErrors.GroupBy(e => e.Category.ToString()).ToDictionary(g => g.Key, g => g.ToList());
            errorCount = submission.ValidationReport.ErrorCount;
            warningCount = submission.ValidationReport.WarningCount;
            totalIssues = allErrors.Count;
        }

        await LoadExportHistory();
        await LoadExaminerQueries();
        await LoadDirectSubmissions();
        _ = LoadDataPreview();
        isLoading = false;
    }

    private void SwitchTab(string tab)
    {
        activeTab = tab;
        if (tab == "data" && !dataLoaded) _ = LoadDataPreview();
    }

    private async Task LoadDataPreview()
    {
        try
        {
            dataRecord = await DataRepo.GetBySubmission(submission!.ReturnCode, submission.Id);
            if (dataRecord is not null && dataRecord.Rows.Any())
                fieldNames = dataRecord.Rows[0].AllFields.Keys.ToList();
        }
        catch { }
        finally { dataLoaded = true; await InvokeAsync(StateHasChanged); }
    }

    private void ToggleCategory(string category)
    {
        if (!expandedCategories.Remove(category)) expandedCategories.Add(category);
    }

    private async Task ApproveSubmission()
    {
        if (approval is null || isProcessingApproval || !currentUserId.HasValue) return;
        isProcessingApproval = true;
        processingApprovalAction = "approve";
        approvalError = null;
        StateHasChanged();
        try
        {
            var comments = string.IsNullOrWhiteSpace(approvalComments) ? null : approvalComments;
            var result = await ApprovalSvc.Approve(SubmissionId, currentUserId.Value, comments);
            if (result == ApprovalActionResult.Success) await LoadSubmission();
            else approvalError = result switch
            {
                ApprovalActionResult.SelfApprovalNotAllowed => "You cannot approve your own submission.",
                ApprovalActionResult.AlreadyProcessed => "This submission has already been reviewed.",
                _ => "Failed to approve. Please try again."
            };
        }
        catch (Exception ex) { approvalError = $"Error: {ex.Message}"; }
        finally { isProcessingApproval = false; processingApprovalAction = null; StateHasChanged(); }
    }

    private async Task RejectSubmission()
    {
        if (approval is null || isProcessingApproval || !currentUserId.HasValue || string.IsNullOrWhiteSpace(approvalComments)) return;
        isProcessingApproval = true;
        processingApprovalAction = "reject";
        approvalError = null;
        StateHasChanged();
        try
        {
            var result = await ApprovalSvc.Reject(SubmissionId, currentUserId.Value, approvalComments);
            if (result == ApprovalActionResult.Success) await LoadSubmission();
            else approvalError = result switch
            {
                ApprovalActionResult.SelfApprovalNotAllowed => "You cannot reject your own submission.",
                ApprovalActionResult.AlreadyProcessed => "This submission has already been reviewed.",
                ApprovalActionResult.CommentsRequired => "Comments are required when rejecting.",
                _ => "Failed to reject. Please try again."
            };
        }
        catch (Exception ex) { approvalError = $"Error: {ex.Message}"; }
        finally { isProcessingApproval = false; processingApprovalAction = null; StateHasChanged(); }
    }

    private async Task RejectAndCloseForm()
    {
        await RejectSubmission();
        if (string.IsNullOrEmpty(approvalError)) _showCommentForm = false;
    }

    private void ToggleCommentForm() => _showCommentForm = !_showCommentForm;
    private async Task WithdrawSubmission()
    {
        if (submission is null)
        {
            return;
        }

        _adminActionError = null;
        _adminActionSuccess = null;

        if (submission.Status != SubmissionStatus.PendingApproval)
        {
            _adminActionError = "Only submissions awaiting checker review can be withdrawn from this screen.";
            return;
        }

        var approvalRecord = await ApprovalRepo.GetBySubmission(submission.Id);
        if (approvalRecord is not null)
        {
            await ApprovalRepo.Delete(approvalRecord);
        }

        submission.MarkHistorical();
        await SubmissionRepo.Update(submission);
        _adminActionSuccess = "Submission withdrawn and archived as historical.";
        await LoadSubmission();
    }

    private Task OverrideStatus()
    {
        _adminActionError = null;
        _adminActionSuccess = null;
        _overrideStatus = submission?.Status.ToString() ?? nameof(SubmissionStatus.Draft);
        _showOverridePanel = !_showOverridePanel;
        return Task.CompletedTask;
    }

    private async Task ApplyOverrideStatus()
    {
        if (submission is null)
        {
            return;
        }

        _adminActionError = null;
        _adminActionSuccess = null;

        if (!Enum.TryParse<SubmissionStatus>(_overrideStatus, out var targetStatus) || !IsOverrideStatusAllowed(targetStatus))
        {
            _adminActionError = "Select a supported override status.";
            return;
        }

        var approvalRecord = await ApprovalRepo.GetBySubmission(submission.Id);
        if (approvalRecord is not null && targetStatus != SubmissionStatus.PendingApproval)
        {
            await ApprovalRepo.Delete(approvalRecord);
        }

        submission.Status = targetStatus;
        await SubmissionRepo.Update(submission);
        _showOverridePanel = false;
        _adminActionSuccess = $"Submission status overridden to {GetStatusLabel(targetStatus.ToString())}.";
        await LoadSubmission();
    }

    private async Task UnlockForEdit()
    {
        if (submission is null)
        {
            return;
        }

        _adminActionError = null;
        _adminActionSuccess = null;

        if (submission.Status is SubmissionStatus.SubmittedToRegulator
            or SubmissionStatus.RegulatorAcknowledged
            or SubmissionStatus.RegulatorAccepted
            or SubmissionStatus.RegulatorQueriesRaised)
        {
            _adminActionError = "Regulator-submitted returns cannot be unlocked from the portal.";
            return;
        }

        var approvalRecord = await ApprovalRepo.GetBySubmission(submission.Id);
        if (approvalRecord is not null)
        {
            await ApprovalRepo.Delete(approvalRecord);
        }

        submission.Status = SubmissionStatus.Draft;
        await SubmissionRepo.Update(submission);
        _adminActionSuccess = "Submission unlocked and returned to draft.";
        await LoadSubmission();
    }

