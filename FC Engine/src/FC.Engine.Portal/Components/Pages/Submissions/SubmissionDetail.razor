    private bool CanTriggerDirectSubmission()
    {
        return submission is not null
            && (submission.Status == SubmissionStatus.Accepted
                || submission.Status == SubmissionStatus.AcceptedWithWarnings);
    }

    private async Task SubmitToRegulatorAsync()
    {
        if (string.IsNullOrEmpty(selectedRegulatorCode) || isSubmittingToRegulator) return;

        isSubmittingToRegulator = true;
        directSubmissionMessage = null;
        StateHasChanged();

        try
        {
            var submittedBy = _presUserName ?? "portal-user";
            var result = await DirectSubmissionService.SubmitToRegulatorAsync(
                SubmissionId, selectedRegulatorCode, submittedBy);

            directSubmissionSuccess = result.Success;
            directSubmissionMessage = result.Success
                ? $"Submitted to {selectedRegulatorCode}. Reference: {result.RegulatorReference}"
                : $"Submission failed: {result.Message}";

            await LoadDirectSubmissions();
            if (result.Success)
            {
                submission = await SubmissionRepo.GetByIdWithReport(SubmissionId);
            }
        }
        catch (Exception ex)
        {
            directSubmissionSuccess = false;
            directSubmissionMessage = ex.Message;
        }
        finally
        {
            isSubmittingToRegulator = false;
            StateHasChanged();
        }
    }

    private async Task RetryDirectSubmissionAsync(int directSubId)
    {
        try
        {
            var result = await DirectSubmissionService.RetrySubmissionAsync(directSubId);
            directSubmissionSuccess = result.Success;
            directSubmissionMessage = result.Success
                ? $"Retry successful. Reference: {result.RegulatorReference}"
                : $"Retry failed: {result.Message}";

            await LoadDirectSubmissions();
        }
        catch (Exception ex)
        {
            directSubmissionSuccess = false;
            directSubmissionMessage = ex.Message;
        }

        StateHasChanged();
    }

