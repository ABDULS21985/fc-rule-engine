        <!-- ═══════════════════════════════════════════════════════════
             FORM ACTIONS
             ═══════════════════════════════════════════════════════════ -->
        <div class="portal-form-actions">
            <div class="portal-form-actions-left">
                <button class="portal-btn portal-btn-ghost"
                        @onclick="ClearForm"
                        disabled="@(isSubmitting || isReadOnlyLocked)"
                        type="button">
                    Clear All
                </button>
                <button class="portal-btn portal-btn-outline"
                        @onclick="ExportAsXml"
                        disabled="@(isSubmitting || isReadOnlyLocked)"
                        type="button">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                    Export as XML
                </button>
            </div>
            <div class="portal-form-actions-right">
                @if (selectedPeriodId > 0)
                {
                    <span class="portal-autosave-indicator portal-autosave-@_saveState">
