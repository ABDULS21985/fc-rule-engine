    private async Task ResumeDraft()
    {
        if (_draftInfo is null) return;
        _showDraftBanner = false;
        _showConflictBanner = false;

        try
        {
            var rows = System.Text.Json.JsonSerializer.Deserialize<List<Dictionary<string, string>>>(_draftInfo.DataJson);
            if (rows is { Count: > 0 })
            {
                formRows = rows;
                isDirty = true;
                _saveState = "idle";
                _saveLabel = "Draft resumed";
            }
        }
        catch { /* deserialization failure — keep current state */ }
    }

    private void DismissDraftBanner() => _showDraftBanner = false;

    private void DismissConflictBanner() => _showConflictBanner = false;

    private void LoadColleagueDraft()
    {
        if (_draftInfo is null) return;
        _showConflictBanner = false;

        try
        {
            var rows = System.Text.Json.JsonSerializer.Deserialize<List<Dictionary<string, string>>>(_draftInfo.DataJson);
            if (rows is { Count: > 0 })
            {
                formRows = rows;
                isDirty = false;
                _saveState = "saved";
                _saveLabel = $"Loaded from {_draftInfo.SavedBy}";
            }
        }
        catch { }
    }

    private async Task TryDeleteDraftSnapshot()
    {
        if (!tenantId.HasValue) return;
        try
        {
            var periodLabel = GetCurrentPeriodLabel();
            await FormDataSvc.DeleteDraftAsync(tenantId.Value, institutionId, ReturnCode, periodLabel);
            _draftInfo = null;
            _showDraftBanner = false;
            _showConflictBanner = false;
        }
        catch { /* non-critical */ }
    }

    private static string GetRelativeTime(DateTime utcTime)
    {
        var elapsed = DateTime.UtcNow - utcTime;
        if (elapsed.TotalMinutes < 1) return "just now";
        if (elapsed.TotalMinutes < 60)
        {
            var mins = (int)elapsed.TotalMinutes;
            return $"{mins} minute{(mins == 1 ? "" : "s")} ago";
        }
        if (elapsed.TotalHours < 24)
        {
            var hrs = (int)elapsed.TotalHours;
            return $"{hrs} hour{(hrs == 1 ? "" : "s")} ago";
        }
        return utcTime.ToLocalTime().ToString("MMMM d 'at' HH:mm");
    }

    private string GetDiffSummary()
    {
        if (_draftInfo is null) return "";
        try
        {
            var draftRows = System.Text.Json.JsonSerializer.Deserialize<List<Dictionary<string, string>>>(_draftInfo.DataJson);
            if (draftRows is null) return "";

            int diffCount = 0;
            for (int r = 0; r < Math.Min(formRows.Count, draftRows.Count); r++)
            {
                foreach (var key in formRows[r].Keys)
                {
                    var cur = formRows[r].TryGetValue(key, out var cv) ? cv : "";
                    var drv = draftRows[r].TryGetValue(key, out var dv) ? dv : "";
                    if (cur != drv) diffCount++;
                }
            }
            if (draftRows.Count != formRows.Count)
                diffCount += Math.Abs(draftRows.Count - formRows.Count) * 3;

            return diffCount == 0
                ? "No visible differences from your colleague's version."
                : $"{diffCount} field value{(diffCount == 1 ? "" : "s")} differ from your colleague's version.";
        }
        catch { return ""; }
    }

    // ── Display Helpers ───────────────────────────────────────────

    private static string GetFieldWidthClass(FieldDisplayItem field)
    {
        if (field.DataType == "Boolean") return "portal-form-group-sm";
        if (field.DataType == "Date") return "portal-form-group-md";
        if (field.DataType == "Text") return "portal-form-group-lg";
        return "portal-form-group-md";
    }

    private static string GetCategoryLabel(string cat)
    {
        if (cat == "FixedRow") return "Fixed Row";
        if (cat == "MultiRow") return "Multi Row";
        if (cat == "ItemCoded") return "Item Coded";
        return cat;
    }

    private static string FormatFrequency(string freq)
    {
        if (freq == "SemiAnnual") return "Semi-Annual";
        return freq;
    }

