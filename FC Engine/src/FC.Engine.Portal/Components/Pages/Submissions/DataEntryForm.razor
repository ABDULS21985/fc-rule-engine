    private record SummaryError(string FieldCode, string FieldLabel, string Message);

    private IEnumerable<SummaryError> GetSummaryErrors()
    {
        foreach (var kvp in fieldErrors)
        {
            // key format: "{rowIdx}_{fieldName}"
            var sep = kvp.Key.IndexOf('_');
            if (sep < 0) continue;
            var fieldName = kvp.Key[(sep + 1)..];
            var rowIdxStr = kvp.Key[..sep];
            int.TryParse(rowIdxStr, out var rowIdx);
            var field = allFields.FirstOrDefault(f => f.FieldName == fieldName);
            var label = field?.DisplayName ?? fieldName;
            var displayLabel = formRows.Count > 1 ? $"Row {rowIdx + 1}: {label}" : label;
            yield return new SummaryError(fieldName, displayLabel, kvp.Value);
        }
    }

