@page "/submit/form/{ReturnCode}"
@attribute [Authorize(Policy = "InstitutionMaker")]
@implements IAsyncDisposable
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using System.Globalization
@using Microsoft.AspNetCore.SignalR.Client

<PageTitle>Data Entry: @ReturnCode — FC Engine Portal</PageTitle>

<div class="portal-page">

    @if (isLoadingTemplate)
    {
        <div class="portal-skeleton portal-skeleton-block" style="height: 120px; margin-bottom: 1.5rem;"></div>
        <div class="portal-skeleton portal-skeleton-block" style="height: 400px;"></div>
    }
    else if (templateDetail is null)
    {
        <div class="portal-empty-state portal-card" style="padding: 3rem;">
            <h3 class="portal-empty-state-title">Template Not Found</h3>
            <p class="portal-empty-state-desc">The template "@ReturnCode" does not exist or is not published.</p>
            <a href="/submit" class="portal-btn portal-btn-primary">Back to Submit</a>
        </div>
    }
    else if (submissionComplete)
    {
        <!-- ═══════════════════════════════════════════════════════════
             SUCCESS STATE
             ═══════════════════════════════════════════════════════════ -->
        <div class="portal-card" style="padding: 3rem; text-align: center;">
            <div style="margin-bottom: 1.5rem;">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--cbn-success-text, #16a34a)" stroke-width="1.5" aria-hidden="true">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
            </div>
            <h2 class="portal-page-title">Submission Complete</h2>
            <p class="portal-page-subtitle" style="margin-bottom: 0.5rem;">
                Your return for <strong>@ReturnCode</strong> has been submitted successfully.
            </p>
            <p class="portal-text-muted" style="margin-bottom: 2rem;">Submission ID: <strong>#@submittedId</strong></p>

            @if (submissionResult is not null && submissionResult.ValidationReport is not null)
            {
                <div class="portal-form-result-stats">
                    <span class="portal-badge portal-badge-lg @(submissionResult.Status == "Accepted" ? "portal-badge-success" : "portal-badge-warning")">
                        @submissionResult.Status
                    </span>
                    @if (submissionResult.ValidationReport.ErrorCount > 0)
                    {
                        <span class="portal-text-danger">@submissionResult.ValidationReport.ErrorCount errors</span>
                    }
                    @if (submissionResult.ValidationReport.WarningCount > 0)
                    {
                        <span class="portal-text-warning">@submissionResult.ValidationReport.WarningCount warnings</span>
                    }
                </div>
            }

            <div style="display: flex; gap: var(--space-3); justify-content: center; margin-top: 2rem;">
                <a href="/submissions/@submittedId" class="portal-btn portal-btn-primary">View Submission</a>
                <a href="/submit" class="portal-btn portal-btn-outline">Submit Another</a>
            </div>
        </div>
    }
    else
    {
        <!-- ═══════════════════════════════════════════════════════════
             BREADCRUMB + BACK BUTTON
             ═══════════════════════════════════════════════════════════ -->
        @{
            var _selectedPeriod = availablePeriods.FirstOrDefault(p => p.ReturnPeriodId == selectedPeriodId);
            var _periodChipLabel = _selectedPeriod?.Label;
            var _periodDeadline = _selectedPeriod?.DeadlineDate;
            var _daysRemaining = _periodDeadline.HasValue
                ? (int)(_periodDeadline.Value.Date - DateTime.Today).TotalDays
                : (int?)null;
            var _deadlineTooltip = _periodDeadline.HasValue
                ? (_daysRemaining >= 0
                    ? $"Due {_periodDeadline.Value:d MMM yyyy} — {_daysRemaining} day{(_daysRemaining == 1 ? "" : "s")} remaining"
                    : $"Due {_periodDeadline.Value:d MMM yyyy} — overdue")
                : null;

            var _bcItems = new List<BreadcrumbItem>
            {
                new("Home", "/"),
                new("Submissions", "/submissions"),
                new("Submit Return", "/submit"),
                new(ReturnCode, IsCurrent: _periodChipLabel is null)
            };
            if (_periodChipLabel is not null)
            {
                _bcItems.Add(new(_periodChipLabel, IsCurrent: true, ChipTooltip: _deadlineTooltip, HasStatusDot: true));
            }
        }
        <PortalPageHeader BackUrl="/submit"
                          Breadcrumb="@_bcItems" />

        <!-- ═══════════════════════════════════════════════════════════
             FORM HEADER
             ═══════════════════════════════════════════════════════════ -->
        <div class="portal-detail-hero">
            <div class="portal-detail-hero-main">
                <div class="portal-detail-hero-title-row">
                    <h1 class="portal-detail-hero-title">@ReturnCode — Data Entry</h1>
                    <span class="portal-badge portal-badge-lg portal-badge-info">Manual Entry</span>
                </div>
                <p class="portal-detail-hero-subtitle">@templateDetail.TemplateName</p>
                <div class="portal-detail-hero-meta">
                    <span class="portal-detail-meta-item"><strong>@templateDetail.FieldCount</strong> fields</span>
                    <span class="portal-detail-meta-item">Category: <strong>@GetCategoryLabel(structuralCategory)</strong></span>
                    <span class="portal-detail-meta-item">Frequency: <strong>@FormatFrequency(templateDetail.Frequency)</strong></span>
                    @if (_validationTriggered && fieldErrors.Any())
                    {
                        <span class="portal-error-count-chip" aria-live="polite">
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                            @fieldErrors.Count error@(fieldErrors.Count == 1 ? "" : "s")
                        </span>
                    }
                </div>
            </div>
            <div class="portal-detail-hero-actions">
                @if (selectedPeriodId > 0)
                {
                    <span class="portal-autosave-indicator portal-autosave-@_saveState" role="status" aria-live="polite">
                        @if (_saveState == "saving")
                        {
                            <span class="portal-autosave-spinner" aria-hidden="true"></span>
                            <span>Saving...</span>
                        }
                        else if (_saveState == "saved")
                        {
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                            <span>@_saveLabel</span>
                        }
                        else if (_saveState == "error")
                        {
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                            <span>Save failed — <button class="portal-autosave-retry-btn" type="button" @onclick="RetrySave">retry</button></span>
                        }
                    </span>
                }
                <a href="/submit" class="portal-btn portal-btn-outline portal-btn-sm">Switch to XML Upload</a>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════
             PROGRESS HEADER
             ═══════════════════════════════════════════════════════════ -->
        @if (selectedPeriodId > 0)
        {
            <div class="portal-form-progress-header">
                <div class="portal-form-progress-bar">
                    <div class="portal-form-progress-fill" style="--pct: @_completionPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"></div>
                </div>
                <div class="portal-form-progress-text">
                    <span>Section @(_currentSectionIndex + 1) of @(Math.Max(1, _sectionNames.Count))</span>
                    <span>·</span>
                    <span>@((int)_completionPct)% complete</span>
                    @if (_errorCount > 0)
                    {
                        <span>·</span>
                        <span>@_errorCount error@(_errorCount == 1 ? "" : "s") remaining</span>
                    }
                </div>
            </div>
        }

        <!-- ═══════════════════════════════════════════════════════════
             ERROR SUMMARY PANEL
             ═══════════════════════════════════════════════════════════ -->
        @if (_validationTriggered)
        {
            @if (fieldErrors.Any())
            {
                <div class="portal-error-summary" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="portal-error-summary-header">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                        </svg>
                        Form cannot be submitted — @fieldErrors.Count error@(fieldErrors.Count == 1 ? "" : "s") found
                    </div>
                    <ul class="portal-error-summary-list" aria-label="Validation errors">
                        @foreach (var err in GetSummaryErrors())
                        {
                            var e = err;
                            <li>
                                <button class="portal-error-link" type="button" @onclick="() => ScrollToField(e.FieldCode)">
                                    @e.FieldLabel: @e.Message
                                </button>
                            </li>
                        }
                    </ul>
                </div>
            }
            else
            {
                <div class="portal-error-summary portal-error-summary--valid" role="status">
                    <div class="portal-error-summary-header">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        All fields valid — ready to submit
                    </div>
                </div>
            }
        }

        <!-- ═══════════════════════════════════════════════════════════
             PERIOD SELECTOR
             ═══════════════════════════════════════════════════════════ -->
        <div class="portal-card portal-form-section">
            <h3 class="portal-form-section-title">Reporting Period</h3>
            @if (isLoadingPeriods)
            {
                <div class="portal-skeleton portal-skeleton-block" style="height: 40px; max-width: 300px;"></div>
            }
            else
            {
                <div class="portal-form-row">
                    <div class="portal-form-group" style="max-width: 300px;">
                        <label for="periodSelect" class="portal-form-label">Select Period</label>
                        <select id="periodSelect"
                                class="portal-form-select"
                                value="@selectedPeriodId"
                                @onchange="OnPeriodChanged">
                            <option value="0">Choose a period...</option>
                            @foreach (var period in availablePeriods)
                            {
                                <option value="@period.ReturnPeriodId" disabled="@period.HasExistingSubmission">
                                    @period.Label @(period.HasExistingSubmission ? "(Already Submitted)" : "")
                                </option>
                            }
                        </select>
                    </div>
                </div>
            }
        </div>

        @if (isReadOnlyLocked)
        {
            <div class="portal-validation-banner portal-validation-banner-warning" role="alert">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M12 9v4"/><path d="M12 17h.01"/><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                </svg>
                <span>@lockStatusMessage</span>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(carryForwardSourcePeriod))
        {
            <div class="portal-validation-banner portal-validation-banner-info portal-cf-banner" role="status" style="margin-top: 0.75rem;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="flex-shrink:0;">
                    <circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/>
                </svg>
                <div class="portal-cf-banner-content">
                    <span>Carry-forward values loaded from <strong>@carryForwardSourcePeriod</strong>.</span>
                    @if (CarryForwardTotal > 0)
                    {
                        <span class="portal-cf-count">
                            @CarryForwardReviewedCount of @CarryForwardTotal reviewed
                            @if (CarryForwardReviewedCount == CarryForwardTotal)
                            {
                                <span class="portal-cf-all-reviewed"> ✓ All reviewed</span>
                            }
                        </span>
                    }
                </div>
                @if (carryForwardKeys.Any())
                {
                    <button class="portal-btn portal-btn-sm portal-btn-outline portal-cf-review-btn"
                            @onclick="ScrollToNextCarriedField"
                            type="button">
                        Review Carried Fields
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <polyline points="9 18 15 12 9 6"/>
                        </svg>
                    </button>
                }
            </div>
        }

        <!-- ── Draft resume banner ─────────────────────────────────── -->
        @if (_showDraftBanner && _draftInfo is not null && !isReadOnlyLocked)
        {
            <div class="portal-autosave-draft-banner" role="alert">
                <svg class="portal-autosave-draft-banner-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
                </svg>
                <div class="portal-autosave-draft-banner-text">
                    <strong>You have a saved draft from @_draftInfo.LastSavedAt.ToLocalTime().ToString("MMMM d 'at' HH:mm")</strong>
                    <span>Resume where you left off or start with a blank form.</span>
                </div>
                <div class="portal-autosave-draft-banner-actions">
                    <button class="portal-btn portal-btn-primary portal-btn-sm" type="button" @onclick="ResumeDraft">Resume draft</button>
                    <button class="portal-btn portal-btn-ghost portal-btn-sm" type="button" @onclick="DismissDraftBanner">Start fresh</button>
                </div>
            </div>
        }

        <!-- ── Conflict banner ─────────────────────────────────────── -->
        @if (_showConflictBanner && _draftInfo is not null)
        {
            <div class="portal-autosave-conflict-banner" role="alert">
                <svg class="portal-autosave-draft-banner-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
                <div class="portal-autosave-draft-banner-text">
                    <strong>@_draftInfo.SavedBy updated this draft @GetRelativeTime(_draftInfo.LastSavedAt)</strong>
                    <span class="portal-text-muted">@GetDiffSummary()</span>
                </div>
                <div class="portal-autosave-draft-banner-actions">
                    <button class="portal-btn portal-btn-warning portal-btn-sm" type="button" @onclick="LoadColleagueDraft">View changes</button>
                    <button class="portal-btn portal-btn-ghost portal-btn-sm" type="button" @onclick="DismissConflictBanner">Dismiss</button>
                </div>
            </div>
        }

        <!-- ═══════════════════════════════════════════════════════════
             FORM LAYOUT: NAVIGATOR + MAIN CONTENT
             ═══════════════════════════════════════════════════════════ -->
        <div class="portal-form-layout">

            <!-- LEFT SECTION NAVIGATOR -->
            @if (_sectionNames.Count > 0 && selectedPeriodId > 0)
            {
                <aside class="portal-form-navigator @(_navigatorExpanded ? "" : "collapsed")" aria-label="Section navigator">
                    <div class="portal-form-navigator-header">
                        <span class="portal-form-navigator-title">Sections</span>
                        <button class="portal-form-navigator-toggle"
                                @onclick="() => _navigatorExpanded = !_navigatorExpanded"
                                type="button"
                                aria-label="@(_navigatorExpanded ? "Collapse" : "Expand") navigator">
                            @if (_navigatorExpanded)
                            {
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                            }
                            else
                            {
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                            }
                        </button>
                    </div>
                    <div class="portal-form-nav-list">
                        @for (int navIdx = 0; navIdx < _sectionNames.Count; navIdx++)
                        {
                            var navI = navIdx;
                            var navName = _sectionNames[navIdx];
                            <button class="portal-form-nav-item @(navI == _currentSectionIndex ? "active" : "") @(_animatingSectionIndex == navI ? "checked" : "")"
                                    @onclick="@(async () => await ScrollToSection(navName, navI))"
                                    type="button"
                                    title="@navName">
                                <span class="portal-form-nav-icon @GetStatusIconClass(navName)" aria-hidden="true">@GetStatusIcon(navName)</span>
                                <span class="portal-form-nav-label">@navName</span>
                            </button>
                        }
                    </div>
                </aside>
            }

            <!-- MAIN FORM CONTENT -->
            <div class="portal-form-main">

        <!-- ═══════════════════════════════════════════════════════════
             DYNAMIC FORM BODY
             ═══════════════════════════════════════════════════════════ -->

        @if (structuralCategory == "FixedRow")
        {
            @for (int secIdx = 0; secIdx < _sectionNames.Count; secIdx++)
            {
                var sIdx = secIdx;
                var secName = _sectionNames[secIdx];
                if (!fieldGroups.TryGetValue(secName, out var secFields)) continue;
                var isLastSec = sIdx == _sectionNames.Count - 1;

                <div id="@GetSectionId(secName)"
                     class="portal-card portal-form-section @(_animatingSectionIndex == sIdx ? "portal-section-checked" : "")">
                    <div class="portal-form-section-header">
                        <h3 class="portal-form-section-title">@secName</h3>
                        <span class="portal-form-section-status-icon @GetStatusIconClass(secName)" aria-label="Section status">@GetStatusIcon(secName)</span>
                    </div>
                    <div class="portal-form-grid">
                        @foreach (var field in secFields)
                        {
                            var fld = field;
                            <div class="portal-form-group @GetFieldWidthClass(fld)">
                                <label class="portal-form-label">
                                    @fld.DisplayName
                                    @if (fld.IsRequired)
                                    {
                                        <span class="portal-form-required" aria-label="required">*</span>
                                    }
                                    <HelpIcon
                                        FieldCode="@fld.FieldName"
                                        FieldLabel="@fld.DisplayName"
                                        HelpText="@fld.HelpText"
                                        RegulatoryReference="@fld.RegulatoryReference"
                                        DataType="@fld.DataType" />
                                </label>
                                @RenderInput(fld, 0)
                                @if (!string.IsNullOrEmpty(fld.HelpText))
                                {
                                    <span class="portal-form-hint">@fld.HelpText</span>
                                }
                                @RenderFieldError(fld, 0)
                            </div>
                        }
                    </div>
                    @if (!isLastSec)
                    {
                        <div class="portal-form-section-footer">
                            <button class="portal-btn portal-btn-outline portal-btn-sm"
                                    @onclick="@(async () => await GoToNextSection(sIdx))"
                                    type="button">
                                Next: @_sectionNames[sIdx + 1] →
                            </button>
                        </div>
                    }
                </div>
            }
        }
        else if (structuralCategory == "MultiRow")
        {
            <div id="@GetSectionId("Return Data")"
                 class="portal-card portal-form-section">
                <!-- ── Table header: title + row count badge + Export CSV + Add Row ── -->
                <div class="portal-form-section-header" style="margin-bottom:var(--space-3);">
                    <div style="display:flex;align-items:center;gap:var(--space-2);flex-wrap:wrap;">
                        <h3 class="portal-form-section-title" style="margin-bottom:0;">
                            Return Data
                            <span class="portal-form-section-status-icon @GetStatusIconClass("Return Data")" aria-label="Section status">@GetStatusIcon("Return Data")</span>
                        </h3>
                        <span class="portal-form-row-count-badge">@formRows.Count row@(formRows.Count != 1 ? "s" : "")</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:var(--space-2);">
                        <button class="portal-btn portal-btn-ghost portal-btn-sm"
                                @onclick="ExportTableAsCsv"
                                type="button"
                                title="Download rows as CSV">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                <polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                            </svg>
                            Export CSV
                        </button>
                        <button class="portal-btn portal-btn-outline portal-btn-sm"
                                @onclick="AddRow"
                                disabled="@isReadOnlyLocked"
                                type="button">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                            </svg>
                            Add Row
                        </button>
                    </div>
                </div>

                @if (!formRows.Any())
                {
                    <div class="portal-empty-state" style="padding: 2rem;">
                        <p class="portal-empty-state-desc">No rows added yet. Click "Add Row" to start entering data.</p>
                    </div>
                }
                else
                {
                    <div class="portal-form-table-wrapper" @onkeydown="HandleTableKeyDown">
                        <table class="portal-table portal-form-table" id="multirow-table" aria-label="Data entry rows">
                            <thead>
                                <tr>
                                    <th class="portal-form-table-rownum" aria-label="Row"></th>
                                    @foreach (var field in nonKeyFields)
                                    {
                                        <th>
                                            @field.DisplayName
                                            @if (field.IsRequired) { <span class="portal-form-required">*</span> }
                                            <HelpIcon
                                                FieldCode="@field.FieldName"
                                                FieldLabel="@field.DisplayName"
                                                HelpText="@field.HelpText"
                                                RegulatoryReference="@field.RegulatoryReference"
                                                DataType="@field.DataType" />
                                        </th>
                                    }
                                    <th class="portal-form-table-actions-cell" aria-label="Actions"></th>
                                </tr>
                            </thead>
                            <tbody id="multirow-tbody">
                                @for (int rowIdx = 0; rowIdx < formRows.Count; rowIdx++)
                                {
                                    var idx = rowIdx;
                                    <tr class="@(RowHasError(idx) ? "portal-form-row-error" : "")" data-row-index="@idx">
                                        <td class="portal-form-table-rownum portal-text-muted" data-label="">
                                            @if (!isReadOnlyLocked)
                                            {
                                                <span class="portal-drag-handle portal-form-drag-handle"
                                                      draggable="true"
                                                      title="Drag to reorder"
                                                      aria-hidden="true">
                                                    <svg width="10" height="14" viewBox="0 0 10 18" fill="currentColor" aria-hidden="true">
                                                        <circle cx="3" cy="3" r="1.5"/><circle cx="7" cy="3" r="1.5"/>
                                                        <circle cx="3" cy="9" r="1.5"/><circle cx="7" cy="9" r="1.5"/>
                                                        <circle cx="3" cy="15" r="1.5"/><circle cx="7" cy="15" r="1.5"/>
                                                    </svg>
                                                </span>
                                            }
                                            <span>@(idx + 1)</span>
                                        </td>
                                        @foreach (var field in nonKeyFields)
                                        {
                                            var fld = field;
                                            <td data-label="@fld.DisplayName" data-field="@fld.FieldName">
                                                @RenderInput(fld, idx)
                                                @RenderFieldError(fld, idx)
                                            </td>
                                        }
                                        <td class="portal-form-table-actions-cell" data-label="">
                                            <div class="portal-form-table-row-actions">
                                                <button class="portal-btn portal-btn-ghost portal-btn-xs"
                                                        @onclick="() => AddRowAfter(idx)"
                                                        disabled="@isReadOnlyLocked"
                                                        type="button"
                                                        title="Add row below"
                                                        aria-label="Add row below @(idx + 1)">
                                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                                                        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                                                    </svg>
                                                </button>
                                                @if (formRows.Count > 1)
                                                {
                                                    <button class="portal-btn portal-btn-ghost portal-btn-xs portal-btn-danger-text"
                                                            @onclick="() => RemoveRow(idx)"
                                                            disabled="@isReadOnlyLocked"
                                                            type="button"
                                                            title="Delete row"
                                                            aria-label="Delete row @(idx + 1)">
                                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                                            <polyline points="3 6 5 6 21 6"/>
                                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                                        </svg>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <p class="portal-form-table-hint">
                        <kbd>Tab</kbd> next cell &nbsp;·&nbsp;
                        <kbd>Enter</kbd> add row &nbsp;·&nbsp;
                        <kbd>Ctrl+D</kbd> duplicate row
                    </p>
                }
            </div>
        }
        else if (structuralCategory == "ItemCoded")
        {
            <div id="@GetSectionId("Return Data")"
                 class="portal-card portal-form-section">
                <!-- ── Table header: title + count badge + Export CSV ── -->
                <div class="portal-form-section-header" style="margin-bottom:var(--space-3);">
                    <div style="display:flex;align-items:center;gap:var(--space-2);flex-wrap:wrap;">
                        <h3 class="portal-form-section-title" style="margin-bottom:0;">
                            Return Data
                            <span class="portal-form-section-status-icon @GetStatusIconClass("Return Data")" aria-label="Section status">@GetStatusIcon("Return Data")</span>
                        </h3>
                        <span class="portal-form-row-count-badge">@itemCodes.Count item code@(itemCodes.Count != 1 ? "s" : "")</span>
                    </div>
                    <button class="portal-btn portal-btn-ghost portal-btn-sm"
                            @onclick="ExportTableAsCsv"
                            type="button"
                            title="Download rows as CSV">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                            <polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                        </svg>
                        Export CSV
                    </button>
                </div>

                <div class="portal-form-table-wrapper">
                    <table class="portal-table portal-form-table" aria-label="Item code data entry">
