    // ── Carry-Forward Review Actions ─────────────────────────────

    private void MarkCarriedFieldReviewed(int rowIdx, string fieldName)
    {
        var key = GetFieldErrorKey(rowIdx, fieldName);
        carryForwardKeys.Remove(key);
        carryForwardReviewedKeys.Add(key);
        StateHasChanged();
    }

    private void UndoCarryForwardChange(int rowIdx, string fieldName)
    {
        var key = GetFieldErrorKey(rowIdx, fieldName);
        if (!carryForwardOriginalValues.TryGetValue(key, out var original)) return;

        formRows[rowIdx][fieldName] = original;
        carryForwardModifiedKeys.Remove(key);
        carryForwardReviewedKeys.Remove(key);
        carryForwardKeys.Add(key);
        MarkDirtyAndDebounce();
    }

    private async Task ScrollToNextCarriedField()
    {
        var unreviewed = carryForwardKeys.OrderBy(k => k).ToList();
        if (!unreviewed.Any()) return;
        _carryReviewCursor = (_carryReviewCursor + 1) % unreviewed.Count;
        await JS.InvokeVoidAsync("portalScrollIntoView", $"carry-{unreviewed[_carryReviewCursor]}");
    }

