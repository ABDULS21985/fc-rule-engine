                            </tr>
                        </thead>
                        <tbody>
                            @for (int rowIdx = 0; rowIdx < formRows.Count; rowIdx++)
                            {
                                var idx = rowIdx;
                                var isTotalRow = idx < itemCodes.Count && itemCodes[idx].IsTotalRow;
                                var trClass = (isTotalRow ? "portal-tmpl-total-row " : "") + (RowHasError(idx) ? "portal-form-row-error" : "");
                                <tr class="@trClass"
                                    data-row-index="@idx">
                                    <td class="portal-form-table-itemcode" data-label="Item Code">
                                        <span class="portal-table-code">@(idx < itemCodes.Count ? itemCodes[idx].ItemCode : "")</span>
                                        @if (idx < itemCodes.Count && !string.IsNullOrEmpty(itemCodes[idx].Description))
                                        {
                                            <span class="portal-form-item-desc">@itemCodes[idx].Description</span>
