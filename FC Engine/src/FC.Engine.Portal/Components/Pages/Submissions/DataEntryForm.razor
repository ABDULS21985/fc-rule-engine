    private void ClearForm()
    {
        if (isReadOnlyLocked)
        {
            return;
        }

        _validationTriggered = false;
        fieldErrors.Clear();
        _inlineState.Clear();
        foreach (var cts in _fieldValidateCts.Values) { cts.Cancel(); cts.Dispose(); }
        _fieldValidateCts.Clear();
        serverErrors.Clear();
        showValidationResult = false;
        submitError = "";
        InitializeFormRows();
        carryForwardKeys.Clear();
        carryForwardOriginalValues.Clear();
        carryForwardReviewedKeys.Clear();
        carryForwardModifiedKeys.Clear();
        ComputeProgress();
        MarkDirtyAndDebounce();
