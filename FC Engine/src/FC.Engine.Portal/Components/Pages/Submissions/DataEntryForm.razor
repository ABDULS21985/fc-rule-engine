    private void BuildSectionNames()
    {
        _sectionNames = structuralCategory == "FixedRow"
            ? fieldGroups.Keys.ToList()
            : new List<string> { "Return Data" };
        _currentSectionIndex = 0;
    }

    private void ComputeProgress()
    {
        var fieldsToCount = structuralCategory == "FixedRow" ? allFields : nonKeyFields;
        if (fieldsToCount.Count == 0 || formRows.Count == 0)
        {
            _totalFields = 0;
            _completedFields = 0;
            _completionPct = 0;
            return;
        }

        _totalFields = fieldsToCount.Count * formRows.Count;
        _completedFields = 0;

        for (int ri = 0; ri < formRows.Count; ri++)
        {
            foreach (var f in fieldsToCount)
            {
                if (!string.IsNullOrWhiteSpace(GetFieldValue(ri, f.FieldName)))
                    _completedFields++;
            }
        }

        _completionPct = Math.Min(100, (_completedFields / (double)_totalFields) * 100);
    }

    private SectionStatus GetSectionStatus(string sectionName)
    {
        var sectionFields = structuralCategory == "FixedRow"
            ? fieldGroups.GetValueOrDefault(sectionName, new List<FieldDisplayItem>())
            : nonKeyFields;

        if (!sectionFields.Any()) return SectionStatus.Untouched;

        bool hasErrors = false;
        bool anyFilled = false;
        bool allRequiredFilled = true;

        for (int ri = 0; ri < formRows.Count; ri++)
        {
            foreach (var f in sectionFields)
            {
                var key = GetFieldErrorKey(ri, f.FieldName);
                if (_inlineState.TryGetValue(key, out var s) && s.Status == "error") hasErrors = true;
                if (!string.IsNullOrWhiteSpace(GetFieldValue(ri, f.FieldName))) anyFilled = true;
                if (f.IsRequired && string.IsNullOrWhiteSpace(GetFieldValue(ri, f.FieldName))) allRequiredFilled = false;
            }
        }

        if (!hasErrors)
            hasErrors = serverErrors.Any(e => sectionFields.Any(f => f.FieldName == e.Field) && e.Severity == "Error");

        bool hasWarnings = serverErrors.Any(e => sectionFields.Any(f => f.FieldName == e.Field) && e.Severity == "Warning");

        if (hasErrors) return SectionStatus.Error;
        if (!anyFilled) return SectionStatus.Untouched;
        if (allRequiredFilled) return SectionStatus.Complete;
        if (hasWarnings) return SectionStatus.Warning;
        return SectionStatus.Untouched;
    }

    private string GetStatusIcon(string sectionName) => GetSectionStatus(sectionName) switch
    {
        SectionStatus.Complete => "✓",
        SectionStatus.Error => "✗",
