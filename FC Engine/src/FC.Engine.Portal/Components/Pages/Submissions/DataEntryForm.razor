                            <span>Save failed — <button class="portal-autosave-retry-btn" type="button" @onclick="RetrySave">retry</button></span>
                        }
                        else
                        {
                            <span class="portal-text-muted">@_saveLabel</span>
                        }
                    </span>
                }
            </div>
        </div>

            </div><!-- /portal-form-main -->
        </div><!-- /portal-form-layout -->

        <!-- STICKY SUBMIT (visible after 50% completion) -->
        @if (_completionPct >= 50 && selectedPeriodId > 0 && !isReadOnlyLocked)
        {
            <div class="portal-form-sticky-submit">
                <button class="portal-btn portal-btn-primary portal-form-sticky-submit-btn"
                        @onclick="SubmitForm"
                        disabled="@(isSubmitting || selectedPeriodId == 0)"
                        type="button">
                    @if (isSubmitting)
                    {
                        <span class="portal-btn-spinner" aria-hidden="true"></span>
                        <span>Submitting...</span>
                    }
                    else
                    {
                        <span>@(requiresApproval ? "Submit for Approval" : "Submit Return")</span>
                    }
                </button>
            </div>
        }

        <!-- ═══════════════════════════════════════════════════════════
             VALIDATION RESULT
             ═══════════════════════════════════════════════════════════ -->
        @if (showValidationResult && serverErrors.Any())
        {
            <div class="portal-card portal-form-validation-result" role="alert">
                <div class="portal-validation-banner portal-validation-banner-error">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                    </svg>
                    <div>
                        <strong>@serverErrors.Count validation issue(s) found</strong>
                        <span class="portal-validation-banner-note">Fix the issues below and try again.</span>
                    </div>
                </div>
                <div class="portal-table-responsive">
                    <table class="portal-table portal-validation-table" aria-label="Validation errors">
                        <thead>
                            <tr>
                                <th>Severity</th>
                                <th>Rule</th>
                                <th>Field</th>
                                <th>Message</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var err in serverErrors)
                            {
                                <tr>
                                    <td><span class="portal-badge portal-badge-sm @(err.Severity == "Error" ? "portal-badge-danger" : "portal-badge-warning")">@err.Severity</span></td>
                                    <td class="portal-table-mono">@err.RuleId</td>
                                    <td class="portal-table-mono">@err.Field</td>
                                    <td>@err.Message</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(submitError))
        {
            <div class="portal-card portal-form-validation-result" role="alert">
                <div class="portal-validation-banner portal-validation-banner-error">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                    </svg>
                    <strong>@submitError</strong>
                </div>
            </div>
        }

        <!-- ═══════════════════════════════════════════════════════════
             STICKY SUBMIT PANEL
             ═══════════════════════════════════════════════════════════ -->
        @if (selectedPeriodId > 0 && !isReadOnlyLocked)
        {
            var (completionPct, clientErrorCount) = ComputeCompletionStats();
            var stickyClass = "portal-sticky-submit" + (_submitState == SubmitState.Success ? " portal-sticky-submit--success" : "");
            <div class="@stickyClass" role="region" aria-label="Submit panel">

                <div class="portal-sticky-submit-left">
                    <button type="button"
                            class="portal-sticky-submit-summary"
                            @onclick="ScrollToErrors"
                            aria-label="@completionPct% complete, @clientErrorCount error(s). Click to scroll to errors.">
                        <div class="portal-sticky-progress">
                            <div class="portal-sticky-progress-bar" style="width: @completionPct%"></div>
                        </div>
                        <span class="portal-sticky-summary-text">
                            @completionPct% complete
                            @if (clientErrorCount > 0)
                            {
                                <span class="portal-sticky-error-count">· @clientErrorCount error@(clientErrorCount != 1 ? "s" : "")</span>
                            }
                        </span>
                    </button>
                </div>

                <div class="portal-sticky-submit-right">
                    <button type="button"
                            class="portal-btn portal-btn-outline portal-btn-sm"
                            @onclick="SaveDraftExplicit"
                            disabled="@(_submitState != SubmitState.Idle || !isDirty)"
                            aria-label="Save draft">
                        @if (saveStatus.StartsWith("Saving"))
                        {
                            <span class="portal-btn-spinner" aria-hidden="true"></span>
                        }
                        Save Draft
                    </button>

                    <button type="button"
                            class="portal-btn portal-sticky-submit-btn @GetSubmitButtonClass()"
                            @onclick="ValidateAndSubmit"
                            disabled="@IsSubmitButtonDisabled()"
                            aria-live="polite"
                            aria-label="@GetSubmitAriaLabel()">
                        @switch (_submitState)
                        {
                            case SubmitState.Validating:
                                <span class="portal-btn-spinner" aria-hidden="true"></span>
                                <span>Validating...</span>
                                break;
                            case SubmitState.Submitting:
                                <span class="portal-btn-spinner" aria-hidden="true"></span>
                                <span>Submitting...</span>
                                break;
                            case SubmitState.Success:
                                <svg class="portal-submit-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                                <span>Submitted!</span>
                                break;
                            case SubmitState.Error:
                                <svg class="portal-submit-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                <span>Submission Failed — retry?</span>
                                break;
                            default:
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                                <span>@(requiresApproval ? "Submit for Approval" : "Validate &amp; Submit")</span>
                                break;
                        }
                    </button>
                </div>

                @if (_submitState == SubmitState.Success)
                {
                    <div class="portal-sticky-countdown" aria-live="polite">
                        <svg class="portal-countdown-ring" viewBox="0 0 36 36" aria-hidden="true">
                            <circle class="portal-countdown-ring-bg" cx="18" cy="18" r="15.9"/>
                            <circle class="portal-countdown-ring-fill" cx="18" cy="18" r="15.9"
                                    style="stroke-dashoffset: @GetCountdownDashOffset()"/>
                        </svg>
                        Redirecting in @_redirectCountdown s...
                    </div>
                    <div class="portal-confetti" aria-hidden="true">
                        @for (int ci = 0; ci < 14; ci++) { <span class="portal-confetti-piece portal-confetti-piece--@(ci % 5)"></span> }
                    </div>
                }
            </div>
        }
    }
</div>


@* ── Feature-discovery beacons (shown once to new users) ── *@
<TourBeaconSet TourKey="data-entry-v1" Beacons="@_dataEntryBeacons" Steps="@_dataEntryTourSteps" />

@code {
    [Parameter] public string ReturnCode { get; set; } = "";

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    [Inject] private TemplateBrowserService BrowserSvc { get; set; } = default!;
    [Inject] private SubmissionService SubmissionSvc { get; set; } = default!;
    [Inject] private FormDataToXmlService XmlSvc { get; set; } = default!;
    [Inject] private ITenantContext TenantContext { get; set; } = default!;
    [Inject] private ICarryForwardService CarryForwardService { get; set; } = default!;
    [Inject] private IReturnLockService ReturnLockService { get; set; } = default!;
    [Inject] private IDraftDataService DraftDataService { get; set; } = default!;
    [Inject] private IGenericDataRepository DataRepo { get; set; } = default!;
    [Inject] private IFormDataService FormDataSvc { get; set; } = default!;

    // ── State ─────────────────────────────────────────────────────
    private bool isLoadingTemplate = true;
    private bool isLoadingPeriods = true;
    private bool isSubmitting;
    private bool submissionComplete;
    private bool showValidationResult;
    private string submitError = "";
    private TemplateDetailModel? templateDetail;
    private string structuralCategory = "FixedRow";

    // Auth
    private int institutionId;
    private int? userId;
    private Guid? tenantId;
    private string userDisplayName = "User";
    private string institutionCode = "";
    private bool requiresApproval;

    // Period
    private int selectedPeriodId;
    private List<PeriodSelectItem> availablePeriods = new();

    // Template metadata
    private List<FieldDisplayItem> allFields = new();
    private List<FieldDisplayItem> nonKeyFields = new();
    private Dictionary<string, List<FieldDisplayItem>> fieldGroups = new();
    private List<FormulaDisplayItem> sumFormulas = new();
    private List<ItemCodeDisplayItem> itemCodes = new();

    // Form data: each row is FieldName → user value
    private List<Dictionary<string, string>> formRows = new();

    // Validation
    private Dictionary<string, string> fieldErrors = new();
    private List<ValidationErrorDto> serverErrors = new();
    private bool _validationTriggered;

    // Inline real-time validation
    private record FieldInlineState(string Status, string Message);
    private Dictionary<string, FieldInlineState> _inlineState = new();
    private Dictionary<string, CancellationTokenSource> _fieldValidateCts = new();

    // Submission result
    private SubmissionResultDto? submissionResult;
    private int submittedId;

    // Draft / carry-forward / lock / autosave
    private int draftSubmissionId;
    private bool isReadOnlyLocked;
    private string lockStatusMessage = string.Empty;
    private string carryForwardSourcePeriod = string.Empty;
    private HashSet<string> carryForwardKeys = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, string> carryForwardOriginalValues = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> carryForwardReviewedKeys = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> carryForwardModifiedKeys = new(StringComparer.OrdinalIgnoreCase);
    private int _carryReviewCursor = -1;
    private int CarryForwardTotal => carryForwardOriginalValues.Count;
    private int CarryForwardReviewedCount => carryForwardReviewedKeys.Count + carryForwardModifiedKeys.Count;
    private string saveStatus = "Saved";
    private bool isDirty;
    private CancellationTokenSource? autoSaveCts;

    // Auto-save indicator (saving / saved / error / conflict)
    private string _saveState = "saved";
    private string _saveLabel = "Saved";

    // Draft recovery / conflict detection
    private ReturnDraft? _draftInfo;
    private bool _showDraftBanner;
    private bool _showConflictBanner;
    private HubConnection? lockHubConnection;
    private CancellationTokenSource? lockHeartbeatCts;

    // ── Submit State Machine ───────────────────────────────────────
    private enum SubmitState { Idle, Validating, Submitting, Success, Error }
    private SubmitState _submitState = SubmitState.Idle;
    private int _redirectCountdown;
    private CancellationTokenSource? _redirectCts;
    private DotNetObjectReference<DataEntryForm>? _dotNetRef;
    private int _lastEditedRowIndex = -1;
    private bool _dragSortInitialized;

    // ── Progress & Navigation ──────────────────────────────────────
    private int _totalFields;
    private int _completedFields;
    private double _completionPct;
    private int _currentSectionIndex;
    private bool _navigatorExpanded = true;
    private List<string> _sectionNames = new();
    private int _animatingSectionIndex = -1;
    private int _errorCount => fieldErrors.Count + serverErrors.Count(e => e.Severity == "Error");
    private enum SectionStatus { Untouched, Error, Warning, Complete }

    // ── Lifecycle ─────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        // Extract auth context
        if (AuthState is not null)
        {
            var state = await AuthState;
            var user = state.User;

            var instIdStr = user.FindFirst("InstitutionId")?.Value;
            int.TryParse(instIdStr, out institutionId);

            var userIdStr = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(userIdStr, out var uid)) userId = uid;

            var tenantStr = user.FindFirst("TenantId")?.Value ?? user.FindFirst("tid")?.Value;
            if (Guid.TryParse(tenantStr, out var tid))
            {
                tenantId = tid;
            }

            userDisplayName = user.FindFirst("DisplayName")?.Value
                              ?? user.FindFirst(ClaimTypes.Name)?.Value
                              ?? user.Identity?.Name
                              ?? "User";

            institutionCode = user.FindFirst("InstitutionName")?.Value ?? "INST001";

            var role = user.FindFirst(ClaimTypes.Role)?.Value ?? "";
            var isMaker = role.Equals("Maker", StringComparison.OrdinalIgnoreCase);
            var makerCheckerEnabled = await SubmissionSvc.IsMakerCheckerEnabled(institutionId);
            requiresApproval = isMaker && makerCheckerEnabled;
        }

        // Load template detail
        try
        {
            templateDetail = await BrowserSvc.GetTemplateDetail(ReturnCode);
            if (templateDetail is not null)
            {
                structuralCategory = templateDetail.StructuralCategory;
                allFields = templateDetail.Fields;
                nonKeyFields = allFields.Where(f => !f.IsKeyField).ToList();
                fieldGroups = allFields.GroupBy(f => f.SectionName)
                    .ToDictionary(g => g.Key, g => g.ToList());

                sumFormulas = templateDetail.Formulas
                    .Where(f => f.Type.Equals("Sum", StringComparison.OrdinalIgnoreCase))
                    .ToList();

                itemCodes = templateDetail.ItemCodes;

                InitializeFormRows();
            }
        }
        catch
        {
            templateDetail = null;
        }
        finally
        {
            isLoadingTemplate = false;
        }

        // Load periods
        try
        {
            availablePeriods = await SubmissionSvc.GetOpenPeriods(institutionId, ReturnCode);
        }
        catch
        {
            availablePeriods = new();
        }
        finally
        {
            isLoadingPeriods = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("portalDataEntryForm.init", _dotNetRef);
        }

        // Init row drag-sort once when MultiRow table first appears
        if (structuralCategory == "MultiRow" && !isReadOnlyLocked && formRows.Any() && !_dragSortInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("FCDragDrop.initTableRowSort", "multirow-tbody", _dotNetRef);
                _dragSortInitialized = true;
            }
            catch { /* JS not ready or table not yet in DOM */ }
        }

        if (structuralCategory != "MultiRow" || isReadOnlyLocked || !formRows.Any())
            _dragSortInitialized = false;
    }

    [JSInvokable]
    public async Task OnCtrlEnter()
    {
        if (_submitState == SubmitState.Idle && selectedPeriodId > 0 && !isReadOnlyLocked)
        {
            await ValidateAndSubmit();
        }
    }

    private async Task OnPeriodChanged(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var parsedPeriodId))
        {
            selectedPeriodId = 0;
            return;
        }

        selectedPeriodId = parsedPeriodId;
        if (selectedPeriodId == 0)
        {
            await ReleaseLock();
            return;
        }

        await InitializeDraftSession();
    }

    private async Task InitializeDraftSession()
    {
        if (!tenantId.HasValue || !userId.HasValue || selectedPeriodId == 0)
        {
            return;
        }

        var previousDraftId = draftSubmissionId;
        draftSubmissionId = await DraftDataService.GetOrCreateDraftSubmission(
            tenantId.Value,
            ReturnCode,
            institutionId,
            selectedPeriodId,
            userId.Value);

        if (previousDraftId > 0 && previousDraftId != draftSubmissionId)
        {
            try
            {
                await ReturnLockService.ReleaseLock(tenantId.Value, previousDraftId, userId.Value);
            }
            catch
            {
                // ignore lock release failures while switching periods
            }
        }

        var lockResult = await ReturnLockService.AcquireLock(
            tenantId.Value,
            draftSubmissionId,
            userId.Value,
            userDisplayName);

        if (!lockResult.Acquired && lockResult.UserId != userId.Value)
        {
            isReadOnlyLocked = true;
            lockStatusMessage = lockResult.Message ?? $"Being edited by {lockResult.UserName}.";
            saveStatus = "Read-only";
        }
        else
        {
            isReadOnlyLocked = false;
            lockStatusMessage = string.Empty;
            await StartLockHeartbeat();
        }

        await LoadExistingDraftData();
        ComputeProgress();

        // Check for a saved JSON draft — used for crash recovery and conflict detection
        _showDraftBanner = false;
        _showConflictBanner = false;
        _draftInfo = null;
        var periodLabel = GetCurrentPeriodLabel();
        var jsonDraft = await FormDataSvc.GetDraftAsync(tenantId.Value, institutionId, ReturnCode, periodLabel);
        if (jsonDraft is not null)
        {
            _draftInfo = jsonDraft;
            if (jsonDraft.SavedBy != userDisplayName)
                _showConflictBanner = true;
            else
                _showDraftBanner = true;
        }

        if (!isReadOnlyLocked)
        {
            var carryForward = await CarryForwardService.GetCarryForwardValues(
                tenantId.Value,
                ReturnCode,
                selectedPeriodId);

            carryForwardSourcePeriod = carryForward.SourcePeriodLabel ?? string.Empty;
            ApplyCarryForwardValues(carryForward.Values);
            if (!_showDraftBanner && !_showConflictBanner)
                await AutoSave();
        }
        else
        {
            carryForwardSourcePeriod = string.Empty;
            carryForwardKeys.Clear();
        }
    }

    private async Task LoadExistingDraftData()
    {
        if (draftSubmissionId <= 0)
        {
            return;
        }

        var existing = await DataRepo.GetBySubmission(ReturnCode, draftSubmissionId);
        if (existing is null || existing.Rows.Count == 0)
        {
            return;
        }

        if (structuralCategory == "FixedRow")
        {
            var row = existing.Rows.First();
            foreach (var field in allFields)
            {
                var value = row.GetValue(field.FieldName);
                if (value is not null)
                {
                    formRows[0][field.FieldName] = FormatValueForInput(field.FieldName, value);
                }
            }

            return;
        }

        if (structuralCategory == "MultiRow")
        {
            formRows.Clear();
            foreach (var existingRow in existing.Rows)
            {
                var row = CreateEmptyRow();
                foreach (var field in allFields)
                {
                    var value = existingRow.GetValue(field.FieldName);
                    if (value is not null)
                    {
                        row[field.FieldName] = FormatValueForInput(field.FieldName, value);
                    }
                }

                formRows.Add(row);
            }

            if (formRows.Count == 0)
            {
                formRows.Add(CreateEmptyRow());
            }

            return;
        }

        if (structuralCategory == "ItemCoded")
        {
            var keyField = allFields.FirstOrDefault(x => x.IsKeyField);
            if (keyField is null)
            {
                return;
            }

            foreach (var existingRow in existing.Rows)
            {
                var keyValue = existingRow.GetValue(keyField.FieldName)?.ToString();
                if (string.IsNullOrWhiteSpace(keyValue))
                {
                    continue;
                }

                var targetRow = formRows.FirstOrDefault(x =>
                    string.Equals(
                        x.TryGetValue(keyField.FieldName, out var currentKey) ? currentKey : string.Empty,
                        keyValue,
                        StringComparison.OrdinalIgnoreCase));
                if (targetRow is null)
                {
                    continue;
                }

                foreach (var field in allFields)
                {
                    var value = existingRow.GetValue(field.FieldName);
                    if (value is not null)
                    {
                        targetRow[field.FieldName] = FormatValueForInput(field.FieldName, value);
                    }
                }
            }
        }
    }

    private async Task StartLockHeartbeat()
    {
        await StopLockHeartbeat();

        lockHeartbeatCts = new CancellationTokenSource();
        var token = lockHeartbeatCts.Token;

        lockHubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/returnlock"))
            .WithAutomaticReconnect()
            .Build();

        lockHubConnection.On<object>("LockLost", async (payload) =>
        {
            isReadOnlyLocked = true;
            lockStatusMessage = "The return is now locked by another user.";
            saveStatus = "Read-only";
            await InvokeAsync(StateHasChanged);
        });

        lockHubConnection.On<object>("LockReleased", async (_) =>
        {
            // Another user released the lock — we could attempt re-acquisition
        });

        try
        {
            await lockHubConnection.StartAsync(token);
            await lockHubConnection.InvokeAsync("JoinSubmission", draftSubmissionId, token);

            // Start periodic heartbeat over the SignalR connection
            _ = Task.Run(async () =>
            {
                try
                {
                    while (!token.IsCancellationRequested)
                    {
                        await Task.Delay(TimeSpan.FromSeconds(60), token);

                        if (lockHubConnection?.State != HubConnectionState.Connected)
                            continue;

                        var response = await lockHubConnection.InvokeAsync<Infrastructure.Hubs.HeartbeatResponse>(
                            "SendHeartbeat", draftSubmissionId, token);

                        if (response is { Acquired: false })
                        {
                            isReadOnlyLocked = true;
                            lockStatusMessage = response.Message ?? "The return is now locked by another user.";
                            saveStatus = "Read-only";
                            await InvokeAsync(StateHasChanged);
                            break;
                        }
                    }
                }
                catch (TaskCanceledException)
                {
                    // ignore
                }
            }, token);
        }
        catch (Exception)
        {
            // Fallback: if SignalR connection fails, use direct service heartbeat
            _ = Task.Run(async () =>
            {
                try
                {
                    while (!token.IsCancellationRequested)
                    {
                        await Task.Delay(TimeSpan.FromSeconds(60), token);

                        if (!tenantId.HasValue || !userId.HasValue || draftSubmissionId <= 0)
                            continue;

                        var heartbeat = await ReturnLockService.Heartbeat(
                            tenantId.Value, draftSubmissionId, userId.Value, token);

                        if (!heartbeat.Acquired)
                        {
                            isReadOnlyLocked = true;
                            lockStatusMessage = heartbeat.Message ?? "The return is now locked by another user.";
                            saveStatus = "Read-only";
                            await InvokeAsync(StateHasChanged);
                            break;
                        }
                    }
                }
                catch (TaskCanceledException)
                {
                    // ignore
                }
            }, token);
        }
    }

    private async Task StopLockHeartbeat()
    {
        lockHeartbeatCts?.Cancel();
        lockHeartbeatCts?.Dispose();
        lockHeartbeatCts = null;

        if (lockHubConnection is not null)
        {
            try
            {
                if (lockHubConnection.State == HubConnectionState.Connected && draftSubmissionId > 0)
                {
                    await lockHubConnection.InvokeAsync("LeaveSubmission", draftSubmissionId);
                }
                await lockHubConnection.DisposeAsync();
            }
            catch
            {
                // ignore dispose errors
            }
            lockHubConnection = null;
        }
    }

    private void ApplyCarryForwardValues(IReadOnlyDictionary<string, object?> values)
    {
        carryForwardKeys.Clear();
        carryForwardOriginalValues.Clear();
        carryForwardReviewedKeys.Clear();
        carryForwardModifiedKeys.Clear();

        if (values.Count == 0 || formRows.Count == 0)
        {
            return;
        }

        foreach (var pair in values)
        {
            if (!formRows[0].ContainsKey(pair.Key))
            {
                continue;
            }

            if (!string.IsNullOrWhiteSpace(formRows[0][pair.Key]))
            {
                continue;
            }

            var formatted = FormatValueForInput(pair.Key, pair.Value);
            formRows[0][pair.Key] = formatted;
            var errorKey = GetFieldErrorKey(0, pair.Key);
            carryForwardKeys.Add(errorKey);
            carryForwardOriginalValues[errorKey] = formatted;
        }

        if (carryForwardKeys.Count > 0)
        {
            isDirty = true;
            saveStatus = "Unsaved changes...";
        }
    }

    // ── Initialization ────────────────────────────────────────────

    private void InitializeFormRows()
    {
        formRows.Clear();

        if (structuralCategory == "FixedRow")
        {
            formRows.Add(CreateEmptyRow());
        }
        else if (structuralCategory == "MultiRow")
        {
            formRows.Add(CreateEmptyRow());
        }
        else if (structuralCategory == "ItemCoded")
        {
            foreach (var ic in itemCodes)
            {
                var row = CreateEmptyRow();
                // Pre-fill key field with item code
                var keyField = allFields.FirstOrDefault(f => f.IsKeyField);
                if (keyField is not null)
                    row[keyField.FieldName] = ic.ItemCode;
                formRows.Add(row);
            }
        }

        BuildSectionNames();
        ComputeProgress();
    }

    private Dictionary<string, string> CreateEmptyRow()
    {
        return allFields.ToDictionary(f => f.FieldName, _ => "");
    }

    // ── Row Management (MultiRow) ─────────────────────────────────

    private void AddRow()
    {
        if (isReadOnlyLocked)
        {
            return;
        }

        formRows.Add(CreateEmptyRow());
        MarkDirtyAndDebounce();
    }

    private void RemoveRow(int index)
    {
        if (isReadOnlyLocked)
        {
            return;
        }

        if (index >= 0 && index < formRows.Count && formRows.Count > 1)
        {
            formRows.RemoveAt(index);
            // Clean up errors for removed and renumbered rows
            fieldErrors.Clear();
            _inlineState.Clear();
            MarkDirtyAndDebounce();
        }
    }

    private void AddRowAfter(int index)
    {
        if (isReadOnlyLocked) return;
        if (index >= 0 && index < formRows.Count)
        {
            formRows.Insert(index + 1, CreateEmptyRow());
            MarkDirtyAndDebounce();
        }
    }

    private void DuplicateRow(int index)
    {
        if (isReadOnlyLocked) return;
        if (index >= 0 && index < formRows.Count)
        {
            var copy = new Dictionary<string, string>(formRows[index]);
            formRows.Insert(index + 1, copy);
            fieldErrors.Clear();
            _inlineState.Clear();
            MarkDirtyAndDebounce();
        }
    }

    private bool RowHasError(int rowIdx) =>
        nonKeyFields.Any(f =>
            fieldErrors.ContainsKey(GetFieldErrorKey(rowIdx, f.FieldName)) ||
            (_inlineState.TryGetValue(GetFieldErrorKey(rowIdx, f.FieldName), out var s) && s.Status == "error"));

    private void HandleTableKeyDown(KeyboardEventArgs e)
    {
        if (isReadOnlyLocked) return;
        if (e.Key == "Enter" && !e.ShiftKey && !e.CtrlKey && !e.AltKey)
            AddRow();
        else if (e.Key == "d" && e.CtrlKey && _lastEditedRowIndex >= 0)
            DuplicateRow(_lastEditedRowIndex);
    }

    private async Task ExportTableAsCsv()
    {
        try
        {
            var sb = new System.Text.StringBuilder();
            sb.Append('﻿'); // UTF-8 BOM for Excel

            if (structuralCategory == "ItemCoded")
            {
                sb.Append("Item Code,Description");
                foreach (var f in nonKeyFields)
                    sb.Append(',').Append(CsvEscape(f.DisplayName));
            }
            else
            {
                sb.Append("Row");
                foreach (var f in nonKeyFields)
                    sb.Append(',').Append(CsvEscape(f.DisplayName));
            }
            sb.AppendLine();

            for (int i = 0; i < formRows.Count; i++)
            {
                if (structuralCategory == "ItemCoded")
                {
                    var code = i < itemCodes.Count ? itemCodes[i].ItemCode : "";
                    var desc = i < itemCodes.Count ? (itemCodes[i].Description ?? "") : "";
                    sb.Append(CsvEscape(code)).Append(',').Append(CsvEscape(desc));
                    foreach (var f in nonKeyFields)
                        sb.Append(',').Append(CsvEscape(GetFieldValue(i, f.FieldName)));
                }
                else
                {
                    sb.Append(i + 1);
                    foreach (var f in nonKeyFields)
                        sb.Append(',').Append(CsvEscape(GetFieldValue(i, f.FieldName)));
                }
                sb.AppendLine();
            }

            var filename = $"{ReturnCode.Replace(" ", "")}_data_{DateTime.Now:yyyyMMdd}.csv";
            await JS.InvokeVoidAsync("portalDownloadFile", sb.ToString(), filename, "text/csv;charset=utf-8");
        }
        catch (Exception ex)
        {
            submitError = $"Export failed: {ex.Message}";
        }
    }

    private static string CsvEscape(string value)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        if (value.Contains(',') || value.Contains('"') || value.Contains('\n') || value.Contains('\r'))
            return "\"" + value.Replace("\"", "\"\"") + "\"";
        return value;
    }

    [JSInvokable]
    public void OnRowReordered(int fromIdx, int toIdx)
    {
        if (isReadOnlyLocked || fromIdx == toIdx) return;
        if (fromIdx < 0 || fromIdx >= formRows.Count || toIdx < 0 || toIdx >= formRows.Count) return;

        var row = formRows[fromIdx];
        formRows.RemoveAt(fromIdx);
        formRows.Insert(toIdx, row);
        fieldErrors.Clear();
        _inlineState.Clear();
        MarkDirtyAndDebounce();
        StateHasChanged();
    }

    // ── Field Value Handling ──────────────────────────────────────

    private void OnFieldChanged(int rowIndex, string fieldName, string value)
    {
        if (isReadOnlyLocked) return;
        if (rowIndex < 0 || rowIndex >= formRows.Count) return;

        formRows[rowIndex][fieldName] = value;
        fieldErrors.Remove(GetFieldErrorKey(rowIndex, fieldName));

        var key = GetFieldErrorKey(rowIndex, fieldName);
        if (carryForwardOriginalValues.TryGetValue(key, out var originalValue))
        {
            carryForwardKeys.Remove(key);
            if (value != originalValue)
                carryForwardModifiedKeys.Add(key);
            else
                carryForwardModifiedKeys.Remove(key); // restored to original
        }
        else
        {
            carryForwardKeys.Remove(key);
        }

        RecalculateSumFormulas(rowIndex);
        MarkDirtyAndDebounce();
    }

    private string GetFieldValue(int rowIndex, string fieldName)
    {
        if (rowIndex >= 0 && rowIndex < formRows.Count && formRows[rowIndex].TryGetValue(fieldName, out var val))
            return val;
        return "";
    }

    // ── Auto-Calculate Sum Formulas ───────────────────────────────

    private void RecalculateSumFormulas(int rowIndex)
    {
        foreach (var formula in sumFormulas)
        {
            try
            {
                var operands = ParseOperandFields(formula.OperandFields);
                if (!operands.Any()) continue;

                decimal sum = 0;
                foreach (var opField in operands)
                {
                    var rawValue = GetFieldValue(rowIndex, opField);
                    if (decimal.TryParse(rawValue, out var numValue))
                        sum += numValue;
                }

                if (rowIndex < formRows.Count && formRows[rowIndex].ContainsKey(formula.TargetField))
                {
                    formRows[rowIndex][formula.TargetField] = sum.ToString("F2");
                }
            }
            catch
            {
                // Silently fail on auto-calculation errors
            }
        }
    }

    private static List<string> ParseOperandFields(string operandFieldsJson)
    {
        // OperandFields is stored as JSON array: ["field1","field2","field3"]
        if (string.IsNullOrWhiteSpace(operandFieldsJson)) return new();
        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<List<string>>(operandFieldsJson) ?? new();
        }
        catch
        {
            return new();
        }
    }

    private void MarkDirtyAndDebounce()
    {
        if (isReadOnlyLocked)
        {
            return;
        }

        isDirty = true;
        saveStatus = "Unsaved changes...";
        _saveState = "idle";
        _saveLabel = "Unsaved changes";
        autoSaveCts?.Cancel();
        autoSaveCts?.Dispose();
        autoSaveCts = new CancellationTokenSource();
        var token = autoSaveCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(5000, token);
                await InvokeAsync(AutoSave);
            }
            catch (TaskCanceledException)
            {
                // ignored
            }
        }, token);
    }

    private async Task AutoSave()
    {
        if (!isDirty || isReadOnlyLocked || draftSubmissionId <= 0 || !tenantId.HasValue)
        {
            return;
        }

        _saveState = "saving";
        _saveLabel = "Saving...";
        saveStatus = "Saving...";
        await InvokeAsync(StateHasChanged);

        try
        {
            await DraftDataService.SaveDraftRows(tenantId.Value, draftSubmissionId, ReturnCode, formRows);

            // Also persist a JSON snapshot for crash recovery / conflict detection
            var periodLabel = GetCurrentPeriodLabel();
            await FormDataSvc.SaveDraftAsync(
                tenantId.Value, institutionId, ReturnCode, periodLabel, formRows, userDisplayName);

            isDirty = false;
            _saveState = "saved";
            _saveLabel = $"Saved {DateTime.Now:HH:mm}";
            saveStatus = _saveLabel;

            if (userId.HasValue)
            {
                await ReturnLockService.Heartbeat(tenantId.Value, draftSubmissionId, userId.Value);
            }
        }
        catch (Exception ex)
        {
            _saveState = "error";
            _saveLabel = "Save failed";
            saveStatus = $"Error saving: {ex.Message}";
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RetrySave()
    {
        isDirty = true;
        await AutoSave();
    }

    // ── Client-Side Validation ────────────────────────────────────

    private bool ValidateClientSide()
    {
        _validationTriggered = true;
        fieldErrors.Clear();
        var isValid = true;

        for (int rowIdx = 0; rowIdx < formRows.Count; rowIdx++)
        {
            var fieldsToValidate = structuralCategory == "FixedRow" ? allFields : nonKeyFields;

            foreach (var field in fieldsToValidate)
            {
                var value = GetFieldValue(rowIdx, field.FieldName);
                var key = GetFieldErrorKey(rowIdx, field.FieldName);

                if (field.IsRequired && string.IsNullOrWhiteSpace(value))
                {
                    fieldErrors[key] = "Required";
                    isValid = false;
                    continue;
                }

                if (string.IsNullOrWhiteSpace(value)) continue;

                var dt = field.DataType;

                if (dt == "Money" || dt == "Decimal" || dt == "Percentage")
                {
                    if (!decimal.TryParse(value, out var numVal))
                    {
                        fieldErrors[key] = "Invalid number";
                        isValid = false;
                    }
                    else
                    {
                        if (!string.IsNullOrEmpty(field.MinValue) && decimal.TryParse(field.MinValue, out var min) && numVal < min)
                        { fieldErrors[key] = $"Min: {min}"; isValid = false; }
                        else if (!string.IsNullOrEmpty(field.MaxValue) && decimal.TryParse(field.MaxValue, out var max) && numVal > max)
                        { fieldErrors[key] = $"Max: {max}"; isValid = false; }
                    }
                }
                else if (dt == "Integer")
                {
                    if (!long.TryParse(value, out _))
                    { fieldErrors[key] = "Whole number required"; isValid = false; }
                }
                else if (dt == "Date")
                {
                    if (!DateTime.TryParse(value, out _))
                    { fieldErrors[key] = "Invalid date"; isValid = false; }
                }
            }
        }

        return isValid;
    }

    // ── Real-Time Inline Validation ───────────────────────────────

    private void OnFieldInput(int rowIdx, string fieldName, string value)
    {
        if (isReadOnlyLocked) return;
        _lastEditedRowIndex = rowIdx;

        if (rowIdx >= 0 && rowIdx < formRows.Count)
        {
            formRows[rowIdx][fieldName] = value;
            fieldErrors.Remove(GetFieldErrorKey(rowIdx, fieldName));

            var cfKey = GetFieldErrorKey(rowIdx, fieldName);
            if (carryForwardOriginalValues.TryGetValue(cfKey, out var originalValue))
            {
                carryForwardKeys.Remove(cfKey);
                if (value != originalValue)
                    carryForwardModifiedKeys.Add(cfKey);
                else
                    carryForwardModifiedKeys.Remove(cfKey);
            }
            else
            {
                carryForwardKeys.Remove(cfKey);
            }

            RecalculateSumFormulas(rowIdx);
            ComputeProgress();
            MarkDirtyAndDebounce();
        }

        // Debounce inline validation at 400 ms
        var key = GetFieldErrorKey(rowIdx, fieldName);
        if (_fieldValidateCts.TryGetValue(key, out var existing))
        {
            existing.Cancel();
            existing.Dispose();
        }

        var cts = new CancellationTokenSource();
        _fieldValidateCts[key] = cts;
        var token = cts.Token;
        var field = allFields.FirstOrDefault(f => f.FieldName == fieldName);
        if (field is null) return;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(400, token);
                await InvokeAsync(() =>
                {
                    _inlineState[key] = ValidateFieldInline(field, value);
                    StateHasChanged();
                });
            }
            catch (TaskCanceledException) { }
        }, token);
    }

    private async Task OnFieldBlurAsync(int rowIdx, string fieldName)
    {
        if (isReadOnlyLocked) return;

        var field = allFields.FirstOrDefault(f => f.FieldName == fieldName);
        if (field is null) return;

        var value = GetFieldValue(rowIdx, fieldName);
        var key = GetFieldErrorKey(rowIdx, fieldName);

        // Cancel any pending debounced validation
        if (_fieldValidateCts.TryGetValue(key, out var cts))
        {
            cts.Cancel();
            cts.Dispose();
            _fieldValidateCts.Remove(key);
        }

        _inlineState[key] = ValidateFieldInline(field, value);
        StateHasChanged();

        // JS call for additional visual marking
        var jsStatus = _inlineState[key].Status switch
        {
            "valid" => "valid",
            "error" => "error",
            _ => "clear"
        };
        var fieldId = $"{field.FieldName}-{rowIdx}";
        try { await JS.InvokeVoidAsync("portalApplyFieldValidation", fieldId, jsStatus); }
        catch { /* non-critical */ }
    }

    private FieldInlineState ValidateFieldInline(FieldDisplayItem field, string value)
    {
        if (field.IsRequired && string.IsNullOrWhiteSpace(value))
            return new("error", "Required field");

        if (string.IsNullOrWhiteSpace(value))
            return new("none", "");

        var dt = field.DataType;

        if (dt is "Money" or "Decimal" or "Percentage")
        {
            if (!decimal.TryParse(value, NumberStyles.Any, CultureInfo.InvariantCulture, out var numVal))
                return new("error", "Must be a valid number");

            // Decimal precision: max 2 places
            var dotIdx = value.IndexOf('.');
            if (dotIdx >= 0 && value.Length - dotIdx - 1 > 2)
                return new("error", "Maximum 2 decimal places");

            if (!string.IsNullOrEmpty(field.MinValue) && decimal.TryParse(field.MinValue, out var min) && numVal < min)
            {
                var msg = min == 0 ? "Must be a positive number" : $"Minimum value is {min:G}";
                return new("error", msg);
            }

            if (!string.IsNullOrEmpty(field.MaxValue) && decimal.TryParse(field.MaxValue, out var max) && numVal > max)
                return new("error", $"Maximum value is {max:G}");

            return new("valid", "");
        }

        if (dt == "Integer")
        {
            if (!long.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var intVal))
                return new("error", "Must be a whole number");

            if (!string.IsNullOrEmpty(field.MinValue) && long.TryParse(field.MinValue, out var minL) && intVal < minL)
            {
                var msg = minL == 0 ? "Must be a positive number" : $"Minimum value is {minL}";
                return new("error", msg);
            }

            if (!string.IsNullOrEmpty(field.MaxValue) && long.TryParse(field.MaxValue, out var maxL) && intVal > maxL)
                return new("error", $"Maximum value is {maxL}");

            return new("valid", "");
        }

        if (dt == "Date")
        {
            if (!DateTime.TryParse(value, out _))
                return new("error", "Invalid date format");
            return new("valid", "");
        }

        // Text: check length if MaxValue represents max chars
        if (dt == "Text" && !string.IsNullOrEmpty(field.MaxValue)
            && int.TryParse(field.MaxValue, out var maxLen) && value.Length > maxLen)
            return new("error", $"Maximum {maxLen} characters");

        return new("valid", "");
    }

    private int GetSectionErrorCount(IEnumerable<FieldDisplayItem> fields)
    {
        int count = 0;
        for (int rowIdx = 0; rowIdx < formRows.Count; rowIdx++)
            foreach (var f in fields)
                if (_inlineState.TryGetValue(GetFieldErrorKey(rowIdx, f.FieldName), out var s) && s.Status == "error")
                    count++;
        return count;
    }

    private bool IsSectionComplete(IEnumerable<FieldDisplayItem> fields)
    {
        var fieldList = fields.ToList();
        bool anyTouched = false;
        for (int rowIdx = 0; rowIdx < formRows.Count; rowIdx++)
            foreach (var f in fieldList)
                if (_inlineState.ContainsKey(GetFieldErrorKey(rowIdx, f.FieldName)))
                    anyTouched = true;

        if (!anyTouched) return false;

        for (int rowIdx = 0; rowIdx < formRows.Count; rowIdx++)
            foreach (var f in fieldList)
            {
                var key = GetFieldErrorKey(rowIdx, f.FieldName);
                if (_inlineState.TryGetValue(key, out var s))
                {
                    if (s.Status == "error") return false;
                }
                else if (f.IsRequired && string.IsNullOrWhiteSpace(GetFieldValue(rowIdx, f.FieldName)))
                    return false;
            }

        return true;
    }

    // ── Form Actions ──────────────────────────────────────────────

    private async Task SubmitForm()
    {
        showValidationResult = false;
        serverErrors.Clear();
        submitError = "";

        if (isReadOnlyLocked)
        {
            submitError = "This return is currently locked by another user and is read-only.";
            return;
        }

        if (!ValidateClientSide())
        {
            // Error summary panel (top of form) shows the full error list
            return;
        }

        if (selectedPeriodId == 0)
        {
            submitError = "Please select a reporting period.";
            return;
        }

        isSubmitting = true;
        StateHasChanged();

        try
        {
            await AutoSave();

            var selectedPeriod = availablePeriods.FirstOrDefault(p => p.ReturnPeriodId == selectedPeriodId);
            var reportingDate = selectedPeriod is not null
                ? selectedPeriod.ReportingDate.ToString("yyyy-MM-dd")
                : DateTime.UtcNow.ToString("yyyy-MM-dd");

            await using var xmlStream = await XmlSvc.ConvertToStream(
                ReturnCode, institutionCode, reportingDate, formRows);

            var result = await SubmissionSvc.ProcessSubmission(
                xmlStream, ReturnCode, institutionId, selectedPeriodId,
                submittedByUserId: userId);

            submissionResult = result;
            submittedId = result.SubmissionId;

            if (result.ValidationReport is not null && result.ValidationReport.Errors.Any())
            {
                serverErrors = result.ValidationReport.Errors;
                showValidationResult = true;

                if (!result.ValidationReport.IsValid)
                {
                    // Rejected — stay on form
                    return;
                }
            }

            // Accepted or AcceptedWithWarnings — delete JSON draft snapshot
            await TryDeleteDraftSnapshot();
            submissionComplete = true;
            await ReleaseLock();
        }
        catch (Exception ex)
        {
            submitError = $"Submission failed: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    // ── State-Machine Submit (sticky panel) ───────────────────────

    private async Task ValidateAndSubmit()
    {
        if (_submitState is SubmitState.Validating or SubmitState.Submitting or SubmitState.Success)
            return;

        _submitState = SubmitState.Validating;
        showValidationResult = false;
        serverErrors.Clear();
        submitError = "";
        StateHasChanged();

        await Task.Delay(250);

        if (isReadOnlyLocked)
        {
            submitError = "This return is currently locked by another user and is read-only.";
            _submitState = SubmitState.Error;
            StateHasChanged();
            return;
        }

        if (selectedPeriodId == 0)
        {
            submitError = "Please select a reporting period.";
            _submitState = SubmitState.Error;
            StateHasChanged();
            return;
        }

        if (!ValidateClientSide())
        {
            submitError = "Please fix the highlighted field errors before submitting.";
            _submitState = SubmitState.Error;
            StateHasChanged();
            await JS.InvokeVoidAsync("portalScrollToElement", ".portal-form-input-error");
            return;
        }

        _submitState = SubmitState.Submitting;
        isSubmitting = true;
        StateHasChanged();

        try
        {
            await AutoSave();

            var selectedPeriod = availablePeriods.FirstOrDefault(p => p.ReturnPeriodId == selectedPeriodId);
            var reportingDate = selectedPeriod is not null
                ? selectedPeriod.ReportingDate.ToString("yyyy-MM-dd")
                : DateTime.UtcNow.ToString("yyyy-MM-dd");

            await using var xmlStream = await XmlSvc.ConvertToStream(
                ReturnCode, institutionCode, reportingDate, formRows);

            var result = await SubmissionSvc.ProcessSubmission(
                xmlStream, ReturnCode, institutionId, selectedPeriodId,
                submittedByUserId: userId);

            submissionResult = result;
            submittedId = result.SubmissionId;

            if (result.ValidationReport is not null && result.ValidationReport.Errors.Any())
            {
                serverErrors = result.ValidationReport.Errors;
                showValidationResult = true;

                if (!result.ValidationReport.IsValid)
                {
                    submitError = $"{result.ValidationReport.ErrorCount} validation error(s) prevented submission.";
                    _submitState = SubmitState.Error;
                    StateHasChanged();
                    await JS.InvokeVoidAsync("portalScrollToElement", ".portal-form-validation-result");
                    return;
                }
            }

            await TryDeleteDraftSnapshot();
            _submitState = SubmitState.Success;
            await ReleaseLock();
            StateHasChanged();
            await StartRedirectCountdown();
        }
        catch (Exception ex)
        {
            submitError = $"Submission failed: {ex.Message}";
            _submitState = SubmitState.Error;
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task SaveDraftExplicit()
    {
        if (!isDirty || draftSubmissionId <= 0) return;
        await AutoSave();
    }

    private async Task ScrollToErrors()
    {
        var selector = fieldErrors.Count > 0
            ? ".portal-form-input-error"
            : ".portal-form-validation-result";
        await JS.InvokeVoidAsync("portalScrollToElement", selector);
    }

    private async Task StartRedirectCountdown()
    {
        _redirectCts?.Cancel();
        _redirectCts?.Dispose();
        _redirectCts = new CancellationTokenSource();
        var token = _redirectCts.Token;

        _redirectCountdown = 3;
        await InvokeAsync(StateHasChanged);

        try
        {
            while (_redirectCountdown > 0 && !token.IsCancellationRequested)
            {
                await Task.Delay(1000, token);
                _redirectCountdown--;
                await InvokeAsync(StateHasChanged);
            }

            if (!token.IsCancellationRequested)
            {
                submissionComplete = true;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (TaskCanceledException) { }
    }

    // ── Sticky Panel Helpers ──────────────────────────────────────

    private (int percent, int errors) ComputeCompletionStats()
    {
        var fieldsToCheck = structuralCategory == "FixedRow" ? allFields : nonKeyFields;
        var computedTargets = sumFormulas.Select(f => f.TargetField).ToHashSet(StringComparer.OrdinalIgnoreCase);

        int total = 0, filled = 0;
        for (int r = 0; r < formRows.Count; r++)
        {
            foreach (var f in fieldsToCheck)
            {
                if (computedTargets.Contains(f.FieldName)) continue;
                if (f.DataType == "Boolean") { total++; filled++; continue; }
                total++;
                if (!string.IsNullOrWhiteSpace(GetFieldValue(r, f.FieldName))) filled++;
            }
        }

        var percent = total > 0 ? (int)Math.Round((double)filled / total * 100) : 0;
        return (percent, fieldErrors.Count);
    }

