    private string GetCountdownDashOffset()
    {
        const double circ = 99.9;
        var progress = _redirectCountdown / 3.0;
        return ((1.0 - progress) * circ).ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
    }

