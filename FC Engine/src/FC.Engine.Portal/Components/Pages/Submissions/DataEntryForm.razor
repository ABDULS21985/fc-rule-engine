    private RenderFragment RenderInput(FieldDisplayItem field, int rowIdx) => __builder =>
    {
        var val = GetFieldValue(rowIdx, field.FieldName);
        var errorKey = GetFieldErrorKey(rowIdx, field.FieldName);
        var isComputedTarget = sumFormulas.Any(f => f.TargetField == field.FieldName);
        // Determine validation display state
        _inlineState.TryGetValue(errorKey, out var inlineState);
        var hasInlineError = inlineState?.Status == "error";
        var isValid = inlineState?.Status == "valid";
        var hasSubmitError = fieldErrors.ContainsKey(errorKey);
        var hasError = hasInlineError || hasSubmitError;

        var wrapperCss = "portal-field-wrapper" +
            (hasError ? " portal-field-wrapper--error" : isValid ? " portal-field-wrapper--valid" : "");
        var inputCss = "portal-form-input portal-form-input-sm" +
            (hasError ? " portal-form-input-error" : "");

        var dt = field.DataType;
        string inputType;
        string step = "";
        string placeholder = "";

        if (dt == "Money" || dt == "Decimal" || dt == "Percentage")
        { inputType = "number"; step = "0.01"; placeholder = "0.00"; }
        else if (dt == "Integer")
        { inputType = "number"; step = "1"; placeholder = "0"; }
        else if (dt == "Date")
        { inputType = "date"; }
        else if (dt == "Boolean")
        { inputType = "checkbox"; }
        else
        { inputType = "text"; placeholder = ""; }

        var errorId = $"{field.FieldName}-{rowIdx}-error";
        var fieldId = $"{field.FieldName}-{rowIdx}";

        var isCarried = carryForwardKeys.Contains(errorKey);
        var isModified = carryForwardModifiedKeys.Contains(errorKey);

        if (isCarried || isModified)
        {
            <div class="@(isCarried ? "portal-field-carried" : "")" id="carry-@errorKey">
                @if (dt == "Boolean")
                {
                    <label class="portal-form-checkbox">
                        <input type="checkbox"
                               id="@fieldId"
                               checked="@(val == "true")"
                               disabled="@isReadOnlyLocked"
                               @onchange="@(e => OnFieldInput(rowIdx, field.FieldName, ((bool)(e.Value ?? false)) ? "true" : "false"))" />
                        <span>@field.DisplayName</span>
                    </label>
                }
                else
                {
                    <div class="@wrapperCss">
                        <input type="@inputType"
                               id="@fieldId"
                               class="@inputCss"
                               value="@val"
                               step="@step"
                               placeholder="@placeholder"
                               readonly="@(isComputedTarget || isReadOnlyLocked)"
                               aria-label="@field.DisplayName"
                               aria-describedby="@(hasError ? errorId : null)"
                               aria-invalid="@(hasError ? "true" : null)"
                               @oninput="@(e => OnFieldInput(rowIdx, field.FieldName, e.Value?.ToString() ?? ""))"
                               @onblur="@(async e => await OnFieldBlurAsync(rowIdx, field.FieldName))" />
                        @if (isValid)
                        {
                            <svg class="portal-field-valid-icon" width="14" height="14" viewBox="0 0 24 24"
                                 fill="none" stroke="var(--cbn-success-text,#16a34a)" stroke-width="2.5"
                                 aria-hidden="true" focusable="false">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        }
                    </div>
                }
                <div class="portal-field-carried-footer">
                    @if (isCarried)
                    {
                        <span class="portal-field-carried-label">↑ Carried from @carryForwardSourcePeriod</span>
                        <span class="portal-field-carried-hint">This value was carried from the previous period. Verify it is still correct.</span>
                        <label class="portal-field-carried-review">
                            <input type="checkbox" @onchange="@(() => MarkCarriedFieldReviewed(rowIdx, field.FieldName))" />
                            <span>Mark reviewed</span>
                        </label>
                    }
                    @if (isModified)
                    {
                        <span class="portal-field-carried-label portal-field-carried-label--modified">✎ Modified from carried value</span>
                        <button class="portal-btn portal-btn-xs portal-btn-ghost portal-cf-undo-btn"
                                type="button"
                                title="Restore original carry-forward value"
                                @onclick="@(() => UndoCarryForwardChange(rowIdx, field.FieldName))">
                            ↩ Undo
                        </button>
                    }
                </div>
            </div>
        }
        else
        {
            if (dt == "Boolean")
            {
                <label class="portal-form-checkbox">
                    <input type="checkbox"
                           id="@fieldId"
                           checked="@(val == "true")"
                           disabled="@isReadOnlyLocked"
                           @onchange="@(e => OnFieldInput(rowIdx, field.FieldName, ((bool)(e.Value ?? false)) ? "true" : "false"))" />
                    <span>@field.DisplayName</span>
                </label>
            }
            else
            {
                <div class="@wrapperCss">
                    <input type="@inputType"
                           id="@fieldId"
                           class="@inputCss"
                           value="@val"
                           step="@step"
                           placeholder="@placeholder"
                           readonly="@(isComputedTarget || isReadOnlyLocked)"
                           aria-label="@field.DisplayName"
                           aria-describedby="@(hasError ? errorId : null)"
                           aria-invalid="@(hasError ? "true" : null)"
                           @oninput="@(e => OnFieldInput(rowIdx, field.FieldName, e.Value?.ToString() ?? ""))"
                           @onblur="@(async e => await OnFieldBlurAsync(rowIdx, field.FieldName))" />
                    @if (isValid)
                    {
                        <svg class="portal-field-valid-icon" width="14" height="14" viewBox="0 0 24 24"
                             fill="none" stroke="var(--cbn-success-text,#16a34a)" stroke-width="2.5"
                             aria-hidden="true" focusable="false">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                    }
                </div>
            }
        }
    };

    private RenderFragment RenderFieldError(FieldDisplayItem field, int rowIdx) => __builder =>
    {
        var key = GetFieldErrorKey(rowIdx, field.FieldName);
        var errorId = $"{field.FieldName}-{rowIdx}-error";

        // Inline validation state takes priority; fall back to submit-time errors
        if (_inlineState.TryGetValue(key, out var inlineState) && inlineState.Status == "error"
            && !string.IsNullOrEmpty(inlineState.Message))
        {
            <span class="portal-form-error-msg" id="@errorId" role="alert">@inlineState.Message</span>
        }
        else if (fieldErrors.TryGetValue(key, out var submitMsg))
        {
            <span class="portal-form-error-msg" id="@errorId" role="alert">@submitMsg</span>
        }
    };

    private string FormatValueForInput(string fieldName, object? value)
    {
        if (value is null)
        {
            return string.Empty;
        }

        var field = allFields.FirstOrDefault(x => x.FieldName == fieldName);
        var dataType = field?.DataType ?? "Text";

        return dataType switch
        {
            "Date" when value is DateTime dt => dt.ToString("yyyy-MM-dd"),
            "Date" when DateTime.TryParse(value.ToString(), out var parsedDt) => parsedDt.ToString("yyyy-MM-dd"),
            "Boolean" when value is bool b => b ? "true" : "false",
            "Money" or "Decimal" or "Percentage" when decimal.TryParse(value.ToString(), out var dec) => dec.ToString(CultureInfo.InvariantCulture),
            "Integer" when int.TryParse(value.ToString(), out var i) => i.ToString(CultureInfo.InvariantCulture),
            _ => value.ToString() ?? string.Empty
        };
    }

