@page "/submissions/{SubmissionId:int}/certificate"
@attribute [Authorize(Policy = "InstitutionUser")]
@inject ExportService ExportSvc
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthProvider

<PageTitle>@(_cert is null ? "Compliance Certificate" : $"Certificate — {_cert.ReturnCode} {_cert.Period}") — RegOS™ Portal</PageTitle>

@* ── Print: hide portal chrome ── *@
<div class="portal-cert-page" id="portal-cert-page">

    @if (_loading)
    {
        <div class="portal-page" style="padding: 2rem;">
            <div class="portal-skeleton portal-skeleton-block" style="height: 60px; margin-bottom: 1rem;"></div>
            <div class="portal-skeleton portal-skeleton-block" style="height: 760px;"></div>
        </div>
    }
    else if (_notEligible)
    {
        <div class="portal-page" style="padding: 2rem; max-width: 680px; margin: 0 auto;">
            <div class="portal-cert-not-eligible">
                <div class="portal-cert-not-eligible-icon" aria-hidden="true">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        <line x1="9" y1="9" x2="15" y2="15"/>
                        <line x1="15" y1="9" x2="9" y2="15"/>
                    </svg>
                </div>
                <h2>Certificate Not Available</h2>
                <p>A compliance certificate can only be issued for submissions with <strong>Accepted</strong> status. This submission has not yet been approved or was rejected.</p>
                <a href="/submissions/@SubmissionId" class="portal-btn portal-btn-ghost portal-btn-sm">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                    Back to Submission
                </a>
            </div>
        </div>
    }
    else if (_cert is not null)
    {
        <div class="portal-page portal-cert-page-inner">

            @* ── Breadcrumb (hidden on print) ── *@
            <nav class="portal-breadcrumb portal-cert-print-hide" aria-label="Breadcrumb">
                <a href="/" class="portal-breadcrumb-link">Dashboard</a>
                <span class="portal-breadcrumb-sep" aria-hidden="true">/</span>
                <a href="/submissions" class="portal-breadcrumb-link">Submissions</a>
                <span class="portal-breadcrumb-sep" aria-hidden="true">/</span>
                <a href="/submissions/@SubmissionId" class="portal-breadcrumb-link">@_cert.ReturnCode — @_cert.Period</a>
                <span class="portal-breadcrumb-sep" aria-hidden="true">/</span>
                <span class="portal-breadcrumb-current">Certificate</span>
            </nav>

            @* ── Controls bar (hidden on print) ── *@
            <div class="portal-cert-v2-controls portal-cert-print-hide" role="toolbar" aria-label="Certificate actions">
                <button class="portal-btn portal-btn-primary portal-btn-sm"
                        @onclick="DownloadPdf">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Download PDF
                </button>

                <button id="cert-share-btn"
                        class="portal-btn portal-btn-outline portal-btn-sm portal-cert-v2-copy-btn"
                        @onclick="ShareLink">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                    Share Link
                </button>

                <button class="portal-btn portal-btn-outline portal-btn-sm"
                        @onclick="OpenEmailModal">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/></svg>
                    Email Certificate
                </button>

                <button class="portal-btn portal-btn-ghost portal-btn-sm"
                        @onclick="PrintPage">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                    Print
                </button>

                <div class="portal-cert-controls-spacer" aria-hidden="true"></div>

                <a href="/submissions/@SubmissionId" class="portal-btn portal-btn-ghost portal-btn-sm">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                    Back to Submission
                </a>
            </div>

            @* ── Certificate document ── *@
            <div id="cert-doc" class="portal-cert-v2 @(_cert.IsSuperseded ? "portal-cert-v2--superseded" : "")">

                @* Subtle crosshatch watermark *@
                <div class="portal-cert-v2-watermark" aria-hidden="true"></div>

                @* SUPERSEDED overlay (shown when amended by later submission) *@
                @if (_cert.IsSuperseded)
                {
                    <div class="portal-cert-v2-superseded-overlay" aria-label="This certificate has been superseded">
                        <span>SUPERSEDED</span>
                    </div>
                }

                @* ── Header: logos + title ── *@
                <div class="portal-cert-v2-header">
                    @if (!string.IsNullOrEmpty(_cert.Branding.LogoUrl))
                    {
                        <img src="@_cert.Branding.LogoUrl" alt="@_cert.InstitutionName logo" class="portal-cert-v2-logo" />
                    }
                    else
                    {
                        <div class="portal-cert-v2-logo-placeholder">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
                            <span class="portal-cert-v2-logo-placeholder-name">@_cert.InstitutionName</span>
                        </div>
                    }

                    <div class="portal-cert-v2-title-center">
                        <h2>Federal Republic of Nigeria</h2>
                        <h1>Certificate of Compliance</h1>
                        <p class="portal-cert-v2-title-subtitle">Financial Conditions Reporting</p>
                    </div>

                    <div class="portal-cert-v2-regulator">
                        <div class="portal-cert-v2-regulator-seal" role="img" aria-label="Central Bank of Nigeria official seal">
                            CBN<br/>SEAL
                        </div>
                        <span class="portal-cert-v2-regulator-name">Central Bank<br/>of Nigeria</span>
                    </div>
                </div>

                @* ── Validity / superseded badge ── *@
                <div class="portal-cert-v2-validity-row">
                    @if (_cert.IsSuperseded)
                    {
                        <span class="portal-cert-v2-validity portal-cert-v2-validity--superseded" role="status">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                            Superseded — A later amendment supersedes this certificate
                        </span>
                    }
                    else
                    {
                        <span class="portal-cert-v2-validity portal-cert-v2-validity--valid" role="status">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                            Valid &middot; Approved by CBN on @_cert.AcceptedAt.ToString("MMMM d, yyyy")
                        </span>
                    }
                </div>

                @* ── Body: institution + return statement ── *@
                <div class="portal-cert-v2-body">
                    <p class="portal-cert-v2-certifies-text">This is to certify that</p>
                    <h2 class="portal-cert-v2-institution">@_cert.InstitutionName</h2>
                    <p class="portal-cert-v2-inst-sub">@_cert.InstitutionType &middot; Institution Code: <strong>@_cert.InstitutionCode</strong></p>

                    <p class="portal-cert-v2-return-text">has successfully submitted the</p>
                    <p class="portal-cert-v2-return-name">@_cert.ReturnCode &mdash; @_cert.Period</p>
                    <p class="portal-cert-v2-compliance-text">
                        in compliance with the Central Bank of Nigeria's Financial Condition<br/>
                        reporting requirements under the Banks and Other Financial Institutions Act.
                    </p>
                </div>

                @* ── Details grid (tabular layout) ── *@
                <div class="portal-cert-v2-details">
                    <div class="portal-cert-v2-detail portal-cert-v2-detail--highlight">
                        <div class="portal-cert-v2-detail-label">Certificate No.</div>
                        <div class="portal-cert-v2-detail-value portal-cert-v2-detail-value--mono">@_cert.CertificateNumber</div>
                    </div>
                    <div class="portal-cert-v2-detail">
                        <div class="portal-cert-v2-detail-label">Submission ID</div>
                        <div class="portal-cert-v2-detail-value">#@_cert.SubmissionId</div>
                    </div>
                    <div class="portal-cert-v2-detail @(_cert.Status == SubmissionStatus.Accepted ? "portal-cert-v2-detail--status-accepted" : "")">
                        <div class="portal-cert-v2-detail-label">Validation Status</div>
                        <div class="portal-cert-v2-detail-value">
                            @(_cert.Status == SubmissionStatus.Accepted ? "Accepted — No Issues" : "Accepted — With Warnings")
                        </div>
                    </div>
                    <div class="portal-cert-v2-detail">
                        <div class="portal-cert-v2-detail-label">Return Period</div>
                        <div class="portal-cert-v2-detail-value">@_cert.Period</div>
                    </div>
                    <div class="portal-cert-v2-detail">
                        <div class="portal-cert-v2-detail-label">Date Submitted</div>
                        <div class="portal-cert-v2-detail-value">@_cert.SubmittedAt.ToString("dd MMMM yyyy")</div>
                    </div>
                    <div class="portal-cert-v2-detail">
                        <div class="portal-cert-v2-detail-label">Date Approved</div>
                        <div class="portal-cert-v2-detail-value">@_cert.AcceptedAt.ToString("dd MMMM yyyy")</div>
                    </div>
                    <div class="portal-cert-v2-detail">
                        <div class="portal-cert-v2-detail-label">Issue Date</div>
                        <div class="portal-cert-v2-detail-value">@_cert.GeneratedAt.ToString("dd MMMM yyyy")</div>
                    </div>
                    <div class="portal-cert-v2-detail">
                        <div class="portal-cert-v2-detail-label">Valid Until</div>
                        <div class="portal-cert-v2-detail-value">@_cert.AcceptedAt.AddYears(7).ToString("dd MMMM yyyy")</div>
                    </div>
                    <div class="portal-cert-v2-detail">
                        <div class="portal-cert-v2-detail-label">Return Code</div>
                        <div class="portal-cert-v2-detail-value">@_cert.ReturnCode</div>
                    </div>
                </div>

                @* ── Approval chain ── *@
                <div class="portal-cert-v2-chain-section">
                    <p class="portal-cert-v2-chain-heading">Approval Chain</p>
                    <div class="portal-cert-v2-chain">
                        <div class="portal-cert-v2-chain-step">
                            <div class="portal-cert-v2-chain-icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            </div>
                            <span class="portal-cert-v2-chain-role">Submitted by</span>
                            <span class="portal-cert-v2-chain-name">@(string.IsNullOrEmpty(_cert.SubmittedByName) ? "—" : _cert.SubmittedByName)</span>
                        </div>

                        <div class="portal-cert-v2-chain-arrow" aria-hidden="true">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                        </div>

                        <div class="portal-cert-v2-chain-step">
                            <div class="portal-cert-v2-chain-icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            </div>
                            <span class="portal-cert-v2-chain-role">Approved by</span>
                            <span class="portal-cert-v2-chain-name">@(string.IsNullOrEmpty(_cert.ApprovedByName) ? "Central Bank of Nigeria" : _cert.ApprovedByName)</span>
                        </div>
                    </div>
                </div>

                @* ── Digital signature block ── *@
                <div class="portal-cert-v2-sig-block">
                    <div class="portal-cert-v2-sig-text">
                        <p>
                            This certificate is electronically generated by the RegOS™ regulatory reporting platform
                            and is valid without a wet signature. The authenticity of this certificate can be verified
                            at any time by scanning the QR code or visiting the verification URL below.
                        </p>
                        <p class="portal-cert-v2-sig-authority">
                            Issued under the authority of the Central Bank of Nigeria Act —
                            Financial Conditions Division, Banking Supervision Department.
                        </p>
                    </div>
                    <div class="portal-cert-v2-sig-seal" aria-hidden="true">
                        <div class="portal-cert-v2-sig-seal-ring">
                            <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="32" cy="32" r="30" stroke="#006B3F" stroke-width="2" stroke-dasharray="4 3"/>
                                <circle cx="32" cy="32" r="22" fill="#006B3F" opacity="0.05"/>
                                <text x="32" y="28" text-anchor="middle" font-size="7" font-weight="800" fill="#006B3F" letter-spacing="1">CENTRAL BANK</text>
                                <text x="32" y="37" text-anchor="middle" font-size="7" font-weight="800" fill="#006B3F" letter-spacing="1">OF NIGERIA</text>
                                <text x="32" y="46" text-anchor="middle" font-size="6" fill="#C8A415" letter-spacing="0.5">✦ FCD ✦</text>
                            </svg>
                        </div>
                    </div>
                </div>

                @* ── Bottom strip: QR + cert number + verify URL ── *@
                <div class="portal-cert-v2-bottom">
                    <div class="portal-cert-v2-qr-wrap">
                        <div class="portal-cert-v2-qr-frame" title="Scan to verify this certificate">
                            <canvas id="cert-qr-canvas" width="80" height="80"></canvas>
                        </div>
                        <span class="portal-cert-v2-qr-label">Scan to Verify</span>
                    </div>

                    <div class="portal-cert-v2-verify-info">
                        <div class="portal-cert-v2-certnum-label">Certificate Number</div>
                        <div class="portal-cert-v2-certnum">@_cert.CertificateNumber</div>
                        <div class="portal-cert-v2-verify-url-row">
                            <span class="portal-cert-v2-verify-url">@_verifyUrl</span>
                        </div>
                        <div class="portal-cert-v2-generated">
                            Generated on @_cert.GeneratedAt.ToString("dd MMM yyyy 'at' HH:mm") UTC &middot; RegOS™ Portal
                        </div>
                    </div>

                    <div class="portal-cert-v2-bottom-right">
                        <div class="portal-cert-v2-disclaimer">
                            This certificate is electronically generated<br/>
                            and valid without wet signature.
                        </div>
                    </div>
                </div>

                @* ── Superseded footer (when applicable) ── *@
                @if (_cert.IsSuperseded)
                {
                    <div class="portal-cert-v2-superseded-footer">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        This certificate has been superseded by a subsequent amendment submission.
                        The latest valid certificate supersedes this document.
                    </div>
                }
            </div>

            @* ── Crop marks for print ── *@
            <div class="portal-cert-crop-marks portal-cert-print-only" aria-hidden="true">
                <span class="portal-cert-crop-tl"></span>
                <span class="portal-cert-crop-tr"></span>
                <span class="portal-cert-crop-bl"></span>
                <span class="portal-cert-crop-br"></span>
            </div>

        </div>
    }

</div>

@* ── Email Certificate Modal ── *@
@if (_emailModalOpen)
{
    <div class="portal-modal-backdrop" @onclick="CloseEmailModal" role="presentation" aria-hidden="true"></div>
    <div class="portal-modal portal-cert-email-modal" role="dialog" aria-modal="true" aria-labelledby="cert-email-modal-title">
        <div class="portal-modal-header">
            <h2 class="portal-modal-title" id="cert-email-modal-title">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/></svg>
                Email Compliance Certificate
            </h2>
            <button class="portal-modal-close" @onclick="CloseEmailModal" aria-label="Close email modal">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="portal-modal-body">
            <p class="portal-cert-email-desc">
                Send the compliance certificate PDF and a verification link to the specified email addresses.
                The certificate for <strong>@_cert?.ReturnCode — @_cert?.Period</strong> will be attached.
            </p>
            <div class="portal-form-group">
                <label class="portal-label" for="cert-email-input">
                    Email Addresses
                    <span class="portal-label-hint">Separate multiple addresses with commas</span>
                </label>
                <textarea id="cert-email-input"
                          class="portal-input portal-cert-email-textarea"
                          placeholder="e.g. compliance@bank.com, audit@bank.com"
                          @bind="_emailAddresses"
                          rows="3"
                          aria-describedby="cert-email-hint"></textarea>
                <span id="cert-email-hint" class="portal-field-hint">
                    The certificate PDF and public verification link will be sent to each address.
                </span>
            </div>
            @if (!string.IsNullOrEmpty(_emailError))
            {
                <div class="portal-alert portal-alert--error" role="alert">@_emailError</div>
            }
            @if (_emailSent)
            {
                <div class="portal-cert-v2-email-feedback" role="status">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    Certificate sent successfully to @_emailSentCount address@(_emailSentCount != 1 ? "es" : "").
                </div>
            }
        </div>
        <div class="portal-modal-footer">
            <button class="portal-btn portal-btn-ghost portal-btn-sm" @onclick="CloseEmailModal">Cancel</button>
            <button class="portal-btn portal-btn-primary portal-btn-sm"
                    @onclick="SendEmail"
                    disabled="@(_emailSending || _emailSent)">
                @if (_emailSending)
                {
                    <span class="portal-spinner portal-spinner-xs" aria-hidden="true"></span>
                    <span>Sending…</span>
                }
                else
                {
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                    <span>Send Certificate</span>
                }
            </button>
        </div>
    </div>
}

@code {
    [Parameter] public int SubmissionId { get; set; }

    private bool _loading = true;
    private bool _notEligible;
    private ComplianceCertificateModel? _cert;
    private string _verifyUrl = "";
    private bool _qrRendered;

    // Email modal state
    private bool _emailModalOpen;
    private string _emailAddresses = "";
    private bool _emailSending;
    private bool _emailSent;
    private string? _emailError;
    private int _emailSentCount;

    private int _institutionId;
    private int _userId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            int.TryParse(authState.User.FindFirst("InstitutionId")?.Value, out _institutionId);
            int.TryParse(authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out _userId);

            if (_institutionId <= 0)
            {
                Navigation.NavigateTo("/access-denied");
                return;
            }

            _cert = await ExportSvc.BuildComplianceCertificateAsync(SubmissionId, _institutionId);
            if (_cert is null)
                _notEligible = true;
            else
                _verifyUrl = $"{Navigation.BaseUri.TrimEnd('/')}/verify/{Uri.EscapeDataString(_cert.CertificateNumber)}";
        }
        catch
        {
            _notEligible = true;
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _cert is not null && !_qrRendered)
        {
            _qrRendered = true;
            await JS.InvokeVoidAsync("portalCertQr", "cert-qr-canvas", _verifyUrl);
        }
    }

    private async Task DownloadPdf()
    {
        await JS.InvokeVoidAsync("portalPrintElement", "cert-doc");
    }

    private async Task PrintPage()
    {
        await JS.InvokeVoidAsync("portalCertPrint");
    }

    private async Task ShareLink()
    {
        await JS.InvokeVoidAsync("portalCertCopyLink", _verifyUrl, "cert-share-btn");
    }

    private void OpenEmailModal()
    {
        _emailAddresses = "";
        _emailError = null;
        _emailSent = false;
        _emailSending = false;
        _emailSentCount = 0;
        _emailModalOpen = true;
    }

    private void CloseEmailModal()
    {
        _emailModalOpen = false;
    }

    private async Task SendEmail()
    {
        _emailError = null;

        var emails = _emailAddresses
            .Split(new[] { ',', ';', '\n' }, StringSplitOptions.RemoveEmptyEntries)
            .Select(e => e.Trim())
            .Where(e => e.Contains('@'))
            .ToList();

        if (emails.Count == 0)
        {
            _emailError = "Please enter at least one valid email address.";
            return;
        }

        _emailSending = true;
        try
        {
            var baseUrl = Navigation.BaseUri.TrimEnd('/');

            await ExportSvc.SendCertificateEmailAsync(
                SubmissionId, _institutionId, _userId, baseUrl, emails);

            _emailSent = true;
            _emailSentCount = emails.Count;
        }
        catch (Exception ex)
        {
            _emailError = "Failed to send email: " + ex.Message;
        }
        finally
        {
            _emailSending = false;
        }
    }
}
