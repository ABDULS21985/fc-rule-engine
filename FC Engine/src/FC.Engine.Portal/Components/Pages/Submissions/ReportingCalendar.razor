@page "/calendar"
@attribute [Authorize(Policy = "InstitutionUser")]
@using Microsoft.AspNetCore.Components.Authorization
@using FC.Engine.Portal.Services
@inject CalendarService CalendarSvc
@inject DeadlineExtensionRequestService ExtensionRequestService
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Reporting Calendar — RegOS™</PageTitle>

@{
    var _bcItems = new List<BreadcrumbItem>
    {
        new("Submissions", Url: "/submissions"),
        new("Reporting Calendar", IsCurrent: true)
    };
}

<PortalPageHeader Breadcrumb="_bcItems" Title="Reporting Calendar" Subtitle="@_subtitle">
    <PrimaryAction>
        <button class="portal-btn portal-btn--primary portal-cal-ical-btn"
                @onclick="ExportIcal"
                disabled="@(_data is null || _loading)"
                title="Export your institution's deadlines to Google Calendar / Outlook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Export my deadlines
        </button>
    </PrimaryAction>
    <SecondaryActions>
        <div class="portal-cal-view-toggle">
            <button class="portal-cal-vtbtn @(_view == "month" ? "portal-cal-vtbtn--active" : "")"
                    @onclick='() => SetView("month")'>Month</button>
            <button class="portal-cal-vtbtn @(_view == "week" ? "portal-cal-vtbtn--active" : "")"
                    @onclick='() => SetView("week")'>Week</button>
            <button class="portal-cal-vtbtn @(_view == "list" ? "portal-cal-vtbtn--active" : "")"
                    @onclick='() => SetView("list")'>List</button>
        </div>
    </SecondaryActions>
</PortalPageHeader>

@* ── Controls Bar ── *@
<div class="portal-cal-controls">
    @* Frequency filter *@
    <div class="portal-cal-freq-tabs">
        @foreach (var f in new[] { "All", "Monthly", "Quarterly", "SemiAnnual" })
        {
            <button class="portal-cal-freq-tab @(_freq == f ? "portal-cal-freq-tab--active" : "")"
                    @onclick="() => SetFreq(f)">
                @(f == "SemiAnnual" ? "Semi-Annual" : f)
            </button>
        }
    </div>

    @* Month / Week navigation *@
    <div class="portal-cal-nav">
        <button class="portal-cal-nav-btn" @onclick="() => Navigate(-1)" title="Previous">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <span class="portal-cal-nav-label">@_navLabel</span>
        <button class="portal-cal-nav-btn" @onclick="() => Navigate(1)" title="Next">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
        <button class="portal-cal-nav-today" @onclick="GoToToday">Today</button>
    </div>

    @* FY config + Compliance ring *@
    <div class="portal-cal-controls-right">
        @* Fiscal Year config *@
        <div class="portal-cal-fy-wrap">
            <button class="portal-cal-fy-btn" @onclick="ToggleFyConfig"
                    title="Configure fiscal year start month">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 1.36 13.57M4.93 19.07A10 10 0 0 1 3.57 5.5"/><path d="M14.83 9.17a4 4 0 0 1 0 5.66M9.17 14.83a4 4 0 0 1 0-5.66"/></svg>
                FY: @MonthName(_fiscalYearStart)
            </button>
            @if (_fyConfigOpen)
            {
                <div class="portal-cal-fy-popover" role="dialog" aria-label="Fiscal year start month">
                    <div class="portal-cal-fy-popover-label">Fiscal year start</div>
                    <div class="portal-cal-fy-months">
                        @for (int m = 1; m <= 12; m++)
                        {
                            int captured = m;
                            <button class="portal-cal-fy-month-btn @(_fiscalYearStart == captured ? "portal-cal-fy-month-btn--active" : "")"
                                    @onclick="() => SetFiscalYearStart(captured)">
                                @MonthName(captured)
                            </button>
                        }
                    </div>
                </div>
            }
        </div>

        @* Compliance ring *@
        <div class="portal-cal-ring-wrap" title="Compliance rate for displayed period">
            <svg class="portal-cal-ring-svg" viewBox="0 0 80 80" aria-label="Compliance @_compliancePct%">
                <circle class="portal-cal-ring-track" cx="40" cy="40" r="32"/>
                <circle class="portal-cal-ring-fill @RingColorClass" cx="40" cy="40" r="32"
                        style="stroke-dashoffset: @RingOffset.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"/>
            </svg>
            <div class="portal-cal-ring-text">
                <span class="portal-cal-ring-pct">@_compliancePct%</span>
                <span class="portal-cal-ring-sub">Compliance</span>
            </div>
        </div>
    </div>
</div>

@* ── Summary Stats ── *@
@if (_data is not null)
{
    <div class="portal-cal-summary">
        <div class="portal-cal-stat">
            <span class="portal-cal-stat-val">@_data.Summary.TotalDueThisMonth</span>
            <span class="portal-cal-stat-lbl">Total Due</span>
        </div>
        <div class="portal-cal-stat portal-cal-stat--green">
            <span class="portal-cal-stat-val">@_data.Summary.SubmittedThisMonth</span>
            <span class="portal-cal-stat-lbl">Submitted</span>
        </div>
        <div class="portal-cal-stat portal-cal-stat--amber">
            <span class="portal-cal-stat-val">@_data.Summary.OutstandingThisMonth</span>
            <span class="portal-cal-stat-lbl">Outstanding</span>
        </div>
        <div class="portal-cal-stat portal-cal-stat--red">
            <span class="portal-cal-stat-val">@_data.Summary.OverdueThisMonth</span>
            <span class="portal-cal-stat-lbl">Overdue</span>
        </div>
    </div>

    @* Band legend *@
    @if (_view == "month")
    {
        <div class="portal-cal-band-legend" aria-label="Regulatory cycle legend">
            <span class="portal-cal-band-legend-label">Regulatory cycles:</span>
            <span class="portal-cal-band portal-cal-band--weekly">CBN Weekly</span>
            <span class="portal-cal-band portal-cal-band--monthly">Monthly</span>
            <span class="portal-cal-band portal-cal-band--quarterly">Quarterly</span>
            <span class="portal-cal-band portal-cal-band--annual">Annual / Semi-Annual</span>
        </div>
    }
}

@* ── Loading / Error ── *@
@if (_loading)
{
    <div class="portal-cal-loading">
        <span class="portal-cal-spinner" aria-hidden="true"></span>
        Loading calendar…
    </div>
}
else if (_error is not null)
{
    <div class="portal-alert portal-alert-error" role="alert">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
            <line x1="10" y1="6" x2="10" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="10" cy="14" r="0.75" fill="currentColor" stroke="none"/>
        </svg>
        <span>Couldn't load reporting calendar.</span>
        <button class="portal-btn portal-btn--ghost portal-btn--sm" @onclick="LoadAsync">Retry</button>
    </div>
}
else if (_data is not null)
{
    @* ══════════════════════ MONTH VIEW ══════════════════════ *@
    @if (_view == "month")
    {
        <div class="portal-cal-month-grid">
            @* Day-of-week header row *@
            <div class="portal-cal-dow-row" role="row">
                @foreach (var dow in new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" })
                {
                    <div class="portal-cal-dow" role="columnheader">@dow</div>
                }
            </div>

            @* Week rows with regulatory bands *@
            @foreach (var week in _weekRows)
            {
                <div class="portal-cal-week-row">
                    @* Regulatory cycle bands *@
                    <div class="portal-cal-bands" aria-label="Regulatory cycles this week">
                        @foreach (var band in week.Bands)
                        {
                            <span class="portal-cal-band portal-cal-band--@band.BandType">@band.Label</span>
                        }
                    </div>

                    @* 7 day cells *@
                    <div class="portal-cal-week-days" role="row">
                        @foreach (var day in week.Days)
                        {
                            var heatClass = ProximityHeatClass(day.Entries);
                            var fyClass = IsFyStart(day.Date) ? " portal-cal-day--fy-start"
                                        : IsFyEnd(day.Date)   ? " portal-cal-day--fy-end"
                                        : "";
                            var dayClass = "portal-cal-day"
                                + (day.IsCurrentMonth ? "" : " portal-cal-day--other")
                                + (day.IsToday ? " portal-cal-day--today" : "")
                                + (day.Entries.Any(e => e.Status == CalendarEntryStatus.Overdue) ? " portal-cal-day--has-overdue" : "")
                                + (heatClass.Length > 0 ? " " + heatClass : "")
                                + fyClass;

                            <div class="@dayClass"
                                 @onmouseenter="() => _hoveredDate = day.Date"
                                 @onmouseleave="() => { _hoveredDate = null; }"
                                 @onfocus="() => _hoveredDate = day.Date"
                                 @onblur="() => { _hoveredDate = null; }"
                                 tabindex="@(day.Entries.Any() ? "0" : "-1")"
                                 role="gridcell"
                                 aria-label="@(day.Date.ToString("d MMMM yyyy") + (day.Entries.Any() ? $": {day.Entries.Count} deadline(s)" : ""))">

                                <span class="portal-cal-day-num">@day.Date.Day</span>

                                @* Colored status dots (up to 3) + ×N overflow badge *@
                                @if (day.Entries.Any())
                                {
                                    <div class="portal-cal-dots" aria-hidden="true">
                                        @foreach (var entry in day.Entries.Take(3))
                                        {
                                            <span class="portal-cal-dot portal-cal-dot--@DotClass(entry)"
                                                  title="@entry.ReturnCode — @StatusLabel(entry.Status)"></span>
                                        }
                                        @if (day.Entries.Count > 3)
                                        {
                                            <span class="portal-cal-overflow-badge">×@(day.Entries.Count - 3)</span>
                                        }
                                    </div>
                                }

                                @* Hover card popover *@
                                @if (_hoveredDate == day.Date && day.Entries.Any())
                                {
                                    <div class="portal-cal-hovercard @HoverCardSide(day.Date)" role="tooltip" aria-live="polite">
                                        <div class="portal-cal-hc-date">@day.Date.ToString("dddd, d MMMM")</div>
                                        <ul class="portal-cal-hc-list">
                                            @foreach (var entry in day.Entries)
                                            {
                                                <li class="portal-cal-hc-item">
                                                    <div class="portal-cal-hc-row">
                                                        <span class="portal-cal-dot portal-cal-dot--@DotClass(entry) portal-cal-dot--lg" aria-hidden="true"></span>
                                                        <div class="portal-cal-hc-info">
                                                            <span class="portal-cal-hc-name">@entry.TemplateName</span>
                                                            <span class="portal-cal-hc-period">@entry.ReturnCode · @entry.PeriodLabel</span>
                                                            @if (!string.IsNullOrEmpty(entry.DeadlineDescription))
                                                            {
                                                                <span class="portal-cal-hc-ddesc">@entry.DeadlineDescription</span>
                                                            }
                                                        </div>
                                                        <span class="portal-cal-hc-badge portal-cal-hc-badge--@DotClass(entry)">@StatusLabel(entry.Status)</span>
                                                    </div>
                                                    @if (entry.Status != CalendarEntryStatus.Submitted)
                                                    {
                                                        <a href="@SubmitUrl(entry)" class="portal-cal-hc-action">
                                                            Submit now →
                                                        </a>
                                                    }
                                                    else if (entry.SubmissionId.HasValue)
                                                    {
                                                        <a href="/submissions/@entry.SubmissionId" class="portal-cal-hc-action portal-cal-hc-action--view">
                                                            View submission →
                                                        </a>
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @* ══════════════════════ WEEK VIEW ══════════════════════ *@
    @if (_view == "week")
    {
        <div class="portal-cal-week-grid">
            @foreach (var day in _weekDays)
            {
                var dayClass = "portal-cal-week-day"
                    + (day.IsToday ? " portal-cal-week-day--today" : "");

                <div class="@dayClass">
                    <div class="portal-cal-week-hdr">
                        <span class="portal-cal-week-dow">@day.Date.ToString("ddd")</span>
                        <span class="portal-cal-week-num @(day.IsToday ? "portal-cal-week-num--today" : "")">@day.Date.Day</span>
                        @if (IsFyStart(day.Date))
                        {
                            <span class="portal-cal-week-fy-badge portal-cal-week-fy-badge--start">FY Start</span>
                        }
                        else if (IsFyEnd(day.Date))
                        {
                            <span class="portal-cal-week-fy-badge portal-cal-week-fy-badge--end">FY End</span>
                        }
                    </div>
                    <div class="portal-cal-week-entries">
                        @if (!day.Entries.Any())
                        {
                            <div class="portal-cal-week-empty">No deadlines</div>
                        }
                        @foreach (var entry in day.Entries)
                        {
                            <div class="portal-cal-week-block portal-cal-week-block--@DotClass(entry)">
                                <div class="portal-cal-week-block-title" title="@entry.TemplateName">@entry.ReturnCode</div>
                                <div class="portal-cal-week-block-period">@entry.PeriodLabel</div>
                                <div class="portal-cal-week-block-freq">@entry.Frequency
                                    @if (!string.IsNullOrEmpty(entry.DeadlineDescription))
                                    {
                                        <span class="portal-cal-week-block-ddesc">· @entry.DeadlineDescription</span>
                                    }
                                </div>
                                @if (entry.Status != CalendarEntryStatus.Submitted)
                                {
                                    <a href="@SubmitUrl(entry)" class="portal-cal-week-block-link">Submit →</a>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @* ══════════════════════ LIST VIEW ══════════════════════ *@
    @if (_view == "list")
    {
        var grouped = _data.Entries
            .Where(e => e.DueDate >= _listRangeStart && e.DueDate <= _listRangeEnd)
            .OrderBy(e => e.DueDate)
            .GroupBy(e => e.DueDate.Date)
            .ToList();

        if (!grouped.Any())
        {
            <div class="portal-cal-list-empty">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <p>No deadlines in this period.</p>
            </div>
        }
        else
        {
            @foreach (var group in grouped)
            {
                var isToday = group.Key == DateTime.Today;
                var isPast = group.Key < DateTime.Today;

                <div class="portal-cal-list-group">
                    <div class="portal-cal-list-date-hdr @(isToday ? "portal-cal-list-date-hdr--today" : "") @(isPast ? "portal-cal-list-date-hdr--past" : "")">
                        <span class="portal-cal-list-date-dow">@group.Key.ToString("dddd")</span>
                        <span class="portal-cal-list-date-val">@group.Key.ToString("d MMMM yyyy")</span>
                        @if (isToday)
                        {
                            <span class="portal-cal-list-today-chip">Today</span>
                        }
                        @if (IsFyStart(group.Key))
                        {
                            <span class="portal-cal-list-fy-chip portal-cal-list-fy-chip--start">FY Start</span>
                        }
                        else if (IsFyEnd(group.Key))
                        {
                            <span class="portal-cal-list-fy-chip portal-cal-list-fy-chip--end">FY End</span>
                        }
                    </div>

                    <div class="portal-cal-list-rows">
                        @foreach (var entry in group.OrderBy(e => e.Status))
                        {
                            var (chipLabel, chipClass) = UrgencyChip(entry);
                            <div class="portal-cal-list-row portal-cal-list-row--@DotClass(entry)">
                                @* Left: status indicator + info *@
                                <div class="portal-cal-list-left">
                                    <span class="portal-cal-dot portal-cal-dot--@DotClass(entry) portal-cal-dot--lg" aria-hidden="true"></span>
                                    <div class="portal-cal-list-info">
                                        <span class="portal-cal-list-name">@entry.TemplateName</span>
                                        <span class="portal-cal-list-meta">
                                            @entry.ReturnCode · @entry.PeriodLabel · @entry.Frequency
                                            @if (!string.IsNullOrEmpty(entry.DeadlineDescription))
                                            {
                                                <span class="portal-cal-list-ddesc">(@entry.DeadlineDescription)</span>
                                            }
                                        </span>
                                    </div>
                                </div>

                                @* Middle: urgency chip *@
                                <div class="portal-cal-list-middle">
                                    <span class="portal-cal-urgency portal-cal-urgency--@chipClass">
                                        @if (entry.Status == CalendarEntryStatus.Submitted)
                                        {
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                                        }
                                        else if (entry.Status == CalendarEntryStatus.Overdue)
                                        {
                                            <span class="portal-cal-urgency-pulse" aria-hidden="true"></span>
                                        }
                                        @chipLabel
                                    </span>
                                </div>

                                @* Right: actions *@
                                <div class="portal-cal-list-actions">
                                    @if (entry.Status == CalendarEntryStatus.Submitted && entry.SubmissionId.HasValue)
                                    {
                                        <a href="/submissions/@entry.SubmissionId" class="portal-btn portal-btn--outline portal-btn--sm">
                                            View →
                                        </a>
                                    }
                                    else if (entry.Status == CalendarEntryStatus.Overdue)
                                    {
                                        <button class="portal-btn portal-btn--sm portal-btn--ghost"
                                                @onclick="() => OpenExtModal(entry)">
                                            Request Extension
                                        </button>
                                        <a href="@SubmitUrl(entry)" class="portal-btn portal-btn--primary portal-btn--sm">
                                            Submit Now →
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="@SubmitUrl(entry)" class="portal-btn portal-btn--primary portal-btn--sm">
                                            Submit Now →
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    }
}

@* ══════════════════════ EXTENSION REQUEST MODAL ══════════════════════ *@
@if (_showExtModal && _extEntry is not null)
{
    <div class="portal-cal-backdrop" @onclick="CloseExtModal" aria-hidden="true"></div>
    <div class="portal-cal-modal" role="dialog" aria-modal="true" aria-labelledby="ext-modal-title">
        <div class="portal-cal-modal-hdr">
            <h2 class="portal-cal-modal-title" id="ext-modal-title">Request Extension</h2>
            <button class="portal-cal-modal-close" @onclick="CloseExtModal" aria-label="Close">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="portal-cal-modal-body">
            <div class="portal-cal-modal-info">
                <span class="portal-cal-dot portal-cal-dot--red portal-cal-dot--lg" aria-hidden="true"></span>
                <div>
                    <div class="portal-cal-modal-return">@_extEntry.TemplateName</div>
                    <div class="portal-cal-modal-period">@_extEntry.ReturnCode · @_extEntry.PeriodLabel · Due @_extEntry.DueDate.ToString("d MMM yyyy")</div>
                </div>
            </div>

            <div class="portal-cal-modal-field">
                <label for="ext-reason" class="portal-cal-modal-label">Reason for extension request <span class="portal-cal-modal-req">*</span></label>
                <textarea id="ext-reason"
                          class="portal-cal-modal-textarea"
                          placeholder="Describe the circumstances preventing timely submission…"
                          rows="4"
                          @bind="_extReason"
                          maxlength="1000"></textarea>
                <span class="portal-cal-modal-char">@_extReason.Length / 1000</span>
            </div>

            <div class="portal-cal-modal-field">
                <label class="portal-cal-modal-label">Supporting document (optional)</label>
                <label class="portal-cal-modal-file-drop" for="ext-file">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    @if (_extFileName is not null)
                    {
                        <span>@_extFileName <span class="portal-cal-modal-file-clear" @onclick="() => _extFileName = null" @onclick:stopPropagation>×</span></span>
                    }
                    else
                    {
                        <span>Click to upload or drag &amp; drop</span>
                    }
                    <InputFile id="ext-file" OnChange="OnExtFileChange" class="portal-cal-modal-file-input" accept=".pdf,.doc,.docx,.jpg,.png" />
                </label>
            </div>

            @if (_extError is not null)
            {
                <div class="portal-cal-modal-error" role="alert">@_extError</div>
            }
        </div>
        <div class="portal-cal-modal-footer">
            <button class="portal-btn portal-btn--ghost" @onclick="CloseExtModal">Cancel</button>
            <button class="portal-btn portal-btn--primary"
                    @onclick="SubmitExtension"
                    disabled="@(_extSubmitting || string.IsNullOrWhiteSpace(_extReason))">
                @if (_extSubmitting)
                {
                    <span class="portal-cal-spinner portal-cal-spinner--sm" aria-hidden="true"></span>
                }
                Submit Request
            </button>
        </div>
    </div>
}

@code {
    // ── URL query params ─────────────────────────────────────────
    [SupplyParameterFromQuery(Name = "view")]  public string? ViewParam  { get; set; }
    [SupplyParameterFromQuery(Name = "freq")]  public string? FreqParam  { get; set; }
    [SupplyParameterFromQuery(Name = "year")]  public int?    YearParam  { get; set; }
    [SupplyParameterFromQuery(Name = "month")] public int?    MonthParam { get; set; }
    [SupplyParameterFromQuery(Name = "module")] public string? ModuleParam { get; set; }
    [SupplyParameterFromQuery(Name = "returnCode")] public string? ReturnCodeParam { get; set; }
    [SupplyParameterFromQuery(Name = "requestExtension")] public bool? RequestExtensionParam { get; set; }

    // ── View state ───────────────────────────────────────────────
    private string _view  = "month";
    private string _freq  = "All";
    private int    _year;
    private int    _month;

    // ── Fiscal year config ────────────────────────────────────────
    private int  _fiscalYearStart = 1;  // 1 = January (default)
    private bool _fyConfigOpen    = false;

    // ── Calendar data ────────────────────────────────────────────
    private CalendarData?         _data;
    private bool                  _loading;
    private Exception?            _error;
    private List<CalendarWeekRow> _weekRows = new();
    private List<CalendarDay>     _weekDays = new();
    private int                   _compliancePct;

    // ── Hover state ───────────────────────────────────────────────
    private DateTime? _hoveredDate;

    // ── Extension modal ──────────────────────────────────────────
    private bool           _showExtModal;
    private CalendarEntry? _extEntry;
    private string         _extReason    = "";
    private string?        _extFileName;
    private IBrowserFile?  _extFile;
    private bool           _extSubmitting;
    private string?        _extError;
    private bool           _extensionQueryProcessed;
    private int            _institutionId;
    private int?           _currentUserId;
    private string         _currentUserDisplayName = "Institution user";

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    // ── Derived ──────────────────────────────────────────────────
    private string _navLabel      => _view == "week" ? WeekLabel() : $"{new DateTime(_year, _month, 1):MMMM yyyy}";
    private string _subtitle      => _data is null ? "" : $"{_data.Summary.TotalDueThisMonth} obligations · {_data.Summary.SubmittedThisMonth} submitted";
    private double _ringCirc      => 2 * Math.PI * 32;
    private double RingOffset     => _ringCirc * (1 - _compliancePct / 100.0);
    private string RingColorClass => _compliancePct >= 80 ? "portal-cal-ring-fill--green"
                                   : _compliancePct >= 50 ? "portal-cal-ring-fill--amber"
                                   : "portal-cal-ring-fill--red";
    private DateTime _listRangeStart => new DateTime(_year, _month, 1);
    private DateTime _listRangeEnd   => _listRangeStart.AddMonths(1).AddDays(-1);

    // ── Lifecycle ─────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var now = DateTime.Today;
        var auth = await AuthState!;
        int.TryParse(auth.User.FindFirst("InstitutionId")?.Value, out _institutionId);
        if (int.TryParse(auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var userId))
        {
            _currentUserId = userId;
        }

        _currentUserDisplayName = auth.User.FindFirst("DisplayName")?.Value
            ?? auth.User.Identity?.Name
            ?? "Institution user";

        _view  = ViewParam  is "month" or "week" or "list" ? ViewParam : "month";
        _freq  = FreqParam  is "Monthly" or "Quarterly" or "SemiAnnual" ? FreqParam : "All";
        _year  = YearParam  is > 2000 and < 2100 ? YearParam.Value : now.Year;
        _month = MonthParam is >= 1 and <= 12      ? MonthParam.Value : now.Month;

        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Restore FY start from localStorage
            try
            {
                var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "fc_cal_fy_start");
                if (int.TryParse(stored, out var month) && month >= 1 && month <= 12)
                {
                    _fiscalYearStart = month;
                    StateHasChanged();
                }
            }
            catch { /* localStorage unavailable during prerender */ }
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error   = null;
        StateHasChanged();
        try
        {
            var rangeStart = new DateTime(_year, _month, 1).AddMonths(-1);
            var rangeEnd   = new DateTime(_year, _month, 1).AddMonths(2).AddDays(-1);

            if (_view == "week")
            {
                var weekStart = GetWeekStart();
                rangeStart = weekStart.AddDays(-7);
                rangeEnd   = weekStart.AddDays(14);
            }

            if (_institutionId <= 0)
            {
                throw new InvalidOperationException("Institution context is unavailable.");
            }

            _data = await CalendarSvc.GetCalendarData(
                institutionId: _institutionId,
                rangeStart: rangeStart,
                rangeEnd: rangeEnd,
                frequencyFilter: _freq == "All" ? null : _freq);

            _compliancePct = _data.Summary.CompliancePercentage;
            BuildCalendarDays();
            BuildWeekDays();
            TryOpenExtensionFromQuery();
        }
        catch (Exception ex)
        {
            _error = ex;
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Calendar Grid Builders ────────────────────────────────────

    private void BuildCalendarDays()
    {
        _weekRows = new List<CalendarWeekRow>();
        if (_data is null) return;

        var firstOfMonth = new DateTime(_year, _month, 1);
        var startOfGrid  = firstOfMonth.AddDays(-(int)firstOfMonth.DayOfWeek);
        var entryByDate  = _data.Entries
            .GroupBy(e => e.DueDate.Date)
            .ToDictionary(g => g.Key, g => g.ToList());

        // Build 6 week rows of 7 days each
        for (int w = 0; w < 6; w++)
        {
            var days = new List<CalendarDay>();
            for (int d = 0; d < 7; d++)
            {
                var date = startOfGrid.AddDays(w * 7 + d);
                entryByDate.TryGetValue(date, out var entries);
                days.Add(new CalendarDay
                {
                    Date           = date,
                    IsCurrentMonth = date.Month == _month,
                    IsToday        = date.Date  == DateTime.Today,
                    Entries        = entries ?? new List<CalendarEntry>()
                });
            }
            _weekRows.Add(new CalendarWeekRow
            {
                Days  = days,
                Bands = GetBandsForWeek(days)
            });
        }
    }

    private List<RegulatoryBand> GetBandsForWeek(List<CalendarDay> week)
    {
        var bands   = new List<RegulatoryBand>();
        var entries = week.SelectMany(d => d.Entries).ToList();

        // CBN Weekly — always present as a baseline regulatory expectation
        bands.Add(new RegulatoryBand("weekly", "CBN Weekly"));

        if (entries.Any(e => e.Frequency == "Monthly"))
            bands.Add(new RegulatoryBand("monthly", "Monthly"));
        if (entries.Any(e => e.Frequency == "Quarterly"))
            bands.Add(new RegulatoryBand("quarterly", "Quarterly"));
        if (entries.Any(e => e.Frequency is "SemiAnnual" or "Annual"))
            bands.Add(new RegulatoryBand("annual", "Annual"));

        return bands;
    }

    private void BuildWeekDays()
    {
        _weekDays = new List<CalendarDay>();
        if (_data is null) return;

        var weekStart   = GetWeekStart();
        var entryByDate = _data.Entries
            .GroupBy(e => e.DueDate.Date)
            .ToDictionary(g => g.Key, g => g.ToList());

        for (int i = 0; i < 7; i++)
        {
            var date = weekStart.AddDays(i);
            entryByDate.TryGetValue(date, out var entries);
            _weekDays.Add(new CalendarDay
            {
                Date           = date,
                IsCurrentMonth = date.Month == _month,
                IsToday        = date.Date  == DateTime.Today,
                Entries        = entries ?? new List<CalendarEntry>()
            });
        }
    }

    private DateTime GetWeekStart()
    {
        var today = DateTime.Today;
        if (_year == today.Year && _month == today.Month)
            return today.AddDays(-(int)today.DayOfWeek);
        var firstOfMonth = new DateTime(_year, _month, 1);
        return firstOfMonth.AddDays(-(int)firstOfMonth.DayOfWeek);
    }

    private string WeekLabel()
    {
        if (!_weekDays.Any()) return "";
        var start = _weekDays.First().Date;
        var end   = _weekDays.Last().Date;
        return start.Month == end.Month
            ? $"{start:d} – {end:d MMMM yyyy}"
            : $"{start:d MMM} – {end:d MMM yyyy}";
    }

    // ── FY Helpers ────────────────────────────────────────────────

    private bool IsFyStart(DateTime d) => d.Month == _fiscalYearStart && d.Day == 1;

    private bool IsFyEnd(DateTime d)
    {
        var endMonth = _fiscalYearStart == 1 ? 12 : ((_fiscalYearStart - 2 + 12) % 12) + 1;
        return d.Month == endMonth && d.Day == DateTime.DaysInMonth(d.Year, d.Month);
    }

    private static string MonthName(int m) => new DateTime(2000, m, 1).ToString("MMM");

    private void ToggleFyConfig() => _fyConfigOpen = !_fyConfigOpen;

    private async Task SetFiscalYearStart(int month)
    {
        _fiscalYearStart = month;
        _fyConfigOpen    = false;
        try { await JS.InvokeVoidAsync("localStorage.setItem", "fc_cal_fy_start", month.ToString()); }
        catch { }
    }

    // ── Proximity Heat ────────────────────────────────────────────

    private static string ProximityHeatClass(List<CalendarEntry> entries)
    {
        if (!entries.Any(e => e.Status != CalendarEntryStatus.Submitted)) return "";
        var pending = entries.Where(e => e.Status != CalendarEntryStatus.Submitted).ToList();
        if (!pending.Any()) return "";
        var minDays = pending.Min(e => e.DaysUntilDue);
        if (minDays < 0)  return "portal-cal-day--heat-overdue";
        if (minDays == 0) return "portal-cal-day--heat-today";
        if (minDays <= 3) return "portal-cal-day--heat-3";
        if (minDays <= 7) return "portal-cal-day--heat-7";
        if (minDays <= 30) return "portal-cal-day--heat-30";
        return "";
    }

    // ── CSS / Label Helpers ────────────────────────────────────────

    private static string DotClass(CalendarEntry entry)
    {
        if (entry.Status == CalendarEntryStatus.Overdue)   return "red";
        if (entry.Status == CalendarEntryStatus.Rejected)  return "red";
        if (entry.Status == CalendarEntryStatus.Submitted) return "green";
        if (entry.Status == CalendarEntryStatus.Draft)     return "amber";
        if (entry.Status == CalendarEntryStatus.NotStarted && entry.DaysUntilDue <= 7) return "amber";
        return "blue";
    }

    private static string StatusLabel(CalendarEntryStatus s) => s switch
    {
        CalendarEntryStatus.Submitted  => "Submitted",
        CalendarEntryStatus.Overdue    => "Overdue",
        CalendarEntryStatus.Rejected   => "Rejected",
        CalendarEntryStatus.Draft      => "Draft",
        CalendarEntryStatus.NotStarted => "Not started",
        _                              => "Unknown"
    };

    private static (string label, string cls) UrgencyChip(CalendarEntry entry)
    {
        if (entry.Status == CalendarEntryStatus.Submitted)
            return ("Submitted ✓", "green");

        if (entry.Status == CalendarEntryStatus.Overdue)
        {
            var days = Math.Abs(entry.DaysUntilDue);
            return (days == 1 ? "Overdue 1 day" : $"Overdue {days} days", "darkred");
        }

        if (entry.DaysUntilDue == 0)
            return ("Due today", "red");

        if (entry.DaysUntilDue > 0 && entry.DaysUntilDue <= 7)
            return ($"Due in {entry.DaysUntilDue} day{(entry.DaysUntilDue == 1 ? "" : "s")}", "amber");

        return ($"Due in {entry.DaysUntilDue} days", "blue");
    }

    private string HoverCardSide(DateTime date)
    {
        var col = (int)date.DayOfWeek;
        return col >= 4 ? "portal-cal-hovercard--left" : "";
    }

    // ── Navigation ────────────────────────────────────────────────

    private async Task Navigate(int delta)
    {
        if (_view == "week")
        {
            var newStart = GetWeekStart().AddDays(delta * 7);
            _year  = newStart.Year;
            _month = newStart.Month;
        }
        else
        {
            var dt = new DateTime(_year, _month, 1).AddMonths(delta);
            _year  = dt.Year;
            _month = dt.Month;
        }
        PushUrl();
        await LoadAsync();
    }

    private async Task GoToToday()
    {
        _year  = DateTime.Today.Year;
        _month = DateTime.Today.Month;
        PushUrl();
        await LoadAsync();
    }

    // ── Filter / View Changes ─────────────────────────────────────

    private async Task SetView(string view)
    {
        _view = view;
        PushUrl();
        BuildCalendarDays();
        BuildWeekDays();
        if (view == "week") await LoadAsync();
    }

    private async Task SetFreq(string freq)
    {
        _freq = freq;
        PushUrl();
        await LoadAsync();
    }

    private void PushUrl()
    {
        var url = Nav.GetUriWithQueryParameters("/calendar", new Dictionary<string, object?>
        {
            ["view"]  = _view  == "month" ? null : _view,
            ["freq"]  = _freq  == "All"   ? null : _freq,
            ["year"]  = _year  == DateTime.Today.Year  ? null : (object?)_year,
            ["month"] = _month == DateTime.Today.Month ? null : (object?)_month
        });
        Nav.NavigateTo(url, forceLoad: false, replace: true);
    }

    // ── Submit URL Builder ────────────────────────────────────────

    private static string SubmitUrl(CalendarEntry entry)
    {
        return entry.StartHref;
    }

    // ── Extension Modal ───────────────────────────────────────────

    private void OpenExtModal(CalendarEntry entry)
    {
        _extEntry      = entry;
        _extReason     = "";
        _extFileName   = null;
        _extFile       = null;
        _extError      = null;
        _extSubmitting = false;
        _showExtModal  = true;
    }

    private void TryOpenExtensionFromQuery()
    {
        if (_extensionQueryProcessed || RequestExtensionParam != true || _data is null)
        {
            return;
        }

        var match = _data.Entries
            .Where(entry => entry.Status != CalendarEntryStatus.Submitted)
            .Where(entry => string.IsNullOrWhiteSpace(ModuleParam)
                || string.Equals(entry.ModuleCode, ModuleParam, StringComparison.OrdinalIgnoreCase))
            .Where(entry => string.IsNullOrWhiteSpace(ReturnCodeParam)
                || string.Equals(entry.ReturnCode, ReturnCodeParam, StringComparison.OrdinalIgnoreCase))
            .OrderBy(entry => entry.DueDate)
            .FirstOrDefault();

        if (match is null)
        {
            return;
        }

        _extensionQueryProcessed = true;
        OpenExtModal(match);
        ClearExtensionRequestQuery();
    }

    private void ClearExtensionRequestQuery()
    {
        var url = Nav.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["module"] = null,
            ["returnCode"] = null,
            ["requestExtension"] = null
        });

        Nav.NavigateTo(url, forceLoad: false, replace: true);
    }

    private void CloseExtModal()
    {
        _showExtModal = false;
        _extEntry     = null;
        _extFile      = null;
    }

    private void OnExtFileChange(InputFileChangeEventArgs e)
    {
        _extFile = e.File;
        _extFileName = e.File.Name;
    }

    private async Task SubmitExtension()
    {
        if (string.IsNullOrWhiteSpace(_extReason))
        {
            _extError = "Please provide a reason for the extension request.";
            return;
        }

        _extSubmitting = true;
        _extError      = null;
        StateHasChanged();

        try
        {
            var attachments = new List<DeadlineExtensionAttachmentUpload>();
            if (_extFile is not null)
            {
                await using var stream = _extFile.OpenReadStream(5 * 1024 * 1024);
                await using var memory = new MemoryStream();
                await stream.CopyToAsync(memory);
                attachments.Add(new DeadlineExtensionAttachmentUpload
                {
                    FileName = _extFile.Name,
                    ContentType = string.IsNullOrWhiteSpace(_extFile.ContentType) ? "application/octet-stream" : _extFile.ContentType,
                    Content = memory.ToArray()
                });
            }

            await ExtensionRequestService.SubmitRequest(
                _institutionId,
                new DeadlineExtensionRequestInput
                {
                    RequestedByUserId = _currentUserId,
                    RequestedByDisplayName = _currentUserDisplayName,
                    ReturnCode = _extEntry!.ReturnCode,
                    TemplateName = _extEntry.TemplateName,
                    ModuleCode = _extEntry.ModuleCode,
                    PeriodLabel = _extEntry.PeriodLabel,
                    DueDate = _extEntry.DueDate,
                    RequestedUntil = null,
                    Reason = _extReason,
                    Attachments = attachments
                });

            await JS.InvokeVoidAsync("portalAnnounce", "Extension request submitted successfully.");
            CloseExtModal();
        }
        catch (Exception ex)
        {
            _extError = ex.Message;
        }

        _extSubmitting = false;
        StateHasChanged();
    }

    // ── iCal Export ───────────────────────────────────────────────

    private async Task ExportIcal()
    {
        if (_data is null) return;

        var ics = BuildIcalString(_data.Entries);
        var fileName = $"my-deadlines-{_year}-{_month:D2}.ics";
        await JS.InvokeVoidAsync("portalDownloadText", fileName, ics, "text/calendar");
    }

    private static string BuildIcalString(List<CalendarEntry> entries)
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("BEGIN:VCALENDAR");
        sb.AppendLine("VERSION:2.0");
        sb.AppendLine("PRODID:-//RegOS™//Reporting Calendar//EN");
        sb.AppendLine("CALSCALE:GREGORIAN");
        sb.AppendLine("METHOD:PUBLISH");
        sb.AppendLine("X-WR-CALNAME:RegOS™ — My Reporting Deadlines");

        foreach (var entry in entries)
        {
            var uid     = $"{entry.ReturnCode}-{entry.PeriodValue}@fcengine";
            var dtDate  = entry.DueDate.ToString("yyyyMMdd");
            var summary = $"{entry.ReturnCode} — {entry.TemplateName} ({entry.PeriodLabel})";
            var ddesc   = string.IsNullOrEmpty(entry.DeadlineDescription) ? "" : $"\\nDeadline: {entry.DeadlineDescription}";
            var desc    = $"Reporting obligation: {entry.ReturnCode}\\nPeriod: {entry.PeriodLabel}\\nFrequency: {entry.Frequency}{ddesc}\\nStatus: {entry.Status}\\nDue: {entry.DueDate:d MMM yyyy}";

            sb.AppendLine("BEGIN:VEVENT");
            sb.AppendLine($"UID:{uid}");
            sb.AppendLine($"DTSTAMP:{DateTime.UtcNow:yyyyMMddTHHmmssZ}");
            sb.AppendLine($"DTSTART;VALUE=DATE:{dtDate}");
            sb.AppendLine($"DTEND;VALUE=DATE:{entry.DueDate.AddDays(1):yyyyMMdd}");
            sb.AppendLine($"SUMMARY:{EscapeIcal(summary)}");
            sb.AppendLine($"DESCRIPTION:{EscapeIcal(desc)}");
            sb.AppendLine($"CATEGORIES:{EscapeIcal(entry.Frequency)}");
            sb.AppendLine("BEGIN:VALARM");
            sb.AppendLine("TRIGGER:-P7D");
            sb.AppendLine("ACTION:DISPLAY");
            sb.AppendLine($"DESCRIPTION:Reminder: {EscapeIcal(summary)} due in 7 days");
            sb.AppendLine("END:VALARM");
            sb.AppendLine("BEGIN:VALARM");
            sb.AppendLine("TRIGGER:-P1D");
            sb.AppendLine("ACTION:DISPLAY");
            sb.AppendLine($"DESCRIPTION:Reminder: {EscapeIcal(summary)} due tomorrow");
            sb.AppendLine("END:VALARM");
            sb.AppendLine("END:VEVENT");
        }

        sb.AppendLine("END:VCALENDAR");
        return sb.ToString();
    }

    private static string EscapeIcal(string s) =>
        s.Replace("\\", "\\\\").Replace(";", "\\;").Replace(",", "\\,");

    // ── Disposal ─────────────────────────────────────────────────
    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
