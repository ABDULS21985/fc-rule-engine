@page "/submissions/{SubmissionId:int}/certificate"
@attribute [Authorize(Policy = "InstitutionUser")]
@inject ExportService ExportSvc
@inject IJSRuntime JS

<PageTitle>Compliance Certificate — FC Engine Portal</PageTitle>

<div class="portal-page">
    @if (isLoading)
    {
        <div class="portal-card" style="padding: 2rem;">
            <div class="portal-skeleton portal-skeleton-block" style="height: 400px;"></div>
        </div>
    }
    else if (cert is null)
    {
        <div class="portal-alert portal-alert-error">Certificate is only available for accepted submissions, or access was denied.</div>
        <a href="/submissions/@SubmissionId" class="portal-btn portal-btn-ghost portal-btn-sm" style="margin-top: 1rem;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
            Back to Submission
        </a>
    }
    else
    {
        <div class="portal-report-controls no-print">
            <a href="/submissions/@SubmissionId" class="portal-btn portal-btn-ghost portal-btn-sm">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                Back
            </a>
            <button class="portal-btn portal-btn-primary portal-btn-sm" @onclick="PrintCert">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                Print Certificate
            </button>
        </div>

        <div id="printable-certificate" class="portal-certificate">
            <div class="portal-certificate-border">
                <div class="portal-certificate-inner">
                    <div class="portal-certificate-seal">
                        <div class="portal-certificate-seal-circle"><span>CBN</span></div>
                    </div>

                    <h1 class="portal-certificate-heading">Certificate of Compliance</h1>
                    <div class="portal-certificate-divider"></div>

                    <p class="portal-certificate-body">This certifies that</p>
                    <h2 class="portal-certificate-institution">@cert.InstitutionName</h2>
                    <p class="portal-certificate-inst-detail">@cert.InstitutionType — Code: @cert.InstitutionCode</p>

                    <p class="portal-certificate-body">has successfully submitted the</p>
                    <h3 class="portal-certificate-return">@cert.ReturnCode — @cert.Period</h3>

                    <p class="portal-certificate-body">
                        in compliance with the Central Bank of Nigeria's Financial Condition reporting requirements.
                    </p>

                    <div class="portal-certificate-divider"></div>

                    <div class="portal-certificate-details">
                        <div class="portal-certificate-detail">
                            <span>Certificate Number</span>
                            <strong>@cert.CertificateNumber</strong>
                        </div>
                        <div class="portal-certificate-detail">
                            <span>Submission ID</span>
                            <strong>#@cert.SubmissionId</strong>
                        </div>
                        <div class="portal-certificate-detail">
                            <span>Status</span>
                            <strong>@(cert.Status == SubmissionStatus.Accepted ? "Accepted — No Issues" : "Accepted — With Warnings")</strong>
                        </div>
                        <div class="portal-certificate-detail">
                            <span>Accepted On</span>
                            <strong>@cert.AcceptedAt.ToString("dd MMMM yyyy")</strong>
                        </div>
                    </div>

                    <div class="portal-certificate-footer">
                        <div class="portal-certificate-stamp">
                            <div class="portal-certificate-stamp-line"></div>
                            <span>Central Bank of Nigeria</span>
                            <span>Financial Conditions Division</span>
                        </div>
                        <p class="portal-certificate-generated">
                            Generated by FC Engine on @cert.GeneratedAt.ToString("dd MMM yyyy 'at' HH:mm") UTC
                        </p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int SubmissionId { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    private bool isLoading = true;
    private int institutionId;
    private ComplianceCertificateModel? cert;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var state = await AuthState!;
            int.TryParse(state.User.FindFirst("InstitutionId")?.Value, out institutionId);
            cert = await ExportSvc.BuildComplianceCertificateAsync(SubmissionId, institutionId);
        }
        catch { }
        finally { isLoading = false; }
    }

    private async Task PrintCert() => await JS.InvokeVoidAsync("portalPrintElement", "printable-certificate");
}
