    private async Task SendToMembers()
    {
        if (_selectedMemberIds.Count == 0) return;
        _isSending = true;

        try
        {
            await NotificationOrchestrator.Notify(new NotificationRequest
            {
                TenantId = _tenantId,
                EventType = NotificationEvents.ScheduledReportReady,
                Title = $"Board pack ready: {_coverTitle}",
                Message = $"A board pack covering {_coverDateFrom:dd MMM yyyy} to {_coverDateTo:dd MMM yyyy} is ready for review.",
                Priority = NotificationPriority.Normal,
                ActionUrl = "/reports/board-pack",
                RecipientUserIds = _selectedMemberIds.ToList(),
                Data = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
                {
                    ["ReportTitle"] = _coverTitle,
                    ["PreparedBy"] = _coverPreparedBy,
                    ["ApprovedBy"] = _coverApprovedBy,
                    ["Confidentiality"] = _coverConfidentiality,
                    ["InstitutionId"] = _institutionId.ToString(),
                    ["GeneratedAtUtc"] = DateTime.UtcNow.ToString("O")
                }
            });

            Toast.Success($"Board pack sent to {_selectedMemberIds.Count} member{(_selectedMemberIds.Count != 1 ? "s" : "")}.");
            _showEmailPanel = false;
            _selectedMemberIds.Clear();
        }
        catch (Exception ex)
        {
            Toast.Error("Failed to send board pack: " + ex.Message);
        }
        finally
        {
            _isSending = false;
        }
    }

    // ── Saved configurations ──
    private async Task SaveCurrentConfig()
    {
        if (string.IsNullOrWhiteSpace(_newConfigName))
        {
            Toast.Error("Please enter a configuration name.");
            return;
        }

        var config = new BoardPackConfig
        {
            Title = _coverTitle,
            DateFrom = _coverDateFrom,
            DateTo = _coverDateTo,
            PreparedBy = _coverPreparedBy,
            ApprovedBy = _coverApprovedBy,
            Confidentiality = _coverConfidentiality,
            SectionOrder = _sections.Select(s => s.Id).ToList(),
            IncludedSections = _sections.Where(s => s.Included).Select(s => s.Id).ToList(),
            SelectedCharts = _selectedChartIds.ToList()
        };

        var json = JsonSerializer.Serialize(config);
        await JS.InvokeVoidAsync("fcBoardPack.saveConfig", _newConfigName, json);

        if (!_savedConfigs.Contains(_newConfigName))
            _savedConfigs.Add(_newConfigName);

        _activeConfigName = _newConfigName;
        _showSaveInput = false;
        _newConfigName = "";
        Toast.Success("Configuration saved.");
    }

    private async Task LoadConfig(string name)
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("fcBoardPack.loadConfig", name);
            if (string.IsNullOrEmpty(json)) return;

            var config = JsonSerializer.Deserialize<BoardPackConfig>(json);
            if (config == null) return;

            _coverTitle = config.Title;
            _coverPreparedBy = config.PreparedBy;
            _coverApprovedBy = config.ApprovedBy;
            _coverConfidentiality = config.Confidentiality;

            // Update date range to current quarter if loading a saved config
            if (config.DateFrom != default) _coverDateFrom = config.DateFrom;
            if (config.DateTo != default) _coverDateTo = config.DateTo;

            // Restore section order and inclusion
            if (config.SectionOrder?.Count > 0)
            {
                var lookup = _sections.ToDictionary(s => s.Id);
                var reordered = new List<BoardPackSectionItem>();
                foreach (var id in config.SectionOrder)
                {
                    if (lookup.TryGetValue(id, out var s))
                    {
                        s.Included = config.IncludedSections?.Contains(id) ?? false;
                        reordered.Add(s);
                    }
                }
                foreach (var s in _sections)
                {
                    if (!reordered.Contains(s))
                    {
                        s.Included = false;
                        reordered.Add(s);
                    }
                }
                _sections = reordered;
            }

            if (config.SelectedCharts != null)
                _selectedChartIds = new HashSet<string>(config.SelectedCharts);

            _activeConfigName = name;
            Toast.Success($"Loaded configuration \"{name}\".");

            // Re-init sortable after DOM update
            StateHasChanged();
            await Task.Delay(50);
            await JS.InvokeVoidAsync("fcBoardPack.initSortable", _dotNetRef);
        }
        catch
        {
            Toast.Error("Failed to load configuration.");
        }
    }

    private async Task DeleteConfig(string name)
    {
        await JS.InvokeVoidAsync("fcBoardPack.deleteConfig", name);
        _savedConfigs.Remove(name);
        if (_activeConfigName == name) _activeConfigName = null;
        Toast.Success("Configuration deleted.");
    }

