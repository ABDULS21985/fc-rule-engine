@page "/reports/board-pack"
@attribute [Authorize(Policy = "InstitutionAdmin")]
@using System.Security.Claims
@using System.Text.Json
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Enums
@using FC.Engine.Domain.Notifications
@inject FC.Engine.Portal.Services.ReportBuilderService ReportSvc
@inject FC.Engine.Portal.Services.InstitutionManagementService InstitutionSvc
@inject FC.Engine.Portal.Services.ToastService Toast
@inject INotificationOrchestrator NotificationOrchestrator
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Board Pack Generator — RegOS™ Portal</PageTitle>

<PortalPageHeader Title="Board Pack Generator" Subtitle="Build branded PDF board packs with drag-to-reorder sections and live preview"
                  Breadcrumb="@(new[] { new BreadcrumbItem("Reports", "/reports"), new BreadcrumbItem("Board Pack", IsCurrent: true) })">
    <PrimaryAction>
        @if (!_isGenerating && _sections.Any(s => s.Included))
        {
            <button class="portal-btn portal-btn-primary" @onclick="GenerateBoardPack">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                Generate PDF
            </button>
        }
    </PrimaryAction>
</PortalPageHeader>

<div class="portal-page">

    @* ── Saved Configurations Bar ── *@
    <div class="bp-saved-bar">
        <div class="bp-saved-left">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            <span class="bp-saved-label">Saved Configurations</span>
            @if (_savedConfigs.Count == 0)
            {
                <span class="bp-saved-empty">None saved yet</span>
            }
            else
            {
                @foreach (var cfg in _savedConfigs)
                {
                    <button class="bp-saved-chip @(cfg == _activeConfigName ? "bp-saved-chip--active" : "")"
                            @onclick="() => LoadConfig(cfg)">
                        @cfg
                        <span class="bp-saved-chip-x" @onclick:stopPropagation @onclick="() => DeleteConfig(cfg)" title="Delete">&times;</span>
                    </button>
                }
            }
        </div>
        <div class="bp-saved-right">
            @if (!_showSaveInput)
            {
                <button class="portal-btn portal-btn-ghost" style="font-size:0.8125rem;" @onclick="() => _showSaveInput = true">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Save Current
                </button>
            }
            else
            {
                <div class="bp-save-input-row">
                    <input type="text" class="portal-form-input" placeholder="e.g. Q4 2025 Board Pack"
                           @bind="_newConfigName" style="max-width:220px; font-size:0.8125rem; padding:0.3rem 0.5rem;" />
                    <button class="portal-btn portal-btn-primary" style="font-size:0.8125rem; padding:0.3rem 0.75rem;" @onclick="SaveCurrentConfig">Save</button>
                    <button class="portal-btn portal-btn-ghost" style="font-size:0.8125rem; padding:0.3rem 0.5rem;" @onclick="() => _showSaveInput = false">Cancel</button>
                </div>
            }
        </div>
    </div>

    @* ── Main Layout: Builder + Live Preview ── *@
    <div class="bp-layout">

        @* ── LEFT: Builder Panel ── *@
        <div class="bp-builder">

            @* ── Cover Page Customization ── *@
            <div class="portal-card bp-card">
                <div class="bp-card-header">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                    <h3>Cover Page</h3>
                </div>

                <div class="bp-cover-grid">
                    <div class="portal-form-group">
                        <label class="portal-form-label">Report Title</label>
                        <input type="text" class="portal-form-input" @bind="_coverTitle" @bind:after="OnCoverChanged"
                               placeholder="e.g. Quarterly Regulatory Board Pack" />
                    </div>
                    <div class="portal-form-group">
                        <label class="portal-form-label">Date Range</label>
                        <div class="bp-date-range">
                            <input type="date" class="portal-form-input" @bind="_coverDateFrom" @bind:after="OnCoverChanged" />
                            <span class="bp-date-sep">to</span>
                            <input type="date" class="portal-form-input" @bind="_coverDateTo" @bind:after="OnCoverChanged" />
                        </div>
                    </div>
                    <div class="portal-form-group">
                        <label class="portal-form-label">Prepared By</label>
                        <input type="text" class="portal-form-input" @bind="_coverPreparedBy" @bind:after="OnCoverChanged"
                               placeholder="Name or department" />
                    </div>
                    <div class="portal-form-group">
                        <label class="portal-form-label">Approved By</label>
                        <input type="text" class="portal-form-input" @bind="_coverApprovedBy" @bind:after="OnCoverChanged"
                               placeholder="Name or title" />
                    </div>
                    <div class="portal-form-group">
                        <label class="portal-form-label">Confidentiality Level</label>
                        <select class="portal-form-input" @bind="_coverConfidentiality" @bind:after="OnCoverChanged">
                            <option value="Public">Public</option>
                            <option value="Internal">Internal</option>
                            <option value="Confidential">Confidential</option>
                            <option value="Strictly Confidential">Strictly Confidential</option>
                        </select>
                    </div>
                </div>
            </div>

            @* ── Sections: Drag to Reorder ── *@
            <div class="portal-card bp-card">
                <div class="bp-card-header">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                    <h3>Sections</h3>
                    <span class="bp-section-count">@_sections.Count(s => s.Included) of @_sections.Count included</span>
                </div>
                <p class="bp-section-hint">Drag to reorder. Check/uncheck to include or exclude sections.</p>

                <div id="bp-section-list" class="bp-section-list">
                    @foreach (var sec in _sections)
                    {
                        <div class="bp-section-item @(sec.Included ? "" : "bp-section-item--excluded")"
                             data-section-id="@sec.Id">
                            <div class="bp-section-handle" title="Drag to reorder">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="5" r="1"/><circle cx="9" cy="12" r="1"/><circle cx="9" cy="19" r="1"/><circle cx="15" cy="5" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="15" cy="19" r="1"/></svg>
                            </div>
                            <label class="bp-section-check">
                                <input type="checkbox" checked="@sec.Included"
                                       @onchange="() => ToggleSection(sec.Id)" />
                            </label>
                            <div class="bp-section-icon" style="background: @sec.Color;">
                                @((MarkupString)sec.IconSvg)
                            </div>
                            <div class="bp-section-info">
                                <span class="bp-section-name">@sec.Name</span>
                                <span class="bp-section-desc">@sec.Description</span>
                            </div>
                            @if (sec.Id == "charts" && sec.Included)
                            {
                                <button class="bp-section-expand-btn" @onclick="() => _chartsExpanded = !_chartsExpanded"
                                        title="@(_chartsExpanded ? "Collapse" : "Select charts")">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="transform:rotate(@(_chartsExpanded ? "180" : "0")deg);transition:transform 0.2s"><polyline points="6 9 12 15 18 9"/></svg>
                                </button>
                            }
                        </div>

                        @if (sec.Id == "charts" && sec.Included && _chartsExpanded)
                        {
                            <div class="bp-chart-picker">
                                @foreach (var chart in _availableCharts)
                                {
                                    var isSelected = _selectedChartIds.Contains(chart.Id);
                                    <label class="bp-chart-thumb @(isSelected ? "bp-chart-thumb--selected" : "")">
                                        <input type="checkbox" checked="@isSelected"
                                               @onchange="() => ToggleChart(chart.Id)" />
                                        <div class="bp-chart-thumb-preview" style="background: @chart.Color;">
                                            @((MarkupString)chart.IconSvg)
                                        </div>
                                        <span class="bp-chart-thumb-label">@chart.Name</span>
                                    </label>
                                }
                            </div>
                        }
                    }
                </div>
            </div>

            @* ── Generate Button + Progress ── *@
            @if (_isGenerating)
            {
                <div class="portal-card bp-card bp-progress-card">
                    <div class="bp-progress-bar-track">
                        <div class="bp-progress-bar-fill" id="bp-progress-fill"></div>
                    </div>
                    <div class="bp-progress-stages">
                        @foreach (var stage in _progressStages)
                        {
                            <div class="bp-progress-stage">
                                @if (stage.Done)
                                {
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--cbn-primary)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                                }
                                else if (stage.Active)
                                {
                                    <span class="bp-progress-spinner"></span>
                                }
                                else
                                {
                                    <span class="bp-progress-dot"></span>
                                }
                                <span class="bp-progress-stage-label @(stage.Active ? "bp-progress-stage-label--active" : "") @(stage.Done ? "bp-progress-stage-label--done" : "")">
                                    @stage.Label
                                </span>
                            </div>
                        }
                    </div>
                </div>
            }
            else if (_generationComplete)
            {
                <div class="portal-card bp-card bp-complete-card">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--cbn-primary)" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    <div class="bp-complete-text">
                        <strong>Board pack generated successfully</strong>
                        <span>Download started automatically.</span>
                    </div>
                    <button class="portal-btn portal-btn-ghost" @onclick="ShowEmailPanel">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        Send to Board Members
                    </button>
                </div>
            }

            @* ── Email Distribution Panel ── *@
            @if (_showEmailPanel)
            {
                <div class="portal-card bp-card bp-email-card">
                    <div class="bp-card-header">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        <h3>Send to Board Members</h3>
                        <button class="bp-email-close" @onclick="() => _showEmailPanel = false">&times;</button>
                    </div>

                    <p style="color: var(--cbn-gray-500); font-size: 0.8125rem; margin-bottom: 0.75rem;">
                        Select team members to receive the board pack PDF with a formal cover note.
                    </p>

                    @if (_teamMembers.Count > 0)
                    {
                        <div class="bp-people-picker">
                            <div class="bp-people-search">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--cbn-gray-400)" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                                <input type="text" class="bp-people-search-input" placeholder="Search members..."
                                       @bind="_memberSearch" @bind:event="oninput" />
                            </div>
                            <div class="bp-people-list">
                                @foreach (var member in FilteredMembers)
                                {
                                    var isSelected = _selectedMemberIds.Contains(member.Id);
                                    <label class="bp-person @(isSelected ? "bp-person--selected" : "")">
                                        <input type="checkbox" checked="@isSelected"
                                               @onchange="() => ToggleMember(member.Id)" />
                                        <div class="bp-person-avatar">@member.Initials</div>
                                        <div class="bp-person-info">
                                            <span class="bp-person-name">@member.DisplayName</span>
                                            <span class="bp-person-email">@member.Email</span>
                                        </div>
                                        <span class="bp-person-role">@member.Role</span>
                                    </label>
                                }
                            </div>
                        </div>

                        @if (_selectedMemberIds.Count > 0)
                        {
                            <div class="bp-email-actions">
                                <span class="bp-email-count">@_selectedMemberIds.Count member@(_selectedMemberIds.Count != 1 ? "s" : "") selected</span>
                                <button class="portal-btn portal-btn-primary" @onclick="SendToMembers" disabled="@_isSending">
                                    @if (_isSending)
                                    {
                                        <span class="portal-btn-spinner" aria-hidden="true"></span>
                                    }
                                    Send Board Pack
                                </button>
                            </div>
                        }
                    }
                    else
                    {
                        <p style="color: var(--cbn-gray-400); font-size:0.85rem;">No team members found.</p>
                    }
                </div>
            }
        </div>

        @* ── RIGHT: Live Preview Panel ── *@
        <div class="bp-preview-panel">
            <div class="bp-preview-header">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                <span>Live Preview</span>
                <span class="bp-preview-badge">@(_sections.Count(s => s.Included)) sections</span>
            </div>
            <div class="bp-preview-viewport">
                <div class="bp-preview-scaler">
                    <div class="bp-preview-page">

                        @* ── Cover Page Preview ── *@
                        <div class="bp-pv-cover">
                            <div class="bp-pv-cover-confidential @GetConfidentialityClass()">
                                @_coverConfidentiality
                            </div>
                            <div class="bp-pv-cover-logo">
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--cbn-primary)" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                            </div>
                            <h2 class="bp-pv-cover-title">@(string.IsNullOrWhiteSpace(_coverTitle) ? "Board Pack" : _coverTitle)</h2>
                            @if (_coverDateFrom != default && _coverDateTo != default)
                            {
                                <p class="bp-pv-cover-date">@_coverDateFrom.ToString("d MMM yyyy") — @_coverDateTo.ToString("d MMM yyyy")</p>
                            }
                            <div class="bp-pv-cover-meta">
                                @if (!string.IsNullOrWhiteSpace(_coverPreparedBy))
                                {
                                    <div class="bp-pv-cover-meta-row">
                                        <span class="bp-pv-cover-meta-label">Prepared by</span>
                                        <span>@_coverPreparedBy</span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(_coverApprovedBy))
                                {
                                    <div class="bp-pv-cover-meta-row">
                                        <span class="bp-pv-cover-meta-label">Approved by</span>
                                        <span>@_coverApprovedBy</span>
                                    </div>
                                }
                            </div>
                            <div class="bp-pv-cover-footer">
                                Generated @DateTime.Now.ToString("d MMM yyyy")
                            </div>
                        </div>

                        @* ── Table of Contents ── *@
                        @if (_sections.Any(s => s.Included))
                        {
                            <div class="bp-pv-toc">
                                <h4 class="bp-pv-toc-title">Table of Contents</h4>
                                @{
                                    var pageNum = 2;
                                }
                                @foreach (var sec in _sections.Where(s => s.Included))
                                {
                                    <div class="bp-pv-toc-row">
                                        <span class="bp-pv-toc-name">@sec.Name</span>
                                        <span class="bp-pv-toc-dots"></span>
                                        <span class="bp-pv-toc-page">@pageNum</span>
                                    </div>
                                    pageNum++;
                                }
                            </div>
                        }

                        @* ── Section Previews ── *@
                        @foreach (var sec in _sections.Where(s => s.Included))
                        {
                            <div class="bp-pv-section">
                                <div class="bp-pv-section-header" style="border-left-color: @sec.Color;">
                                    @((MarkupString)sec.IconSvg)
                                    <span>@sec.Name</span>
                                </div>
                                <div class="bp-pv-section-body">
                                    @if (sec.Id == "executive-summary")
                                    {
                                        <div class="bp-pv-placeholder-lines">
                                            <div class="bp-pv-line" style="width:100%"></div>
                                            <div class="bp-pv-line" style="width:92%"></div>
                                            <div class="bp-pv-line" style="width:85%"></div>
                                            <div class="bp-pv-line" style="width:60%"></div>
                                        </div>
                                    }
                                    else if (sec.Id == "compliance-dashboard")
                                    {
                                        <div class="bp-pv-stats-row">
                                            <div class="bp-pv-stat"><div class="bp-pv-stat-val">98%</div><div class="bp-pv-stat-label">Compliance</div></div>
                                            <div class="bp-pv-stat"><div class="bp-pv-stat-val">24</div><div class="bp-pv-stat-label">Submitted</div></div>
                                            <div class="bp-pv-stat"><div class="bp-pv-stat-val">2</div><div class="bp-pv-stat-label">Pending</div></div>
                                        </div>
                                    }
                                    else if (sec.Id == "submission-history")
                                    {
                                        <div class="bp-pv-mini-table">
                                            <div class="bp-pv-mini-th"><span>Return</span><span>Period</span><span>Status</span></div>
                                            <div class="bp-pv-mini-tr"><span>CBN100</span><span>Jan 2026</span><span class="bp-pv-badge bp-pv-badge--green">Accepted</span></div>
                                            <div class="bp-pv-mini-tr"><span>CBN200</span><span>Jan 2026</span><span class="bp-pv-badge bp-pv-badge--green">Accepted</span></div>
                                            <div class="bp-pv-mini-tr"><span>CBN300</span><span>Jan 2026</span><span class="bp-pv-badge bp-pv-badge--amber">Warnings</span></div>
                                        </div>
                                    }
                                    else if (sec.Id == "validation-report")
                                    {
                                        <div class="bp-pv-stats-row">
                                            <div class="bp-pv-stat"><div class="bp-pv-stat-val" style="color:var(--cbn-danger)">3</div><div class="bp-pv-stat-label">Errors</div></div>
                                            <div class="bp-pv-stat"><div class="bp-pv-stat-val" style="color:var(--cbn-warning,#d97706)">7</div><div class="bp-pv-stat-label">Warnings</div></div>
                                        </div>
                                        <div class="bp-pv-placeholder-lines" style="margin-top:0.5rem;">
                                            <div class="bp-pv-line" style="width:100%"></div>
                                            <div class="bp-pv-line" style="width:78%"></div>
                                        </div>
                                    }
                                    else if (sec.Id == "charts")
                                    {
                                        @if (_selectedChartIds.Count > 0)
                                        {
                                            <div class="bp-pv-chart-grid">
                                                @foreach (var chartId in _selectedChartIds)
                                                {
                                                    var chart = _availableCharts.FirstOrDefault(c => c.Id == chartId);
                                                    if (chart != null)
                                                    {
                                                        <div class="bp-pv-chart-mini" style="border-color: @chart.Color;">
                                                            @((MarkupString)chart.PreviewSvg)
                                                            <span>@chart.Name</span>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span style="color:var(--cbn-gray-400); font-size:0.625rem;">No charts selected</span>
                                        }
                                    }
                                </div>
                            </div>
                        }

                        @if (!_sections.Any(s => s.Included))
                        {
                            <div class="bp-pv-empty">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--cbn-gray-300)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/></svg>
                                <span>Include sections to preview</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    // ── Auth state ──
    private Guid _tenantId;
    private int _institutionId;
    private int _userId;

    // ── Cover page fields ──
    private string _coverTitle = "";
    private DateTime _coverDateFrom = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
    private DateTime _coverDateTo = DateTime.Now;
    private string _coverPreparedBy = "";
    private string _coverApprovedBy = "";
    private string _coverConfidentiality = "Confidential";

    // ── Sections ──
    private List<BoardPackSectionItem> _sections = new();
    private bool _chartsExpanded;

    // ── Charts ──
    private List<ChartOption> _availableCharts = new();
    private HashSet<string> _selectedChartIds = new() { "compliance-trend", "submission-volume" };

    // ── Generation ──
    private bool _isGenerating;
    private bool _generationComplete;
    private List<ProgressStage> _progressStages = new();

    // ── Email distribution ──
    private bool _showEmailPanel;
    private bool _isSending;
    private string _memberSearch = "";
    private List<MemberItem> _teamMembers = new();
    private HashSet<int> _selectedMemberIds = new();

    // ── Saved configs ──
    private List<string> _savedConfigs = new();
    private string? _activeConfigName;
    private bool _showSaveInput;
    private string _newConfigName = "";

    // ── Reports (for actual generation) ──
    private List<FC.Engine.Domain.Entities.SavedReport> _reports = new();

    private DotNetObjectReference<BoardPack>? _dotNetRef;

    // ── Filtered members for people picker ──
    private IEnumerable<MemberItem> FilteredMembers =>
        string.IsNullOrWhiteSpace(_memberSearch)
            ? _teamMembers
            : _teamMembers.Where(m =>
                m.DisplayName.Contains(_memberSearch, StringComparison.OrdinalIgnoreCase) ||
                m.Email.Contains(_memberSearch, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState!;
        _tenantId = Guid.Parse(state.User.FindFirst("TenantId")!.Value);
        _institutionId = int.Parse(state.User.FindFirst("InstitutionId")!.Value);
        var userIdClaim = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value
                       ?? state.User.FindFirst("UserId")?.Value;
        _userId = int.TryParse(userIdClaim, out var uid) ? uid : 0;
        _coverPreparedBy = state.User.Identity?.Name ?? "";

        InitSections();
        InitCharts();

        try
        {
            _reports = (await ReportSvc.GetSavedReports(_tenantId, _institutionId)).ToList();
        }
        catch { /* saved reports unavailable */ }

        try
        {
            var members = await InstitutionSvc.GetTeamMembers(_institutionId);
            _teamMembers = members.Where(m => m.IsActive).Select(m => new MemberItem
            {
                Id = m.Id,
                DisplayName = m.DisplayName,
                Email = m.Email,
                Role = m.Role,
                Initials = m.Initials
            }).ToList();
        }
        catch { /* team members unavailable */ }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("fcBoardPack.initSortable", _dotNetRef);

            // Load saved config keys
            try
            {
                var keys = await JS.InvokeAsync<string[]>("fcBoardPack.listConfigKeys");
                _savedConfigs = keys?.ToList() ?? new();
                StateHasChanged();
            }
            catch { }
        }
    }

