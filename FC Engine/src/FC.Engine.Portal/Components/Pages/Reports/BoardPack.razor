    [JSInvokable("OnSectionsReordered")]
    public void OnSectionsReordered(string[] newOrder)
    {
        var lookup = _sections.ToDictionary(s => s.Id);
        var reordered = new List<BoardPackSectionItem>();
        foreach (var id in newOrder)
        {
            if (lookup.TryGetValue(id, out var s))
                reordered.Add(s);
        }
        // Add any missing ones at the end
        foreach (var s in _sections)
        {
            if (!reordered.Contains(s))
                reordered.Add(s);
        }
        _sections = reordered;
        InvokeAsync(StateHasChanged);
    }

