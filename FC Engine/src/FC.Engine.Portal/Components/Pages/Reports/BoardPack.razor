    // ── Generation ──
    private async Task GenerateBoardPack()
    {
        var includedSections = _sections.Where(s => s.Included).ToList();
        if (includedSections.Count == 0) return;

        if (string.IsNullOrWhiteSpace(_coverTitle))
        {
            Toast.Error("Please enter a report title on the cover page.");
            return;
        }

        _isGenerating = true;
        _generationComplete = false;
        _showEmailPanel = false;

        _progressStages = new List<ProgressStage>
        {
            new() { Label = "Generating cover page" },
            new() { Label = "Fetching data" },
            new() { Label = "Rendering charts" },
            new() { Label = "Compiling PDF" }
        };
        _progressStages[0].Active = true;
        StateHasChanged();

        try
        {
            // Stage 1: Cover
            await JS.InvokeVoidAsync("fcBoardPack.animateProgress", 0, _progressStages.Count);
            await Task.Delay(600);

            // Stage 2: Fetch data
            _progressStages[0].Done = true; _progressStages[0].Active = false;
            _progressStages[1].Active = true;
            StateHasChanged();
            await JS.InvokeVoidAsync("fcBoardPack.animateProgress", 1, _progressStages.Count);

            // Build report IDs from selected saved reports
            var reportIds = _reports.Select(r => r.Id).ToList();
            byte[] pdfBytes;

            if (reportIds.Count > 0)
            {
                pdfBytes = await ReportSvc.GenerateBoardPack(_tenantId, _institutionId, reportIds, _coverTitle);
            }
            else
            {
                // Simulate generation when no saved reports are available
                await Task.Delay(800);
                pdfBytes = Array.Empty<byte>();
            }

            // Stage 3: Charts
            _progressStages[1].Done = true; _progressStages[1].Active = false;
            _progressStages[2].Active = true;
            StateHasChanged();
            await JS.InvokeVoidAsync("fcBoardPack.animateProgress", 2, _progressStages.Count);
            await Task.Delay(500);

            // Stage 4: Compile
            _progressStages[2].Done = true; _progressStages[2].Active = false;
            _progressStages[3].Active = true;
            StateHasChanged();
            await JS.InvokeVoidAsync("fcBoardPack.animateProgress", 3, _progressStages.Count);
            await Task.Delay(400);

            _progressStages[3].Done = true; _progressStages[3].Active = false;
            StateHasChanged();

            // Download
            if (pdfBytes.Length > 0)
            {
                var base64 = Convert.ToBase64String(pdfBytes);
                var fileName = $"BoardPack-{DateTime.UtcNow:yyyyMMdd-HHmm}.pdf";
                await JS.InvokeVoidAsync("portalDownloadFile", fileName, "application/pdf", base64);
            }

            await Task.Delay(300);
            _isGenerating = false;
            _generationComplete = true;
            Toast.Success("Board pack generated successfully.");
        }
        catch (Exception ex)
        {
            _isGenerating = false;
            Toast.Error("Failed to generate board pack: " + ex.Message);
            await JS.InvokeVoidAsync("fcBoardPack.resetProgress");
        }
    }

