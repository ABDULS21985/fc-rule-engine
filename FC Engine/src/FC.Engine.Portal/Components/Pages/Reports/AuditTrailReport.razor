@page "/reports/audit"
@attribute [Authorize(Policy = "InstitutionAdmin")]
@using System.Security.Claims
@inject ExportService ExportSvc
@inject IJSRuntime JS

<PageTitle>Audit Trail — FC Engine Portal</PageTitle>

<PortalPageHeader Breadcrumb="_breadcrumb"
                  Title="Audit Trail"
                  Subtitle="Complete record of all submission and approval actions.">
    <SecondaryActions>
        @if (trail is not null && !isLoading)
        {
            <button class="portal-btn portal-btn-ghost portal-btn-sm no-print" @onclick="ExportCsv">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                    <polyline points="7 10 12 15 17 10"/>
                    <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Export CSV
            </button>
            <button class="portal-btn portal-btn-ghost portal-btn-sm no-print" @onclick="PrintReport">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <polyline points="6 9 6 2 18 2 18 9"/>
                    <path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/>
                    <rect x="6" y="14" width="12" height="8"/>
                </svg>
                Print / PDF
            </button>
        }
    </SecondaryActions>
    <PrimaryAction>
        <button class="portal-btn portal-btn-primary portal-btn-sm no-print" @onclick="GenerateReport" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="portal-btn-spinner" aria-hidden="true"></span>
            }
            Generate
        </button>
    </PrimaryAction>
</PortalPageHeader>

<div class="portal-page">

    @* ── A. Error banner ── *@
    @if (_error is not null)
    {
        <div class="portal-alert portal-alert-error no-print" role="alert">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="flex-shrink:0;">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span>@_error</span>
            <button class="portal-btn portal-btn-ghost portal-btn-xs" @onclick="GenerateReport" style="margin-left: auto;">
                Retry
            </button>
        </div>
    }

    @* ── B. Date preset bar ── *@
    <div class="portal-date-preset-bar no-print" role="group" aria-label="Date range presets">
        @foreach (var preset in _presets)
        {
            var key = preset.Key;
            <button class="portal-date-preset-pill @(_activePreset == key ? "portal-date-preset-pill--active" : "")"
                    @onclick="() => ApplyPreset(key)"
                    aria-pressed="@(_activePreset == key ? "true" : "false")">
                @preset.Label
            </button>
        }
    </div>

    @* ── C. Custom date range inputs ── *@
    @if (_activePreset == "custom")
    {
        <div class="portal-card no-print" style="padding: var(--space-4); display: flex; align-items: flex-end; gap: var(--space-4); flex-wrap: wrap; margin-bottom: var(--space-4);">
            <div>
                <label class="portal-form-label" for="audit-date-from">From</label>
                <input id="audit-date-from" type="date" class="portal-form-input" @bind="filterStart" style="width: 160px;" />
            </div>
            <div>
                <label class="portal-form-label" for="audit-date-to">To</label>
                <input id="audit-date-to" type="date" class="portal-form-input" @bind="filterEnd" style="width: 160px;" />
            </div>
            <button class="portal-btn portal-btn-primary portal-btn-sm" @onclick="GenerateReport" disabled="@isLoading">
                Apply
            </button>
        </div>
    }

    @* ── D. Loading skeletons ── *@
    @if (isLoading)
    {
        <SkeletonGuard OnRetry="GenerateReport">
            <div class="fc-skel-stats-row" style="margin-bottom: var(--space-5);" aria-hidden="true">
                <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Stat" Index="0" />
                <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Stat" Index="1" />
                <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Stat" Index="2" />
                <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Stat" Index="3" />
            </div>
            <div class="portal-card portal-card-flush" aria-hidden="true" style="padding: var(--space-4);">
                <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.TableRows" Index="4" RowCount="8" />
            </div>
        </SkeletonGuard>
    }
    else if (trail is not null)
    {
        @* ── E. Report content ── *@
        <div id="printable-audit-trail">

            @* 1. Print letterhead *@
            <div class="portal-print-letterhead print-only">
                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                    <div>
                        <strong style="font-size: 1.125rem;">Audit Trail Report</strong>
                        <br />@trail.InstitutionName (@trail.InstitutionCode)
                        <br />Period: @trail.StartDate.ToString("dd MMM yyyy") to @trail.EndDate.ToString("dd MMM yyyy")
                        <br />Generated: @trail.GeneratedAt.ToString("dd MMM yyyy HH:mm") UTC
                    </div>
                    <div style="text-align: right; font-size: 0.75rem; color: #6b7280;">
                        FC Engine Portal
                        <br />Central Bank of Nigeria
                    </div>
                </div>
            </div>

            @* 2. Print watermark *@
            <div class="portal-print-watermark print-only" aria-hidden="true">CONFIDENTIAL</div>

            @* 3. KPI strip *@
            <div class="portal-audit-kpi-strip" aria-label="Summary statistics">
                <div class="portal-audit-kpi">
                    <span class="portal-audit-kpi__value">@trail.TotalEntries</span>
                    <span class="portal-audit-kpi__label">Total Actions</span>
                </div>
                <div class="portal-audit-kpi">
                    <span class="portal-audit-kpi__value" style="color: var(--portal-color-info, #0ea5e9);">@_kpiSubmitted</span>
                    <span class="portal-audit-kpi__label">Submitted</span>
                </div>
                <div class="portal-audit-kpi">
                    <span class="portal-audit-kpi__value" style="color: var(--portal-color-success, #16a34a);">@_kpiApproved</span>
                    <span class="portal-audit-kpi__label">Approved</span>
                </div>
                <div class="portal-audit-kpi">
                    <span class="portal-audit-kpi__value" style="color: var(--portal-color-danger, #dc2626);">@_kpiRejected</span>
                    <span class="portal-audit-kpi__label">Rejected</span>
                </div>
            </div>

            @* 4. Toolbar row *@
            @if (trail.Entries.Any())
            {
                <div class="no-print" style="display: flex; align-items: center; flex-wrap: wrap; gap: var(--space-3); margin-bottom: var(--space-4);">

                    @* Action filter pills *@
                    <div class="portal-action-filter-bar" role="group" aria-label="Filter by action type">
                        <button class="portal-action-filter-pill @(_actionFilter.Count == 0 ? "portal-action-filter-pill--active" : "")"
                                @onclick='() => ToggleActionFilter("All")'
                                aria-pressed="@(_actionFilter.Count == 0 ? "true" : "false")">
                            All
                        </button>
                        @foreach (var action in new[] { "Submitted", "Approved", "Rejected", "Resubmitted" })
                        {
                            var a = action;
                            <button class="portal-action-filter-pill @(_actionFilter.Contains(a) ? "portal-action-filter-pill--active" : "")"
                                    @onclick="() => ToggleActionFilter(a)"
                                    aria-pressed="@(_actionFilter.Contains(a) ? "true" : "false")">
                                @a
                            </button>
                        }
                        @if (ActiveFilterCount > 0)
                        {
                            <span class="portal-badge portal-badge-sm portal-badge-info" aria-label="@ActiveFilterCount active filter(s)">
                                @ActiveFilterCount
                            </span>
                        }
                    </div>

                    @* User search *@
                    <input type="search"
                           class="portal-form-input"
                           placeholder="Filter by user..."
                           style="width: 200px;"
                           @bind="_userFilter"
                           @bind:event="oninput"
                           aria-label="Filter entries by user name" />

                    @* View toggle *@
                    <div class="portal-view-toggle no-print" role="group" aria-label="Switch view" style="margin-left: auto;">
                        <button class="portal-view-toggle-btn @(_viewMode == "timeline" ? "portal-view-toggle-btn--active" : "")"
                                @onclick='() => _viewMode = "timeline"'
                                aria-pressed="@(_viewMode == "timeline" ? "true" : "false")">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <line x1="5" y1="12" x2="19" y2="12"/>
                                <circle cx="5" cy="12" r="2" fill="currentColor" stroke="none"/>
                                <circle cx="19" cy="12" r="2" fill="currentColor" stroke="none"/>
                            </svg>
                            Timeline
                        </button>
                        <button class="portal-view-toggle-btn @(_viewMode == "table" ? "portal-view-toggle-btn--active" : "")"
                                @onclick='() => _viewMode = "table"'
                                aria-pressed="@(_viewMode == "table" ? "true" : "false")">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <rect x="3" y="3" width="18" height="18" rx="2"/>
                                <line x1="3" y1="9" x2="21" y2="9"/>
                                <line x1="3" y1="15" x2="21" y2="15"/>
                                <line x1="9" y1="3" x2="9" y2="21"/>
                            </svg>
                            Table
                        </button>
                    </div>
                </div>
            }

            @* 5. Timeline view *@
            @if (_viewMode == "timeline")
            {
                @if (!FilteredEntries.Any())
                {
                    <div class="portal-card portal-empty-state" style="padding: 3rem;">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true" style="margin-bottom: 1rem; opacity: 0.35;">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        <h3 class="portal-empty-state-title">No Activity Found</h3>
                        <p class="portal-empty-state-desc">No audit trail entries match the current filters.</p>
                    </div>
                }
                else
                {
                    <div class="portal-audit-timeline" aria-label="Audit trail timeline">
                        @foreach (var group in TimelineGroups)
                        {
                            var groupDate = group.Key;
                            var isExpanded = _expandedGroups.Contains(groupDate);
                            var groupList = group.ToList();
                            var suspicious = HasSuspiciousActivity(groupList);
                            <div class="portal-audit-tl-group">
                                <button class="portal-audit-tl-group-header"
                                        @onclick="() => ToggleGroup(groupDate)"
                                        aria-expanded="@(isExpanded ? "true" : "false")"
                                        aria-controls="tl-group-@groupDate.ToString("yyyyMMdd")">
                                    <span class="portal-audit-tl-group-date">@groupDate.ToString("dd MMM yyyy")</span>
                                    <span class="portal-audit-tl-group-count" aria-label="@groupList.Count action(s) on this date">
                                        · @groupList.Count action@(groupList.Count == 1 ? "" : "s")
                                    </span>
                                    @if (suspicious)
                                    {
                                        <span class="portal-badge portal-badge-sm portal-badge-warning" style="margin-left: var(--space-2);" title="5 or more submissions from the same user within 1 hour">
                                            High Activity
                                        </span>
                                    }
                                    <svg class="portal-audit-tl-chevron @(isExpanded ? "portal-audit-tl-chevron--open" : "")"
                                         width="14" height="14" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2.5"
                                         style="margin-left: auto; transition: transform 0.2s; @(isExpanded ? "transform: rotate(180deg);" : "")"
                                         aria-hidden="true">
                                        <polyline points="6 9 12 15 18 9"/>
                                    </svg>
                                </button>

                                @if (isExpanded)
                                {
                                    <div class="portal-audit-tl-entries" id="tl-group-@groupDate.ToString("yyyyMMdd")" role="list">
                                        @foreach (var entry in groupList.OrderByDescending(e => e.Timestamp))
                                        {
                                            <div class="portal-audit-tl-row" role="listitem">
                                                <span class="portal-audit-tl-dot @GetDotClass(entry.Action)" aria-hidden="true"></span>
                                                <div class="portal-audit-tl-content">
                                                    <span class="portal-badge portal-badge-sm @GetActionBadge(entry.Action)">@entry.Action</span>
                                                    <span style="font-size: 0.8125rem; font-weight: 500; margin-left: var(--space-2);">@entry.UserName</span>
                                                    <span class="portal-td-mono" style="font-size: 0.75rem; margin-left: var(--space-2); background: var(--portal-surface-alt, #f3f4f6); border-radius: 4px; padding: 1px 6px;">@entry.ReturnCode</span>
                                                    <span style="font-size: 0.75rem; color: #6b7280; margin-left: var(--space-2);">@entry.Period</span>
                                                    <a href="/submissions/@entry.SubmissionId" class="portal-link" style="font-size: 0.75rem; margin-left: var(--space-2);">#@entry.SubmissionId</a>
                                                    @if (!string.IsNullOrEmpty(entry.Details))
                                                    {
                                                        <div style="font-size: 0.6875rem; color: #9ca3af; margin-top: 2px;">@entry.Details</div>
                                                    }
                                                </div>
                                                <span class="portal-audit-tl-time" aria-label="Time: @entry.Timestamp.ToString("HH:mm")">
                                                    @entry.Timestamp.ToString("HH:mm")
                                                </span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            }

            @* 6. Table view *@
            @if (_viewMode == "table")
            {
                @if (!FilteredEntries.Any())
                {
                    <div class="portal-card portal-empty-state" style="padding: 3rem;">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true" style="margin-bottom: 1rem; opacity: 0.35;">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        <h3 class="portal-empty-state-title">No Activity Found</h3>
                        <p class="portal-empty-state-desc">No audit trail entries match the current filters.</p>
                    </div>
                }
                else
                {
                    <div class="portal-card portal-card-flush">
                        <div class="portal-report-table-scroll">
                            <table class="portal-report-table" aria-label="Audit trail entries">
                                <thead>
                                    <tr>
                                        <th class="portal-th-sortable" @onclick='() => Sort("timestamp")' aria-sort="@(_sortCol == "timestamp" ? (_sortDesc ? "descending" : "ascending") : "none")" style="cursor: pointer; white-space: nowrap; user-select: none;">
                                            Date / Time
                                            <span class="portal-sort-icon @(_sortCol == "timestamp" ? "portal-sort-icon--active" : "")" aria-hidden="true">@SortArrow("timestamp")</span>
                                        </th>
                                        <th class="portal-th-sortable" @onclick='() => Sort("user")' aria-sort="@(_sortCol == "user" ? (_sortDesc ? "descending" : "ascending") : "none")" style="cursor: pointer; user-select: none;">
                                            User
                                            <span class="portal-sort-icon @(_sortCol == "user" ? "portal-sort-icon--active" : "")" aria-hidden="true">@SortArrow("user")</span>
                                        </th>
                                        <th>Action</th>
                                        <th class="portal-th-sortable" @onclick='() => Sort("code")' aria-sort="@(_sortCol == "code" ? (_sortDesc ? "descending" : "ascending") : "none")" style="cursor: pointer; user-select: none;">
                                            Return Code
                                            <span class="portal-sort-icon @(_sortCol == "code" ? "portal-sort-icon--active" : "")" aria-hidden="true">@SortArrow("code")</span>
                                        </th>
                                        <th>Period</th>
                                        <th>Sub ID</th>
                                        <th>Status</th>
                                        <th>Details</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in PagedEntries)
                                    {
                                        <tr>
                                            <td style="font-size: 0.75rem; white-space: nowrap;">@entry.Timestamp.ToString("dd MMM yyyy HH:mm")</td>
                                            <td style="font-size: 0.8125rem;">@entry.UserName</td>
                                            <td><span class="portal-badge portal-badge-sm @GetActionBadge(entry.Action)">@entry.Action</span></td>
                                            <td class="portal-td-mono">@entry.ReturnCode</td>
                                            <td style="font-size: 0.8125rem;">@entry.Period</td>
                                            <td><a href="/submissions/@entry.SubmissionId" class="portal-link">#@entry.SubmissionId</a></td>
                                            <td><span class="portal-badge portal-badge-sm portal-badge-neutral">@entry.Status</span></td>
                                            <td style="font-size: 0.6875rem; color: #6b7280; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@entry.Details">@entry.Details</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @* Pagination *@
                        @if (TotalPages > 1)
                        {
                            <div class="portal-pagination no-print" aria-label="Table pagination">
                                <span class="portal-table-count" aria-live="polite">
                                    @((_page - 1) * PageSize + 1)–@(Math.Min(_page * PageSize, SortedFilteredEntries.Count)) of @SortedFilteredEntries.Count
                                </span>
                                <button class="portal-btn portal-btn-ghost portal-btn-xs"
                                        @onclick="PrevPage"
                                        disabled="@(_page <= 1)"
                                        aria-label="Previous page">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                                </button>
                                <span class="portal-pagination-label" aria-current="page">Page @_page of @TotalPages</span>
                                <button class="portal-btn portal-btn-ghost portal-btn-xs"
                                        @onclick="NextPage"
                                        disabled="@(_page >= TotalPages)"
                                        aria-label="Next page">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                                </button>
                            </div>
                        }
                    </div>
                }
            }

            @* 7. Print footer *@
            <div class="portal-report-print-footer print-only">
                Generated by FC Engine — Central Bank of Nigeria
            </div>

        </div>
    }
    else if (!isLoading && _error is null)
    {
        <div class="portal-info-note no-print" role="status">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="flex-shrink:0;">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="16" x2="12" y2="12"/>
                <line x1="12" y1="8" x2="12.01" y2="8"/>
            </svg>
            Select a date range above and click <strong>Generate</strong> to load the audit trail.
        </div>
    }

</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private static readonly IReadOnlyList<BreadcrumbItem> _breadcrumb = new List<BreadcrumbItem>
    {
        new() { Label = "Home",        Url = "/" },
        new() { Label = "Reports",     Url = "/reports/saved" },
        new() { Label = "Audit Trail", IsCurrent = true }
    };

    private record PresetOption(string Key, string Label);
    private static readonly PresetOption[] _presets =
    {
        new("this-month",   "This Month"),
        new("last-month",   "Last Month"),
        new("this-quarter", "This Quarter"),
        new("last-quarter", "Last Quarter"),
        new("ytd",          "YTD"),
        new("custom",       "Custom"),
    };

    private bool isLoading = true;
    private int institutionId;
    private int currentUserId;
    private DateTime filterStart = DateTime.UtcNow.AddMonths(-1).Date;
    private DateTime filterEnd   = DateTime.UtcNow.Date;
    private string _activePreset = "this-month";
    private AuditTrailModel? trail;
    private string? _error;

    // Filter state
    private HashSet<string> _actionFilter = new();
    private string _userFilter = "";
    private string _viewMode = "timeline";
    private HashSet<DateTime> _expandedGroups = new();

    // Table sort/page
    private string _sortCol = "timestamp";
    private bool   _sortDesc = true;
    private int    _page = 1;
    private const int PageSize = 25;

    // KPI derived
    private int _kpiSubmitted;
    private int _kpiApproved;
    private int _kpiRejected;

    private List<AuditTrailEntry> FilteredEntries
    {
        get
        {
            if (trail is null) return new();
            return trail.Entries
                .Where(e =>
                    (_actionFilter.Count == 0 || _actionFilter.Contains(e.Action)) &&
                    (string.IsNullOrEmpty(_userFilter) || e.UserName.Contains(_userFilter, StringComparison.OrdinalIgnoreCase)))
                .ToList();
        }
    }

    private IEnumerable<IGrouping<DateTime, AuditTrailEntry>> TimelineGroups =>
        FilteredEntries
            .GroupBy(e => e.Timestamp.Date)
            .OrderByDescending(g => g.Key);

    private List<AuditTrailEntry> SortedFilteredEntries
    {
        get
        {
            IEnumerable<AuditTrailEntry> items = FilteredEntries;
            items = (_sortCol, _sortDesc) switch
            {
                ("timestamp", true)  => items.OrderByDescending(e => e.Timestamp),
                ("timestamp", false) => items.OrderBy(e => e.Timestamp),
                ("user",      true)  => items.OrderByDescending(e => e.UserName),
                ("user",      false) => items.OrderBy(e => e.UserName),
                ("code",      true)  => items.OrderByDescending(e => e.ReturnCode),
                ("code",      false) => items.OrderBy(e => e.ReturnCode),
                _                   => items.OrderByDescending(e => e.Timestamp),
            };
            return items.ToList();
        }
    }

    private IEnumerable<AuditTrailEntry> PagedEntries =>
        SortedFilteredEntries.Skip((_page - 1) * PageSize).Take(PageSize);

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(SortedFilteredEntries.Count / (double)PageSize));

    private int ActiveFilterCount => _actionFilter.Count + (string.IsNullOrEmpty(_userFilter) ? 0 : 1);

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState!;
        int.TryParse(state.User.FindFirst("InstitutionId")?.Value, out institutionId);
        int.TryParse(state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out currentUserId);
        ApplyPreset("this-month", autoGenerate: false);
        await GenerateReport();
    }

    private void ApplyPreset(string key, bool autoGenerate = true)
    {
        _activePreset = key;
        var now = DateTime.UtcNow;
        switch (key)
        {
            case "this-month":
                filterStart = new DateTime(now.Year, now.Month, 1);
                filterEnd   = now.Date;
                break;
            case "last-month":
                var lm = now.AddMonths(-1);
                filterStart = new DateTime(lm.Year, lm.Month, 1);
                filterEnd   = new DateTime(lm.Year, lm.Month, DateTime.DaysInMonth(lm.Year, lm.Month));
                break;
            case "this-quarter":
                int q = (now.Month - 1) / 3;
                filterStart = new DateTime(now.Year, q * 3 + 1, 1);
                filterEnd   = now.Date;
                break;
            case "last-quarter":
                int lq = (now.Month - 1) / 3 - 1;
                int lqY = now.Year;
                if (lq < 0) { lq = 3; lqY--; }
                filterStart = new DateTime(lqY, lq * 3 + 1, 1);
                filterEnd   = new DateTime(lqY, lq * 3 + 3, DateTime.DaysInMonth(lqY, lq * 3 + 3));
                break;
            case "ytd":
                filterStart = new DateTime(now.Year, 1, 1);
                filterEnd   = now.Date;
                break;
        }
        if (autoGenerate) _ = GenerateReport();
    }

    private async Task GenerateReport()
    {
        isLoading = true;
        _error = null;
        try
        {
            trail = await ExportSvc.BuildAuditTrailAsync(institutionId, filterStart, filterEnd.AddDays(1));
            _kpiSubmitted = trail.Entries.Count(e => e.Action == "Submitted");
            _kpiApproved  = trail.Entries.Count(e => e.Action == "Approved");
            _kpiRejected  = trail.Entries.Count(e => e.Action == "Rejected");
            // Default: expand all groups
            _expandedGroups = trail.Entries.Select(e => e.Timestamp.Date).ToHashSet();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleActionFilter(string action)
    {
        if (action == "All")
        {
            _actionFilter.Clear();
        }
        else
        {
            if (!_actionFilter.Add(action))
                _actionFilter.Remove(action);
        }
        _page = 1;
    }

    private void ToggleGroup(DateTime date)
    {
        if (!_expandedGroups.Add(date))
            _expandedGroups.Remove(date);
    }

    private void Sort(string col)
    {
        if (_sortCol == col) _sortDesc = !_sortDesc;
        else { _sortCol = col; _sortDesc = false; }
        _page = 1;
    }

    private string SortArrow(string col) =>
        _sortCol == col ? (_sortDesc ? "↓" : "↑") : "↕";

    private void PrevPage() { if (_page > 1)          _page--; }
    private void NextPage() { if (_page < TotalPages)  _page++; }

    private static bool HasSuspiciousActivity(IEnumerable<AuditTrailEntry> entries)
    {
        var submissions = entries.Where(e => e.Action == "Submitted")
                                 .GroupBy(e => e.UserName);
        foreach (var group in submissions)
        {
            var times = group.Select(e => e.Timestamp).OrderBy(t => t).ToList();
            for (int i = 0; i + 4 < times.Count; i++)
                if ((times[i + 4] - times[i]).TotalHours <= 1) return true;
        }
        return false;
    }

    private static string GetDotClass(string action) => action.ToLowerInvariant() switch
    {
        "submitted"   => "portal-audit-tl-dot--submitted",
        "approved"    => "portal-audit-tl-dot--approved",
        "rejected"    => "portal-audit-tl-dot--rejected",
        "resubmitted" => "portal-audit-tl-dot--resubmitted",
        _             => ""
    };

    private async Task ExportCsv()
    {
        if (trail is null) return;
        var csv = ExportSvc.ExportAuditTrailCsv(trail);
        await JS.InvokeVoidAsync("portalDownloadFile", csv,
            $"audit-trail-{filterStart:yyyyMMdd}-{filterEnd:yyyyMMdd}.csv", "text/csv");
        if (currentUserId > 0)
            await ExportSvc.NotifyExportReady(institutionId, currentUserId, "Audit trail CSV", "/reports/audit");
    }

    private async Task PrintReport() =>
        await JS.InvokeVoidAsync("portalPrintElement", "printable-audit-trail");

    private static string GetActionBadge(string action) => action switch
    {
        "Submitted"   => "portal-badge-info",
        "Approved"    => "portal-badge-success",
        "Rejected"    => "portal-badge-danger",
        "Resubmitted" => "portal-badge-warning",
        _             => "portal-badge-neutral"
    };
}
