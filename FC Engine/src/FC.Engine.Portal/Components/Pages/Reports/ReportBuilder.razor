@page "/reports/builder"
@page "/reports/builder/{reportId:int}"
@attribute [Authorize(Policy = "InstitutionUser")]
@inject ReportBuilderService ReportSvc
@inject FC.Engine.Portal.Services.ToastService Toast
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Report Builder — FC Engine Portal</PageTitle>

<div class="portal-page">
    @if (_loading)
    {
        <div class="portal-card" style="padding: 2rem;">
            <div class="portal-skeleton portal-skeleton-block" style="height: 80px; margin-bottom: 1rem;"></div>
            <div class="portal-skeleton portal-skeleton-block" style="height: 400px;"></div>
        </div>
    }
    else if (!_hasAccess)
    {
        <div class="portal-card portal-empty-state" style="padding: 3rem; text-align: center;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" aria-hidden="true">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0110 0v4"/>
            </svg>
            <h3 class="portal-empty-state-title" style="margin-top: 1rem;">Report Builder — Enterprise Feature</h3>
            <p class="portal-empty-state-desc">
                The Report Builder is available on Enterprise plans and above.
                Contact your administrator to upgrade your subscription.
            </p>
        </div>
    }
    else
    {
        <!-- Header -->
        <div class="portal-page-header" style="margin-bottom: 1rem;">
            <div>
                <h2 class="portal-page-title">Report Builder</h2>
                <p class="portal-page-subtitle">Select fields, add filters, and run ad-hoc queries across your regulatory data.</p>
            </div>
            <div style="display: flex; gap: 0.5rem;">
                <button class="portal-btn portal-btn-primary portal-btn-sm" @onclick="RunReport" disabled="@(_running || _selectedFields.Count == 0)">
                    @if (_running)
                    {
                        <span class="portal-btn-spinner" aria-hidden="true"></span>
                    }
                    Run Report
                </button>
                <button class="portal-btn portal-btn-outline portal-btn-sm" @onclick="ShowSaveDialog" disabled="@(_selectedFields.Count == 0)">Save</button>
                @if (_result is not null)
                {
                    <button class="portal-btn portal-btn-ghost portal-btn-sm" @onclick="ExportCsv">CSV</button>
                }
            </div>
        </div>

        <div class="rb-layout">
            <!-- Left Panel: Field Selector -->
            <div class="rb-field-panel portal-card">
                <h3 class="rb-panel-title">Fields</h3>
                <input type="text" class="portal-form-input rb-field-search" placeholder="Search fields..."
                       @bind="_fieldSearch" @bind:event="oninput" />

                @foreach (var module in FilteredTree())
                {
                    <div class="rb-module-group">
                        <button class="rb-module-toggle" @onclick="() => ToggleModule(module.ModuleCode)">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                @if (_expandedModules.Contains(module.ModuleCode))
                                {
                                    <polyline points="6 9 12 15 18 9"/>
                                }
                                else
                                {
                                    <polyline points="9 18 15 12 9 6"/>
                                }
                            </svg>
                            <span class="rb-module-name">@module.ModuleName</span>
                        </button>

                        @if (_expandedModules.Contains(module.ModuleCode))
                        {
                            @foreach (var template in module.Templates)
                            {
                                <div class="rb-template-group">
                                    <button class="rb-template-toggle" @onclick="() => ToggleTemplate(template.TemplateCode)">
                                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                            @if (_expandedTemplates.Contains(template.TemplateCode))
                                            {
                                                <polyline points="6 9 12 15 18 9"/>
                                            }
                                            else
                                            {
                                                <polyline points="9 18 15 12 9 6"/>
                                            }
                                        </svg>
                                        <span class="rb-template-name">@template.TemplateName</span>
                                    </button>

                                    @if (_expandedTemplates.Contains(template.TemplateCode))
                                    {
                                        <ul class="rb-field-list">
                                            @foreach (var field in template.Fields)
                                            {
                                                var isSelected = _selectedFields.Any(f => f.FieldCode == field.FieldCode && f.TemplateCode == template.TemplateCode);
                                                <li class="rb-field-item @(isSelected ? "rb-field-selected" : "")"
                                                    @onclick="() => ToggleField(module.ModuleCode, template.TemplateCode, field)">
                                                    <span class="rb-field-label">@field.FieldLabel</span>
                                                    <span class="rb-field-type">@field.DataType</span>
                                                </li>
                                            }
                                        </ul>
                                    }
                                </div>
                            }
                        }
                    </div>
                }
            </div>

            <!-- Right Panel: Configuration + Results -->
            <div class="rb-main-panel">
                <!-- Selected Fields -->
                @if (_selectedFields.Count > 0)
                {
                    <div class="portal-card rb-section">
                        <h4 class="rb-section-title">Selected Fields (@_selectedFields.Count)</h4>
                        <div class="rb-chip-list">
                            @foreach (var field in _selectedFields)
                            {
                                <span class="rb-chip">
                                    @(field.Alias ?? field.FieldCode)
                                    <button class="rb-chip-remove" @onclick="() => RemoveField(field)" aria-label="Remove field">x</button>
                                </span>
                            }
                        </div>
                    </div>
                }

                <!-- Filters -->
                <div class="portal-card rb-section">
                    <div class="rb-section-header">
                        <h4 class="rb-section-title">Filters</h4>
                        <button class="portal-btn portal-btn-ghost portal-btn-sm" @onclick="AddFilter">+ Add Filter</button>
                    </div>
                    @foreach (var filter in _filters)
                    {
                        <div class="rb-filter-row">
                            <select class="portal-form-input rb-filter-field" @bind="filter.Field">
                                <option value="">— Select Field —</option>
                                @foreach (var f in _selectedFields)
                                {
                                    <option value="@f.FieldCode">@(f.Alias ?? f.FieldCode)</option>
                                }
                            </select>
                            <select class="portal-form-input rb-filter-op" @bind="filter.Operator">
                                <option value="=">=</option>
                                <option value="!=">!=</option>
                                <option value=">">&gt;</option>
                                <option value=">=">&gt;=</option>
                                <option value="<">&lt;</option>
                                <option value="<=">&lt;=</option>
                                <option value="LIKE">Contains</option>
                                <option value="IN">In</option>
                            </select>
                            <input type="text" class="portal-form-input rb-filter-value" @bind="filter.Value" placeholder="Value" />
                            <button class="portal-btn portal-btn-ghost portal-btn-sm" @onclick="() => RemoveFilter(filter)">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                            </button>
                        </div>
                    }
                </div>

                <!-- Aggregation & Sort -->
                <div class="rb-row-2col">
                    <div class="portal-card rb-section">
                        <div class="rb-section-header">
                            <h4 class="rb-section-title">Aggregation</h4>
                            <button class="portal-btn portal-btn-ghost portal-btn-sm" @onclick="AddAggregation">+ Add</button>
                        </div>
                        @foreach (var agg in _aggregations)
                        {
                            <div class="rb-filter-row">
                                <select class="portal-form-input" @bind="agg.Function">
                                    <option value="SUM">SUM</option>
                                    <option value="AVG">AVG</option>
                                    <option value="MIN">MIN</option>
                                    <option value="MAX">MAX</option>
                                    <option value="COUNT">COUNT</option>
                                </select>
                                <select class="portal-form-input" @bind="agg.Field">
                                    <option value="">— Field —</option>
                                    @foreach (var f in _selectedFields)
                                    {
                                        <option value="@f.FieldCode">@(f.Alias ?? f.FieldCode)</option>
                                    }
                                </select>
                                <button class="portal-btn portal-btn-ghost portal-btn-sm" @onclick="() => RemoveAggregation(agg)">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                </button>
                            </div>
                        }
                    </div>

                    <div class="portal-card rb-section">
                        <div class="rb-section-header">
                            <h4 class="rb-section-title">Sort</h4>
                            <button class="portal-btn portal-btn-ghost portal-btn-sm" @onclick="AddSort">+ Add</button>
                        </div>
                        @foreach (var sort in _sorts)
                        {
                            <div class="rb-filter-row">
                                <select class="portal-form-input" @bind="sort.Field">
                                    <option value="">— Field —</option>
                                    @foreach (var f in _selectedFields)
                                    {
                                        <option value="@f.FieldCode">@(f.Alias ?? f.FieldCode)</option>
                                    }
                                </select>
                                <select class="portal-form-input" style="max-width: 100px;" @bind="sort.Direction">
                                    <option value="ASC">ASC</option>
                                    <option value="DESC">DESC</option>
                                </select>
                                <button class="portal-btn portal-btn-ghost portal-btn-sm" @onclick="() => RemoveSort(sort)">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                </button>
                            </div>
                        }
                    </div>
                </div>

                <!-- Results -->
                @if (_result is not null)
                {
                    <div class="portal-card rb-section">
                        <div class="rb-section-header">
                            <h4 class="rb-section-title">Results — @_result.TotalRowCount rows (@(_result.QueryDurationMs)ms)</h4>
                            <div style="display: flex; gap: 0.25rem;">
                                <button class="portal-btn portal-btn-ghost portal-btn-sm @(_displayMode == "grid" ? "rb-tab-active" : "")" @onclick='() => SetDisplayMode("grid")'>Grid</button>
                                <button class="portal-btn portal-btn-ghost portal-btn-sm @(_displayMode == "chart" ? "rb-tab-active" : "")" @onclick='() => SetDisplayMode("chart")'>Chart</button>
                            </div>
                        </div>

                        @if (_displayMode == "grid")
                        {
                            <div class="portal-table-responsive">
                                <table class="portal-table rb-result-table">
                                    <thead>
                                        <tr>
                                            @foreach (var col in _result.Columns)
                                            {
                                                <th>@col</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _result.Rows.Take(_pageSize))
                                        {
                                            <tr>
                                                @foreach (var col in _result.Columns)
                                                {
                                                    <td>@FormatValue(row.GetValueOrDefault(col))</td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            @if (_result.TotalRowCount > _pageSize)
                            {
                                <p style="padding: 0.5rem; font-size: 0.75rem; color: #64748b;">
                                    Showing @_pageSize of @_result.TotalRowCount rows.
                                </p>
                            }
                        }
                        else
                        {
                            <div style="height: 350px; position: relative;">
                                <canvas id="reportChart"></canvas>
                            </div>
                        }
                    </div>
                }
                else if (_error is not null)
                {
                    <div class="portal-card rb-section" style="border-left: 3px solid #ef4444; padding: 1rem;">
                        <p style="color: #ef4444; margin: 0;">@_error</p>
                    </div>
                }
            </div>
        </div>

        <!-- Save Dialog -->
        @if (_showSaveDialog)
        {
            <div class="portal-modal-backdrop" @onclick="() => _showSaveDialog = false">
                <div class="portal-modal" style="max-width: 500px;" @onclick:stopPropagation="true">
                    <h3 class="portal-modal-title">Save Report</h3>
                    <div class="portal-form-group">
                        <label class="portal-form-label">Name <span class="portal-form-required">*</span></label>
                        <input type="text" class="portal-form-input" @bind="_saveName" placeholder="My Report" />
                    </div>
                    <div class="portal-form-group">
                        <label class="portal-form-label">Description</label>
                        <input type="text" class="portal-form-input" @bind="_saveDescription" placeholder="Optional description" />
                    </div>
                    <div class="portal-form-group">
                        <label class="portal-form-label">
                            <input type="checkbox" @bind="_saveShared" /> Share with all users
                        </label>
                    </div>
                    <div style="display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 1rem;">
                        <button class="portal-btn portal-btn-ghost" @onclick="() => _showSaveDialog = false">Cancel</button>
                        <button class="portal-btn portal-btn-primary" @onclick="SaveReport" disabled="@string.IsNullOrWhiteSpace(_saveName)">Save</button>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int? ReportId { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _hasAccess;
    private bool _running;
    private Guid _tenantId;
    private int _institutionId;
    private int _userId;
    private string _fieldSearch = "";
    private string _displayMode = "grid";
    private string? _error;
    private int _pageSize = 100;

    private List<ModuleFieldTree> _fieldTree = new();
    private HashSet<string> _expandedModules = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _expandedTemplates = new(StringComparer.OrdinalIgnoreCase);

    private List<ReportFieldDef> _selectedFields = new();
    private List<ReportFilterDef> _filters = new();
    private List<ReportAggregationDef> _aggregations = new();
    private List<ReportSortDef> _sorts = new();
    private ReportQueryResult? _result;

    // Save dialog
    private bool _showSaveDialog;
    private string _saveName = "";
    private string? _saveDescription;
    private bool _saveShared;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState!;
        Guid.TryParse(state.User.FindFirst("TenantId")?.Value, out _tenantId);
        int.TryParse(state.User.FindFirst("InstitutionId")?.Value, out _institutionId);
        int.TryParse(state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out _userId);

        _hasAccess = await ReportSvc.HasReportBuilderAccess(_tenantId);

        if (_hasAccess)
        {
            _fieldTree = await ReportSvc.GetFieldTree(_tenantId);

            // If editing an existing report, load its definition
            if (ReportId.HasValue)
            {
                var report = await ReportSvc.GetReportById(ReportId.Value);
                if (report is not null && report.TenantId == _tenantId)
                {
                    var def = System.Text.Json.JsonSerializer.Deserialize<ReportDefinition>(report.Definition);
                    if (def is not null)
                    {
                        _selectedFields = def.Fields;
                        _filters = def.Filters;
                        _aggregations = def.Aggregations;
                        _sorts = def.SortBy;
                        _saveName = report.Name;
                        _saveDescription = report.Description;
                        _saveShared = report.IsShared;
                    }
                }
            }
        }

        _loading = false;
    }

    private List<ModuleFieldTree> FilteredTree()
    {
        if (string.IsNullOrWhiteSpace(_fieldSearch))
            return _fieldTree;

        var search = _fieldSearch.Trim();
        return _fieldTree
            .Select(m => new ModuleFieldTree
            {
                ModuleCode = m.ModuleCode,
                ModuleName = m.ModuleName,
                Templates = m.Templates
                    .Select(t => new TemplateFieldNode
                    {
                        TemplateCode = t.TemplateCode,
                        TemplateName = t.TemplateName,
                        Fields = t.Fields
                            .Where(f => f.FieldLabel.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                                        f.FieldCode.Contains(search, StringComparison.OrdinalIgnoreCase))
                            .ToList()
                    })
                    .Where(t => t.Fields.Count > 0)
                    .ToList()
            })
            .Where(m => m.Templates.Count > 0)
            .ToList();
    }

    private void ToggleModule(string code)
    {
        if (!_expandedModules.Add(code)) _expandedModules.Remove(code);
    }

    private void ToggleTemplate(string code)
    {
        if (!_expandedTemplates.Add(code)) _expandedTemplates.Remove(code);
    }

    private void ToggleField(string moduleCode, string templateCode, FieldNode field)
    {
        var existing = _selectedFields.FirstOrDefault(
            f => f.FieldCode == field.FieldCode && f.TemplateCode == templateCode);

        if (existing is not null)
            _selectedFields.Remove(existing);
        else
            _selectedFields.Add(new ReportFieldDef
            {
                ModuleCode = moduleCode,
                TemplateCode = templateCode,
                FieldCode = field.FieldCode,
                Alias = field.FieldLabel
            });
    }

    private void RemoveField(ReportFieldDef field) => _selectedFields.Remove(field);
    private void AddFilter() => _filters.Add(new ReportFilterDef());
    private void RemoveFilter(ReportFilterDef f) => _filters.Remove(f);
    private void AddAggregation() => _aggregations.Add(new ReportAggregationDef { Function = "SUM" });
    private void RemoveAggregation(ReportAggregationDef a) => _aggregations.Remove(a);
    private void AddSort() => _sorts.Add(new ReportSortDef { Direction = "ASC" });
    private void RemoveSort(ReportSortDef s) => _sorts.Remove(s);

    private async Task RunReport()
    {
        _running = true;
        _error = null;
        _result = null;
        StateHasChanged();

        try
        {
            var definition = BuildDefinition();
            _result = await ReportSvc.RunReport(definition, _tenantId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _running = false;
        }
    }

    private void SetDisplayMode(string mode)
    {
        _displayMode = mode;
        if (mode == "chart" && _result is not null)
        {
            _ = RenderChart();
        }
    }

    private async Task RenderChart()
    {
        if (_result is null || _result.Columns.Count < 2) return;
        await Task.Yield(); // Let Blazor render the canvas

        var labelCol = _result.Columns[0];
        var dataCol = _result.Columns.Count > 1 ? _result.Columns[1] : _result.Columns[0];

        var labels = _result.Rows.Select(r => r.GetValueOrDefault(labelCol)?.ToString() ?? "").ToList();
        var data = _result.Rows.Select(r =>
        {
            var val = r.GetValueOrDefault(dataCol);
            return val switch
            {
                decimal d => d,
                int i => (decimal)i,
                long l => (decimal)l,
                double dbl => (decimal)dbl,
                string s when decimal.TryParse(s, out var parsed) => parsed,
                _ => 0m
            };
        }).ToList();

        var chartData = new
        {
            labels,
            datasets = new[]
            {
                new { label = dataCol, data }
            }
        };

        await JS.InvokeVoidAsync("renderChart", "reportChart", "bar", chartData);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_displayMode == "chart" && _result is not null)
        {
            await RenderChart();
        }
    }

    private ReportDefinition BuildDefinition() => new()
    {
        Fields = _selectedFields.ToList(),
        Filters = _filters.Where(f => !string.IsNullOrWhiteSpace(f.Field)).ToList(),
        Aggregations = _aggregations.Where(a => !string.IsNullOrWhiteSpace(a.Field)).ToList(),
        SortBy = _sorts.Where(s => !string.IsNullOrWhiteSpace(s.Field)).ToList(),
        Limit = 1000,
        DisplayMode = _displayMode == "chart" ? "BarChart" : "Grid"
    };

    private void ShowSaveDialog() => _showSaveDialog = true;

    private async Task SaveReport()
    {
        if (string.IsNullOrWhiteSpace(_saveName)) return;

        try
        {
            var definition = BuildDefinition();

            if (ReportId.HasValue)
            {
                var existing = await ReportSvc.GetReportById(ReportId.Value);
                if (existing is not null && existing.TenantId == _tenantId)
                {
                    existing.Name = _saveName;
                    existing.Description = _saveDescription;
                    existing.Definition = System.Text.Json.JsonSerializer.Serialize(definition);
                    existing.IsShared = _saveShared;
                    await ReportSvc.UpdateReport(existing);
                }
            }
            else
            {
                await ReportSvc.SaveReport(
                    _tenantId, _institutionId, _userId,
                    _saveName, _saveDescription, definition, _saveShared);
            }

            _showSaveDialog = false;
            Toast.Show("Report saved successfully.", "success");
        }
        catch (Exception ex)
        {
            Toast.Show($"Failed to save: {ex.Message}", "error");
        }
    }

    private async Task ExportCsv()
    {
        if (_result is null) return;

        var sb = new System.Text.StringBuilder();
        sb.AppendLine(string.Join(",", _result.Columns.Select(EscCsv)));
        foreach (var row in _result.Rows)
        {
            sb.AppendLine(string.Join(",", _result.Columns.Select(col =>
                EscCsv(row.GetValueOrDefault(col)?.ToString() ?? ""))));
        }

        await JS.InvokeVoidAsync("portalDownloadFile", sb.ToString(),
            $"report-{DateTime.UtcNow:yyyyMMddHHmm}.csv", "text/csv");
    }

    private static string FormatValue(object? value) => value switch
    {
        null => "",
        DateTime dt => dt.ToString("dd MMM yyyy"),
        decimal d => d.ToString("N2"),
        double dbl => dbl.ToString("N2"),
        _ => value.ToString() ?? ""
    };

    private static string EscCsv(string? v)
    {
        if (string.IsNullOrEmpty(v)) return "";
        if (v.Contains(',') || v.Contains('"') || v.Contains('\n'))
            return "\"" + v.Replace("\"", "\"\"") + "\"";
        return v;
    }
}
