@page "/subscription/invoices"
@attribute [Authorize(Policy = "InstitutionUser")]
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Enums
@inject ISubscriptionService SubscriptionService
@inject ITenantContext TenantContext

<PageTitle>My Invoices</PageTitle>

<div class="portal-sub-shell">
    <header class="portal-page-header portal-page-header-split">
        <div class="portal-page-header-main">
            <p class="portal-sub-kicker">Subscription</p>
            <h1 class="portal-page-title">Invoices</h1>
            <p class="portal-page-subtitle">Review invoice lifecycle, issue drafts, and record manual payments.</p>
        </div>
        <div class="portal-page-header-actions portal-sub-actions-top">
            <button class="portal-btn portal-btn-primary portal-btn-sm"
                    disabled="@(_busyInvoiceId.HasValue)"
                    @onclick="GenerateInvoice">
                Generate Draft Invoice
            </button>
        </div>
    </header>

    @if (_loading)
    {
        <section class="portal-card">
            <p>Loading invoices...</p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="portal-alert portal-alert-error">@_error</div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="portal-alert portal-alert-success">@_message</div>
        }

        <section class="portal-dash-stats">
            <article class="portal-stat-card">
                <div class="portal-stat-label">Total Invoices</div>
                <div class="portal-stat-value">@_invoices.Count</div>
                <div class="portal-stat-detail">all billing documents</div>
            </article>
            <article class="portal-stat-card">
                <div class="portal-stat-label">Outstanding</div>
                <div class="portal-stat-value">@FormatCurrency(_invoices.Where(i => i.Status is InvoiceStatus.Issued or InvoiceStatus.Overdue).Sum(i => i.TotalAmount))</div>
                <div class="portal-stat-detail">issued and overdue</div>
            </article>
            <article class="portal-stat-card">
                <div class="portal-stat-label">Paid</div>
                <div class="portal-stat-value">@FormatCurrency(_invoices.Where(i => i.Status == InvoiceStatus.Paid).Sum(i => i.TotalAmount))</div>
                <div class="portal-stat-detail">confirmed payments</div>
            </article>
            <article class="portal-stat-card">
                <div class="portal-stat-label">Draft</div>
                <div class="portal-stat-value">@_invoices.Count(i => i.Status == InvoiceStatus.Draft)</div>
                <div class="portal-stat-detail">pending issue</div>
            </article>
        </section>

        <section class="portal-card">
            <div class="portal-table-container">
                <table class="portal-table">
                    <thead>
                        <tr>
                            <th>Invoice</th>
                            <th>Status</th>
                            <th>Period</th>
                            <th>Total (NGN)</th>
                            <th>Due Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!_invoices.Any())
                        {
                            <tr>
                                <td colspan="6" class="portal-table-primary">No invoices yet. Generate your first draft invoice.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var invoice in _invoices)
                            {
                                <tr>
                                    <td>
                                        <span class="portal-table-primary">@invoice.InvoiceNumber</span>
                                    </td>
                                    <td>
                                        <span class="portal-badge @GetStatusBadgeClass(invoice.Status)">@invoice.Status</span>
                                    </td>
                                    <td>
                                        @invoice.PeriodStart.ToString("yyyy-MM-dd")<br />
                                        <span class="portal-text-sm">to @invoice.PeriodEnd.ToString("yyyy-MM-dd")</span>
                                    </td>
                                    <td>@FormatCurrency(invoice.TotalAmount)</td>
                                    <td>@(invoice.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                    <td>
                                        <div class="portal-sub-action-stack">
                                            @if (invoice.Status == InvoiceStatus.Draft)
                                            {
                                                <button class="portal-btn portal-btn-outline portal-btn-sm"
                                                        disabled="@(_busyInvoiceId == invoice.Id)"
                                                        @onclick="() => Issue(invoice.Id)">
                                                    Issue
                                                </button>
                                            }
                                            else if (invoice.Status is InvoiceStatus.Issued or InvoiceStatus.Overdue)
                                            {
                                                <span class="portal-sub-caption">Awaiting payment confirmation</span>
                                            }
                                            else
                                            {
                                                <span class="portal-sub-caption">No actions</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>

@code {
    private bool _loading = true;
    private string? _error;
    private string? _message;
    private int? _busyInvoiceId;
    private Guid _tenantId;
    private List<FC.Engine.Domain.Entities.Invoice> _invoices = new();

    protected override async Task OnInitializedAsync()
    {
        if (!TenantContext.CurrentTenantId.HasValue)
        {
            _error = "Tenant context not available.";
            _loading = false;
            return;
        }

        _tenantId = TenantContext.CurrentTenantId.Value;
        await Load();
    }

    private async Task Load()
    {
        try
        {
            _invoices = await SubscriptionService.GetInvoices(_tenantId, 1, 100);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task GenerateInvoice()
    {
        _busyInvoiceId = -1;
        _error = null;
        _message = null;

        try
        {
            var invoice = await SubscriptionService.GenerateInvoice(_tenantId);
            _message = $"Generated draft invoice {invoice.InvoiceNumber}.";
            await Load();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busyInvoiceId = null;
        }
    }

    private async Task Issue(int invoiceId)
    {
        _busyInvoiceId = invoiceId;
        _error = null;
        _message = null;

        try
        {
            var invoice = await SubscriptionService.IssueInvoice(invoiceId);
            _message = $"Issued invoice {invoice.InvoiceNumber}.";
            await Load();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busyInvoiceId = null;
        }
    }

    private static string GetStatusBadgeClass(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => "portal-badge-info",
        InvoiceStatus.Issued => "portal-badge-warning",
        InvoiceStatus.Overdue => "portal-badge-danger",
        InvoiceStatus.Paid => "portal-badge-success",
        InvoiceStatus.Voided => "portal-badge-neutral",
        _ => "portal-badge-neutral"
    };

    private static string FormatCurrency(decimal value) => value.ToString("N2");
}
