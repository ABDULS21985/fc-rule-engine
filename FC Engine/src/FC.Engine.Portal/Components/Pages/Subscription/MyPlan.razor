@page "/subscription/my-plan"
@attribute [Authorize(Policy = "InstitutionUser")]
@inject ISubscriptionService SubscriptionService
@inject ITenantContext TenantContext
@inject ToastService Toast

<PageTitle>My Plan</PageTitle>

<div class="portal-sub-shell">

    <SubscriptionOverdueBanner />

    <header class="portal-page-header portal-page-header-split">
        <div class="portal-page-header-main">
            <p class="portal-sub-kicker">Subscription</p>
            <h1 class="portal-page-title">My Plan</h1>
            <p class="portal-page-subtitle">Track limits, feature access, and subscription lifecycle in real time.</p>
        </div>
        <div class="portal-page-header-actions portal-sub-actions-top">
            <a class="portal-btn portal-btn-outline portal-btn-sm" href="/subscription/modules">Manage Modules</a>
            <a class="portal-btn portal-btn-outline portal-btn-sm" href="/subscription/invoices">View Invoices</a>
            @if (!_loading && _availablePlans.Any())
            {
                <button class="portal-btn portal-btn-primary portal-btn-sm" @onclick="OpenUpgradeModal">
                    Upgrade Plan
                </button>
            }
        </div>
    </header>

    @if (_loading)
    {
        <section class="portal-card">
            <p>Loading subscription...</p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="portal-alert portal-alert-error">@_error</div>
    }
    else if (_subscription is not null && _usage is not null)
    {
        @* ── Plan Hero Card ───────────────────────────────────── *@
        <div class="portal-sub-plan-hero @GetTierClass(_subscription.Plan?.Tier ?? 1)">
            <div class="portal-sub-plan-hero-main">
                <p class="portal-sub-plan-hero-kicker">Current Subscription</p>
                <h2 class="portal-sub-plan-hero-name">@(_subscription.Plan?.PlanName ?? _subscription.Plan?.PlanCode ?? "—")</h2>
                <p class="portal-sub-plan-hero-price">
                    NGN @FormatCurrency(_subscription.Plan?.BasePriceMonthly ?? 0)
                    <span>/ month</span>
                </p>
                <div class="portal-sub-plan-hero-meta">
                    <span class="portal-badge @GetStatusBadgeClass(_subscription.Status)">@_subscription.Status</span>
                    @if (_subscription.BillingFrequency == BillingFrequency.Annual)
                    {
                        <span class="portal-badge portal-badge-info">Annual Billing</span>
                    }
                    else
                    {
                        <span class="portal-badge portal-badge-neutral">Monthly Billing</span>
                    }
                    @if ((_subscription.Plan?.Tier ?? 0) > 0)
                    {
                        <span class="portal-badge portal-badge-neutral">Tier @_subscription.Plan!.Tier</span>
                    }
                </div>
            </div>
            <div class="portal-sub-renewal">
                @{ var days = GetRenewalDays(); }
                <span class="portal-sub-renewal-days">@days</span>
                <span class="portal-sub-renewal-label">days until renewal</span>
                <span class="portal-sub-renewal-date">@_subscription.CurrentPeriodEnd.ToString("dd MMM yyyy")</span>
                @if (days <= 7)
                {
                    <span class="portal-badge portal-badge-warning" style="margin-top: 4px;">Renewing soon</span>
                }
            </div>
        </div>

        @* ── Usage Meters ──────────────────────────────────────── *@
        <section class="portal-card portal-sub-usage-card">
            <div class="portal-sub-section-head">
                <h2>Usage Against Plan Limits</h2>
                <span class="portal-sub-caption">As of @_usage.AsOfDate.ToString("dd MMM yyyy")</span>
            </div>
            <div class="portal-sub-usage-grid">
                @UsageMeter("Users", _usage.ActiveUsers, _usage.ActiveUsersLimit)
                @UsageMeter("Entities", _usage.ActiveEntities, _usage.ActiveEntitiesLimit)
                @UsageMeter("Modules", _usage.ActiveModules, _usage.ActiveModulesLimit)
                @UsageMeter("API Calls", _usage.ApiCallCount,
                    _usage.ApiCallLimit <= 0 ? 1 : _usage.ApiCallLimit,
                    _usage.ApiCallLimit <= 0)
                @StorageMeter("Storage", _usage.StorageUsedMb, _usage.StorageLimitMb)
                @SubmissionsMeter("Returns Submitted", _usage.ReturnsSubmitted)
            </div>
        </section>

        @* ── Plan Comparison (next tier) ───────────────────────── *@
        @if (_availablePlans.Any())
        {
            var nextPlan = _availablePlans.OrderBy(p => p.Tier).First();
            <section class="portal-card portal-sub-compare-section">
                <div class="portal-sub-section-head">
                    <div>
                        <h2>What You'd Gain — @nextPlan.PlanName</h2>
                        <p class="portal-sub-caption">NGN @FormatCurrency(nextPlan.BasePriceMonthly) / month</p>
                    </div>
                    <button class="portal-btn portal-btn-primary portal-btn-sm" @onclick="OpenUpgradeModal">
                        Upgrade to @nextPlan.PlanName →
                    </button>
                </div>
                <table class="portal-sub-compare-table">
                    <thead>
                        <tr>
                            <th>Limit</th>
                            <th>@(_subscription.Plan?.PlanName ?? "Current")</th>
                            <th>@nextPlan.PlanName</th>
                            <th>Change</th>
                        </tr>
                    </thead>
                    <tbody>
                        @CompareRow("Users per Entity",
                            FormatLimit(_subscription.Plan?.MaxUsersPerEntity ?? 0),
                            FormatLimit(nextPlan.MaxUsersPerEntity),
                            nextPlan.MaxUsersPerEntity > (_subscription.Plan?.MaxUsersPerEntity ?? 0))
                        @CompareRow("Entities",
                            FormatLimit(_subscription.Plan?.MaxEntities ?? 0),
                            FormatLimit(nextPlan.MaxEntities),
                            nextPlan.MaxEntities > (_subscription.Plan?.MaxEntities ?? 0))
                        @CompareRow("Modules",
                            FormatLimit(_subscription.Plan?.MaxModules ?? 0),
                            FormatLimit(nextPlan.MaxModules),
                            nextPlan.MaxModules > (_subscription.Plan?.MaxModules ?? 0))
                        @CompareRow("API Calls / Month",
                            FormatLimit(_subscription.Plan?.MaxApiCallsPerMonth ?? 0),
                            FormatLimit(nextPlan.MaxApiCallsPerMonth),
                            nextPlan.MaxApiCallsPerMonth > (_subscription.Plan?.MaxApiCallsPerMonth ?? 0))
                        @CompareRow("Storage",
                            $"{(_subscription.Plan?.MaxStorageMb ?? 0):N0} MB",
                            $"{nextPlan.MaxStorageMb:N0} MB",
                            nextPlan.MaxStorageMb > (_subscription.Plan?.MaxStorageMb ?? 0))
                    </tbody>
                </table>
            </section>
        }

        @* ── Features ─────────────────────────────────────────── *@
        <section class="portal-card portal-sub-feature-card">
            <div class="portal-sub-section-head">
                <h2>Plan Features</h2>
            </div>
            @if (_features.Count == 0)
            {
                <p class="portal-sub-caption">No plan features declared.</p>
            }
            else
            {
                <div class="portal-sub-feature-list">
                    @foreach (var feature in _features)
                    {
                        <span class="portal-badge portal-badge-info portal-badge-lg">
                            @feature.Replace('_', ' ')
                        </span>
                    }
                </div>
            }
        </section>
    }

</div>

@* ── Upgrade Plan Modal ────────────────────────────────────────────── *@
@if (_showUpgradeModal)
{
    <div class="portal-sub-upgrade-modal" role="dialog" aria-modal="true"
         aria-labelledby="upgrade-modal-title">
        <div class="portal-sub-upgrade-backdrop" @onclick="CloseUpgradeModal"></div>
        <div class="portal-sub-upgrade-panel">

            @* Modal header *@
            <div class="portal-sub-upgrade-head">
                <div>
                    @if (_upgradeStep == 1)
                    {
                        <h2 id="upgrade-modal-title">Choose Your Plan</h2>
                        <p class="portal-sub-caption">Select a plan to see what you'd gain.</p>
                    }
                    else
                    {
                        <h2 id="upgrade-modal-title">Confirm Upgrade</h2>
                        <p class="portal-sub-caption">Review changes before proceeding.</p>
                    }
                </div>
                <button class="portal-sub-upgrade-close" @onclick="CloseUpgradeModal" aria-label="Close dialog">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                         width="18" height="18" aria-hidden="true">
                        <path d="M18 6L6 18M6 6l12 12"/>
                    </svg>
                </button>
            </div>

            @if (_upgradeStep == 1)
            {
                @* Step 1: Plan cards *@
                <div class="portal-sub-plan-cards">

                    @* Current plan — shown as reference *@
                    <div class="portal-sub-plan-card portal-sub-plan-card--current">
                        <div>
                            <p class="portal-sub-caption">Current Plan</p>
                            <p class="portal-sub-plan-card-name">@(_subscription?.Plan?.PlanName ?? "—")</p>
                        </div>
                        <p class="portal-sub-plan-card-price">
                            NGN @FormatCurrency(_subscription?.Plan?.BasePriceMonthly ?? 0)
                            <span>/month</span>
                        </p>
                        <ul class="portal-sub-plan-card-features">
                            <li>✓ @FormatLimit(_subscription?.Plan?.MaxModules ?? 0) modules</li>
                            <li>✓ @FormatLimit(_subscription?.Plan?.MaxUsersPerEntity ?? 0) users / entity</li>
                            <li>✓ @FormatLimit(_subscription?.Plan?.MaxEntities ?? 0) entities</li>
                            <li>✓ @(_subscription?.Plan?.MaxStorageMb ?? 0) MB storage</li>
                        </ul>
                    </div>

                    @* Upgrade options *@
                    @foreach (var plan in _availablePlans.OrderBy(p => p.Tier))
                    {
                        var localCode = plan.PlanCode;
                        var isSelected = _selectedPlanCode == localCode;
                        <div class="portal-sub-plan-card @(isSelected ? "portal-sub-plan-card--selected" : "")"
                             @onclick="() => SelectPlan(localCode)" role="button" tabindex="0">
                            <div>
                                @if (isSelected)
                                {
                                    <p class="portal-sub-caption portal-sub-plan-card-selected-label">✓ Selected</p>
                                }
                                else
                                {
                                    <p class="portal-sub-caption">Tier @plan.Tier</p>
                                }
                                <p class="portal-sub-plan-card-name">@plan.PlanName</p>
                            </div>
                            <p class="portal-sub-plan-card-price">
                                NGN @FormatCurrency(plan.BasePriceMonthly)
                                <span>/month</span>
                            </p>
                            <ul class="portal-sub-plan-card-features">
                                <li>✓ @FormatLimit(plan.MaxModules) modules</li>
                                <li>✓ @FormatLimit(plan.MaxUsersPerEntity) users / entity</li>
                                <li>✓ @FormatLimit(plan.MaxEntities) entities</li>
                                <li>✓ @plan.MaxStorageMb MB storage</li>
                                @foreach (var feat in plan.GetFeatures().Take(3))
                                {
                                    <li>✓ @feat.Replace('_', ' ')</li>
                                }
                            </ul>
                        </div>
                    }
                </div>

                <div class="portal-sub-checkout-actions">
                    <button class="portal-btn portal-btn-outline" @onclick="CloseUpgradeModal">Cancel</button>
                    <button class="portal-btn portal-btn-primary"
                            disabled="@(_selectedPlanCode is null)"
                            @onclick="GoToCheckout">
                        Continue →
                    </button>
                </div>
            }
            else
            {
                @* Step 2: Checkout summary *@
                var selectedPlan = _availablePlans.FirstOrDefault(p => p.PlanCode == _selectedPlanCode);
                @if (selectedPlan is not null)
                {
                    <div class="portal-sub-checkout">
                        <div class="portal-sub-checkout-card">
                            <div class="portal-sub-checkout-row">
                                <span class="portal-sub-inv-row-label">Upgrading from</span>
                                <span>@(_subscription?.Plan?.PlanName ?? "—")</span>
                            </div>
                            <div class="portal-sub-checkout-row">
                                <span class="portal-sub-inv-row-label">Upgrading to</span>
                                <strong>@selectedPlan.PlanName</strong>
                            </div>
                            <div class="portal-sub-checkout-row">
                                <span class="portal-sub-inv-row-label">Previous monthly price</span>
                                <span>NGN @FormatCurrency(_subscription?.Plan?.BasePriceMonthly ?? 0)</span>
                            </div>
                            <div class="portal-sub-checkout-row">
                                <span class="portal-sub-inv-row-label">New monthly price</span>
                                <span>NGN @FormatCurrency(selectedPlan.BasePriceMonthly)</span>
                            </div>
                            <div class="portal-sub-checkout-row">
                                <span class="portal-sub-inv-row-label">Effective date</span>
                                <span>Immediately on confirm</span>
                            </div>
                            <div class="portal-sub-checkout-row portal-sub-checkout-row--total">
                                <span>New Monthly Total</span>
                                <span>NGN @FormatCurrency(selectedPlan.BasePriceMonthly)</span>
                            </div>
                        </div>
                        <p class="portal-sub-caption" style="padding: 0 var(--space-1);">
                            Your plan will be upgraded immediately. The next billing cycle will reflect
                            the new plan pricing. This action cannot be undone.
                        </p>
                    </div>

                    <div class="portal-sub-checkout-actions">
                        <button class="portal-btn portal-btn-outline"
                                @onclick='() => _upgradeStep = 1'>
                            ← Back
                        </button>
                        <button class="portal-btn portal-btn-primary"
                                disabled="@_upgrading"
                                @onclick="ConfirmUpgrade">
                            @if (_upgrading)
                            {
                                <span class="portal-btn-spinner" aria-hidden="true"></span>
                                <span>Upgrading...</span>
                            }
                            else
                            {
                                <span>Confirm Upgrade</span>
                            }
                        </button>
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private Subscription? _subscription;
    private UsageSummary? _usage;
    private List<string> _features = new();
    private List<SubscriptionPlan> _availablePlans = new();

    // Upgrade modal
    private bool _showUpgradeModal;
    private int _upgradeStep = 1;
    private string? _selectedPlanCode;
    private bool _upgrading;

    protected override async Task OnInitializedAsync()
    {
        var tenantId = TenantContext.CurrentTenantId;
        if (!tenantId.HasValue)
        {
            _error = "Tenant context not available.";
            _loading = false;
            return;
        }

        try
        {
            _subscription = await SubscriptionService.GetActiveSubscription(tenantId.Value);
            _usage = await SubscriptionService.GetUsageSummary(tenantId.Value);
            _features = _subscription.Plan?.GetFeatures() ?? new List<string>();
            _availablePlans = await SubscriptionService.GetAvailablePlans(tenantId.Value);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenUpgradeModal()
    {
        _upgradeStep = 1;
        _selectedPlanCode = null;
        _showUpgradeModal = true;
    }

    private void CloseUpgradeModal()
    {
        _showUpgradeModal = false;
        _upgrading = false;
    }

    private void SelectPlan(string planCode) => _selectedPlanCode = planCode;

    private void GoToCheckout()
    {
        if (_selectedPlanCode is not null) _upgradeStep = 2;
    }

    private async Task ConfirmUpgrade()
    {
        if (_selectedPlanCode is null || !TenantContext.CurrentTenantId.HasValue) return;
        _upgrading = true;
        try
        {
            _subscription = await SubscriptionService.UpgradePlan(
                TenantContext.CurrentTenantId.Value, _selectedPlanCode);
            _features = _subscription.Plan?.GetFeatures() ?? new List<string>();
            _availablePlans = await SubscriptionService.GetAvailablePlans(
                TenantContext.CurrentTenantId.Value);
            Toast.Success("Plan upgraded successfully.");
            CloseUpgradeModal();
        }
        catch (Exception ex)
        {
            Toast.Error("Upgrade failed: " + ex.Message);
        }
        finally
        {
            _upgrading = false;
        }
    }

    private int GetRenewalDays()
        => Math.Max(0, (int)(_subscription!.CurrentPeriodEnd - DateTime.UtcNow).TotalDays);

    private static string GetTierClass(int tier) => tier switch
    {
        1 => "portal-sub-plan-tier-1",
        2 => "portal-sub-plan-tier-2",
        3 => "portal-sub-plan-tier-3",
        >= 4 => "portal-sub-plan-tier-4",
        _ => "portal-sub-plan-tier-1"
    };

    private RenderFragment CompareRow(string label, string current, string next, bool isGain) =>
        builder =>
        {
            builder.OpenElement(0, "tr");
            builder.OpenElement(1, "td");
            builder.AddContent(2, label);
            builder.CloseElement();
            builder.OpenElement(3, "td");
            builder.AddContent(4, current);
            builder.CloseElement();
            builder.OpenElement(5, "td");
            builder.AddContent(6, next);
            builder.CloseElement();
            builder.OpenElement(7, "td");
            if (isGain)
            {
                builder.OpenElement(8, "span");
                builder.AddAttribute(9, "class", "portal-sub-compare-delta portal-sub-compare-delta--gain");
                builder.AddContent(10, "↑ More");
                builder.CloseElement();
            }
            else
            {
                builder.OpenElement(8, "span");
                builder.AddAttribute(9, "class", "portal-sub-compare-delta portal-sub-compare-delta--neutral");
                builder.AddContent(10, "Same");
                builder.CloseElement();
            }
            builder.CloseElement();
            builder.CloseElement();
        };

    private static string FormatLimit(int value) => value <= 0 ? "Unlimited" : value.ToString("N0");

    private RenderFragment UsageMeter(string label, int current, int limit, bool unlimited = false) =>
        builder =>
        {
            var percent = unlimited ? 0m : GetPercent(current, limit);
            var meterClass = GetMeterClass(percent);

            builder.OpenElement(0, "article");
            builder.AddAttribute(1, "class", "portal-sub-meter");

            builder.OpenElement(2, "div");
            builder.AddAttribute(3, "class", "portal-sub-meter-top");
            builder.OpenElement(4, "span");
            builder.AddContent(5, label);
            builder.CloseElement();
            builder.OpenElement(6, "strong");
            builder.AddContent(7, unlimited ? $"{current} / Unlimited" : $"{current} / {limit}");
            builder.CloseElement();
            builder.CloseElement();

            builder.OpenElement(8, "div");
            builder.AddAttribute(9, "class", "portal-sub-meter-track");
            builder.OpenElement(10, "div");
            builder.AddAttribute(11, "class", meterClass);
            builder.AddAttribute(12, "style", $"width:{percent:0.##}%");
            builder.CloseElement();
            builder.CloseElement();

            builder.OpenElement(13, "div");
            builder.AddAttribute(14, "class", "portal-sub-meter-foot");
            builder.AddContent(15, unlimited ? "No plan cap" : $"{percent:0.#}% used");
            builder.CloseElement();

            builder.CloseElement();
        };

    private RenderFragment StorageMeter(string label, decimal current, int limit) =>
        builder =>
        {
            var percent = GetPercent(current, limit);
            var meterClass = GetMeterClass(percent);

            builder.OpenElement(0, "article");
            builder.AddAttribute(1, "class", "portal-sub-meter");

            builder.OpenElement(2, "div");
            builder.AddAttribute(3, "class", "portal-sub-meter-top");
            builder.OpenElement(4, "span");
            builder.AddContent(5, label);
            builder.CloseElement();
            builder.OpenElement(6, "strong");
            builder.AddContent(7, $"{current:N2} / {limit:N0} MB");
            builder.CloseElement();
            builder.CloseElement();

            builder.OpenElement(8, "div");
            builder.AddAttribute(9, "class", "portal-sub-meter-track");
            builder.OpenElement(10, "div");
            builder.AddAttribute(11, "class", meterClass);
            builder.AddAttribute(12, "style", $"width:{percent:0.##}%");
            builder.CloseElement();
            builder.CloseElement();

            builder.OpenElement(13, "div");
            builder.AddAttribute(14, "class", "portal-sub-meter-foot");
            builder.AddContent(15, $"{percent:0.#}% used");
            builder.CloseElement();

            builder.CloseElement();
        };

    private RenderFragment SubmissionsMeter(string label, int count) =>
        builder =>
        {
            builder.OpenElement(0, "article");
            builder.AddAttribute(1, "class", "portal-sub-meter");

            builder.OpenElement(2, "div");
            builder.AddAttribute(3, "class", "portal-sub-meter-top");
            builder.OpenElement(4, "span");
            builder.AddContent(5, label);
            builder.CloseElement();
            builder.OpenElement(6, "strong");
            builder.AddContent(7, count.ToString("N0"));
            builder.CloseElement();
            builder.CloseElement();

            builder.OpenElement(8, "div");
            builder.AddAttribute(9, "class", "portal-sub-meter-track");
            builder.OpenElement(10, "div");
            builder.AddAttribute(11, "class", "portal-sub-meter-fill");
            builder.AddAttribute(12, "style", "width: 100%");
            builder.CloseElement();
            builder.CloseElement();

            builder.OpenElement(13, "div");
            builder.AddAttribute(14, "class", "portal-sub-meter-foot");
            builder.AddContent(15, "this billing period");
            builder.CloseElement();

            builder.CloseElement();
        };

    private static decimal GetPercent(int current, int limit)
        => limit <= 0 ? 0 : Math.Clamp((decimal)current / limit * 100m, 0m, 100m);

    private static decimal GetPercent(decimal current, int limit)
        => limit <= 0 ? 0 : Math.Clamp(current / limit * 100m, 0m, 100m);

    private static string GetMeterClass(decimal percent) => percent switch
    {
        >= 90m => "portal-sub-meter-fill portal-sub-meter-fill-danger",
        >= 75m => "portal-sub-meter-fill portal-sub-meter-fill-warning",
        _ => "portal-sub-meter-fill"
    };

    private static string GetStatusBadgeClass(SubscriptionStatus status) => status switch
    {
        SubscriptionStatus.Active => "portal-badge-success",
        SubscriptionStatus.Trial => "portal-badge-info",
        SubscriptionStatus.PastDue => "portal-badge-warning",
        SubscriptionStatus.Suspended => "portal-badge-danger",
        SubscriptionStatus.Cancelled => "portal-badge-danger",
        SubscriptionStatus.Expired => "portal-badge-danger",
        _ => "portal-badge-neutral"
    };

    private static string FormatCurrency(decimal value) => value.ToString("N2");
}
