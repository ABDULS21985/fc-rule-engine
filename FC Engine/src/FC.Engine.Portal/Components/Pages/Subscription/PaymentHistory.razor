@page "/subscription/payments"
@attribute [Authorize(Policy = "InstitutionUser")]
@inject ISubscriptionService SubscriptionService
@inject ITenantContext TenantContext

<PageTitle>Payment History</PageTitle>

<div class="portal-sub-shell">

    <SubscriptionOverdueBanner />

    <header class="portal-page-header portal-page-header-split">
        <div class="portal-page-header-main">
            <p class="portal-sub-kicker">Subscription</p>
            <h1 class="portal-page-title">Payment History</h1>
            <p class="portal-page-subtitle">Audit all captured payments and reconciliation references.</p>
        </div>
        <div class="portal-page-header-actions portal-sub-actions-top">
            <a class="portal-btn portal-btn-outline portal-btn-sm" href="/subscription/invoices">Back to Invoices</a>
        </div>
    </header>

    @if (_loading)
    {
        <SkeletonGuard OnRetry="ReloadAsync">
            <div aria-busy="true" aria-label="Loading payments...">
                <div class="fc-skel-stats-row fc-skel-section">
                    <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Stat" Index="0" />
                    <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Stat" Index="3" />
                    <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Stat" Index="6" />
                    <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Stat" Index="9" />
                </div>
                <section class="portal-card fc-skel-section">
                    <div class="fc-skel fc-skel-text-lg" style="width: 200px; --skeleton-index: 12; margin-bottom: var(--space-4);"></div>
                    @for (int i = 0; i < 6; i++)
                    {
                        var si = 13 + i;
                        <div style="display:flex; align-items:center; gap:var(--space-4); padding:var(--space-3) 0; border-bottom:1px solid var(--cbn-border-subtle);">
                            <div class="fc-skel fc-skel-circle" style="width:36px; height:36px; --skeleton-index: @si;"></div>
                            <div style="flex:1; display:flex; flex-direction:column; gap:var(--space-1);">
                                <div class="fc-skel fc-skel-text-lg" style="width: 50%; --skeleton-index: @si;"></div>
                                <div class="fc-skel fc-skel-text" style="width: 35%; --skeleton-index: @si;"></div>
                            </div>
                            <div class="fc-skel fc-skel-text-lg" style="width: 90px; --skeleton-index: @si;"></div>
                        </div>
                    }
                </section>
            </div>
        </SkeletonGuard>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="portal-alert portal-alert-error">@_error</div>
    }
    else
    {
        <section class="portal-dash-stats">
            <article class="portal-stat-card">
                <div class="portal-stat-label">Payments</div>
                <div class="portal-stat-value">@_totalCount</div>
                <div class="portal-stat-detail">all records</div>
            </article>
            <article class="portal-stat-card">
                <div class="portal-stat-label">Confirmed</div>
                <div class="portal-stat-value">@_payments.Count(p => p.Status == PaymentStatus.Confirmed)</div>
                <div class="portal-stat-detail">successful collections</div>
            </article>
            <article class="portal-stat-card">
                <div class="portal-stat-label">Failed</div>
                <div class="portal-stat-value @(_payments.Any(p => p.Status == PaymentStatus.Failed) ? "portal-stat-value--danger" : "")">
                    @_payments.Count(p => p.Status == PaymentStatus.Failed)
                </div>
                <div class="portal-stat-detail">requires retry</div>
            </article>
            <article class="portal-stat-card">
                <div class="portal-stat-label">Total Paid</div>
                <div class="portal-stat-value">
                    @FormatCurrency(_payments.Where(p => p.Status == PaymentStatus.Confirmed).Sum(p => p.Amount))
                </div>
                <div class="portal-stat-detail">NGN confirmed amount</div>
            </article>
        </section>

        @if (!_payments.Any())
        {
            <section class="portal-card">
                <div class="portal-empty-state">
                    <p>No payment records yet.</p>
                </div>
            </section>
        }
        else
        {
            <section class="portal-card">
                <div class="portal-sub-section-head">
                    <h2>Payment Records</h2>
                    <span class="portal-sub-caption">@_totalCount record@(_totalCount == 1 ? "" : "s")</span>
                </div>

                <div class="portal-pay-tl">
                    @foreach (var payment in _payments)
                    {
                        var dotClass = payment.Status switch
                        {
                            PaymentStatus.Confirmed => "portal-pay-tl-dot--confirmed",
                            PaymentStatus.Failed => "portal-pay-tl-dot--failed",
                            _ => "portal-pay-tl-dot--pending"
                        };
                        var badgeClass = payment.Status switch
                        {
                            PaymentStatus.Confirmed => "portal-badge-success",
                            PaymentStatus.Failed => "portal-badge-danger",
                            PaymentStatus.Pending => "portal-badge-warning",
                            _ => "portal-badge-neutral"
                        };
                        var iconHtml = payment.Status switch
                        {
                            PaymentStatus.Confirmed => "✓",
                            PaymentStatus.Failed => "✕",
                            _ => "..."
                        };

                        <div class="portal-pay-tl-item">
                            <div class="portal-pay-tl-status">
                                <div class="portal-pay-tl-dot @dotClass" aria-hidden="true">
                                    @iconHtml
                                </div>
                            </div>

                            <div class="portal-pay-tl-body">
                                <p class="portal-pay-tl-method">
                                    @payment.PaymentMethod
                                    @if (!string.IsNullOrWhiteSpace(payment.ProviderName))
                                    {
                                        <span class="portal-sub-caption"> via @payment.ProviderName</span>
                                    }
                                </p>
                                @if (!string.IsNullOrWhiteSpace(payment.PaymentReference) ||
                                     !string.IsNullOrWhiteSpace(payment.ProviderTransactionId))
                                {
                                    <p class="portal-pay-tl-ref">
                                        Ref: @(payment.PaymentReference ?? payment.ProviderTransactionId)
                                    </p>
                                }
                                @if (!string.IsNullOrWhiteSpace(payment.FailureReason))
                                {
                                    <p class="portal-pay-tl-failure">@payment.FailureReason</p>
                                }
                                <p class="portal-pay-tl-date">
                                    @payment.CreatedAt.ToString("dd MMM yyyy, HH:mm") UTC
                                    &nbsp;·&nbsp;
                                    <span class="portal-badge portal-badge-sm @badgeClass">@payment.Status</span>
                                </p>
                            </div>

                            <div class="portal-pay-tl-amount">
                                <span class="portal-pay-tl-currency">NGN</span>
                                @FormatCurrency(payment.Amount)
                            </div>
                        </div>
                    }
                </div>
            </section>

            @* ── Pagination ────────────────────────────────────────── *@
            @if (_totalPages > 1)
            {
                <nav class="portal-pagination" role="navigation" aria-label="Payment history pagination">
                    <span class="portal-pagination-info">
                        Showing @(((_currentPage - 1) * PageSize) + 1)–@(Math.Min(_currentPage * PageSize, _totalCount)) of @_totalCount
                    </span>
                    <div class="portal-pagination-controls">
                        <button class="portal-btn portal-btn-ghost portal-btn-sm"
                                disabled="@(_currentPage <= 1)"
                                @onclick="() => GoToPage(_currentPage - 1)"
                                aria-label="Previous page">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <polyline points="15 18 9 12 15 6"/>
                            </svg>
                        </button>
                        @for (int p = 1; p <= _totalPages; p++)
                        {
                            var pageNum = p;
                            @if (ShouldShowPageButton(pageNum))
                            {
                                <button class="portal-btn @(pageNum == _currentPage ? "portal-btn-primary portal-btn-sm" : "portal-btn-ghost portal-btn-sm")"
                                        @onclick="() => GoToPage(pageNum)"
                                        aria-label="Go to page @pageNum"
                                        aria-current="@(pageNum == _currentPage ? "page" : null)">
                                    @pageNum
                                </button>
                            }
                            else if (ShouldShowEllipsis(pageNum))
                            {
                                <span class="portal-pagination-ellipsis">...</span>
                            }
                        }
                        <button class="portal-btn portal-btn-ghost portal-btn-sm"
                                disabled="@(_currentPage >= _totalPages)"
                                @onclick="() => GoToPage(_currentPage + 1)"
                                aria-label="Next page">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <polyline points="9 18 15 12 9 6"/>
                            </svg>
                        </button>
                    </div>
                </nav>
            }
        }
    }
</div>

@code {
    private const int PageSize = 20;

    private bool _loading = true;
    private string? _error;
    private List<Payment> _payments = new();

    // Pagination
    private int _currentPage = 1;
    private int _totalCount;
    private int _totalPages => _totalCount <= 0 ? 1 : (int)Math.Ceiling((double)_totalCount / PageSize);

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        if (!TenantContext.CurrentTenantId.HasValue)
        {
            _error = "Tenant context not available.";
            _loading = false;
            return;
        }

        var tenantId = TenantContext.CurrentTenantId.Value;

        try
        {
            _totalCount = await SubscriptionService.GetPaymentCount(tenantId);
            _payments = await SubscriptionService.GetPayments(tenantId, _currentPage, PageSize);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > _totalPages || page == _currentPage) return;
        if (!TenantContext.CurrentTenantId.HasValue) return;

        _currentPage = page;
        _error = null;
        try
        {
            _payments = await SubscriptionService.GetPayments(TenantContext.CurrentTenantId.Value, _currentPage, PageSize);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        StateHasChanged();
    }

    private bool ShouldShowPageButton(int pageNum)
        => pageNum == 1 || pageNum == _totalPages
           || (pageNum >= _currentPage - 1 && pageNum <= _currentPage + 1);

    private bool ShouldShowEllipsis(int pageNum)
        => pageNum == _currentPage - 2 || pageNum == _currentPage + 2;

    private static string FormatCurrency(decimal value) => value.ToString("N2");
}
