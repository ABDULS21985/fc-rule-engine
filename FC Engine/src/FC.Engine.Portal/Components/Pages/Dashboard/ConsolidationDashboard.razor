@page "/dashboard/consolidation"
@attribute [Authorize(Policy = "InstitutionUser")]
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Models
@inject ITenantContext TenantContext
@inject IJurisdictionConsolidationService ConsolidationService
@inject IJSRuntime JS

<PageTitle>Cross-Module Data Consolidation</PageTitle>

<div class="portal-page">

    <PortalPageHeader Title="Cross-Module Data Consolidation"
                      Subtitle="Entity hierarchy, submission status, and consolidated financials across jurisdictions."
                      Breadcrumb="@_breadcrumb">
        <SecondaryActions>
            @if (_data is not null && _reconAlerts.Count > 0)
            {
                <button class="portal-btn portal-btn--outline portal-btn--sm"
                        @onclick="() => _showReconPanel = !_showReconPanel">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    Alerts (@_reconAlerts.Count)
                </button>
            }
        </SecondaryActions>
        <PrimaryAction>
            @if (_data is not null)
            {
                <button class="portal-btn portal-btn--gold portal-btn--sm" @onclick="DownloadConsolidated" disabled="@_downloading">
                    @if (_downloading)
                    {
                        <span class="portal-btn-spinner"></span>
                    }
                    else
                    {
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    }
                    Download Consolidated
                </button>
            }
        </PrimaryAction>
    </PortalPageHeader>

    @* ── 7. Reconciliation Alerts Banner ── *@
    @if (_showReconPanel && _reconAlerts.Count > 0)
    {
        <div class="consol-recon-banner" role="alert">
            <div class="consol-recon-banner-header">
                <div class="consol-recon-banner-title">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    <span>Reconciliation Discrepancies</span>
                    <span class="consol-recon-count">@_reconAlerts.Count</span>
                </div>
                <button class="consol-recon-close" @onclick="() => _showReconPanel = false" aria-label="Dismiss alerts">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            @foreach (var alert in _reconAlerts)
            {
                <div class="consol-recon-item consol-recon-item--@alert.Severity.ToString().ToLowerInvariant()">
                    <div class="consol-recon-item-head">
                        <span class="consol-recon-severity consol-recon-severity--@alert.Severity.ToString().ToLowerInvariant()">
                            @alert.Severity.ToString().ToUpperInvariant()
                        </span>
                        <span class="consol-recon-item-title">@alert.Title</span>
                        @if (alert.Difference.HasValue)
                        {
                            <span class="consol-recon-diff">
                                @(alert.Difference.Value >= 0 ? "+" : "")@alert.Difference.Value.ToString("N2") @_data!.ReportingCurrency
                            </span>
                        }
                        <button class="consol-recon-drill-btn" @onclick="() => ToggleDrilldown(alert.AlertId)">
                            @if (_expandedAlerts.Contains(alert.AlertId))
                            {
                                <span>Hide details</span>
                            }
                            else
                            {
                                <span>Drill down</span>
                            }
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="@(_expandedAlerts.Contains(alert.AlertId) ? "consol-chevron--up" : "")"><polyline points="6 9 12 15 18 9"/></svg>
                        </button>
                    </div>
                    <p class="consol-recon-msg">@alert.Message</p>
                    @if (_expandedAlerts.Contains(alert.AlertId) && alert.DrilldownItems.Count > 0)
                    {
                        <table class="consol-recon-drill-table">
                            <thead>
                                <tr>
                                    <th>Entity</th>
                                    <th>Field</th>
                                    <th>Reported</th>
                                    <th>Expected</th>
                                    <th>Diff</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in alert.DrilldownItems)
                                {
                                    <tr class="@(d.Difference != 0 ? "consol-recon-drill-row--mismatch" : "")">
                                        <td>@d.EntityName</td>
                                        <td class="portal-table-mono">@d.FieldCode</td>
                                        <td class="portal-table-mono">@d.ReportedValue.ToString("N2")</td>
                                        <td class="portal-table-mono">@d.ExpectedValue.ToString("N2")</td>
                                        <td class="portal-table-mono @(d.Difference != 0 ? "consol-val--danger" : "consol-val--ok")">
                                            @(d.Difference >= 0 ? "+" : "")@d.Difference.ToString("N2")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            }
        </div>
    }

    @if (_loading)
    {
        <SkeletonGuard OnRetry="ReloadAsync">
            <div aria-busy="true" aria-label="Loading consolidation data…">
                <div class="fc-skel-stats-row fc-skel-section">
                    <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Stat" Index="0" />
                    <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Stat" Index="3" />
                    <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Stat" Index="6" />
                    <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Stat" Index="9" />
                </div>
                <div class="consol-layout fc-skel-section">
                    <div class="portal-card" style="padding: 1rem;">
                        <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Text" Index="12" />
                        <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Text" Index="13" />
                        <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Text" Index="14" />
                        <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Text" Index="15" />
                        <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Text" Index="16" />
                    </div>
                    <div class="portal-card" style="padding: 1rem;">
                        <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.FormTable" Index="17" />
                    </div>
                </div>
            </div>
        </SkeletonGuard>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="portal-alert portal-alert-error">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            <p>@_error</p>
        </div>
    }
    else if (_data is not null)
    {
        @* ── Stat Cards ── *@
        <div class="portal-dash-stats" style="margin-bottom: var(--space-5);">
            <div class="portal-stat-card">
                <div class="portal-stat-header">
                    <div class="portal-stat-icon portal-stat-icon-blue">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4-4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                    </div>
                </div>
                <span class="portal-stat-value">@_data.SubsidiaryCount</span>
                <span class="portal-stat-label">Entities</span>
            </div>
            <div class="portal-stat-card">
                <div class="portal-stat-header">
                    <div class="portal-stat-icon portal-stat-icon-green">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                    </div>
                </div>
                <span class="portal-stat-value">@FormatAmount(_data.GrossAmount)</span>
                <span class="portal-stat-label">Gross (@_data.ReportingCurrency)</span>
            </div>
            <div class="portal-stat-card">
                <div class="portal-stat-header">
                    <div class="portal-stat-icon portal-stat-icon-amber">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                    </div>
                </div>
                <span class="portal-stat-value consol-stat-elim">@FormatAmount(_data.EliminationAdjustments)</span>
                <span class="portal-stat-label">Eliminations</span>
            </div>
            <div class="portal-stat-card">
                <div class="portal-stat-header">
                    <div class="portal-stat-icon portal-stat-icon-purple">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    </div>
                </div>
                <span class="portal-stat-value">@FormatAmount(_data.NetAmount)</span>
                <span class="portal-stat-label">Net Consolidated (@_data.ReportingCurrency)</span>
            </div>
        </div>

        @* ── Main 2-column layout: Tree + Content ── *@
        <div class="consol-layout">

            @* ── 1. Entity Hierarchy Tree ── *@
            <aside class="consol-tree-panel portal-card" aria-label="Entity hierarchy">
                <div class="consol-tree-header">
                    <h3 class="consol-tree-title">Entity Structure</h3>
                    @if (_selectedEntityId.HasValue)
                    {
                        <button class="consol-tree-clear" @onclick="ClearEntityFilter" title="Show all entities">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                            Clear
                        </button>
                    }
                </div>
                <div class="consol-tree-body">
                    @if (_data.EntityHierarchy.Count > 0)
                    {
                        @foreach (var root in _data.EntityHierarchy)
                        {
                            RenderTreeNode(root, 0);
                        }
                    }
                    else
                    {
                        <p class="consol-tree-empty">No entity structure available.</p>
                    }
                </div>
            </aside>

            @* ── Right content area ── *@
            <div class="consol-content">

                @* ── 2. Consolidation Status Matrix ── *@
                @if (_statusMatrix.Count > 0)
                {
                    <div class="portal-card consol-section">
                        <h3 class="portal-card-title" style="padding: 1rem 1.25rem 0;">Submission Status Matrix</h3>
                        <p class="consol-section-desc">Rows = entities, columns = return types. Each cell shows submission status.</p>
                        <div class="portal-table-container">
                            <table class="portal-table consol-matrix-table">
                                <thead>
                                    <tr>
                                        <th class="consol-matrix-entity-col">Entity</th>
                                        @foreach (var col in _returnColumns)
                                        {
                                            <th class="consol-matrix-cell-col" title="@col">@col</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in _statusMatrix)
                                    {
                                        var isSelected = _selectedEntityId == row.EntityId;
                                        <tr class="@(isSelected ? "consol-matrix-row--active" : "")">
                                            <td class="consol-matrix-entity">
                                                <span class="consol-matrix-entity-name">@row.EntityName</span>
                                                <span class="consol-matrix-entity-code">@row.EntityCode</span>
                                            </td>
                                            @foreach (var col in _returnColumns)
                                            {
                                                var cell = row.Returns.FirstOrDefault(r => r.ReturnCode == col);
                                                var status = cell?.Status ?? ConsolidationSubmissionStatus.Missing;
                                                <td class="consol-matrix-cell">
                                                    <span class="consol-status-dot consol-status-dot--@status.ToString().ToLowerInvariant()"
                                                          title="@GetStatusLabel(status)@(cell?.SubmittedAt != null ? $" — {cell.SubmittedAt:d MMM yyyy}" : "")">
                                                        @GetStatusIcon(status)
                                                    </span>
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="consol-matrix-legend">
                            <span class="consol-legend-item"><span class="consol-status-dot consol-status-dot--accepted">&#10003;</span> Accepted</span>
                            <span class="consol-legend-item"><span class="consol-status-dot consol-status-dot--submitted">&#8226;</span> Submitted</span>
                            <span class="consol-legend-item"><span class="consol-status-dot consol-status-dot--pending">&#9711;</span> Pending</span>
                            <span class="consol-legend-item"><span class="consol-status-dot consol-status-dot--rejected">&#10007;</span> Rejected</span>
                            <span class="consol-legend-item"><span class="consol-status-dot consol-status-dot--missing">&mdash;</span> Missing</span>
                        </div>
                    </div>
                }

                @* ── 3. Aggregation Comparison ── *@
                @if (_aggregationFields.Count > 0)
                {
                    <div class="portal-card consol-section">
                        <h3 class="portal-card-title" style="padding: 1rem 1.25rem 0;">Aggregation Comparison</h3>
                        <p class="consol-section-desc">Numeric field totals with per-entity breakdown.</p>
                        <div class="consol-agg-list">
                            @foreach (var field in _aggregationFields)
                            {
                                var maxVal = field.EntityValues.Count > 0 ? field.EntityValues.Max(v => v.Value) : 1m;
                                if (maxVal == 0) maxVal = 1;

                                <div class="consol-agg-card">
                                    <div class="consol-agg-header">
                                        <div>
                                            <span class="consol-agg-field-name">@field.FieldName</span>
                                            <span class="consol-agg-field-code">@field.FieldCode</span>
                                        </div>
                                        <div class="consol-agg-totals">
                                            <span class="consol-agg-total">@field.GroupTotal.ToString("N2") <small>@field.Currency</small></span>
                                            @if (field.Variance != 0)
                                            {
                                                <span class="consol-agg-variance @(field.Variance > 0 ? "consol-agg-variance--over" : "consol-agg-variance--under")">
                                                    @(field.Variance > 0 ? "+" : "")@field.Variance.ToString("N2") (@field.VariancePercent.ToString("F1")%)
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="consol-agg-variance consol-agg-variance--match">Balanced</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="consol-agg-bars">
                                        @foreach (var entity in field.EntityValues)
                                        {
                                            var pct = maxVal > 0 ? (double)(entity.Value / maxVal) * 100 : 0;
                                            <div class="consol-agg-bar-row">
                                                <span class="consol-agg-bar-label" title="@entity.EntityName">@entity.EntityName</span>
                                                <div class="consol-agg-bar-track">
                                                    <div class="consol-agg-bar-fill" style="width: @pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                                </div>
                                                <span class="consol-agg-bar-value">
                                                    @entity.Value.ToString("N2")
                                                    @* ── 4. FX Conversion Indicator ── *@
                                                    @if (entity.LocalCurrency != field.Currency && !string.IsNullOrEmpty(entity.LocalCurrency))
                                                    {
                                                        <span class="consol-fx-chip @(entity.IsFxStale ? "consol-fx-chip--stale" : "")">
                                                            @entity.LocalCurrency @entity.LocalValue.ToString("N0") &#64; @entity.FxRate.ToString("N2")
                                                            <small>(@entity.FxRateDate.ToString("d MMM"))</small>
                                                            @if (entity.IsFxStale)
                                                            {
                                                                <span class="consol-fx-stale-badge" title="Rate is older than 24 hours">Stale</span>
                                                            }
                                                        </span>
                                                    }
                                                </span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @* ── By Jurisdiction (existing table, enhanced with FX indicators) ── *@
                <div class="portal-card consol-section">
                    <h3 class="portal-card-title" style="padding: 1rem 1.25rem 0;">By Jurisdiction</h3>
                    <div class="portal-table-container">
                        <table class="portal-table">
                            <thead>
                                <tr>
                                    <th>Jurisdiction</th>
                                    <th>Entities</th>
                                    <th>Submissions</th>
                                    <th>Overdue</th>
                                    <th>Gross (Local)</th>
                                    <th>FX Rate</th>
                                    <th>Gross (@_data.ReportingCurrency)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in _filteredJurisdictions)
                                {
                                    <tr>
                                        <td>
                                            <span class="consol-jurisdiction-flag">@row.CountryCode</span>
                                            @row.CountryName
                                        </td>
                                        <td>@row.InstitutionCount</td>
                                        <td>@row.SubmissionCount</td>
                                        <td>
                                            @if (row.OverdueSubmissionCount > 0)
                                            {
                                                <span class="consol-overdue-badge">@row.OverdueSubmissionCount</span>
                                            }
                                            else
                                            {
                                                <span class="consol-val--ok">0</span>
                                            }
                                        </td>
                                        <td class="portal-table-mono">@row.GrossAmountLocal.ToString("N2") @row.Currency</td>
                                        <td>
                                            @* ── 4. FX conversion indicator ── *@
                                            <span class="consol-fx-inline @(row.IsFxRateStale ? "consol-fx-chip--stale" : "")">
                                                @row.FxRateToReportingCurrency.ToString("N4")
                                                @if (row.FxRateDate != default)
                                                {
                                                    <small class="consol-fx-date">(@row.FxRateDate.ToString("d MMM"))</small>
                                                }
                                                @if (row.IsFxRateStale)
                                                {
                                                    <span class="consol-fx-stale-badge" title="Rate is older than 24 hours">Stale</span>
                                                }
                                            </span>
                                        </td>
                                        <td class="portal-table-mono">@row.GrossAmountReportingCurrency.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                @* ── 5. Elimination Entries ── *@
                @if (_eliminations.Count > 0)
                {
                    <div class="portal-card consol-section">
                        <h3 class="portal-card-title" style="padding: 1rem 1.25rem 0;">
                            Intercompany Eliminations
                            <span class="consol-elim-count">@_eliminations.Count entries</span>
                        </h3>
                        <p class="consol-section-desc">Intercompany transactions eliminated from consolidated totals.</p>
                        <div class="consol-elim-list">
                            @foreach (var elim in _eliminations)
                            {
                                <div class="consol-elim-row @(elim.IsMatched ? "consol-elim-row--matched" : "consol-elim-row--unmatched")">
                                    <div class="consol-elim-main">
                                        <div class="consol-elim-desc-line">
                                            <span class="consol-elim-category-badge">@elim.Category</span>
                                            <span class="consol-elim-desc">@elim.Description</span>
                                            <span class="consol-elim-badge">Eliminated</span>
                                        </div>
                                        <div class="consol-elim-amount-line">
                                            <span class="consol-elim-amount">
                                                @if (elim.Currency != _data.ReportingCurrency)
                                                {
                                                    <span class="consol-elim-local">@elim.Currency @elim.Amount.ToString("N2")</span>
                                                    <span class="consol-elim-eq">=</span>
                                                }
                                                <span class="consol-elim-converted">@_data.ReportingCurrency @elim.AmountReportingCurrency.ToString("N2")</span>
                                            </span>
                                        </div>
                                        <div class="consol-elim-parties">
                                            <span class="consol-elim-source">@elim.SourceEntityName</span>
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                                            <span class="consol-elim-counter">@elim.CounterpartyEntityName</span>
                                        </div>
                                    </div>
                                    @if (!elim.IsMatched)
                                    {
                                        <span class="consol-elim-warn" title="Counterparty entry not found or amount mismatch">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                                            Unmatched
                                        </span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {

    @* ── Render helper for the tree (declared outside lifecycle methods to work in Blazor) ── *@
    private void RenderTreeNode(EntityNode node, int depth) => __builder.AddContent(0, RenderTreeNodeFragment(node, depth));

    private RenderFragment RenderTreeNodeFragment(EntityNode node, int depth) => __builder =>
    {
        var isSelected = _selectedEntityId == node.EntityId;
        var isExpanded = _expandedNodes.Contains(node.EntityId);
        var hasChildren = node.Children.Count > 0;

        <div class="consol-tree-node" style="--depth: @depth">
            <button class="consol-tree-node-btn @(isSelected ? "consol-tree-node-btn--active" : "")"
                    @onclick="() => SelectEntity(node.EntityId)"
                    title="@node.Name (@node.Code)">
                @if (hasChildren)
                {
                    <button class="consol-tree-toggle"
                            @onclick="() => ToggleNode(node.EntityId)"
                            @onclick:stopPropagation="true"
                            aria-label="@(isExpanded ? "Collapse" : "Expand") @node.Name">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"
                             class="@(isExpanded ? "consol-tree-chevron--open" : "")">
                            <polyline points="9 18 15 12 9 6" />
                        </svg>
                    </button>
                }
                else
                {
                    <span class="consol-tree-spacer"></span>
                }
                <span class="consol-tree-icon">
                    @switch (node.EntityType)
                    {
                        case "HoldingCompany":
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12" y2="18.01"/><line x1="8" y1="6" x2="8" y2="6.01"/><line x1="16" y1="6" x2="16" y2="6.01"/><line x1="8" y1="10" x2="8" y2="10.01"/><line x1="16" y1="10" x2="16" y2="10.01"/><line x1="8" y1="14" x2="8" y2="14.01"/><line x1="16" y1="14" x2="16" y2="14.01"/></svg>
                            break;
                        case "Branch":
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 009 9"/></svg>
                            break;
                        default:
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
                            break;
                    }
                </span>
                <span class="consol-tree-label">@node.Name</span>
                @if (node.PendingCount > 0)
                {
                    <span class="consol-tree-pending" title="@node.PendingCount pending">@node.PendingCount</span>
                }
            </button>
        </div>

        @if (hasChildren && isExpanded)
        {
            @foreach (var child in node.Children)
            {
                RenderTreeNode(child, depth + 1);
            }
        }
    };

    // ── State ──
    private bool _loading = true;
    private bool _downloading;
    private string? _error;
    private CrossJurisdictionConsolidation? _data;
    private int? _selectedEntityId;
    private bool _showReconPanel;

    private readonly HashSet<int> _expandedNodes = new();
    private readonly HashSet<string> _expandedAlerts = new();

    // Computed / filtered views
    private List<ConsolidationStatusEntry> _statusMatrix = new();
    private List<string> _returnColumns = new();
    private List<AggregationField> _aggregationFields = new();
    private List<EliminationEntry> _eliminations = new();
    private List<ReconciliationAlert> _reconAlerts = new();
    private List<JurisdictionConsolidationItem> _filteredJurisdictions = new();

    private readonly IReadOnlyList<BreadcrumbItem> _breadcrumb = new List<BreadcrumbItem>
    {
        new("Home", "/"),
        new("Dashboard", "/dashboard"),
        new("Consolidation", null, IsCurrent: true)
    };

    // ── Lifecycle ──

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var tenantId = TenantContext.CurrentTenantId;
            if (!tenantId.HasValue)
            {
                _error = "Tenant context unavailable.";
                return;
            }

            _data = await ConsolidationService.GetConsolidation(tenantId.Value, "NGN");

            // Expand root nodes by default
            foreach (var root in _data.EntityHierarchy)
                _expandedNodes.Add(root.EntityId);

            // Auto-show recon banner if there are Error-level alerts
            _reconAlerts = _data.ReconciliationAlerts;
            _showReconPanel = _reconAlerts.Any(a => a.Severity == ReconciliationAlertSeverity.Error);

            ApplyEntityFilter();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Tree interactions ──

    private void ToggleNode(int entityId)
    {
        if (!_expandedNodes.Add(entityId))
            _expandedNodes.Remove(entityId);
    }

    private void SelectEntity(int entityId)
    {
        _selectedEntityId = _selectedEntityId == entityId ? null : entityId;
        ApplyEntityFilter();
    }

    private void ClearEntityFilter()
    {
        _selectedEntityId = null;
        ApplyEntityFilter();
    }

    private void ApplyEntityFilter()
    {
        if (_data is null) return;

        if (_selectedEntityId.HasValue)
        {
            var entityIds = CollectEntityIds(_data.EntityHierarchy, _selectedEntityId.Value);
            _statusMatrix = _data.StatusMatrix.Where(s => entityIds.Contains(s.EntityId)).ToList();
            _aggregationFields = _data.AggregationFields
                .Select(f => new AggregationField
                {
                    FieldCode = f.FieldCode,
                    FieldName = f.FieldName,
                    GroupTotal = f.EntityValues.Where(v => entityIds.Contains(v.EntityId)).Sum(v => v.Value),
                    ExpectedTotal = f.ExpectedTotal,
                    Currency = f.Currency,
                    EntityValues = f.EntityValues.Where(v => entityIds.Contains(v.EntityId)).ToList()
                })
                .ToList();
            _eliminations = _data.Eliminations.Where(e => entityIds.Contains(e.SourceEntityId) || entityIds.Contains(e.CounterpartyEntityId)).ToList();

            // Filter jurisdictions by looking at entity submissions
            var entityCodes = _statusMatrix.Select(s => s.EntityCode).ToHashSet(StringComparer.OrdinalIgnoreCase);
            _filteredJurisdictions = _data.Jurisdictions;
        }
        else
        {
            _statusMatrix = _data.StatusMatrix;
            _aggregationFields = _data.AggregationFields;
            _eliminations = _data.Eliminations;
            _filteredJurisdictions = _data.Jurisdictions;
        }

        _returnColumns = _statusMatrix
            .SelectMany(s => s.Returns)
            .Select(r => r.ReturnCode)
            .Distinct()
            .OrderBy(c => c)
            .ToList();
    }

    private static HashSet<int> CollectEntityIds(List<EntityNode> nodes, int targetId)
    {
        var result = new HashSet<int>();
        foreach (var node in nodes)
        {
            if (CollectIdsRecursive(node, targetId, result))
                break;
        }
        return result;
    }

    private static bool CollectIdsRecursive(EntityNode node, int targetId, HashSet<int> result)
    {
        if (node.EntityId == targetId)
        {
            AddAllDescendants(node, result);
            return true;
        }
        foreach (var child in node.Children)
        {
            if (CollectIdsRecursive(child, targetId, result))
                return true;
        }
        return false;
    }

    private static void AddAllDescendants(EntityNode node, HashSet<int> result)
    {
        result.Add(node.EntityId);
        foreach (var child in node.Children)
            AddAllDescendants(child, result);
    }

    // ── Reconciliation drill-down ──

    private void ToggleDrilldown(string alertId)
    {
        if (!_expandedAlerts.Add(alertId))
            _expandedAlerts.Remove(alertId);
    }

    // ── Download consolidated return ──

    private async Task DownloadConsolidated()
    {
        if (_data is null) return;
        _downloading = true;
        StateHasChanged();

        try
        {
            var csv = BuildConsolidatedCsv();
            var fileName = $"Consolidation_{_data.ReportingCurrency}_{DateTime.UtcNow:yyyyMMdd_HHmmss}.csv";
            var bytes = System.Text.Encoding.UTF8.GetBytes(csv);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("portalDownloadFile", fileName, "text/csv", base64);
        }
        catch
        {
            // Silently handle — button state resets
        }
        finally
        {
            _downloading = false;
            StateHasChanged();
        }
    }

    private string BuildConsolidatedCsv()
    {
        var sb = new System.Text.StringBuilder();

        // Header
        sb.AppendLine($"Consolidated Return,Generated {DateTime.UtcNow:dd MMM yyyy HH:mm} UTC");
        sb.AppendLine($"Reporting Currency,{_data!.ReportingCurrency}");
        sb.AppendLine($"Entities,{_data.SubsidiaryCount}");
        sb.AppendLine($"Gross,{_data.GrossAmount:N2}");
        sb.AppendLine($"Eliminations,{_data.EliminationAdjustments:N2}");
        sb.AppendLine($"Net Consolidated,{_data.NetAmount:N2}");
        sb.AppendLine();

        // Jurisdictions
        sb.AppendLine("JURISDICTIONS");
        sb.AppendLine("Country,Currency,Entities,Submissions,Overdue,Gross (Local),FX Rate,FX Date,Gross (Reporting)");
        foreach (var j in _filteredJurisdictions)
        {
            sb.AppendLine($"{Esc(j.CountryName)},{j.Currency},{j.InstitutionCount},{j.SubmissionCount},{j.OverdueSubmissionCount},{j.GrossAmountLocal:N2},{j.FxRateToReportingCurrency:N4},{j.FxRateDate:dd MMM yyyy},{j.GrossAmountReportingCurrency:N2}");
        }
        sb.AppendLine();

        // Aggregation Fields
        if (_aggregationFields.Count > 0)
        {
            sb.AppendLine("AGGREGATION");
            sb.AppendLine("Field,Entity,Value (Reporting),Local Currency,Local Value,FX Rate");
            foreach (var f in _aggregationFields)
            {
                foreach (var e in f.EntityValues)
                {
                    sb.AppendLine($"{Esc(f.FieldName)},{Esc(e.EntityName)},{e.Value:N2},{e.LocalCurrency},{e.LocalValue:N2},{e.FxRate:N4}");
                }
            }
            sb.AppendLine();
        }

        // Eliminations
        if (_eliminations.Count > 0)
        {
            sb.AppendLine("ELIMINATIONS");
            sb.AppendLine("Category,Description,Source Entity,Counterparty,Amount,Currency,Amount (Reporting),Matched");
            foreach (var e in _eliminations)
            {
                sb.AppendLine($"{Esc(e.Category)},{Esc(e.Description)},{Esc(e.SourceEntityName)},{Esc(e.CounterpartyEntityName)},{e.Amount:N2},{e.Currency},{e.AmountReportingCurrency:N2},{(e.IsMatched ? "Yes" : "No")}");
            }
        }

        return sb.ToString();
    }

    // ── Formatting helpers ──

    private static string FormatAmount(decimal amount)
    {
        if (Math.Abs(amount) >= 1_000_000_000)
            return (amount / 1_000_000_000).ToString("N2") + "B";
        if (Math.Abs(amount) >= 1_000_000)
            return (amount / 1_000_000).ToString("N2") + "M";
        if (Math.Abs(amount) >= 1_000)
            return (amount / 1_000).ToString("N1") + "K";
        return amount.ToString("N2");
    }

    private static string GetStatusLabel(ConsolidationSubmissionStatus status) => status switch
    {
        ConsolidationSubmissionStatus.Accepted => "Accepted",
        ConsolidationSubmissionStatus.Submitted => "Submitted",
        ConsolidationSubmissionStatus.Pending => "Pending",
        ConsolidationSubmissionStatus.Rejected => "Rejected",
        _ => "Missing"
    };

    private static string GetStatusIcon(ConsolidationSubmissionStatus status) => status switch
    {
        ConsolidationSubmissionStatus.Accepted => "\u2713",
        ConsolidationSubmissionStatus.Submitted => "\u2022",
        ConsolidationSubmissionStatus.Pending => "\u25CB",
        ConsolidationSubmissionStatus.Rejected => "\u2717",
        _ => "\u2014"
    };

    private static string Esc(string? v)
    {
        if (string.IsNullOrEmpty(v)) return "";
        if (v.Contains(',') || v.Contains('"') || v.Contains('\n'))
            return "\"" + v.Replace("\"", "\"\"") + "\"";
        return v;
    }
}
