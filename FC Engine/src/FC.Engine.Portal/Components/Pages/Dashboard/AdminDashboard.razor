@code {
    private AdminDashboardData? _data;
    private bool _loading = true;
    private bool _chartsRendered;
    private string? _error;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        _chartsRendered = false;
        StateHasChanged();

        try
        {
            if (TenantContext.CurrentTenantId is not { } tenantId)
            {
                _error = "Tenant context is not available for this dashboard.";
                return;
            }

            _data = await DashboardService.GetAdminDashboard(tenantId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_data is null || _chartsRendered)
        {
            return;
        }

        await Charts.RenderLineChart("adminDataQualityChart", _data.DataQualityTrend);
        var notifLabels = new[] { "Delivered", "Sent", "Queued", "Failed" };
        var notifValues = new[] { _data.NotificationStats.Delivered, _data.NotificationStats.Sent, _data.NotificationStats.Queued, _data.NotificationStats.Failed };
        var notifColors = new[] { "#0f766e", "#3b82f6", "#d97706", "#b91c1c" };
        await Charts.RenderDonutWithColors("adminNotificationChart", notifLabels, notifValues, notifColors);
        _chartsRendered = true;
    }

    private static IReadOnlyList<UsageTile> BuildUsageTiles(AdminDashboardData data)
    {
        return
        [
            new UsageTile("Users", data.Usage.UsersUsed.ToString("N0"), data.Usage.UsersLimit.ToString("N0"), data.Usage.UsersUsagePercent),
            new UsageTile("Entities", data.Usage.EntitiesUsed.ToString("N0"), data.Usage.EntitiesLimit.ToString("N0"), data.Usage.EntitiesUsagePercent),
            new UsageTile("Modules", data.Usage.ModulesUsed.ToString("N0"), data.Usage.ModulesLimit.ToString("N0"), data.Usage.ModulesUsagePercent),
            new UsageTile("Storage", data.Usage.StorageUsedMb.ToString("0.##") + " MB", data.Usage.StorageLimitMb.ToString("N0") + " MB", data.Usage.StorageUsagePercent),
            new UsageTile("API calls", data.Usage.ApiCallsUsed.ToString("N0"), data.Usage.ApiCallsLimit.ToString("N0"), data.Usage.ApiUsagePercent)
        ];
    }

    private static decimal BuildControlScore(AdminDashboardData data, decimal usagePressure)
    {
        var headroomScore = Math.Max(0m, 100m - usagePressure);
        return Math.Round((data.ValidationPassRate + data.CompletenessScore + headroomScore) / 3m, 1);
    }

    private static decimal BuildDeliveryRate(NotificationStats stats)
    {
        return stats.Sent <= 0 ? 100m : Math.Round((decimal)stats.Delivered * 100m / stats.Sent, 2);
    }

    private static string ResolveBannerTone(decimal controlScore, decimal usagePressure, decimal outstandingBalance)
    {
        if (controlScore < 60m || usagePressure >= 90m || outstandingBalance > 0m)
        {
            return "critical";
        }

        if (controlScore < 75m || usagePressure >= 75m)
        {
            return "warning";
        }

        return "success";
    }

    private static string BuildBannerHeadline(decimal controlScore, decimal usagePressure, decimal outstandingBalance)
    {
        if (controlScore < 60m || usagePressure >= 90m)
        {
            return "This tenant workspace needs active administrative attention.";
        }

        if (outstandingBalance > 0m)
        {
            return "The tenant is operational, but commercial or capacity pressure is building.";
        }

        return "The tenant workspace is operating inside healthy quality and capacity bands.";
    }

    private static string BuildBannerDetail(decimal controlScore, string tightestResource, decimal usagePressure, decimal deliveryRate)
    {
        return $"Workspace readiness is {controlScore:0}/100. The tightest capacity area is {tightestResource} at {usagePressure:0.#}%, while notification delivery is running at {deliveryRate:0.#}%.";
    }

    private static string FormatCurrency(decimal amount, string currency)
    {
        return $"{currency} {amount:N2}";
    }

    private static string BuildContributorShare(int count, IEnumerable<UserContributionItem> contributors)
    {
        var total = contributors.Sum(x => x.SubmissionCount);
        if (total <= 0)
        {
            return "0%";
        }

        return $"{Math.Round((decimal)count * 100m / total, 1):0.#}% of volume";
    }

    private sealed record UsageTile(string Label, string UsedText, string LimitText, decimal Percent);
}
