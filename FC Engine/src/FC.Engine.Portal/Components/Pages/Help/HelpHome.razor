@page "/help"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "InstitutionUser")]

<PageTitle>Help Center — RegOS™ Portal</PageTitle>

<HelpLayout>
    <!-- Search -->
    <div class="help-search-wrapper">
        <div class="help-search-box">
            <svg class="help-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" class="help-search-input" placeholder="Search for help..."
                   @bind="searchQuery" @bind:event="oninput" aria-label="Search help articles" />
            @if (!string.IsNullOrEmpty(searchQuery))
            {
                <button class="help-search-clear" @onclick="ClearSearch" aria-label="Clear search">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(searchQuery))
    {
        <!-- Search Results -->
        <div class="help-search-results">
            <h2 class="help-section-title">Search Results for "@searchQuery"</h2>
            @if (filteredTopics.Count == 0)
            {
                <p class="help-empty-text">No results found. Try a different search term or browse the topics below.</p>
            }
            else
            {
                <div class="help-topics-grid">
                    @foreach (var topic in filteredTopics)
                    {
                        <a href="@topic.Link" class="help-topic-card">
                            <div class="help-topic-icon" aria-hidden="true">@((MarkupString)topic.Icon)</div>
                            <h3 class="help-topic-title">@HighlightMatch(topic.Title)</h3>
                            <p class="help-topic-desc">@HighlightMatch(topic.Description)</p>
                        </a>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <!-- Quick Links -->
        <div class="help-quick-links">
            <a href="/help/submission-guide" class="help-quick-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/>
                </svg>
                How to Submit a Return
            </a>
            <a href="/help/validation-errors" class="help-quick-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                    <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
                Understanding Validation Errors
            </a>
            <a href="/schemas" class="help-quick-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                XML Schema Guide
            </a>
            <a href="/help/support" class="help-quick-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
                </svg>
                Contact Support
            </a>
            <a href="/help/knowledge-base" class="help-quick-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/>
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>
                </svg>
                Knowledge Base
            </a>
        </div>

        <!-- Popular Topics -->
        <h2 class="help-section-title">Popular Topics</h2>
        <div class="help-topics-grid">
            @foreach (var topic in allTopics)
            {
                <a href="@topic.Link" class="help-topic-card">
                    <div class="help-topic-icon" aria-hidden="true">@((MarkupString)topic.Icon)</div>
                    <h3 class="help-topic-title">@topic.Title</h3>
                    <p class="help-topic-desc">@topic.Description</p>
                </a>
            }
        </div>
    }
</HelpLayout>

@code {
    private string searchQuery = "";
    private List<HelpTopic> filteredTopics = new();

    private readonly List<HelpTopic> allTopics = new()
    {
        new("Getting Started", "Step-by-step guide for first-time users of the FI Portal.",
            "/help/getting-started",
            "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><circle cx='12' cy='12' r='10'/><polygon points='10 8 16 12 10 16 10 8'/></svg>"),
        new("Submission Process", "Learn how to prepare and submit your regulatory returns.",
            "/help/submission-guide",
            "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4'/><polyline points='17 8 12 3 7 8'/><line x1='12' y1='3' x2='12' y2='15'/></svg>"),
        new("XML Format Guide", "Understand the XML structure and format requirements for each return type.",
            "/help/submission-guide#xml-format",
            "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><polyline points='16 18 22 12 16 6'/><polyline points='8 6 2 12 8 18'/></svg>"),
        new("Validation Errors", "Catalog of validation error types with explanations and fixes.",
            "/help/validation-errors",
            "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z'/><line x1='12' y1='9' x2='12' y2='13'/><line x1='12' y1='17' x2='12.01' y2='17'/></svg>"),
        new("Maker-Checker Workflow", "How the dual-approval process works for your institution.",
            "/help/faq#approvals",
            "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'/></svg>"),
        new("Account & Security", "Managing your account, password, and team members.",
            "/help/faq#account",
            "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><rect x='3' y='11' width='18' height='11' rx='2' ry='2'/><path d='M7 11V7a5 5 0 0110 0v4'/></svg>"),
        new("Reporting Calendar", "Deadlines, reporting periods, and submission windows.",
            "/help/faq#compliance",
            "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><rect x='3' y='4' width='18' height='18' rx='2' ry='2'/><line x1='16' y1='2' x2='16' y2='6'/><line x1='8' y1='2' x2='8' y2='6'/><line x1='3' y1='10' x2='21' y2='10'/></svg>"),
        new("Knowledge Base", "Searchable onboarding, module, FAQ, and troubleshooting articles.",
            "/help/knowledge-base",
            "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M4 19.5A2.5 2.5 0 016.5 17H20'/><path d='M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z'/></svg>"),
        new("Contact Support", "Get help from the CBN support team.",
            "/help/support",
            "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z'/></svg>")
    };

    private MarkupString HighlightMatch(string text)
    {
        if (string.IsNullOrEmpty(searchQuery) || string.IsNullOrEmpty(text))
            return new MarkupString(text);

        var idx = text.IndexOf(searchQuery, StringComparison.OrdinalIgnoreCase);
        if (idx < 0) return new MarkupString(text);

        var before = text[..idx];
        var match = text[idx..(idx + searchQuery.Length)];
        var after = text[(idx + searchQuery.Length)..];
        return new MarkupString($"{before}<mark>{match}</mark>{after}");
    }

    private void ClearSearch() => searchQuery = "";

    protected override void OnParametersSet() => ApplySearch();

    private void ApplySearch()
    {
        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            filteredTopics = new();
            return;
        }
        filteredTopics = allTopics
            .Where(t => t.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)
                || t.Description.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private record HelpTopic(string Title, string Description, string Link, string Icon);
}
