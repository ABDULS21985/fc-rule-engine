    private static string ComplianceFillClass(decimal pct)
    {
        if (pct < 50) return "pd-compliance-fill--low";
        if (pct < 80) return "pd-compliance-fill--mid";
        return "pd-compliance-fill--high";
    }

    private static string CompliancePctClass(decimal pct)
    {
        if (pct < 50) return "pd-pct--low";
        if (pct < 80) return "pd-pct--mid";
        return "pd-pct--high";
    }

    private static string GetSubStatusClass(string status) => status switch
    {
        "Approved"       => "pd-badge pd-badge--green",
        "Rejected"       => "pd-badge pd-badge--red",
        "PendingApproval"or "Submitted" => "pd-badge pd-badge--amber",
        _                => "pd-badge pd-badge--gray"
    };

    private static string TruncateName(string name, int max) =>
        name.Length <= max ? name : name[..(max - 1)] + "…";

    private static string FormatCurrencyShort(decimal v)
    {
        if (v >= 1_000_000) return $"₦{v / 1_000_000:0.0}M";
        if (v >= 1_000) return $"₦{v / 1_000:0.0}K";
        return $"₦{v:N0}";
    }
