@code {
    [CascadingParameter] private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private ForeSightDashboardData? _dashboard;
    private Guid _tenantId;
    private bool _isLoading = true;
    private bool _busy;
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;

        try
        {
            var auth = await AuthenticationStateTask;
            var tenantValue = auth.User.FindFirst("tenant_id")?.Value
                ?? auth.User.FindFirst("TenantId")?.Value
                ?? throw new InvalidOperationException("Tenant context is missing from the current session.");

            _tenantId = Guid.Parse(tenantValue);
            _dashboard = await LoadDashboardAsync(_tenantId);
        }
        catch (Exception ex)
        {
            _error = $"Unable to load ForeSight predictions: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RefreshAsync()
    {
        if (_tenantId == Guid.Empty)
        {
            return;
        }

        _busy = true;
        _error = null;

        try
        {
            await RunPredictionsAsync(_tenantId, "PORTAL_USER");
            _dashboard = await LoadDashboardAsync(_tenantId);
        }
        catch (Exception ex)
        {
            _error = $"Unable to refresh ForeSight predictions: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DownloadPdfAsync()
    {
        if (_tenantId == Guid.Empty)
        {
            return;
        }

        _busy = true;
        _error = null;

        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var foreSightService = scope.ServiceProvider.GetRequiredService<IForeSightService>();
            var bytes = await foreSightService.ExportFilingRiskReportAsync(_tenantId);
            var fileName = $"foresight-filing-risk-{DateTime.UtcNow:yyyyMMddHHmmss}.pdf";
            await JS.InvokeVoidAsync("portalDownloadBase64File", Convert.ToBase64String(bytes), fileName, "application/pdf");
        }
        catch (Exception ex)
        {
            _error = $"Unable to export the filing-risk report: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DismissAlertAsync(int alertId)
    {
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var foreSightService = scope.ServiceProvider.GetRequiredService<IForeSightService>();
            await foreSightService.DismissAlertAsync(alertId, "PORTAL_USER");
            if (_dashboard is not null)
            {
                _dashboard.Alerts.RemoveAll(x => x.Id == alertId);
            }
        }
        catch (Exception ex)
        {
            _error = $"Unable to dismiss alert: {ex.Message}";
        }
    }

    private async Task<ForeSightDashboardData> LoadDashboardAsync(Guid tenantId)
    {
        await using var readScope = ScopeFactory.CreateAsyncScope();
        var readService = readScope.ServiceProvider.GetRequiredService<IForeSightService>();
        var dashboard = await readService.GetTenantDashboardAsync(tenantId);

        if (!NeedsBootstrap(dashboard))
        {
            return dashboard;
        }

        await RunPredictionsAsync(tenantId, "FORESIGHT_AUTO");

        await using var refreshedScope = ScopeFactory.CreateAsyncScope();
        var refreshedService = refreshedScope.ServiceProvider.GetRequiredService<IForeSightService>();
        return await refreshedService.GetTenantDashboardAsync(tenantId);
    }

    private async Task RunPredictionsAsync(Guid tenantId, string performedBy)
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var foreSightService = scope.ServiceProvider.GetRequiredService<IForeSightService>();
        await foreSightService.RunAllPredictionsAsync(tenantId, performedBy);
    }

    private static bool NeedsBootstrap(ForeSightDashboardData dashboard) =>
        dashboard.FilingRisks.Count == 0
        && dashboard.CapitalForecasts.Count == 0
        && dashboard.ComplianceForecast is null
        && dashboard.Alerts.Count == 0;

    private static decimal BuildAverageConfidence(ForeSightDashboardData dashboard)
    {
        var scores = dashboard.FilingRisks.Select(x => x.ConfidenceScore)
            .Concat(dashboard.CapitalForecasts.Select(x => x.ConfidenceScore))
            .Concat(dashboard.ComplianceForecast is null ? [] : [dashboard.ComplianceForecast.ConfidenceScore])
            .ToList();

        return scores.Count == 0 ? 0m : scores.Average();
    }

    private static string ResolveBannerTone(int filingHigh, int capitalHigh, int alertCount)
    {
        if (filingHigh >= 3 || capitalHigh >= 2 || alertCount >= 4)
        {
            return "critical";
        }

        if (filingHigh > 0 || capitalHigh > 0 || alertCount > 0)
        {
            return "warning";
        }

        return "success";
    }

    private static string BuildBannerHeadline(int filingHigh, int capitalHigh, int alertCount)
    {
        var totalSignals = filingHigh + capitalHigh + alertCount;
        return totalSignals > 0
            ? $"{totalSignals} live predictive signal(s) need human review."
            : "The current institution is operating inside expected predictive bands.";
    }

    private static string BuildBannerDetail(int filingHigh, int capitalHigh, decimal averageConfidence)
    {
        return filingHigh + capitalHigh > 0
            ? $"{filingHigh} filing risk(s) and {capitalHigh} capital warning(s) are currently elevated, with average confidence at {averageConfidence:P0}."
            : $"All visible forecasts are currently in lower bands, with average confidence at {averageConfidence:P0}.";
    }

    private static string BuildRiskClass(string riskBand)
    {
        return riskBand.ToUpperInvariant() switch
        {
            "CRITICAL" => "portal-fs40-risk--critical",
            "HIGH" => "portal-fs40-risk--high",
            "MEDIUM" => "portal-fs40-risk--medium",
            "LOW" => "portal-fs40-risk--low",
            _ => "portal-fs40-risk--none"
        };
    }
}
