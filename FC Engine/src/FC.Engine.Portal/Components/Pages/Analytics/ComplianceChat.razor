@page "/analytics/chat"
@attribute [Authorize]
@using System.Globalization
@using System.Security.Claims
@using FC.Engine.Domain.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@inject IComplianceIqService ComplianceIqService
@inject NavigationManager Navigation

<PageTitle>ComplianceIQ</PageTitle>
<HeadContent>
    <link rel="stylesheet" href="FC.Engine.Portal.styles.css?v=20260316-chat" />
</HeadContent>

<div class="portal-iq-shell">
    <div class="portal-iq-orb portal-iq-orb--emerald" aria-hidden="true"></div>
    <div class="portal-iq-orb portal-iq-orb--gold" aria-hidden="true"></div>

    <div class="portal-iq-frame">
        <aside class="portal-iq-rail">
            <div class="portal-iq-brand">
                <div class="portal-iq-brand-mark" aria-hidden="true">
                    <svg viewBox="0 0 36 36" width="36" height="36">
                        <rect width="36" height="36" rx="9" fill="var(--cbn-green-deep, #006B3F)" />
                        <text x="18" y="24" text-anchor="middle" fill="white" font-size="12" font-weight="700" font-family="sans-serif">IQ</text>
                    </svg>
                </div>
                <div class="portal-iq-brand-copy">
                    <span class="portal-iq-brand-name">ComplianceIQ</span>
                    <span class="portal-iq-brand-tagline">Institution analyst workspace</span>
                </div>
            </div>

            <section class="portal-iq-rail-hero">
                <span class="portal-iq-overline">Analytics workspace</span>
                <h1 class="portal-iq-rail-title">Turn filings, anomalies, and compliance signals into grounded answers.</h1>
                <p class="portal-iq-rail-desc">Investigate regulatory questions with cited tenant evidence, structured tables, and follow-up prompts that keep the thread moving.</p>

                <div class="portal-iq-progress-cluster">
                    <div class="portal-iq-progress-ring" style="@SessionReadinessStyle" aria-hidden="true">
                        <div class="portal-iq-progress-ring-inner">
                            <strong>@SessionReadinessPct%</strong>
                            <span>@SessionReadinessLabel</span>
                        </div>
                    </div>
                    <div class="portal-iq-progress-copy">
                        <span class="portal-iq-progress-chip">@ConversationStatusLabel</span>
                        <strong>@ConversationHeadline</strong>
                        <p>@ConversationSupportingText</p>
                    </div>
                </div>
            </section>

            <section class="portal-iq-rail-card">
                <div class="portal-iq-rail-card-head">
                    <span>Live workspace snapshot</span>
                    <strong>@ConversationStatusLabel</strong>
                </div>

                <div class="portal-iq-rail-metrics">
                    <div class="portal-iq-rail-metric">
                        <span>Turns</span>
                        <strong>@AnalystTurnCount</strong>
                        <small>assistant responses captured</small>
                    </div>
                    <div class="portal-iq-rail-metric">
                        <span>Evidence</span>
                        <strong>@CitationCount</strong>
                        <small>citations surfaced so far</small>
                    </div>
                    <div class="portal-iq-rail-metric">
                        <span>Latest intent</span>
                        <strong>@LatestIntentLabel</strong>
                        <small>@LatestLatencyLabel</small>
                    </div>
                    <div class="portal-iq-rail-metric">
                        <span>Export</span>
                        <strong>@ExportStateLabel</strong>
                        <small>@ExportStateSupportingText</small>
                    </div>
                </div>
            </section>

            <section class="portal-iq-rail-card portal-iq-rail-card--prompts">
                <div class="portal-iq-rail-card-head">
                    <span>Suggested asks</span>
                    <strong>Grounded starting points</strong>
                </div>

                @foreach (var group in RailQuestionGroups)
                {
                    <div class="portal-iq-question-group">
                        <div class="portal-iq-question-group-title">@group.Key</div>
                        <div class="portal-iq-question-group-list">
                            @foreach (var question in group.Take(2))
                            {
                                <button class="portal-iq-quick-link"
                                        type="button"
                                        @onclick="() => AskQuickQuestionAsync(question.QuestionText)"
                                        disabled="@_isLoading">
                                    <i class="@question.IconClass" aria-hidden="true"></i>
                                    <span>@question.QuestionText</span>
                                </button>
                            }
                        </div>
                    </div>
                }
            </section>

            <section class="portal-iq-rail-card portal-iq-rail-card--trust">
                <div class="portal-iq-rail-card-head">
                    <span>Current focus</span>
                    <strong>Analyst guardrails</strong>
                </div>

                <ul class="portal-iq-mini-list">
                    @foreach (var signal in _trustSignals)
                    {
                        <li>
                            <span class="portal-iq-mini-list-dot" aria-hidden="true"></span>
                            <span>@signal</span>
                        </li>
                    }
                </ul>
            </section>
        </aside>

        <main class="portal-iq-main">
            <section class="portal-iq-main-head">
                <div class="portal-iq-main-copy">
                    <span class="portal-iq-overline">Live workspace</span>
                    <h2>ComplianceIQ analyst desk</h2>
                    <p>Review grounded answers, inspect supporting evidence, and move from broad questions into precise follow-ups without leaving the workspace.</p>
                </div>

                <div class="portal-iq-main-actions">
                    <button class="portal-btn portal-btn-outline portal-btn-sm" type="button" @onclick="GoToHistory">
                        Query History
                    </button>
                    <button class="portal-btn portal-btn-outline portal-btn-sm" type="button" @onclick="ExportConversationAsync" disabled="@(!_conversationId.HasValue)">
                        Export PDF
                    </button>
                    <button class="portal-btn portal-btn-primary portal-btn-sm" type="button" @onclick="StartNewConversation">
                        New Chat
                    </button>
                </div>
            </section>

            <div class="portal-iq-main-badges" aria-label="Workspace qualities">
                <span class="portal-iq-main-badge">Grounded answers only</span>
                <span class="portal-iq-main-badge">Tenant-linked citations</span>
                <span class="portal-iq-main-badge">Read-only and audit-logged</span>
            </div>

            <div class="portal-iq-workspace">
                <section class="portal-iq-stat-grid" aria-label="Conversation metrics">
                    <article class="portal-iq-stat-card">
                        <span class="portal-iq-stat-label">Conversation</span>
                        <strong class="portal-iq-stat-value">@ConversationStatusLabel</strong>
                        <p>@ConversationStatSupportingText</p>
                    </article>
                    <article class="portal-iq-stat-card">
                        <span class="portal-iq-stat-label">Turns processed</span>
                        <strong class="portal-iq-stat-value">@_messages.Count</strong>
                        <p>@UserTurnCount user prompts, @AnalystTurnCount assistant replies</p>
                    </article>
                    <article class="portal-iq-stat-card">
                        <span class="portal-iq-stat-label">Evidence surfaced</span>
                        <strong class="portal-iq-stat-value">@CitationCount</strong>
                        <p>@TableResponseCount table-backed response@(TableResponseCount == 1 ? "" : "s")</p>
                    </article>
                    <article class="portal-iq-stat-card">
                        <span class="portal-iq-stat-label">Latest posture</span>
                        <strong class="portal-iq-stat-value">@LatestConfidenceLabel</strong>
                        <p>@LatestIntentLabel</p>
                    </article>
                </section>

                <section class="portal-iq-stage">
                    <div class="portal-iq-stage-head">
                        <div>
                            <span class="portal-iq-stage-label">Conversation canvas</span>
                            <strong>@StageHeadline</strong>
                        </div>

                        @if (LatestResponse is not null)
                        {
                            <div class="portal-iq-stage-meta">
                                <span class="@ResolveConfidenceClass(LatestResponse.ConfidenceLevel)">@LatestResponse.ConfidenceLevel</span>
                                <span class="portal-iq-stage-meta-item">@LatestResponse.TotalTimeMs ms</span>
                                @if (LatestResponse.Citations.Count > 0)
                                {
                                    <span class="portal-iq-stage-meta-item">@LatestResponse.Citations.Count source@(LatestResponse.Citations.Count == 1 ? "" : "s")</span>
                                }
                            </div>
                        }
                    </div>

                    <div class="portal-iq-transcript" aria-live="polite">
                        @if (_messages.Count == 0)
                        {
                            <div class="portal-iq-empty-state">
                                <div class="portal-iq-empty-copy">
                                    <span class="portal-iq-overline">Start from a grounded prompt</span>
                                    <h3>Ask about risk, deadlines, anomalies, or filing health.</h3>
                                    <p>ComplianceIQ responds with tenant-scoped evidence, structured results where possible, and follow-up suggestions to help your team move faster.</p>
                                </div>

                                <div class="portal-iq-starter-grid">
                                    @foreach (var question in StarterQuestions)
                                    {
                                        <button class="portal-iq-starter-card"
                                                type="button"
                                                @onclick="() => AskQuickQuestionAsync(question.QuestionText)"
                                                disabled="@_isLoading">
                                            <div class="portal-iq-starter-icon" aria-hidden="true">
                                                <i class="@question.IconClass"></i>
                                            </div>
                                            <div class="portal-iq-starter-body">
                                                <span class="portal-iq-starter-category">@NormalizeCategory(question.Category)</span>
                                                <strong>@question.QuestionText</strong>
                                            </div>
                                        </button>
                                    }
                                </div>

                                <div class="portal-iq-highlight-row">
                                    <article class="portal-iq-highlight-card">
                                        <span>Grounded evidence</span>
                                        <strong>Every answer stays linked to your tenant context.</strong>
                                    </article>
                                    <article class="portal-iq-highlight-card">
                                        <span>Structured outputs</span>
                                        <strong>Tables appear inline when the query returns measurable data.</strong>
                                    </article>
                                    <article class="portal-iq-highlight-card">
                                        <span>Actionable follow-ups</span>
                                        <strong>Suggested next asks keep the investigation moving.</strong>
                                    </article>
                                </div>
                            </div>
                        }
                        else
                        {
                            @foreach (var message in _messages)
                            {
                                @if (message.IsUser)
                                {
                                    <div class="portal-iq-message portal-iq-message--user">
                                        <article class="portal-iq-message-card portal-iq-message-card--user">
                                            <div class="portal-iq-message-head">
                                                <span class="portal-iq-message-author">You</span>
                                                <span class="portal-iq-message-kicker">Question</span>
                                            </div>
                                            <div class="portal-iq-message-text">@message.Text</div>
                                        </article>
                                    </div>
                                }
                                else
                                {
                                    <div class="portal-iq-message portal-iq-message--assistant">
                                        <div class="portal-iq-avatar" aria-hidden="true">IQ</div>
                                        <article class="portal-iq-message-card portal-iq-message-card--assistant">
                                            <div class="portal-iq-message-head portal-iq-message-head--assistant">
                                                <div>
                                                    <span class="portal-iq-message-author">ComplianceIQ</span>
                                                    <strong>@ResolveAssistantHeading(message.Response)</strong>
                                                </div>
                                                @if (message.Response is not null)
                                                {
                                                    <div class="portal-iq-response-meta">
                                                        <span class="@ResolveConfidenceClass(message.Response.ConfidenceLevel)">@message.Response.ConfidenceLevel</span>
                                                        <span class="portal-iq-response-time">@message.Response.TotalTimeMs ms</span>
                                                    </div>
                                                }
                                            </div>

                                            <div class="portal-iq-message-text portal-iq-message-text--assistant">@message.Text</div>

                                            @if (message.Response?.Rows.Count > 0)
                                            {
                                                <div class="portal-iq-table-shell">
                                                    <table class="portal-iq-table" aria-label="ComplianceIQ response data">
                                                        <thead>
                                                            <tr>
                                                                @foreach (var header in message.Response.Rows[0].Keys)
                                                                {
                                                                    <th scope="col">@FormatHeader(header)</th>
                                                                }
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var row in message.Response.Rows.Take(10))
                                                            {
                                                                <tr>
                                                                    @foreach (var header in message.Response.Rows[0].Keys)
                                                                    {
                                                                        <td>@FormatCell(row.GetValueOrDefault(header))</td>
                                                                    }
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }

                                            @if (message.Response?.Citations.Count > 0)
                                            {
                                                <div class="portal-iq-citation-block">
                                                    <span class="portal-iq-block-label">Sources</span>
                                                    <div class="portal-iq-chip-row">
                                                        @foreach (var citation in message.Response.Citations.Take(5))
                                                        {
                                                            <span class="portal-iq-chip">@FormatCitation(citation)</span>
                                                        }
                                                    </div>
                                                </div>
                                            }

                                            @if (message.Response?.FollowUpSuggestions.Count > 0)
                                            {
                                                <div class="portal-iq-followups">
                                                    <span class="portal-iq-block-label">Suggested follow-ups</span>
                                                    <div class="portal-iq-chip-row">
                                                        @foreach (var suggestion in message.Response.FollowUpSuggestions)
                                                        {
                                                            <button class="portal-iq-chip portal-iq-chip--action"
                                                                    type="button"
                                                                    @onclick="() => AskQuickQuestionAsync(suggestion)"
                                                                    disabled="@_isLoading">
                                                                @suggestion
                                                            </button>
                                                        }
                                                    </div>
                                                </div>
                                            }

                                            @if (message.Response?.TurnId is int turnId)
                                            {
                                                <div class="portal-iq-feedback-row">
                                                    <span class="portal-iq-block-label">Was this useful?</span>
                                                    <div class="portal-iq-feedback-actions">
                                                        <button class="portal-iq-feedback-btn" type="button" @onclick="() => SubmitFeedbackAsync(turnId, (short)5)">
                                                            Helpful
                                                        </button>
                                                        <button class="portal-iq-feedback-btn portal-iq-feedback-btn--muted" type="button" @onclick="() => SubmitFeedbackAsync(turnId, (short)2)">
                                                            Needs work
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        </article>
                                    </div>
                                }
                            }

                            @if (_isLoading)
                            {
                                <div class="portal-iq-message portal-iq-message--assistant">
                                    <div class="portal-iq-avatar" aria-hidden="true">IQ</div>
                                    <article class="portal-iq-message-card portal-iq-message-card--assistant portal-iq-message-card--loading">
                                        <div class="portal-iq-loading-row">
                                            <span class="portal-iq-spinner" aria-hidden="true"></span>
                                            <div>
                                                <strong>Processing grounded query...</strong>
                                                <p>Pulling the most relevant tenant evidence and shaping the response.</p>
                                            </div>
                                        </div>
                                    </article>
                                </div>
                            }
                        }
                    </div>
                </section>

                <section class="portal-iq-composer">
                    <div class="portal-iq-composer-head">
                        <div>
                            <span class="portal-iq-overline">Compose</span>
                            <h3>Ask a grounded follow-up</h3>
                        </div>
                        <div class="portal-iq-composer-status">Read-only and audit-logged</div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_error))
                    {
                        <div class="portal-iq-error-banner">@_error</div>
                    }

                    <div class="portal-iq-composer-box">
                        <input class="portal-iq-input"
                               type="text"
                               placeholder="@ComposerPlaceholder"
                               @bind="_query"
                               @bind:event="oninput"
                               @onkeydown="HandleKeyDown"
                               disabled="@_isLoading"
                               aria-label="ComplianceIQ query input" />
                        <button class="portal-btn portal-btn-primary portal-iq-send-btn"
                                type="button"
                                @onclick="SendAsync"
                                disabled="@(_isLoading || string.IsNullOrWhiteSpace(_query))">
                            @(_isLoading ? "Working..." : "Ask ComplianceIQ")
                        </button>
                    </div>

                    <div class="portal-iq-composer-foot">
                        <small>Responses are grounded in approved returns, linked analytics, and platform records for the active institution workspace.</small>
                        <small>Press Enter to submit</small>
                    </div>
                </section>
            </div>
        </main>
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private static readonly ComplianceIqQuickQuestionView[] _fallbackQuestions =
    [
        new() { Id = 1, QuestionText = "Which anomalies need attention before the next submission?", Category = "Anomalies", IconClass = "bi-exclamation-diamond" },
        new() { Id = 2, QuestionText = "Summarize the latest compliance health signals for this institution.", Category = "Health", IconClass = "bi-activity" },
        new() { Id = 3, QuestionText = "Which returns are closest to deadline this cycle?", Category = "Deadlines", IconClass = "bi-calendar-event" },
        new() { Id = 4, QuestionText = "Show the biggest CAR and liquidity movements in the latest period.", Category = "Capital", IconClass = "bi-graph-up-arrow" },
        new() { Id = 5, QuestionText = "What filing trends should I escalate to the checker today?", Category = "Workflow", IconClass = "bi-person-check" },
        new() { Id = 6, QuestionText = "List overdue compliance actions with the strongest regulatory impact.", Category = "Actions", IconClass = "bi-shield-check" }
    ];

    private static readonly string[] _trustSignals =
    [
        "Answers stay grounded in the active tenant workspace rather than generic guidance.",
        "Returned tables, citations, and follow-up prompts remain attached to the current thread.",
        "The workspace is read-only, so analysts can explore safely before formal submission actions."
    ];

    private readonly List<ChatMessage> _messages = new();
    private IReadOnlyList<ComplianceIqQuickQuestionView> _quickQuestions = Array.Empty<ComplianceIqQuickQuestionView>();
    private Guid? _conversationId;
    private string _query = string.Empty;
    private bool _isLoading;
    private string? _error;

    private IEnumerable<ComplianceIqQuickQuestionView> PromptCatalog => _quickQuestions.Count > 0 ? _quickQuestions : _fallbackQuestions;

    private IEnumerable<ComplianceIqQuickQuestionView> StarterQuestions =>
        PromptCatalog.Take(6);

    private IEnumerable<IGrouping<string, ComplianceIqQuickQuestionView>> RailQuestionGroups =>
        PromptCatalog
            .Where(x => !string.IsNullOrWhiteSpace(x.QuestionText))
            .GroupBy(x => NormalizeCategory(x.Category))
            .Take(3);

    private ComplianceIqQueryResponse? LatestResponse =>
        _messages.LastOrDefault(x => !x.IsUser)?.Response;

    private int UserTurnCount => _messages.Count(x => x.IsUser);

    private int AnalystTurnCount => _messages.Count(x => !x.IsUser);

    private int CitationCount => _messages.Sum(x => x.Response?.Citations.Count ?? 0);

    private int TableResponseCount => _messages.Count(x => x.Response?.Rows.Count > 0);

    private string ConversationStatusLabel => _conversationId.HasValue ? "Live conversation" : "Fresh briefing";

    private string ConversationHeadline => _conversationId.HasValue
        ? "Evidence-linked dialogue is in progress."
        : "Start with a focused regulatory or filing question.";

    private string ConversationSupportingText => _conversationId.HasValue
        ? "Continue the active thread to preserve context, citations, and suggested follow-ups."
        : "Launch a new thread with anomalies, deadlines, return trends, or compliance health signals.";

    private string ConversationStatSupportingText => _conversationId.HasValue
        ? "Thread memory is active for this session."
        : "A new thread is created after the first answer.";

    private string ExportStateLabel => _conversationId.HasValue ? "Ready" : "Pending";

    private string ExportStateSupportingText => _conversationId.HasValue
        ? "Conversation can be exported to PDF."
        : "Available after the first assistant response.";

    private string LatestConfidenceLabel => LatestResponse?.ConfidenceLevel ?? "Awaiting reply";

    private string LatestIntentLabel => ResolveAssistantHeading(LatestResponse);

    private string LatestLatencyLabel => LatestResponse is null
        ? "No query issued yet"
        : $"{LatestResponse.TotalTimeMs} ms on last response";

    private string StageHeadline => _messages.Count == 0
        ? "Prompt library and grounded analysis"
        : "Threaded investigation workspace";

    private string ComposerPlaceholder => _messages.Count == 0
        ? "Ask about CAR, NPL trend, deadlines, anomalies, or compliance health..."
        : "Ask a follow-up about the latest anomaly, deadline, return variance, or compliance signal...";

    private string SessionReadinessLabel => AnalystTurnCount switch
    {
        0 => "Ready",
        1 or 2 => "Active",
        3 or 4 => "In flow",
        _ => "Deep dive"
    };

    private int SessionReadinessPct => AnalystTurnCount switch
    {
        0 => 18,
        1 => 46,
        2 => 62,
        3 => 78,
        4 => 90,
        _ => 100
    };

    private string SessionReadinessStyle =>
        $"background: conic-gradient(var(--cbn-green-deep, #006B3F) 0 {SessionReadinessPct}%, rgba(0, 107, 63, 0.12) {SessionReadinessPct}% 100%)";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _quickQuestions = await ComplianceIqService.GetQuickQuestionsAsync(false);
        }
        catch
        {
            _quickQuestions = _fallbackQuestions;
        }
    }

    private async Task SendAsync()
    {
        if (_isLoading || string.IsNullOrWhiteSpace(_query))
        {
            return;
        }

        var prompt = _query.Trim();
        _query = string.Empty;
        _error = null;
        _messages.Add(new ChatMessage { IsUser = true, Text = prompt });
        _isLoading = true;

        try
        {
            var authState = await AuthenticationStateTask;
            var principal = authState.User;
            var tenantId = PortalTenantClaimResolver.ResolveTenantId(principal);
            var userId = principal.FindFirst(ClaimTypes.NameIdentifier)?.Value
                ?? principal.Identity?.Name
                ?? "unknown";
            var userRole = principal.FindFirst(ClaimTypes.Role)?.Value ?? "InstitutionUser";

            var response = await ComplianceIqService.QueryAsync(new ComplianceIqQueryRequest
            {
                Query = prompt,
                TenantId = tenantId,
                UserId = userId,
                UserRole = userRole,
                ConversationId = _conversationId,
                IsRegulatorContext = false
            });

            _conversationId = response.ConversationId;
            _messages.Add(new ChatMessage
            {
                IsUser = false,
                Text = response.Answer,
                Response = response
            });
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _messages.Add(new ChatMessage
            {
                IsUser = false,
                Text = "ComplianceIQ could not process that question. Try a more specific metric, period, or module."
            });
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task AskQuickQuestionAsync(string question)
    {
        _query = question;
        await SendAsync();
    }

    private void HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" && !args.ShiftKey)
        {
            _ = SendAsync();
        }
    }

    private void StartNewConversation()
    {
        _conversationId = null;
        _messages.Clear();
        _query = string.Empty;
        _error = null;
    }

    private void GoToHistory()
    {
        Navigation.NavigateTo("/analytics/chat/history");
    }

    private Task ExportConversationAsync()
    {
        if (_conversationId.HasValue)
        {
            Navigation.NavigateTo($"/complianceiq/conversations/{_conversationId.Value:D}/export", forceLoad: true);
        }

        return Task.CompletedTask;
    }

    private async Task SubmitFeedbackAsync(int turnId, short rating)
    {
        try
        {
            var authState = await AuthenticationStateTask;
            var tenantId = PortalTenantClaimResolver.ResolveTenantId(authState.User);
            var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value
                ?? authState.User.Identity?.Name
                ?? "unknown";

            await ComplianceIqService.SubmitFeedbackAsync(turnId, tenantId, userId, rating, null);
        }
        catch
        {
        }
    }

    private static string NormalizeCategory(string? category) =>
        string.IsNullOrWhiteSpace(category) ? "Grounded prompts" : category.Trim();

    private static string ResolveAssistantHeading(ComplianceIqQueryResponse? response)
    {
        if (response is null || string.IsNullOrWhiteSpace(response.IntentCode))
        {
            return "Grounded response";
        }

        var normalized = response.IntentCode.Replace("_", " ", StringComparison.Ordinal).ToLowerInvariant();
        return CultureInfo.InvariantCulture.TextInfo.ToTitleCase(normalized);
    }

    private static string ResolveConfidenceClass(string? confidenceLevel) => confidenceLevel switch
    {
        "HIGH" => "portal-iq-status-chip portal-iq-status-chip--high",
        "MEDIUM" => "portal-iq-status-chip portal-iq-status-chip--medium",
        "LOW" => "portal-iq-status-chip portal-iq-status-chip--low",
        _ => "portal-iq-status-chip"
    };

    private static string FormatHeader(string value) =>
        value.Replace("_", " ", StringComparison.Ordinal).Trim();

    private static string FormatCitation(ComplianceIqCitation citation)
    {
        var module = string.IsNullOrWhiteSpace(citation.SourceModule) ? "Unknown module" : citation.SourceModule;
        var period = string.IsNullOrWhiteSpace(citation.SourcePeriod) ? "latest" : citation.SourcePeriod;
        return $"{module} / {period}";
    }

    private static string FormatCell(object? value) => value switch
    {
        null => "—",
        decimal number => number.ToString("N2", CultureInfo.InvariantCulture),
        double number => number.ToString("N2", CultureInfo.InvariantCulture),
        float number => number.ToString("N2", CultureInfo.InvariantCulture),
        DateTime date => date.ToString("dd MMM yyyy", CultureInfo.InvariantCulture),
        bool flag => flag ? "Yes" : "No",
        _ => value.ToString() ?? "—"
    };

    private sealed class ChatMessage
    {
        public bool IsUser { get; set; }
        public string Text { get; set; } = string.Empty;
        public ComplianceIqQueryResponse? Response { get; set; }
    }
}
