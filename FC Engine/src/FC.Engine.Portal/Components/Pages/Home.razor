    // ── Deadline Widget Helpers ───────────────────────────────────

    private static string GetDeadlineBarColor(int daysRemaining, DeadlineStatus status)
    {
        if (status == DeadlineStatus.Submitted) return "#059669";
        if (status == DeadlineStatus.Overdue || daysRemaining <= 0) return "#ef4444";
        if (daysRemaining <= 3) return "#ef4444";
        if (daysRemaining <= 7) return "#f59e0b";
        return "#059669";
    }

    private static double GetDeadlineRingProgress(DeadlineItem d)
    {
        if (d.Status == DeadlineStatus.Submitted) return 1.0;
        if (d.Status == DeadlineStatus.Overdue)   return 1.0;
        return Math.Clamp((30.0 - d.DaysRemaining) / 30.0, 0.05, 0.95);
    }

    private static string FormatRelativeDue(int days)
    {
        if (days < 0) return $"{Math.Abs(days)} day{(Math.Abs(days) != 1 ? "s" : "")} overdue";
        if (days == 0) return "Due today";
        if (days == 1) return "Tomorrow";
        return $"in {days} days";
    }

    private static string GetDeadlinePeriodLabel(DeadlineItem d)
    {
        var date = d.DueDate;
        return d.Frequency.ToLowerInvariant() switch
        {
            "quarterly" => $"Q{(date.Month - 1) / 3 + 1} {date.Year}",
            "monthly"   => date.ToString("MMM yyyy"),
            "annual" or "annually" or "yearly" => $"FY {date.Year}",
            _           => date.ToString("MMM yyyy")
        };
    }

    [JSInvokable]
    public void OnWidgetReordered(int fromIdx, int toIdx)
    {
        // Widget DOM order is handled by the JS module; Blazor re-render not required.
        _ = fromIdx;
        _ = toIdx;
    }

    [JSInvokable]
    public async Task OnChartSegmentClick(string canvasId, int index, string label)
    {
        if (data is null) return;
        _drilldownTitle = label;
        _drilldownReturnName = data.TemplateHealth.FirstOrDefault(t => t.ReturnCode == label)?.ReturnName
                            ?? data.TopModules.FirstOrDefault(m => m.ReturnCode == label)?.ReturnName
                            ?? label;
        data.DrilldownByReturnCode.TryGetValue(label, out var items);
        _drilldownItems = items ?? new();
        _drilldownOpen = true;
        await InvokeAsync(StateHasChanged);
    }

