<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script>(function(){var t=localStorage.getItem('portal-theme');if(t==='dark'||(t===null&&window.matchMedia('(prefers-color-scheme: dark)').matches)){document.documentElement.setAttribute('data-theme','dark');}})();</script>
    <title>RegOS™ — Institution Portal</title>
    <base href="/" />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <meta name="theme-color" content="#006B3F" />
    <link rel="stylesheet" href="css/portal.css?v=1" />
    <link rel="stylesheet" href="css/motion.css?v=1" />
    <link rel="stylesheet" href="css/fonts.css" />
    <HeadOutlet @rendermode="RenderMode.InteractiveServer" />
</head>
<body>
    <Routes @rendermode="RenderMode.InteractiveServer" />
    <div id="components-reconnect-modal" style="display:none">
        <div class="reconnect-overlay" style="position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.5)">
            <div style="background:#fff;padding:2rem;border-radius:8px;text-align:center;max-width:360px">
                <p style="margin:0 0 .5rem;font-weight:600">Connection lost</p>
                <p style="margin:0;color:#666">Attempting to reconnect to the server...</p>
            </div>
        </div>
    </div>
    <script src="_framework/blazor.web.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.6/dist/chart.umd.min.js"></script>
    <script src="js/charts.js"></script>
    <script src="js/portal.js"></script>
    <script src="js/motion.js"></script>
    <script src="js/dragdrop.js"></script>
    <script src="js/shortcuts.js"></script>
    <script src="js/presence.js"></script>
    <script src="js/help.js"></script>
    <script src="js/branding-editor.js"></script>
    <script src="js/migration.js"></script>
</body>
</html>
