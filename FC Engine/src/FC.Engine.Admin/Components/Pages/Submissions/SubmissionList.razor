@page "/submissions"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Entities
@using FC.Engine.Domain.Enums
@inject ISubmissionRepository SubmissionRepo
@inject NavigationManager Nav

<div class="fc-list-page">
    <div class="fc-list-page-header">
        <div class="fc-list-page-header-text">
            <h1>
                Submissions
                @if (_submissions.Any())
                {
                    <span class="fc-list-count-chip">@_submissions.Count</span>
                }
            </h1>
            <p>View all return submissions and their validation results</p>
        </div>
    </div>

    <div class="fc-list-card">
        <div class="fc-list-toolbar">
            <div class="fc-list-toolbar-filters">
                <div class="fc-list-search-wrap">
                    <svg class="fc-list-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    <input class="fc-list-search-input" placeholder="Search by return code or institution..." @bind="_searchTerm" @bind:event="oninput" />
                </div>
                <input class="fc-list-filter-select" type="number" placeholder="Institution ID" @bind="_institutionId" style="max-width:160px;" />
                <select class="fc-list-filter-select" @bind="_statusFilter">
                    <option value="">All Statuses</option>
                    @foreach (var s in Enum.GetValues<SubmissionStatus>())
                    {
                        <option value="@s">@FormatStatus(s)</option>
                    }
                </select>
                <button class="fc-btn fc-btn--primary fc-btn--sm" @onclick="Search">Search</button>
            </div>
            <div class="fc-list-toolbar-actions">
                @if (_submissions.Any())
                {
                    <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="ClearResults">Clear</button>
                }
            </div>
        </div>

        @if (_error != null)
        {
            <div class="alert alert-error" style="margin:var(--space-4) var(--space-5);border-radius:var(--radius-sm);">@_error</div>
        }

        @if (_loading)
        {
            <div class="fc-list-skeleton">
                @for (var i = 0; i < 6; i++)
                {
                    <div class="fc-list-skeleton-row">
                        <div class="fc-list-skeleton-cell" style="width:40px;"></div>
                        <div class="fc-list-skeleton-cell" style="width:80px;"></div>
                        <div class="fc-list-skeleton-cell" style="flex:1;"></div>
                        <div class="fc-list-skeleton-cell" style="width:100px;"></div>
                        <div class="fc-list-skeleton-cell" style="width:70px;"></div>
                        <div class="fc-list-skeleton-cell" style="width:120px;"></div>
                    </div>
                }
            </div>
        }
        else if (!_searched)
        {
            <div class="fc-list-empty">
                <svg class="fc-list-empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                <h3 class="fc-list-empty-title">Search for submissions</h3>
                <p class="fc-list-empty-text">Enter an Institution ID and click Search to view submission records and validation results.</p>
            </div>
        }
        else if (!FilteredSubmissions.Any())
        {
            <div class="fc-list-empty">
                <svg class="fc-list-empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/></svg>
                <h3 class="fc-list-empty-title">No submissions found</h3>
                <p class="fc-list-empty-text">No submissions match your search criteria. Try a different Institution ID or adjust filters.</p>
            </div>
        }
        else
        {
            <div class="fc-table-wrap">
                <table class="fc-table" role="table">
                    <thead>
                        <tr>
                            <th scope="col">ID</th>
                            <th scope="col">Return Code</th>
                            <th scope="col">Institution</th>
                            <th scope="col">Period</th>
                            <th scope="col">Status</th>
                            <th scope="col">Submitted</th>
                            <th scope="col">Errors</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in PagedSubmissions)
                        {
                            <tr class="fc-list-row-clickable" @onclick="() => ViewSubmission(s.Id)">
                                <td><a class="fc-list-cell-link" href="/submissions/@s.Id">@s.Id</a></td>
                                <td><a class="fc-list-cell-link" href="/templates/@s.ReturnCode">@s.ReturnCode</a></td>
                                <td class="fc-list-cell-strong">@(s.Institution?.InstitutionName ?? "—")</td>
                                <td class="fc-list-cell-muted">@(s.ReturnPeriod?.ReportingDate.ToString("yyyy-MM-dd") ?? "—")</td>
                                <td>
                                    <span class="fc-badge @StatusBadge(GetStatusClass(s.Status))">
                                        @FormatStatus(s.Status)
                                    </span>
                                </td>
                                <td class="fc-list-cell-muted">@s.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    @{
                                        var errCount = s.ValidationReport?.Errors.Count ?? 0;
                                    }
                                    @if (errCount > 0)
                                    {
                                        <span class="fc-badge fc-badge--danger">@errCount</span>
                                    }
                                    else
                                    {
                                        <span class="fc-list-cell-muted">0</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="fc-list-footer">
                <div class="fc-list-footer-summary">
                    Showing <strong>@PagedSubmissions.Count()</strong> of <strong>@FilteredSubmissions.Count()</strong> submissions
                    @if (TotalPages > 1)
                    {
                        <span> &mdash; Page @_currentPage of @TotalPages</span>
                    }
                </div>
                @if (TotalPages > 1)
                {
                    <div class="fc-list-pagination">
                        <button class="fc-list-page-btn" disabled="@(_currentPage <= 1)" @onclick="() => _currentPage--">&laquo;</button>
                        @for (var p = Math.Max(1, _currentPage - 2); p <= Math.Min(TotalPages, _currentPage + 2); p++)
                        {
                            var page = p;
                            <button class="fc-list-page-btn @(page == _currentPage ? "fc-list-page-btn-active" : "")" @onclick="() => _currentPage = page">@(page)</button>
                        }
                        <button class="fc-list-page-btn" disabled="@(_currentPage >= TotalPages)" @onclick="() => _currentPage++">&raquo;</button>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private int _institutionId;
    private bool _searched;
    private bool _loading;
    private string? _error;
    private string _searchTerm = "";
    private string _statusFilter = "";
    private int _currentPage = 1;
    private const int PageSize = 20;
    private List<Submission> _submissions = new();

    private IEnumerable<Submission> FilteredSubmissions => _submissions
        .Where(s => string.IsNullOrEmpty(_searchTerm) ||
                    s.ReturnCode.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    (s.Institution?.InstitutionName?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(s => string.IsNullOrEmpty(_statusFilter) || s.Status.ToString() == _statusFilter);

    private IEnumerable<Submission> PagedSubmissions => FilteredSubmissions
        .Skip((_currentPage - 1) * PageSize)
        .Take(PageSize);

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredSubmissions.Count() / (double)PageSize));

    private async Task Search()
    {
        _error = null;
        _searched = true;
        _currentPage = 1;
        _loading = true;
        try
        {
            if (_institutionId <= 0)
            {
                _error = "Please enter a valid Institution ID";
                _loading = false;
                return;
            }
            _submissions = (await SubmissionRepo.GetByInstitution(_institutionId)).ToList();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        _loading = false;
    }

    private void ClearResults()
    {
        _submissions.Clear();
        _searched = false;
        _error = null;
        _searchTerm = "";
        _statusFilter = "";
        _currentPage = 1;
    }

    private void ViewSubmission(int id) => Nav.NavigateTo($"/submissions/{id}");

    private static string FormatStatus(SubmissionStatus status) => status switch
    {
        SubmissionStatus.Accepted => "Accepted",
        SubmissionStatus.AcceptedWithWarnings => "Warnings",
        SubmissionStatus.Rejected => "Rejected",
        SubmissionStatus.Validating => "Validating",
        SubmissionStatus.Parsing => "Parsing",
        _ => "Draft"
    };

    private static string GetStatusClass(SubmissionStatus status) => status switch
    {
        SubmissionStatus.Accepted => "accepted",
        SubmissionStatus.AcceptedWithWarnings => "acceptedwithwarnings",
        SubmissionStatus.Rejected => "rejected",
        SubmissionStatus.Validating => "validating",
        SubmissionStatus.Parsing => "parsing",
        _ => "draft"
    };

    private static string StatusBadge(string status) => status.ToLowerInvariant() switch
    {
        "published" or "active" or "accepted" => "fc-badge--success",
        "draft" or "pending" => "fc-badge--warning",
        "review" or "inreview" => "fc-badge--review",
        "deprecated" or "retired" or "disabled" or "archived" => "fc-badge--muted",
        "rejected" or "failed" or "error" => "fc-badge--danger",
        "processing" or "validating" or "parsing" => "fc-badge--info",
        "acceptedwithwarnings" or "warnings" or "warning" => "fc-badge--warning",
        _ => "fc-badge--neutral"
    };
}
