@page "/submissions"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Entities
@using FC.Engine.Domain.Enums
@inject ISubmissionRepository SubmissionRepo
@inject NavigationManager Nav

<PageHeader Title="Submissions"
            Subtitle="View all return submissions and their validation results"
            CountBadge="@(_submissions.Any() ? _submissions.Count : null)">
    <PrimaryAction>
        <a href="/submissions/kanban" class="fc-btn fc-btn--outline fc-btn--sm">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Kanban View
        </a>
    </PrimaryAction>
</PageHeader>

<div class="fc-list-page">

    @if (!_searched && !_loading)
    {
        <div class="fc-list-card">
            <div class="fc-list-toolbar">
                <div class="fc-list-toolbar-filters">
                    <div class="fc-list-search-wrap">
                        <svg class="fc-list-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                        <input class="fc-list-search-input" placeholder="Search by return code or institution..." @bind="_searchTerm" @bind:event="oninput" />
                    </div>
                    <input class="fc-list-filter-select" type="number" placeholder="Institution ID" @bind="_institutionId" style="max-width:160px;" />
                    <select class="fc-list-filter-select" @bind="_statusFilter">
                        <option value="">All Statuses</option>
                        @foreach (var s in Enum.GetValues<SubmissionStatus>())
                        {
                            <option value="@s">@FormatStatus(s)</option>
                        }
                    </select>
                    <button class="fc-btn fc-btn--primary fc-btn--sm" @onclick="Search">Search</button>
                </div>
            </div>

            @if (_error != null)
            {
                <div class="alert alert-error" style="margin:var(--space-4) var(--space-5);border-radius:var(--radius-sm);">@_error</div>
            }

            <div class="fc-list-empty">
                <svg class="fc-list-empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                <h3 class="fc-list-empty-title">Search for submissions</h3>
                <p class="fc-list-empty-text">Enter an Institution ID and click Search to view submission records and validation results.</p>
            </div>
        </div>
    }
    else
    {
        <DataTable TItem="Submission"
                   Items="@FilteredSubmissions.ToList()"
                   Loading="_loading"
                   PageSize="20"
                   ShowPagination="true"
                   Sortable="true"
                   Clickable="true"
                   OnRowClick="@(item => ViewSubmission(item.Id))"
                   EmptyTitle="No submissions found"
                   EmptyText="No submissions match your search criteria."
                   SkeletonRows="6">
            <ToolbarContent>
                <div class="fc-list-search-wrap">
                    <svg class="fc-list-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    <input class="fc-list-search-input" placeholder="Search by return code or institution..." @bind="_searchTerm" @bind:event="oninput" />
                </div>
                <input class="fc-list-filter-select" type="number" placeholder="Institution ID" @bind="_institutionId" style="max-width:160px;" />
                <select class="fc-list-filter-select" @bind="_statusFilter">
                    <option value="">All Statuses</option>
                    @foreach (var s in Enum.GetValues<SubmissionStatus>())
                    {
                        <option value="@s">@FormatStatus(s)</option>
                    }
                </select>
                <button class="fc-btn fc-btn--primary fc-btn--sm" @onclick="Search">Search</button>
                @if (_submissions.Any())
                {
                    <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="ClearResults">Clear</button>
                }
                @if (_error != null)
                {
                    <div class="alert alert-error" style="margin:var(--space-4) var(--space-5);border-radius:var(--radius-sm);">@_error</div>
                }
            </ToolbarContent>
            <ChildContent>
                <DataColumn TItem="Submission" Title="ID" SortKey="x => x.Id">
                    <CellTemplate>
                        <a class="fc-list-cell-link" href="/submissions/@context.Id">@context.Id</a>
                    </CellTemplate>
                </DataColumn>
                <DataColumn TItem="Submission" Title="Return Code" SortKey="x => x.ReturnCode">
                    <CellTemplate>
                        <a class="fc-list-cell-link" href="/templates/@context.ReturnCode">@context.ReturnCode</a>
                    </CellTemplate>
                </DataColumn>
                <DataColumn TItem="Submission" Title="Institution" SortKey="x => x.Institution!.InstitutionName" CellClass="fc-list-cell-strong">
                    <CellTemplate>@(context.Institution?.InstitutionName ?? "—")</CellTemplate>
                </DataColumn>
                <DataColumn TItem="Submission" Title="Period" SortKey="x => x.ReturnPeriod!.ReportingDate" CellClass="fc-list-cell-muted">
                    <CellTemplate>@(context.ReturnPeriod?.ReportingDate.ToString("yyyy-MM-dd") ?? "—")</CellTemplate>
                </DataColumn>
                <DataColumn TItem="Submission" Title="Status" SortKey="x => x.Status">
                    <CellTemplate>
                        <span class="fc-badge @StatusBadge(GetStatusClass(context.Status))">
                            @FormatStatus(context.Status)
                        </span>
                    </CellTemplate>
                </DataColumn>
                <DataColumn TItem="Submission" Title="Submitted" SortKey="x => x.CreatedAt" CellClass="fc-list-cell-muted">
                    <CellTemplate>@context.CreatedAt.ToString("yyyy-MM-dd HH:mm")</CellTemplate>
                </DataColumn>
                <DataColumn TItem="Submission" Title="Errors" SortKey="x => x.ValidationReport!.Errors.Count">
                    <CellTemplate>
                        @{
                            var errCount = context.ValidationReport?.Errors.Count ?? 0;
                        }
                        @if (errCount > 0)
                        {
                            <span class="fc-badge fc-badge--danger">@errCount</span>
                        }
                        else
                        {
                            <span class="fc-list-cell-muted">0</span>
                        }
                    </CellTemplate>
                </DataColumn>
            </ChildContent>
        </DataTable>
    }
</div>

@code {
    private int _institutionId;
    private bool _searched;
    private bool _loading;
    private string? _error;
    private string _searchTerm = "";
    private string _statusFilter = "";
    private List<Submission> _submissions = new();

    private IEnumerable<Submission> FilteredSubmissions => _submissions
        .Where(s => string.IsNullOrEmpty(_searchTerm) ||
                    s.ReturnCode.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    (s.Institution?.InstitutionName?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(s => string.IsNullOrEmpty(_statusFilter) || s.Status.ToString() == _statusFilter);

    private async Task Search()
    {
        _error = null;
        _searched = true;
        _loading = true;
        try
        {
            if (_institutionId <= 0)
            {
                _error = "Please enter a valid Institution ID";
                _loading = false;
                return;
            }
            _submissions = (await SubmissionRepo.GetByInstitution(_institutionId)).ToList();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        _loading = false;
    }

    private void ClearResults()
    {
        _submissions.Clear();
        _searched = false;
        _error = null;
        _searchTerm = "";
        _statusFilter = "";
    }

    private void ViewSubmission(int id) => Nav.NavigateTo($"/submissions/{id}");

    private static string FormatStatus(SubmissionStatus status) => status switch
    {
        SubmissionStatus.Accepted => "Accepted",
        SubmissionStatus.AcceptedWithWarnings => "Warnings",
        SubmissionStatus.Rejected => "Rejected",
        SubmissionStatus.Validating => "Validating",
        SubmissionStatus.Parsing => "Parsing",
        _ => "Draft"
    };

    private static string GetStatusClass(SubmissionStatus status) => status switch
    {
        SubmissionStatus.Accepted => "accepted",
        SubmissionStatus.AcceptedWithWarnings => "acceptedwithwarnings",
        SubmissionStatus.Rejected => "rejected",
        SubmissionStatus.Validating => "validating",
        SubmissionStatus.Parsing => "parsing",
        _ => "draft"
    };

    private static string StatusBadge(string status) => status.ToLowerInvariant() switch
    {
        "published" or "active" or "accepted" => "fc-badge--success",
        "draft" or "pending" => "fc-badge--warning",
        "review" or "inreview" => "fc-badge--review",
        "deprecated" or "retired" or "disabled" or "archived" => "fc-badge--muted",
        "rejected" or "failed" or "error" => "fc-badge--danger",
        "processing" or "validating" or "parsing" => "fc-badge--info",
        "acceptedwithwarnings" or "warnings" or "warning" => "fc-badge--warning",
        _ => "fc-badge--neutral"
    };
}
