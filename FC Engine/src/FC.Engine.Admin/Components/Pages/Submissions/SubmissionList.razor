@page "/submissions"
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Entities
@inject ISubmissionRepository SubmissionRepo

<div class="page-header">
    <h1>Submissions</h1>
    <p>View all return submissions and their validation results</p>
</div>

<div class="card">
    <div class="filter-bar">
        <input class="form-control" type="number" placeholder="Institution ID" @bind="_institutionId" />
        <button class="btn btn-primary" @onclick="Search">Search</button>
    </div>

    @if (_error != null)
    {
        <div class="alert alert-danger">@_error</div>
    }

    @if (_submissions.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Return Code</th>
                    <th>Institution</th>
                    <th>Period</th>
                    <th>Status</th>
                    <th>Submitted</th>
                    <th>Errors</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in _submissions)
                {
                    <tr>
                        <td>@s.Id</td>
                        <td><a href="/templates/@s.ReturnCode">@s.ReturnCode</a></td>
                        <td>@s.Institution?.InstitutionName</td>
                        <td>@s.ReturnPeriod?.ReportingDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            <span class="badge @GetStatusBadge(s.Status.ToString())">
                                @s.Status
                            </span>
                        </td>
                        <td>@s.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@(s.ValidationReport?.Errors.Count ?? 0)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else if (_searched)
    {
        <div class="text-center text-muted">No submissions found</div>
    }
</div>

@code {
    private int _institutionId;
    private bool _searched;
    private string? _error;
    private List<Submission> _submissions = new();

    private async Task Search()
    {
        _error = null;
        _searched = true;
        try
        {
            if (_institutionId <= 0)
            {
                _error = "Please enter a valid Institution ID";
                return;
            }
            _submissions = (await SubmissionRepo.GetByInstitution(_institutionId)).ToList();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private static string GetStatusBadge(string status) => status switch
    {
        "Validated" => "badge-published",
        "ValidationFailed" => "badge-deprecated",
        "Processing" => "badge-review",
        "Draft" => "badge-draft",
        _ => "badge-draft"
    };
}
