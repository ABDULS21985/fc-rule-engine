@page "/submissions/direct"
@attribute [Authorize(Policy = "PlatformAdmin")]
@inject IDirectSubmissionRepository DirectSubmissionRepo
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Entities
@using FC.Engine.Domain.Enums

<PageTitle>Direct Regulatory Submissions</PageTitle>

<PageHeader Title="Direct Regulatory Submissions"
            Subtitle="Track regulator-bound API submissions, in-flight delivery status, and retry pressure across the platform."
            StatusBadge="@ResolveStatusBadge()"
            StatusVariant="@ResolveStatusVariant()">
    <PrimaryAction>
        <button class="fc-btn fc-btn--primary" @onclick="LoadData" disabled="@isLoading">Refresh</button>
    </PrimaryAction>
</PageHeader>

<div class="fc-page">
    @if (isLoading)
    {
        <div class="rg-premium-flow">
            <div class="rg-premium-banner"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="138px" /></div>
            <div class="rg-premium-stat-grid">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="rg-premium-stat"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="140px" /></div>
                }
            </div>
            <div class="rg-premium-content-grid">
                <div class="rg-premium-main"><div class="rg-premium-panel"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="480px" /></div></div>
                <div class="rg-premium-side"><div class="rg-premium-panel"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="240px" /></div><div class="rg-premium-panel"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="280px" /></div></div>
            </div>
        </div>
    }
    else
    {
        <div class="rg-premium-flow">
            <section class="rg-premium-banner @ResolveBannerTone()" aria-label="Submission delivery posture">
                <div class="rg-premium-banner__grid">
                    <div>
                        <div class="rg-premium-banner__eyebrow">Delivery posture</div>
                        <h2 class="rg-premium-banner__headline">@BuildBannerHeadline()</h2>
                        <p class="rg-premium-banner__detail">@BuildBannerDetail()</p>
                    </div>
                    <div class="rg-premium-banner__meta">
                        <div class="rg-premium-banner__meta-label">Current acceptance rate</div>
                        <div class="rg-premium-banner__meta-value">@AcceptedRate.ToString("F0")%</div>
                        <div class="rg-premium-banner__meta-copy">@BuildRegulatorFocusCopy()</div>
                    </div>
                </div>
            </section>

            <section class="rg-premium-hero" aria-labelledby="direct-submission-hero-title">
                <div class="rg-premium-hero__grid">
                    <div>
                        <div class="rg-premium-hero__eyebrow">Direct submission lane</div>
                        <h1 id="direct-submission-hero-title" class="rg-premium-hero__title">Watch the delivery queue before regulators see the failure pattern.</h1>
                        <p class="rg-premium-hero__subtitle">
                            This view gives platform operators one place to see regulator mix, delivery outcomes, retry pressure,
                            and the exact submissions still sitting in-flight or failing to reach external regulator endpoints.
                        </p>
                        <div class="rg-premium-badge-row">
                            <span class="rg-premium-chip rg-premium-chip--info">@totalSubmissions total submissions</span>
                            <span class="rg-premium-chip @BuildAcceptedChipClass()">@acceptedCount accepted</span>
                            <span class="rg-premium-chip @BuildPendingChipClass()">@pendingCount in-flight</span>
                            <span class="rg-premium-chip @BuildFailedChipClass()">@failedCount failed</span>
                        </div>
                    </div>
                    <div class="rg-premium-hero__aside">
                        <div class="rg-premium-note">
                            <div class="rg-premium-note__label">Filters</div>
                            <div class="rg-premium-note__value">@BuildFilterLabel()</div>
                            <div class="rg-premium-note__copy">Current operator filter scope applied to the direct submission queue.</div>
                        </div>
                        <div class="rg-premium-note">
                            <div class="rg-premium-note__label">Retry posture</div>
                            <div class="rg-premium-note__value">@pendingCount</div>
                            <div class="rg-premium-note__copy">Items still submitted, acknowledged, or actively retrying against regulator endpoints.</div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="rg-premium-stat-grid" aria-label="Direct submission metrics">
                <article class="rg-premium-stat"><div class="rg-premium-stat__label">Total sent</div><div class="rg-premium-stat__value rg-premium-stat__value--info">@totalSubmissions</div><div class="rg-premium-stat__note">Direct submissions currently loaded across regulator delivery channels.</div></article>
                <article class="rg-premium-stat"><div class="rg-premium-stat__label">Accepted</div><div class="rg-premium-stat__value @BuildAcceptedValueClass()">@acceptedCount</div><div class="rg-premium-stat__note">Submissions that completed external regulator acceptance.</div></article>
                <article class="rg-premium-stat"><div class="rg-premium-stat__label">Pending or in-flight</div><div class="rg-premium-stat__value @BuildPendingValueClass()">@pendingCount</div><div class="rg-premium-stat__note">Submitted, acknowledged, or retrying items that still require delivery monitoring.</div></article>
                <article class="rg-premium-stat"><div class="rg-premium-stat__label">Failed or exhausted</div><div class="rg-premium-stat__value @BuildFailedValueClass()">@failedCount</div><div class="rg-premium-stat__note">Items that failed delivery or exhausted retry attempts.</div></article>
            </section>

            <section class="rg-premium-content-grid">
                <div class="rg-premium-main">
                    <section class="rg-premium-panel">
                        <div class="rg-premium-panel__header">
                            <div>
                                <div class="rg-premium-panel__eyebrow">Queue monitor</div>
                                <h2 class="rg-premium-panel__title">Direct submission queue</h2>
                                <p class="rg-premium-panel__subtitle">Filter by regulator and delivery status to isolate the part of the queue needing action.</p>
                            </div>
                            <div class="rg-premium-panel__metric">
                                <span class="rg-premium-panel__metric-label">Visible items</span>
                                @filteredSubmissions.Count
                            </div>
                        </div>
                        <div class="rg-premium-panel__body rg-premium-panel__body--table">
                            <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:16px;">
                                <select class="admin-form-select" style="min-width:150px;" @bind="filterRegulator" @bind:after="ApplyFilter">
                                    <option value="">All Regulators</option>
                                    <option value="CBN">CBN</option>
                                    <option value="NFIU">NFIU</option>
                                    <option value="NDIC">NDIC</option>
                                    <option value="SEC">SEC</option>
                                    <option value="NAICOM">NAICOM</option>
                                    <option value="PENCOM">PenCom</option>
                                </select>
                                <select class="admin-form-select" style="min-width:150px;" @bind="filterStatus" @bind:after="ApplyFilter">
                                    <option value="">All Statuses</option>
                                    <option value="Submitted">Submitted</option>
                                    <option value="Acknowledged">Acknowledged</option>
                                    <option value="Accepted">Accepted</option>
                                    <option value="Failed">Failed</option>
                                    <option value="RetryScheduled">Retry Scheduled</option>
                                    <option value="Exhausted">Exhausted</option>
                                </select>
                            </div>

                            @if (filteredSubmissions.Count == 0)
                            {
                                <div class="rg-premium-empty">No direct submissions match the current filter scope.</div>
                            }
                            else
                            {
                                <div class="admin-table-wrap">
                                    <table class="admin-table">
                                        <thead>
                                            <tr>
                                                <th>ID</th>
                                                <th>Submission</th>
                                                <th>Regulator</th>
                                                <th>Status</th>
                                                <th>Reference</th>
                                                <th>Attempts</th>
                                                <th>Submitted</th>
                                                <th>Acknowledged</th>
                                                <th>Created By</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var ds in filteredSubmissions)
                                            {
                                                <tr>
                                                    <td>@ds.Id</td>
                                                    <td><a href="/submissions/@ds.SubmissionId">#@ds.SubmissionId</a></td>
                                                    <td><strong>@ds.RegulatorCode</strong></td>
                                                    <td><span class="fc-badge @SubmissionBadge(ds.Status)">@ds.Status</span></td>
                                                    <td style="font-family:monospace; font-size:0.8rem;">@(ds.RegulatorReference ?? "-")</td>
                                                    <td>@ds.AttemptCount / @ds.MaxAttempts</td>
                                                    <td>@(ds.SubmittedAt?.ToString("dd MMM yyyy HH:mm") ?? "-")</td>
                                                    <td>@(ds.AcknowledgedAt?.ToString("dd MMM yyyy HH:mm") ?? "-")</td>
                                                    <td>@ds.CreatedBy</td>
                                                </tr>
                                                @if (!string.IsNullOrWhiteSpace(ds.ErrorMessage))
                                                {
                                                    <tr>
                                                        <td colspan="9" style="background:#fff8e1; color:#92400e; font-size:0.8rem; padding:0.45rem 1rem;">@ds.ErrorMessage</td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </section>
                </div>

                <aside class="rg-premium-side">
                    <section class="rg-premium-panel">
                        <div class="rg-premium-panel__header"><div><div class="rg-premium-panel__eyebrow">Regulator mix</div><h2 class="rg-premium-panel__title">Delivery concentration</h2><p class="rg-premium-panel__subtitle">Regulators currently carrying the heaviest direct submission load.</p></div></div>
                        <div class="rg-premium-panel__body">
                            @if (RegulatorCounts.Count == 0)
                            {
                                <div class="rg-premium-empty">No regulator mix is available yet.</div>
                            }
                            else
                            {
                                <div class="rg-premium-list">
                                    @foreach (var item in RegulatorCounts.Take(5))
                                    {
                                        <article class="rg-premium-list__item"><div class="rg-premium-list__top"><div class="rg-premium-list__heading">@item.Key</div><div class="rg-premium-list__value">@item.Value</div></div></article>
                                    }
                                </div>
                            }
                        </div>
                    </section>

                    <section class="rg-premium-panel">
                        <div class="rg-premium-panel__header"><div><div class="rg-premium-panel__eyebrow">Error rail</div><h2 class="rg-premium-panel__title">Recent delivery issues</h2><p class="rg-premium-panel__subtitle">Latest errors visible in the current queue scope.</p></div></div>
                        <div class="rg-premium-panel__body">
                            @if (!RecentErrors.Any())
                            {
                                <div class="rg-premium-empty">No delivery errors are visible in the current filtered queue.</div>
                            }
                            else
                            {
                                <div class="rg-premium-list">
                                    @foreach (var item in RecentErrors)
                                    {
                                        <article class="rg-premium-list__item">
                                            <div class="rg-premium-list__top"><div class="rg-premium-list__heading">#@item.SubmissionId · @item.RegulatorCode</div><span class="fc-badge @SubmissionBadge(item.Status)">@item.Status</span></div>
                                            <div class="rg-premium-list__meta">@item.ErrorMessage</div>
                                        </article>
                                    }
                                </div>
                            }
                        </div>
                    </section>
                </aside>
            </section>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<DirectSubmission> allSubmissions = new();
    private List<DirectSubmission> filteredSubmissions = new();

    private string filterRegulator = string.Empty;
    private string filterStatus = string.Empty;

    private int totalSubmissions;
    private int acceptedCount;
    private int pendingCount;
    private int failedCount;

    private decimal AcceptedRate => totalSubmissions == 0 ? 0m : decimal.Round((decimal)acceptedCount / totalSubmissions * 100m, 1);

    private List<KeyValuePair<string, int>> RegulatorCounts => filteredSubmissions
        .GroupBy(d => d.RegulatorCode)
        .OrderByDescending(g => g.Count())
        .Select(g => new KeyValuePair<string, int>(g.Key, g.Count()))
        .ToList();

    private List<DirectSubmission> RecentErrors => filteredSubmissions
        .Where(d => !string.IsNullOrWhiteSpace(d.ErrorMessage))
        .OrderByDescending(d => d.CreatedAt)
        .Take(4)
        .ToList();

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        isLoading = true;

        var submitted = await DirectSubmissionRepo.GetSubmittedAwaitingStatus(500);
        var retries = await DirectSubmissionRepo.GetPendingRetries(500);
        allSubmissions = submitted.Concat(retries).OrderByDescending(d => d.CreatedAt).ToList();

        totalSubmissions = allSubmissions.Count;
        acceptedCount = allSubmissions.Count(d => d.Status == DirectSubmissionStatus.Accepted);
        pendingCount = allSubmissions.Count(d => d.Status == DirectSubmissionStatus.Submitted
            || d.Status == DirectSubmissionStatus.Acknowledged
            || d.Status == DirectSubmissionStatus.Submitting
            || d.Status == DirectSubmissionStatus.RetryScheduled);
        failedCount = allSubmissions.Count(d => d.Status == DirectSubmissionStatus.Failed
            || d.Status == DirectSubmissionStatus.Exhausted
            || d.Status == DirectSubmissionStatus.Rejected);

        ApplyFilter();
        isLoading = false;
    }

    private void ApplyFilter()
    {
        filteredSubmissions = allSubmissions.Where(d =>
        {
            if (!string.IsNullOrEmpty(filterRegulator) && !string.Equals(d.RegulatorCode, filterRegulator, StringComparison.OrdinalIgnoreCase))
            {
                return false;
            }

            if (!string.IsNullOrEmpty(filterStatus) && !string.Equals(d.Status.ToString(), filterStatus, StringComparison.OrdinalIgnoreCase))
            {
                return false;
            }

            return true;
        }).ToList();
    }

    private string ResolveStatusBadge() => isLoading
        ? "Refreshing"
        : failedCount > 0
            ? $"{failedCount} failed"
            : pendingCount > 0
                ? $"{pendingCount} in-flight"
                : "Delivery stable";

    private string ResolveStatusVariant() => failedCount > 0 ? "danger" : pendingCount > 0 ? "warning" : "success";

    private string ResolveBannerTone() => failedCount > 0 ? "rg-premium-banner--danger" : pendingCount > 0 ? "rg-premium-banner--warning" : "rg-premium-banner--success";

    private string BuildBannerHeadline() => failedCount > 0
        ? "Some regulator-bound submissions are failing hard enough to require operator attention."
        : pendingCount > 0
            ? "Delivery is active, but there are still regulator endpoints with live queue pressure."
            : "The current direct submission queue is stable across active regulator endpoints.";

    private string BuildBannerDetail() => $"The dashboard is tracking {totalSubmissions} direct submissions, with {acceptedCount} accepted, {pendingCount} in-flight, and {failedCount} failed or exhausted outcomes.";

    private string BuildRegulatorFocusCopy() => RegulatorCounts.Count == 0
        ? "No regulator concentration is visible yet."
        : $"{RegulatorCounts[0].Key} currently carries the heaviest visible direct submission volume in the filtered queue.";

    private string BuildAcceptedChipClass() => acceptedCount > 0 ? "rg-premium-chip--success" : "rg-premium-chip--info";
    private string BuildPendingChipClass() => pendingCount > 0 ? "rg-premium-chip--warning" : "rg-premium-chip--success";
    private string BuildFailedChipClass() => failedCount > 0 ? "rg-premium-chip--danger" : "rg-premium-chip--success";
    private string BuildAcceptedValueClass() => acceptedCount > 0 ? "rg-premium-stat__value--success" : string.Empty;
    private string BuildPendingValueClass() => pendingCount > 0 ? "rg-premium-stat__value--warning" : "rg-premium-stat__value--success";
    private string BuildFailedValueClass() => failedCount > 0 ? "rg-premium-stat__value--danger" : "rg-premium-stat__value--success";
    private string BuildFilterLabel() => string.IsNullOrWhiteSpace(filterRegulator) && string.IsNullOrWhiteSpace(filterStatus)
        ? "All regulators"
        : $"{(string.IsNullOrWhiteSpace(filterRegulator) ? "All regulators" : filterRegulator)} / {(string.IsNullOrWhiteSpace(filterStatus) ? "All statuses" : filterStatus)}";

    private static string SubmissionBadge(DirectSubmissionStatus status) => status switch
    {
        DirectSubmissionStatus.Submitted or DirectSubmissionStatus.Acknowledged => "fc-badge--info",
        DirectSubmissionStatus.Accepted => "fc-badge--success",
        DirectSubmissionStatus.Rejected or DirectSubmissionStatus.Failed or DirectSubmissionStatus.Exhausted => "fc-badge--danger",
        DirectSubmissionStatus.RetryScheduled or DirectSubmissionStatus.QualityFeedback or DirectSubmissionStatus.Submitting => "fc-badge--warning",
        _ => "fc-badge--neutral"
    };
}
