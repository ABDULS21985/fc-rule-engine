@page "/submissions/{Id:int}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using System.Text.Json
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.DataRecord
@using FC.Engine.Domain.Entities
@using FC.Engine.Domain.Enums
@inject IGenericDataRepository GenericDataRepo
@inject ISubmissionRepository SubmissionRepo
@inject NavigationManager Nav

<PageHeader Title="@($"Submission #{Id}")"
            BackUrl="/submissions">
    <PrimaryAction>
        @if (_submission is not null)
        {
            <a href="/templates/@_submission.ReturnCode" class="fc-btn fc-btn--outline fc-btn--sm">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                View Template
            </a>
        }
    </PrimaryAction>
</PageHeader>

<div class="fc-detail-page">

    @if (_loading)
    {
        <div class="fc-skel-detail" role="status" aria-label="Loading submission">
            <div class="fc-skel-detail-hero">
                <div class="fc-skel fc-skel-text-xl" style="--skel-w:180px"></div>
                <div class="fc-skel fc-skel-text" style="--skel-w:260px"></div>
                <div class="fc-flex-row--gap3 fc-mt-2">
                    <div class="fc-skel" style="--skel-w:80px;--skel-h:24px"></div>
                    <div class="fc-skel" style="--skel-w:100px;--skel-h:24px"></div>
                </div>
            </div>
            <div class="fc-skel-detail-tabs">
                <div class="fc-skel fc-skel-detail-tab" style="--skel-w:70px"></div>
                <div class="fc-skel fc-skel-detail-tab" style="--skel-w:80px"></div>
                <div class="fc-skel fc-skel-detail-tab" style="--skel-w:100px"></div>
            </div>
            <div class="fc-skel-detail-section">
                @for (var i = 0; i < 5; i++)
                {
                    <div class="fc-skel fc-skel-text" style="--skel-w:@(30 + i * 15)%"></div>
                }
            </div>
        </div>
    }
    else if (_submission == null)
    {
        <div class="fc-alert fc-alert--inline fc-alert--error">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            Submission not found
        </div>
    }
    else
    {
        <!-- Hero Header -->
        <section class="fc-detail-hero" role="banner">
            <div class="fc-detail-hero-left">
                <div class="fc-detail-hero-title-row">
                    <h1 class="fc-detail-hero-title">Submission #@Id</h1>
                    <span class="fc-detail-status fc-detail-status-@_submission.Status.ToString().ToLowerInvariant()">
                        <span class="fc-detail-status-dot" aria-hidden="true"></span>
                        @FormatStatus(_submission.Status)
                    </span>
                </div>
                <p class="fc-detail-hero-subtitle">
                    Return Code <a href="/templates/@_submission.ReturnCode">@_submission.ReturnCode</a>
                    @if (_submission.SubmittedAt is not null)
                    {
                        @:&middot; Submitted @_submission.SubmittedAt.Value.ToString("d MMM yyyy, HH:mm") UTC
                    }
                    else
                    {
                        @:&middot; Created @_submission.CreatedAt.ToString("d MMM yyyy, HH:mm") UTC
                    }
                </p>

                <div class="fc-detail-hero-meta">
                    <div class="fc-detail-meta-item">
                        <span class="fc-detail-meta-label">Return Code</span>
                        <span class="fc-detail-meta-value">
                            <a href="/templates/@_submission.ReturnCode" class="fc-link-plain">
                                <code>@_submission.ReturnCode</code>
                            </a>
                        </span>
                    </div>
                    <div class="fc-detail-meta-item">
                        <span class="fc-detail-meta-label">Institution</span>
                        <span class="fc-detail-meta-value">@(_submission.Institution?.InstitutionName ?? $"#{_submission.InstitutionId}")</span>
                    </div>
                    <div class="fc-detail-meta-item">
                        <span class="fc-detail-meta-label">Period</span>
                        <span class="fc-detail-meta-value">@(_submission.ReturnPeriod?.ReportingDate.ToString("yyyy-MM-dd") ?? $"#{_submission.ReturnPeriodId}")</span>
                    </div>
                    <div class="fc-detail-meta-item">
                        <span class="fc-detail-meta-label">Processing</span>
                        <span class="fc-detail-meta-value">@(_submission.ProcessingDurationMs is { } dur ? $"{dur}ms" : "—")</span>
                    </div>
                    @if (_submission.TemplateVersionId.HasValue)
                    {
                        <div class="fc-detail-meta-item">
                            <span class="fc-detail-meta-label">Template Version</span>
                            <span class="fc-detail-meta-value">v@(_submission.TemplateVersionId)</span>
                        </div>
                    }
                </div>
            </div>

        </section>

        <!-- Tabbed Navigation -->
        <div class="fc-tabs" role="tablist" aria-label="Submission sections">
            <button class="fc-tab @(_activeTab == "overview" ? "fc-tab-active" : "")"
                    role="tab" aria-selected="@(_activeTab == "overview")" @onclick='() => _activeTab = "overview"'>
                Overview
            </button>
            <button class="fc-tab @(_activeTab == "validation" ? "fc-tab-active" : "")"
                    role="tab" aria-selected="@(_activeTab == "validation")" @onclick='() => _activeTab = "validation"'>
                Validation
                @if (_submission.ValidationReport != null)
                {
                    <span class="fc-tab-badge">@(_submission.ValidationReport.Errors.Count)</span>
                }
            </button>
            <button class="fc-tab @(_activeTab == "data" ? "fc-tab-active" : "")"
                    role="tab" aria-selected="@(_activeTab == "data")" @onclick='() => _activeTab = "data"'>
                Submission Data
            </button>
        </div>

        <!-- Tab: Overview -->
        <div class="fc-tab-content @(_activeTab == "overview" ? "fc-tab-content-active" : "")" role="tabpanel">
            <div class="fc-section">
                <div class="fc-section-header">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                        Submission Details
                    </h3>
                </div>
                <div class="fc-section-body">
                    <div class="fc-detail-info-grid">
                        <div class="fc-detail-info-item">
                            <span class="fc-detail-info-label">Submission ID</span>
                            <span class="fc-detail-info-value">#@_submission.Id</span>
                        </div>
                        <div class="fc-detail-info-item">
                            <span class="fc-detail-info-label">Return Code</span>
                            <span class="fc-detail-info-value">
                                <a href="/templates/@_submission.ReturnCode"><code>@_submission.ReturnCode</code></a>
                            </span>
                        </div>
                        <div class="fc-detail-info-item">
                            <span class="fc-detail-info-label">Status</span>
                            <span class="fc-detail-info-value">
                                <span class="fc-detail-status fc-detail-status-@_submission.Status.ToString().ToLowerInvariant()">
                                    <span class="fc-detail-status-dot" aria-hidden="true"></span>
                                    @FormatStatus(_submission.Status)
                                </span>
                            </span>
                        </div>
                        <div class="fc-detail-info-item">
                            <span class="fc-detail-info-label">Institution</span>
                            <span class="fc-detail-info-value">@(_submission.Institution?.InstitutionName ?? "—") <span class="fc-text-subtle">(#@_submission.InstitutionId)</span></span>
                        </div>
                        <div class="fc-detail-info-item">
                            <span class="fc-detail-info-label">Return Period</span>
                            <span class="fc-detail-info-value">@(_submission.ReturnPeriod?.ReportingDate.ToString("yyyy-MM-dd") ?? "—") <span class="fc-text-subtle">(#@_submission.ReturnPeriodId)</span></span>
                        </div>
                        @if (_submission.TemplateVersionId.HasValue)
                        {
                            <div class="fc-detail-info-item">
                                <span class="fc-detail-info-label">Template Version ID</span>
                                <span class="fc-detail-info-value">@_submission.TemplateVersionId</span>
                            </div>
                        }
                        <div class="fc-detail-info-item">
                            <span class="fc-detail-info-label">Submitted At</span>
                            <span class="fc-detail-info-value">
                                @if (_submission.SubmittedAt is not null)
                                {
                                    @(_submission.SubmittedAt.Value.ToString("d MMM yyyy, HH:mm:ss"))@: UTC
                                }
                                else
                                {
                                    <span class="fc-text-subtle">Not yet submitted</span>
                                }
                            </span>
                        </div>
                        <div class="fc-detail-info-item">
                            <span class="fc-detail-info-label">Processing Duration</span>
                            <span class="fc-detail-info-value">@(_submission.ProcessingDurationMs is { } durMs ? $"{durMs}ms" : "—")</span>
                        </div>
                        <div class="fc-detail-info-item">
                            <span class="fc-detail-info-label">Created At</span>
                            <span class="fc-detail-info-value">@_submission.CreatedAt.ToString("d MMM yyyy, HH:mm:ss") UTC</span>
                        </div>
                    </div>
                </div>
            </div>

            @if (_submission.ValidationReport != null)
            {
                <div class="fc-section">
                    <div class="fc-section-header">
                        <h3>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
                            Validation Summary
                        </h3>
                        <span class="fc-detail-status @(_submission.ValidationReport.IsValid ? "fc-detail-status-accepted" : "fc-detail-status-rejected")">
                            <span class="fc-detail-status-dot" aria-hidden="true"></span>
                            @(_submission.ValidationReport.IsValid ? "Valid" : "Invalid")
                        </span>
                    </div>
                    <div class="fc-section-body">
                        <div class="fc-detail-validation-summary">
                            <div class="fc-detail-val-stat fc-detail-val-error">
                                <div>
                                    <div class="fc-detail-val-stat-count">@_submission.ValidationReport.ErrorCount</div>
                                    <div class="fc-detail-val-stat-label">Errors</div>
                                </div>
                            </div>
                            <div class="fc-detail-val-stat fc-detail-val-warning">
                                <div>
                                    <div class="fc-detail-val-stat-count">@_submission.ValidationReport.WarningCount</div>
                                    <div class="fc-detail-val-stat-label">Warnings</div>
                                </div>
                            </div>
                            <div class="fc-detail-val-stat @(_submission.ValidationReport.IsValid ? "fc-detail-val-success" : "fc-detail-val-error")">
                                <div>
                                    <div class="fc-detail-val-stat-count">@_submission.ValidationReport.Errors.Count</div>
                                    <div class="fc-detail-val-stat-label">Total Issues</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Tab: Validation -->
        <div class="fc-tab-content @(_activeTab == "validation" ? "fc-tab-content-active" : "")" role="tabpanel">
            @if (_submission.ValidationReport != null)
            {
                var report = _submission.ValidationReport;

                <!-- Validation Counters -->
                <div class="fc-section">
                    <div class="fc-section-header">
                        <h3>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                            Validation Report
                        </h3>
                        <span class="fc-detail-status @(report.IsValid ? "fc-detail-status-accepted" : "fc-detail-status-rejected")">
                            <span class="fc-detail-status-dot" aria-hidden="true"></span>
                            @(report.IsValid ? "Passed" : "Failed")
                        </span>
                    </div>
                    <div class="fc-section-body">
                        <div class="fc-detail-validation-summary">
                            <div class="fc-detail-val-stat fc-detail-val-error">
                                <div>
                                    <div class="fc-detail-val-stat-count">@report.ErrorCount</div>
                                    <div class="fc-detail-val-stat-label">Errors</div>
                                </div>
                            </div>
                            <div class="fc-detail-val-stat fc-detail-val-warning">
                                <div>
                                    <div class="fc-detail-val-stat-count">@report.WarningCount</div>
                                    <div class="fc-detail-val-stat-label">Warnings</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Error Table -->
                var errors    = report.Errors.Where(e => e.Severity == ValidationSeverity.Error).ToList();
                var nonErrors = report.Errors.Where(e => e.Severity != ValidationSeverity.Error).ToList();
                @if (report.Errors.Any())
                {
                    @if (errors.Count > 0)
                    {
                        <div class="fc-section">
                            <div class="fc-section-header">
                                <h3>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                    Errors (@errors.Count)
                                </h3>
                            </div>
                            <div class="fc-overflow-x">
                                <table class="fc-detail-field-table">
                                    <thead>
                                        <tr>
                                            <th>Rule ID</th>
                                            <th>Category</th>
                                            <th>Field</th>
                                            <th>Message</th>
                                            <th>Expected</th>
                                            <th>Actual</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var err in errors)
                                        {
                                            <tr>
                                                <td><code>@err.RuleId</code></td>
                                                <td><span class="fc-badge fc-badge--info">@err.Category</span></td>
                                                <td><code>@err.Field</code></td>
                                                <td>@err.Message</td>
                                                <td>@err.ExpectedValue</td>
                                                <td>@err.ActualValue</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                    @if (nonErrors.Count > 0)
                    {
                        <div class="fc-section">
                            <div class="fc-section-header">
                                <h3>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                                    Warnings (@nonErrors.Count)
                                </h3>
                            </div>
                            <div class="fc-overflow-x">
                                <table class="fc-detail-field-table">
                                    <thead>
                                        <tr>
                                            <th>Rule ID</th>
                                            <th>Category</th>
                                            <th>Field</th>
                                            <th>Message</th>
                                            <th>Expected</th>
                                            <th>Actual</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var warn in nonErrors)
                                        {
                                            <tr>
                                                <td><code>@warn.RuleId</code></td>
                                                <td><span class="fc-badge fc-badge--info">@warn.Category</span></td>
                                                <td><code>@warn.Field</code></td>
                                                <td>@warn.Message</td>
                                                <td>@warn.ExpectedValue</td>
                                                <td>@warn.ActualValue</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="fc-section">
                        <div class="fc-section-body">
                            <div class="fc-detail-empty">
                                <svg viewBox="0 0 24 24" fill="none" stroke="var(--cbn-success)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                <p class="fc-detail-empty-title">All checks passed</p>
                                <p class="fc-detail-empty-text">No validation errors or warnings were found for this submission.</p>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="fc-section">
                    <div class="fc-section-body">
                        <div class="fc-detail-empty">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                            <p class="fc-detail-empty-title">No validation report</p>
                            <p class="fc-detail-empty-text">Validation has not been completed for this submission.</p>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Tab: Submission Data -->
        <div class="fc-tab-content @(_activeTab == "data" ? "fc-tab-content-active" : "")" role="tabpanel">
            <div class="fc-section">
                <div class="fc-section-header">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
                        Submission Data
                    </h3>
                </div>
                <div class="fc-section-body">
                    @if (!string.IsNullOrEmpty(_submission.RawXml))
                    {
                        <pre class="fc-detail-code-block">@_submission.RawXml</pre>
                    }
                    else if (!string.IsNullOrEmpty(_submission.ParsedDataJson))
                    {
                        <pre class="fc-detail-code-block">@_submission.ParsedDataJson</pre>
                    }
                    else if (!string.IsNullOrEmpty(_fallbackSubmissionDataJson))
                    {
                        <pre class="fc-detail-code-block">@_fallbackSubmissionDataJson</pre>
                    }
                    else
                    {
                        <div class="fc-detail-empty">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
                            <p class="fc-detail-empty-title">No submission data available</p>
                            <p class="fc-detail-empty-text">Neither the stored payload nor the ingested submission rows are available for this record.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private bool _loading = true;
    private Submission? _submission;
    private string _activeTab = "overview";
    private string? _fallbackSubmissionDataJson;

    protected override async Task OnInitializedAsync()
    {
        _submission = await SubmissionRepo.GetByIdWithReport(Id);
        if (_submission is not null
            && string.IsNullOrWhiteSpace(_submission.RawXml)
            && string.IsNullOrWhiteSpace(_submission.ParsedDataJson))
        {
            var record = await GenericDataRepo.GetBySubmission(_submission.ReturnCode, _submission.Id);
            if (record is not null)
            {
                _fallbackSubmissionDataJson = SerializeRecord(record);
            }
        }

        _loading = false;
    }

    private static string FormatStatus(SubmissionStatus status) => status switch
    {
        SubmissionStatus.Draft => "Draft",
        SubmissionStatus.Parsing => "Parsing",
        SubmissionStatus.Validating => "Validating",
        SubmissionStatus.Accepted => "Accepted",
        SubmissionStatus.AcceptedWithWarnings => "Accepted with Warnings",
        SubmissionStatus.Rejected => "Rejected",
        SubmissionStatus.PendingApproval => "Pending Approval",
        SubmissionStatus.ApprovalRejected => "Approval Rejected",
        SubmissionStatus.Historical => "Historical",
        SubmissionStatus.SubmittedToRegulator => "Submitted to Regulator",
        SubmissionStatus.RegulatorAcknowledged => "Regulator Acknowledged",
        SubmissionStatus.RegulatorAccepted => "Regulator Accepted",
        SubmissionStatus.RegulatorQueriesRaised => "Queries Raised",
        _ => status.ToString()
    };

    private static string SerializeRecord(ReturnDataRecord record)
    {
        var payload = new
        {
            record.ReturnCode,
            record.TemplateVersionId,
            Category = record.Category.ToString(),
            Rows = record.Rows.Select(row => new
            {
                row.RowKey,
                Fields = row.AllFields
            })
        };

        return JsonSerializer.Serialize(payload, new JsonSerializerOptions
        {
            WriteIndented = true
        });
    }
}
