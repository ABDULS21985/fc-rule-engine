@page "/users"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "AdminOnly")]
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Entities
@using FC.Engine.Domain.Enums
@using FC.Engine.Application.Services
@using FC.Engine.Admin.Services
@inject IPortalUserRepository UserRepo
@inject AuthService AuthService
@inject ToastService Toast
@inject DialogService Dialog

<div class="admin-page">

    <!-- Breadcrumb -->
    <nav class="detail-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Dashboard</a>
        <span class="detail-breadcrumb-sep" aria-hidden="true">/</span>
        <span class="detail-breadcrumb-current">Users</span>
    </nav>

    <!-- Page Header -->
    <div class="admin-header">
        <div class="admin-header-top">
            <div>
                <h1>User Management</h1>
                <p class="admin-header-subtitle">Manage platform identities, roles, and access across the FC Engine administrative portal.</p>
            </div>
            <button class="fc-btn fc-btn--primary" @onclick="OpenCreateModal" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add User
            </button>
        </div>

        <!-- Summary Chips -->
        <div class="fc-chip-group">
            <span class="fc-chip">
                <span class="fc-chip__count">@_users.Count</span> Total Users
            </span>
            <span class="fc-chip">
                <span class="fc-chip__dot fc-chip__dot--active" aria-hidden="true"></span>
                <span class="fc-chip__count">@_users.Count(u => u.IsActive)</span> Active
            </span>
            @if (_users.Any(u => !u.IsActive))
            {
                <span class="fc-chip">
                    <span class="fc-chip__dot fc-chip__dot--inactive" aria-hidden="true"></span>
                    <span class="fc-chip__count">@_users.Count(u => !u.IsActive)</span> Inactive
                </span>
            }
            <span class="fc-chip">
                <span class="fc-chip__dot fc-chip__dot--admin" aria-hidden="true"></span>
                <span class="fc-chip__count">@_users.Count(u => u.Role == PortalRole.Admin)</span> Admins
            </span>
            <span class="fc-chip">
                <span class="fc-chip__dot fc-chip__dot--approver" aria-hidden="true"></span>
                <span class="fc-chip__count">@_users.Count(u => u.Role == PortalRole.Approver)</span> Approvers
            </span>
            <span class="fc-chip">
                <span class="fc-chip__dot fc-chip__dot--viewer" aria-hidden="true"></span>
                <span class="fc-chip__count">@_users.Count(u => u.Role == PortalRole.Viewer)</span> Viewers
            </span>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="admin-toolbar">
        <div class="admin-toolbar-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" placeholder="Search by name or email..." @bind="_searchQuery" @bind:event="oninput" aria-label="Search users" />
        </div>
        <div class="admin-toolbar-filter">
            <select @bind="_roleFilter" aria-label="Filter by role">
                <option value="">All Roles</option>
                @foreach (var role in Enum.GetValues<PortalRole>())
                {
                    <option value="@role">@role</option>
                }
            </select>
            <select @bind="_statusFilter" aria-label="Filter by status">
                <option value="">All Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
            </select>
        </div>
    </div>

    <!-- Content -->
    @if (_loading)
    {
        <div class="skel-user-grid" role="status" aria-label="Loading users">
            @for (var i = 0; i < 6; i++)
            {
                <div class="skel-user-card">
                    <div class="skel-user-header">
                        <div class="skel skel-circle skel-user-avatar" style="width:48px;height:48px;"></div>
                        <div class="skel-user-info">
                            <div class="skel skel-text" style="width:120px;"></div>
                            <div class="skel skel-text" style="width:160px;"></div>
                        </div>
                        <div class="skel" style="width:60px;height:22px;border-radius:var(--radius-pill);"></div>
                    </div>
                    <div class="skel-user-meta">
                        <div class="skel" style="width:80px;height:10px;"></div>
                        <div class="skel" style="width:100px;height:10px;"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (!FilteredUsers.Any())
    {
        <div class="admin-empty">
            <div class="admin-empty-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4-4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            @if (string.IsNullOrEmpty(_searchQuery) && string.IsNullOrEmpty(_roleFilter) && string.IsNullOrEmpty(_statusFilter))
            {
                <h3 class="admin-empty-title">No users found</h3>
                <p class="admin-empty-text">Add the first user to begin managing platform access.</p>
            }
            else
            {
                <h3 class="admin-empty-title">No matching users</h3>
                <p class="admin-empty-text">Try adjusting your search or filters.</p>
            }
        </div>
    }
    else
    {
        <!-- User Card Grid -->
        <div class="user-grid" role="list">
            @foreach (var user in FilteredUsers)
            {
                <div class="user-card" role="listitem">
                    <div class="user-card-header">
                        <div class="user-avatar" aria-hidden="true">@GetInitials(user.DisplayName)</div>
                        <div class="user-identity">
                            <div class="user-name" title="@user.DisplayName">@user.DisplayName</div>
                            <div class="user-email" title="@user.Email">@user.Email</div>
                        </div>
                        <span class="role-badge @GetRoleBadgeClass(user.Role)">@user.Role</span>
                    </div>

                    <div class="user-meta">
                        <span class="user-meta-item">
                            <span class="user-status-dot @(user.IsActive ? "user-status-dot-active" : "user-status-dot-inactive")" aria-hidden="true"></span>
                            @(user.IsActive ? "Active" : "Inactive")
                        </span>
                        <span class="user-meta-item" title="@user.Username">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4-4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            @user.Username
                        </span>
                        <span class="user-meta-item">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            @if (user.LastLoginAt.HasValue)
                            {
                                @user.LastLoginAt.Value.ToString("dd MMM yyyy, HH:mm")
                            }
                            else
                            {
                                <span>Never logged in</span>
                            }
                        </span>
                    </div>

                    <div class="user-card-actions">
                        <button class="fc-btn fc-btn--ghost" @onclick="() => OpenEditModal(user)" type="button" title="Edit user">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            Edit
                        </button>
                        <button class="fc-btn fc-btn--ghost" @onclick="() => ResetPassword(user)" type="button" title="Reset password">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                            Reset Password
                        </button>
                        <button class="fc-btn fc-btn--ghost @(user.IsActive ? "fc-btn--danger" : "")"
                                @onclick="() => ToggleUserStatus(user)" type="button"
                                title="@(user.IsActive ? "Disable account" : "Enable account")">
                            @if (user.IsActive)
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                                <span>Disable</span>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                <span>Enable</span>
                            }
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Create/Edit User Modal -->
<AppModal @bind-Visible="_showModal" Title="@(_editingUser is null ? "Create New User" : "Edit User")"
          Subtitle="@(_editingUser is null ? "Add a new platform user with role-based access" : $"Update details for {_editingUser.DisplayName}")"
          Size="lg">
    <ChildContent>
        @if (!string.IsNullOrEmpty(_formError))
        {
            <AppAlert Variant="AppAlert.AlertVariant.Error" Message="@_formError" Dismissible="true" OnDismiss="() => _formError = null" />
        }

        <div class="admin-form-grid">
            @if (_editingUser is null)
            {
                <div class="admin-form-group">
                    <label class="admin-form-label admin-form-label-required">Username</label>
                    <input class="admin-form-input" @bind="_formUsername" placeholder="e.g. jdoe" />
                </div>
            }

            <div class="admin-form-group">
                <label class="admin-form-label admin-form-label-required">Display Name</label>
                <input class="admin-form-input" @bind="_formDisplayName" placeholder="e.g. John Doe" />
            </div>

            <div class="admin-form-group">
                <label class="admin-form-label admin-form-label-required">Email Address</label>
                <input class="admin-form-input" type="email" @bind="_formEmail" placeholder="e.g. john.doe@cbn.gov.ng" />
            </div>

            @if (_editingUser is null)
            {
                <div class="admin-form-group">
                    <label class="admin-form-label admin-form-label-required">Password</label>
                    <input class="admin-form-input" type="password" @bind="_formPassword" placeholder="Minimum 8 characters" />
                </div>
            }
        </div>

        <!-- Role Selection -->
        <div style="margin-top: var(--space-6);">
            <div class="admin-form-section-label">Role Assignment</div>
            <div class="role-cards">
                <label class="role-card role-card-admin @(_formRole == PortalRole.Admin ? "role-card-selected" : "")"
                       tabindex="0" @onkeydown="e => HandleRoleKeyDown(e, PortalRole.Admin)">
                    <input type="radio" name="role-select" checked="@(_formRole == PortalRole.Admin)" @onchange="() => _formRole = PortalRole.Admin" />
                    <div class="role-card-radio"><div class="role-card-radio-inner"></div></div>
                    <div class="role-card-content">
                        <div class="role-card-title">Admin</div>
                        <div class="role-card-desc">Full platform administration access including user management, system configuration, and all data operations.</div>
                    </div>
                </label>

                <label class="role-card role-card-approver @(_formRole == PortalRole.Approver ? "role-card-selected" : "")"
                       tabindex="0" @onkeydown="e => HandleRoleKeyDown(e, PortalRole.Approver)">
                    <input type="radio" name="role-select" checked="@(_formRole == PortalRole.Approver)" @onchange="() => _formRole = PortalRole.Approver" />
                    <div class="role-card-radio"><div class="role-card-radio-inner"></div></div>
                    <div class="role-card-content">
                        <div class="role-card-title">Approver</div>
                        <div class="role-card-desc">Can review, approve, and manage template workflows, version publishing, and submission oversight.</div>
                    </div>
                </label>

                <label class="role-card role-card-viewer @(_formRole == PortalRole.Viewer ? "role-card-selected" : "")"
                       tabindex="0" @onkeydown="e => HandleRoleKeyDown(e, PortalRole.Viewer)">
                    <input type="radio" name="role-select" checked="@(_formRole == PortalRole.Viewer)" @onchange="() => _formRole = PortalRole.Viewer" />
                    <div class="role-card-radio"><div class="role-card-radio-inner"></div></div>
                    <div class="role-card-content">
                        <div class="role-card-title">Viewer</div>
                        <div class="role-card-desc">Read-only access to permitted templates, submissions, and dashboard analytics.</div>
                    </div>
                </label>
            </div>
        </div>
    </ChildContent>
    <FooterContent>
        <button class="fc-btn fc-btn--outline" @onclick="CloseModal" type="button">Cancel</button>
        <button class="fc-btn fc-btn--primary" @onclick="SaveUser" disabled="@_saving" type="button">
            @if (_saving)
            {
                <span class="spinner" style="width:16px;height:16px;"></span>
            }
            @(_editingUser is null ? "Create User" : "Save Changes")
        </button>
    </FooterContent>
</AppModal>

<!-- Reset Password Modal -->
<AppModal @bind-Visible="_showPasswordModal" Title="Reset Password" Subtitle="@($"Set a new password for {_passwordResetUser?.DisplayName}")" Size="sm">
    <ChildContent>
        @if (!string.IsNullOrEmpty(_passwordError))
        {
            <AppAlert Variant="AppAlert.AlertVariant.Error" Message="@_passwordError" Dismissible="true" OnDismiss="() => _passwordError = null" />
        }
        <div class="admin-form-group">
            <label class="admin-form-label admin-form-label-required">New Password</label>
            <input class="admin-form-input" type="password" @bind="_newPassword" placeholder="Minimum 8 characters" />
        </div>
    </ChildContent>
    <FooterContent>
        <button class="fc-btn fc-btn--outline" @onclick="() => _showPasswordModal = false" type="button">Cancel</button>
        <button class="fc-btn fc-btn--primary" @onclick="ConfirmResetPassword" disabled="@_saving" type="button">
            @if (_saving)
            {
                <span class="spinner" style="width:16px;height:16px;"></span>
            }
            Reset Password
        </button>
    </FooterContent>
</AppModal>

@code {
    private IReadOnlyList<PortalUser> _users = Array.Empty<PortalUser>();
    private bool _loading = true;

    // Filters
    private string _searchQuery = "";
    private string _roleFilter = "";
    private string _statusFilter = "";

    // Create/Edit modal
    private bool _showModal;
    private PortalUser? _editingUser;
    private string _formUsername = "";
    private string _formDisplayName = "";
    private string _formEmail = "";
    private string _formPassword = "";
    private PortalRole _formRole = PortalRole.Viewer;
    private string? _formError;
    private bool _saving;

    // Password reset modal
    private bool _showPasswordModal;
    private PortalUser? _passwordResetUser;
    private string _newPassword = "";
    private string? _passwordError;

    private IEnumerable<PortalUser> FilteredUsers => _users
        .Where(u => string.IsNullOrEmpty(_searchQuery) ||
                    u.DisplayName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    u.Email.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    u.Username.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
        .Where(u => string.IsNullOrEmpty(_roleFilter) ||
                    u.Role.ToString() == _roleFilter)
        .Where(u => string.IsNullOrEmpty(_statusFilter) ||
                    (_statusFilter == "active" && u.IsActive) ||
                    (_statusFilter == "inactive" && !u.IsActive))
        .OrderByDescending(u => u.Role == PortalRole.Admin)
        .ThenByDescending(u => u.Role == PortalRole.Approver)
        .ThenBy(u => u.DisplayName);

    protected override async Task OnInitializedAsync()
    {
        _users = await UserRepo.GetAll();
        _loading = false;
    }

    // --- Helpers ---
    private void HandleRoleKeyDown(KeyboardEventArgs e, PortalRole role)
    {
        if (e.Key is "Enter" or " ")
            _formRole = role;
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
        return parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant();
    }

    private static string GetRoleBadgeClass(PortalRole role) => role switch
    {
        PortalRole.Admin => "role-badge-admin",
        PortalRole.Approver => "role-badge-approver",
        _ => "role-badge-viewer"
    };

    // --- Create / Edit Modal ---
    private void OpenCreateModal()
    {
        _editingUser = null;
        _formUsername = "";
        _formDisplayName = "";
        _formEmail = "";
        _formPassword = "";
        _formRole = PortalRole.Viewer;
        _formError = null;
        _showModal = true;
    }

    private void OpenEditModal(PortalUser user)
    {
        _editingUser = user;
        _formDisplayName = user.DisplayName;
        _formEmail = user.Email;
        _formRole = user.Role;
        _formError = null;
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
        _editingUser = null;
    }

    private async Task SaveUser()
    {
        _formError = null;
        _saving = true;

        try
        {
            if (_editingUser is null)
            {
                // Create
                if (string.IsNullOrWhiteSpace(_formUsername) || string.IsNullOrWhiteSpace(_formPassword))
                {
                    _formError = "Username and password are required.";
                    _saving = false;
                    return;
                }
                if (string.IsNullOrWhiteSpace(_formDisplayName))
                {
                    _formError = "Display name is required.";
                    _saving = false;
                    return;
                }

                await AuthService.CreateUser(_formUsername.Trim(), _formDisplayName.Trim(), _formEmail.Trim(), _formPassword, _formRole);
                Toast.Success($"User '{_formDisplayName.Trim()}' created successfully.");
            }
            else
            {
                // Edit
                if (string.IsNullOrWhiteSpace(_formDisplayName))
                {
                    _formError = "Display name is required.";
                    _saving = false;
                    return;
                }

                _editingUser.DisplayName = _formDisplayName.Trim();
                _editingUser.Email = _formEmail.Trim();
                _editingUser.Role = _formRole;
                await UserRepo.Update(_editingUser);
                Toast.Success($"User '{_editingUser.DisplayName}' updated successfully.");
            }

            _users = await UserRepo.GetAll();
            _showModal = false;
            _editingUser = null;
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    // --- Password Reset ---
    private void ResetPassword(PortalUser user)
    {
        _passwordResetUser = user;
        _newPassword = "";
        _passwordError = null;
        _showPasswordModal = true;
    }

    private async Task ConfirmResetPassword()
    {
        _passwordError = null;
        if (_passwordResetUser is null) return;

        if (string.IsNullOrWhiteSpace(_newPassword) || _newPassword.Length < 8)
        {
            _passwordError = "Password must be at least 8 characters.";
            return;
        }

        _saving = true;
        try
        {
            await AuthService.ChangePassword(_passwordResetUser.Id, _newPassword);
            Toast.Success($"Password for '{_passwordResetUser.DisplayName}' has been reset.");
            _showPasswordModal = false;
        }
        catch (Exception ex)
        {
            _passwordError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    // --- Toggle Status ---
    private async Task ToggleUserStatus(PortalUser user)
    {
        var action = user.IsActive ? "Disable" : "Enable";
        var confirmed = await Dialog.Confirm(new ConfirmRequest
        {
            Title = $"{action} User",
            Message = $"{action} the account for {user.DisplayName}? {(user.IsActive ? "They will not be able to sign in." : "They will be able to sign in again.")}",
            ConfirmText = action,
            IsDestructive = user.IsActive,
            Icon = user.IsActive ? "archive" : "publish"
        });

        if (!confirmed) return;

        user.IsActive = !user.IsActive;
        await UserRepo.Update(user);
        _users = await UserRepo.GetAll();
        Toast.Success($"User '{user.DisplayName}' has been {(user.IsActive ? "enabled" : "disabled")}.");
    }
}
