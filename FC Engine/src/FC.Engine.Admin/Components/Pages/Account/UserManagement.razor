@page "/users"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "CanManageUsers")]
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Entities
@using FC.Engine.Domain.Enums
@using FC.Engine.Application.Services
@using FC.Engine.Admin.Services
@using Microsoft.EntityFrameworkCore
@inject IPortalUserRepository UserRepo
@inject IPortalRoleCatalogService RoleCatalog
@inject AuthService AuthService
@inject ToastService Toast
@inject DialogService Dialog
@inject IDbContextFactory<FC.Engine.Infrastructure.Metadata.MetadataDbContext> DbFactory

<PageHeader Title="User Management"
            Subtitle="Manage platform identities, roles, and access across the RegOS™ administrative portal.">
    <PrimaryAction>
        <button class="fc-btn fc-btn--primary" @onclick="OpenCreateModal" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add User
        </button>
    </PrimaryAction>
</PageHeader>

<div class="fc-page">

    <!-- Toolbar -->
    <div class="fc-toolbar">
        <div class="fc-toolbar-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" placeholder="Search by name or email..." @bind="_searchQuery" @bind:event="oninput" aria-label="Search users" />
        </div>
        <div class="fc-toolbar-filter">
            <select @bind="_roleFilter" aria-label="Filter by role">
                <option value="">All Roles</option>
                @foreach (var role in _roleOptions.Select(r => r.Role).Distinct())
                {
                    <option value="@role">@role</option>
                }
            </select>
            <select @bind="_statusFilter" aria-label="Filter by status">
                <option value="">All Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
            </select>
        </div>
    </div>

    <!-- Content -->
    @if (_loading)
    {
        <div class="fc-skel-fc-user-grid" role="status" aria-label="Loading users">
            @for (var i = 0; i < 6; i++)
            {
                <div class="fc-skel-fc-user-card">
                    <div class="fc-skel-user-header">
                        <div class="fc-skel fc-skel-circle fc-skel-user-avatar" style="--skel-w:48px;--skel-h:48px"></div>
                        <div class="fc-skel-user-info">
                            <div class="fc-skel fc-skel-text" style="--skel-w:120px"></div>
                            <div class="fc-skel fc-skel-text" style="--skel-w:160px"></div>
                        </div>
                        <div class="fc-skel fc-skel-circle" style="--skel-w:60px;--skel-h:22px"></div>
                    </div>
                    <div class="fc-skel-fc-user-meta">
                        <div class="fc-skel" style="--skel-w:80px;--skel-h:10px"></div>
                        <div class="fc-skel" style="--skel-w:100px;--skel-h:10px"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (!FilteredUsers.Any())
    {
        <div class="fc-empty">
            <div class="fc-empty-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4-4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            @if (string.IsNullOrEmpty(_searchQuery) && string.IsNullOrEmpty(_roleFilter) && string.IsNullOrEmpty(_statusFilter))
            {
                <h3 class="fc-empty-title">No users found</h3>
                <p class="fc-empty-text">Add the first user to begin managing platform access.</p>
            }
            else
            {
                <h3 class="fc-empty-title">No matching users</h3>
                <p class="fc-empty-text">Try adjusting your search or filters.</p>
            }
        </div>
    }
    else
    {
        <!-- User Card Grid -->
        <div class="fc-user-grid" role="list">
            @foreach (var user in FilteredUsers)
            {
                <div class="fc-user-card" role="listitem">
                    <div class="fc-user-card-header">
                        <div class="fc-user-avatar" aria-hidden="true">@GetInitials(user.DisplayName)</div>
                        <div class="fc-user-identity">
                            <div class="fc-user-name" title="@user.DisplayName">@user.DisplayName</div>
                            <div class="fc-user-email" title="@user.Email">@user.Email</div>
                        </div>
                        <span class="fc-role-badge @GetRoleBadgeClass(user.Role)">@user.Role</span>
                    </div>

                    <div class="fc-user-meta">
                        <span class="fc-user-meta-item">
                            <span class="fc-user-status-dot @(user.IsActive ? "fc-user-status-dot-active" : "fc-user-status-dot-inactive")" aria-hidden="true"></span>
                            @(user.IsActive ? "Active" : "Inactive")
                        </span>
                        <span class="fc-user-meta-item" title="@user.Username">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4-4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            @user.Username
                        </span>
                        <span class="fc-user-meta-item">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            @if (user.LastLoginAt.HasValue)
                            {
                                @user.LastLoginAt.Value.ToString("dd MMM yyyy, HH:mm")
                            }
                            else
                            {
                                <span>Never logged in</span>
                            }
                        </span>
                    </div>

                    <div class="fc-user-card-actions">
                        <button class="fc-btn fc-btn--ghost" @onclick="() => OpenEditModal(user)" type="button" title="Edit user">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            Edit
                        </button>
                        <button class="fc-btn fc-btn--ghost" @onclick="() => ResetPassword(user)" type="button" title="Reset password">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                            Reset Password
                        </button>
                        <button class="fc-btn fc-btn--ghost @(user.IsActive ? "fc-btn--danger" : "")"
                                @onclick="() => ToggleUserStatus(user)" type="button"
                                title="@(user.IsActive ? "Disable account" : "Enable account")">
                            @if (user.IsActive)
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                                <span>Disable</span>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                <span>Enable</span>
                            }
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Create/Edit User Modal -->
<AppModal @bind-Visible="_showModal" Title="@(_editingUser is null ? "Create New User" : "Edit User")"
          Subtitle="@(_editingUser is null ? "Add a new platform user with fc-role-based access" : $"Update details for {_editingUser.DisplayName}")"
          Size="lg">
    <ChildContent>
        @if (!string.IsNullOrEmpty(_formError))
        {
            <AppAlert Variant="AppAlert.AlertVariant.Error" Message="@_formError" Dismissible="true" OnDismiss="() => _formError = null" />
        }

        <div class="fc-form-grid">
            @if (_editingUser is null)
            {
                <div class="fc-form-group">
                    <label class="fc-form-label fc-form-label-required">Username</label>
                    <input class="fc-form-input" @bind="_formUsername" placeholder="e.g. jdoe" />
                </div>
            }

                <div class="fc-form-group">
                    <label class="fc-form-label">Tenant Scope</label>
                    <select class="fc-form-input" value="@_formTenantId" @onchange="OnTenantScopeChanged">
                        <option value="">Platform Admin (no tenant)</option>
                        @foreach (var t in _tenantOptions)
                        {
                            <option value="@t.TenantId">@t.TenantName</option>
                        }
                    </select>
                <small class="fc-form-hint">Leave as "Platform Admin" for users who need cross-tenant access.</small>
            </div>

            <div class="fc-form-group">
                <label class="fc-form-label fc-form-label-required">Display Name</label>
                <input class="fc-form-input" @bind="_formDisplayName" placeholder="e.g. John Doe" />
            </div>

            <div class="fc-form-group">
                <label class="fc-form-label fc-form-label-required">Email Address</label>
                <input class="fc-form-input" type="email" @bind="_formEmail" placeholder="e.g. john.doe@cbn.gov.ng" />
            </div>

            @if (_editingUser is null)
            {
                <div class="fc-form-group">
                    <label class="fc-form-label fc-form-label-required">Password</label>
                    <input class="fc-form-input" type="password" @bind="_formPassword" placeholder="Minimum 12 characters" />
                </div>
            }
        </div>

        <!-- Role Selection -->
        <div class="fc-mt-6">
            <div class="fc-form-section-label">Role Assignment</div>
            <div class="fc-role-cards">
                @foreach (var roleOption in _roleOptions)
                {
                    <label class="fc-role-card @GetRoleCardClass(roleOption.Role) @(_formRole == roleOption.Role ? "fc-role-card-selected" : "")"
                           tabindex="0" @onkeydown="e => HandleRoleKeyDown(e, roleOption.Role)">
                        <input type="radio" name="fc-role-select" checked="@(_formRole == roleOption.Role)" @onchange="() => _formRole = roleOption.Role" />
                        <div class="fc-role-card-radio"><div class="fc-role-card-radio-inner"></div></div>
                        <div class="fc-role-card-content">
                            <div class="fc-role-card-title">@roleOption.DisplayName</div>
                            <div class="fc-role-card-desc">@roleOption.Description</div>
                        </div>
                    </label>
                }
            </div>
        </div>
    </ChildContent>
    <FooterContent>
        <button class="fc-btn fc-btn--outline" @onclick="CloseModal" type="button">Cancel</button>
        <button class="fc-btn fc-btn--primary @(_saving ? "fc-btn--loading" : "")" @onclick="SaveUser" disabled="@_saving" aria-busy="@(_saving ? "true" : null)" type="button">
            @if (_saving)
            {
                <span class="fc-spinner fc-spinner--sm fc-spinner--white" aria-hidden="true"></span>
            }
            @(_editingUser is null ? "Create User" : "Save Changes")
        </button>
    </FooterContent>
</AppModal>

<!-- Reset Password Modal -->
<AppModal @bind-Visible="_showPasswordModal" Title="Reset Password" Subtitle="@($"Set a new password for {_passwordResetUser?.DisplayName}")" Size="sm">
    <ChildContent>
        @if (!string.IsNullOrEmpty(_passwordError))
        {
            <AppAlert Variant="AppAlert.AlertVariant.Error" Message="@_passwordError" Dismissible="true" OnDismiss="() => _passwordError = null" />
        }
        <div class="fc-form-group">
            <label class="fc-form-label fc-form-label-required">New Password</label>
            <input class="fc-form-input" type="password" @bind="_newPassword" placeholder="Minimum 12 characters" />
        </div>
    </ChildContent>
    <FooterContent>
        <button class="fc-btn fc-btn--outline" @onclick="() => _showPasswordModal = false" type="button">Cancel</button>
        <button class="fc-btn fc-btn--primary @(_saving ? "fc-btn--loading" : "")" @onclick="ConfirmResetPassword" disabled="@_saving" aria-busy="@(_saving ? "true" : null)" type="button">
            @if (_saving)
            {
                <span class="fc-spinner fc-spinner--sm fc-spinner--white" aria-hidden="true"></span>
            }
            Reset Password
        </button>
    </FooterContent>
</AppModal>

@code {
    private IReadOnlyList<PortalUser> _users = Array.Empty<PortalUser>();
    private bool _loading = true;

    // Filters
    private string _searchQuery = "";
    private string _roleFilter = "";
    private string _statusFilter = "";

    // Create/Edit modal
    private bool _showModal;
    private PortalUser? _editingUser;
    private string _formUsername = "";
    private string _formDisplayName = "";
    private string _formEmail = "";
    private string _formPassword = "";
    private PortalRole _formRole = PortalRole.Viewer;
    private string _formTenantId = "";
    private string? _formError;
    private bool _saving;

    // Tenant options for scoping
    private List<TenantOption> _tenantOptions = new();
    private IReadOnlyList<PortalRoleOption> _roleOptions = Array.Empty<PortalRoleOption>();

    // Password reset modal
    private bool _showPasswordModal;
    private PortalUser? _passwordResetUser;
    private string _newPassword = "";
    private string? _passwordError;

    private IEnumerable<PortalUser> FilteredUsers => _users
        .Where(u => string.IsNullOrEmpty(_searchQuery) ||
                    u.DisplayName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    u.Email.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    u.Username.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
        .Where(u => string.IsNullOrEmpty(_roleFilter) ||
                    u.Role.ToString() == _roleFilter)
        .Where(u => string.IsNullOrEmpty(_statusFilter) ||
                    (_statusFilter == "active" && u.IsActive) ||
                    (_statusFilter == "inactive" && !u.IsActive))
        .OrderByDescending(u => u.Role == PortalRole.Admin)
        .ThenByDescending(u => u.Role == PortalRole.Approver)
        .ThenBy(u => u.DisplayName);

    protected override async Task OnInitializedAsync()
    {
        _users = await UserRepo.GetAll();
        _roleOptions = await RoleCatalog.GetPortalRoles(null);
        await using var db = await DbFactory.CreateDbContextAsync();
        _tenantOptions = await db.Tenants
            .Where(t => t.Status == Domain.Enums.TenantStatus.Active)
            .OrderBy(t => t.TenantName)
            .Select(t => new TenantOption { TenantId = t.TenantId, TenantName = t.TenantName })
            .ToListAsync();
        _loading = false;
    }

    // --- Helpers ---
    private void HandleRoleKeyDown(KeyboardEventArgs e, PortalRole role)
    {
        if (e.Key is "Enter" or " ")
            _formRole = role;
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
        return parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant();
    }

    private static string GetRoleBadgeClass(PortalRole role) => role switch
    {
        PortalRole.Admin => "fc-role-badge-admin",
        PortalRole.Approver => "fc-role-badge-approver",
        _ => "fc-role-badge-viewer"
    };

    private static string GetRoleCardClass(PortalRole role) => role switch
    {
        PortalRole.Admin => "fc-role-card-admin",
        PortalRole.Approver => "fc-role-card-approver",
        _ => "fc-role-card-viewer"
    };

    // --- Create / Edit Modal ---
    private async Task OpenCreateModal()
    {
        _editingUser = null;
        _formUsername = "";
        _formDisplayName = "";
        _formEmail = "";
        _formPassword = "";
        _formRole = PortalRole.Viewer;
        _formTenantId = "";
        _formError = null;
        await LoadRoleOptions(null);
        _showModal = true;
    }

    private async Task OpenEditModal(PortalUser user)
    {
        _editingUser = user;
        _formDisplayName = user.DisplayName;
        _formEmail = user.Email;
        _formRole = user.Role;
        _formTenantId = user.TenantId?.ToString() ?? "";
        _formError = null;
        await LoadRoleOptions(user.TenantId);
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
        _editingUser = null;
    }

    private async Task SaveUser()
    {
        _formError = null;
        _saving = true;

        try
        {
            if (_editingUser is null)
            {
                // Create
                if (string.IsNullOrWhiteSpace(_formUsername) || string.IsNullOrWhiteSpace(_formPassword))
                {
                    _formError = "Username and password are required.";
                    _saving = false;
                    return;
                }
                if (string.IsNullOrWhiteSpace(_formDisplayName))
                {
                    _formError = "Display name is required.";
                    _saving = false;
                    return;
                }
                if (_formPassword.Length < 12)
                {
                    _formError = "Password must be at least 12 characters.";
                    _saving = false;
                    return;
                }
                if (string.IsNullOrWhiteSpace(_formEmail) || !_formEmail.Contains('@'))
                {
                    _formError = "A valid email address is required.";
                    _saving = false;
                    return;
                }
                if (await UserRepo.EmailExists(_formEmail.Trim()))
                {
                    _formError = "A user with this email address already exists.";
                    _saving = false;
                    return;
                }

                Guid? tenantId = string.IsNullOrEmpty(_formTenantId) ? null : Guid.TryParse(_formTenantId, out var tid) ? tid : null;
                await AuthService.CreateUser(_formUsername.Trim(), _formDisplayName.Trim(), _formEmail.Trim(), _formPassword, _formRole, tenantId);
                Toast.Success($"User '{_formDisplayName.Trim()}' created successfully.");
            }
            else
            {
                // Edit
                if (string.IsNullOrWhiteSpace(_formDisplayName))
                {
                    _formError = "Display name is required.";
                    _saving = false;
                    return;
                }
                if (string.IsNullOrWhiteSpace(_formEmail) || !_formEmail.Contains('@'))
                {
                    _formError = "A valid email address is required.";
                    _saving = false;
                    return;
                }
                if (await UserRepo.EmailExists(_formEmail.Trim(), _editingUser.Id))
                {
                    _formError = "A user with this email address already exists.";
                    _saving = false;
                    return;
                }

                Guid? tenantId = string.IsNullOrEmpty(_formTenantId) ? null : Guid.TryParse(_formTenantId, out var etid) ? etid : null;
                await AuthService.UpdateUser(_editingUser.Id, _formDisplayName.Trim(), _formEmail.Trim(), _formRole, tenantId);
                Toast.Success($"User '{_formDisplayName.Trim()}' updated successfully.");
            }

            _users = await UserRepo.GetAll();
            _showModal = false;
            _editingUser = null;
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    // --- Password Reset ---
    private void ResetPassword(PortalUser user)
    {
        _passwordResetUser = user;
        _newPassword = "";
        _passwordError = null;
        _showPasswordModal = true;
    }

    private async Task ConfirmResetPassword()
    {
        _passwordError = null;
        if (_passwordResetUser is null) return;

        if (string.IsNullOrWhiteSpace(_newPassword) || _newPassword.Length < 12)
        {
            _passwordError = "Password must be at least 12 characters.";
            return;
        }

        _saving = true;
        try
        {
            await AuthService.ChangePassword(_passwordResetUser, _newPassword);
            Toast.Success($"Password for '{_passwordResetUser.DisplayName}' has been reset.");
            _showPasswordModal = false;
        }
        catch (Exception ex)
        {
            _passwordError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    // --- Toggle Status ---
    private async Task ToggleUserStatus(PortalUser user)
    {
        var action = user.IsActive ? "Disable" : "Enable";
        var confirmed = await Dialog.Confirm(new ConfirmRequest
        {
            Title = $"{action} User",
            Message = $"{action} the account for {user.DisplayName}? {(user.IsActive ? "They will not be able to sign in." : "They will be able to sign in again.")}",
            ConfirmText = action,
            IsDestructive = user.IsActive,
            Icon = user.IsActive ? "archive" : "publish"
        });

        if (!confirmed) return;

        try
        {
            await AuthService.SetUserStatus(user.Id, !user.IsActive);
            _users = await UserRepo.GetAll();
            var updated = _users.FirstOrDefault(u => u.Id == user.Id);
            if (updated is not null)
                Toast.Success($"User '{updated.DisplayName}' has been {(updated.IsActive ? "enabled" : "disabled")}.");
        }
        catch (Exception ex)
        {
            Toast.Error($"Failed to {action.ToLower()} user: {ex.Message}");
        }
    }

    private async Task OnTenantScopeChanged(ChangeEventArgs e)
    {
        _formTenantId = e.Value?.ToString() ?? "";
        Guid? tenantId = string.IsNullOrEmpty(_formTenantId) ? null : Guid.TryParse(_formTenantId, out var tid) ? tid : null;
        await LoadRoleOptions(tenantId);
    }

    private async Task LoadRoleOptions(Guid? tenantId)
    {
        _roleOptions = await RoleCatalog.GetPortalRoles(tenantId);
        if (_roleOptions.Count == 0)
        {
            _roleOptions = new[]
            {
                new PortalRoleOption { Role = PortalRole.Admin, DisplayName = "Admin", Description = "Role configuration unavailable." },
                new PortalRoleOption { Role = PortalRole.Approver, DisplayName = "Approver", Description = "Role configuration unavailable." },
                new PortalRoleOption { Role = PortalRole.Viewer, DisplayName = "Viewer", Description = "Role configuration unavailable." }
            };
        }

        if (!_roleOptions.Any(r => r.Role == _formRole))
            _formRole = _roleOptions[0].Role;
    }

    private sealed class TenantOption
    {
        public Guid TenantId { get; set; }
        public string TenantName { get; set; } = string.Empty;
    }
}
