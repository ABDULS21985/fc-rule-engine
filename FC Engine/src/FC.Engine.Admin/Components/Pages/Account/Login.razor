@page "/login"
@layout FC.Engine.Admin.Components.Layout.LoginLayout
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.ValueObjects
@inject ITenantBrandingService BrandingService
@inject ITenantContext TenantContext

<div class="fc-login-container">
    <div class="fc-login-card">
        <div class="fc-login-card-accent"></div>

        <div class="fc-login-card-body">
            <!-- Header -->
            <div class="fc-login-card-header">
                <div class="fc-login-card-logo">
                    <img src="@_branding.LogoUrl" alt="@_branding.CompanyName" width="56" height="46" />
                </div>
                <h2 class="fc-login-title">Secure Login</h2>
                <p class="fc-login-subtitle">Use your authorized credentials to access the platform</p>
            </div>

            <!-- Password Reset Success -->
            @if (_resetSuccess)
            {
                <div class="fc-alert fc-alert--inline fc-alert--success" role="alert">
                    <svg class="fc-alert__icon" viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span>Your password has been reset successfully. Sign in with your new password.</span>
                </div>
            }

            <!-- Error Alert -->
            @if (_hasError)
            {
                <div class="fc-alert fc-alert--inline fc-alert--error" role="alert">
                    <svg class="fc-alert__icon" viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                    </svg>
                    <span>@(_errorMessage)</span>
                </div>
            }

            <!-- Login Form -->
            @if (_showMfaChallenge && !string.IsNullOrWhiteSpace(_challenge))
            {
                <form id="loginForm" method="post" action="/account/login" novalidate>
                    <input type="hidden" name="challengeId" value="@_challenge" />

                    <div class="fc-floating-field">
                        <input
                            id="mfaCode"
                            name="mfaCode"
                            type="text"
                            class="fc-floating-input"
                            placeholder=" "
                            maxlength="6"
                            autocomplete="one-time-code"
                            aria-label="MFA code"
                            aria-required="true" />
                        <label for="mfaCode" class="fc-floating-label">Authenticator Code</label>
                    </div>

                    <div class="fc-floating-field">
                        <input
                            id="backupCode"
                            name="backupCode"
                            type="text"
                            class="fc-floating-input"
                            placeholder=" "
                            maxlength="9"
                            aria-label="Backup code" />
                        <label for="backupCode" class="fc-floating-label">Backup Code (optional)</label>
                    </div>

                    <button type="submit" class="fc-btn fc-btn--gold-submit" id="submitBtn">
                        <span class="fc-btn-label">
                            <span>Verify Code</span>
                        </span>
                        <span class="fc-btn-loading">
                            <span>Verifying&hellip;</span>
                        </span>
                    </button>
                </form>
            }
            else
            {
                <form id="loginForm" method="post" action="/account/login" novalidate>
                    <!-- Username Field -->
                    <div class="fc-floating-field">
                        <input
                            id="username"
                            name="username"
                            type="text"
                            class="fc-floating-input"
                            placeholder=" "
                            required
                            autocomplete="username"
                            aria-label="Username"
                            aria-required="true" />
                        <label for="username" class="fc-floating-label">Username</label>
                        <svg class="field-icon" viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
                            <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                        </svg>
                    </div>

                    <!-- Password Field -->
                    <div class="fc-floating-field">
                        <input
                            id="password"
                            name="password"
                            type="password"
                            class="fc-floating-input"
                            placeholder=" "
                            required
                            autocomplete="current-password"
                            aria-label="Password"
                            aria-required="true" />
                        <label for="password" class="fc-floating-label">Password</label>
                        <svg class="field-icon" viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
                            <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
                        </svg>
                        <button type="button" class="password-toggle" id="pwdToggle" aria-label="Toggle password visibility" tabindex="-1">
                            <svg class="eye-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                            <svg class="eye-closed" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                                <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/>
                                <line x1="1" y1="1" x2="23" y2="23"/>
                            </svg>
                        </button>
                        <!-- Caps Lock Warning -->
                        <div class="caps-lock-warning" id="capsWarning" role="status" aria-live="polite">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                            </svg>
                            <span>Caps Lock is on</span>
                        </div>
                    </div>

                    <!-- Remember Me / Forgot Password Row -->
                    <div class="fc-login-utility-row">
                        <label class="fc-login-checkbox">
                            <input type="checkbox" name="rememberMe" value="true" />
                            <span class="checkbox-visual" aria-hidden="true">
                                <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="10" height="10">
                                    <polyline points="2.5 6 5 8.5 9.5 3.5"/>
                                </svg>
                            </span>
                            <span class="checkbox-label">Remember me</span>
                        </label>
                        <a href="/forgot-password" class="fc-login-forgot-link" tabindex="0">Forgot password?</a>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="fc-btn fc-btn--gold-submit" id="submitBtn">
                        <span class="fc-btn-label">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
                                <path fill-rule="evenodd" d="M3 3a1 1 0 011 1v12a1 1 0 11-2 0V4a1 1 0 011-1zm7.707 3.293a1 1 0 010 1.414L9.414 9H17a1 1 0 110 2H9.414l1.293 1.293a1 1 0 01-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                            <span>Sign In</span>
                        </span>
                        <span class="fc-btn-loading">
                            <svg class="loading-spinner" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                                <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-dasharray="31.4 31.4" stroke-linecap="round"/>
                            </svg>
                            <span>Authenticating&hellip;</span>
                        </span>
                    </button>
                </form>
            }

            <!-- Security Notice -->
            <div class="fc-login-security-notice">
                <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14" aria-hidden="true">
                    <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span>Protected by secure session management. Contact your administrator for access issues.</span>
            </div>

            <!-- Footer -->
            <div class="fc-login-card-footer">
                <span>Powered by <strong>@_branding.CompanyName</strong></span>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        // Password visibility toggle
        var pwdInput = document.getElementById('password');
        var toggle = document.getElementById('pwdToggle');
        if (toggle && pwdInput) {
            toggle.addEventListener('click', function () {
                var isPassword = pwdInput.type === 'password';
                pwdInput.type = isPassword ? 'text' : 'password';
                toggle.classList.toggle('active', isPassword);
            });
        }

        // Caps Lock detection on password field
        var capsWarning = document.getElementById('capsWarning');
        if (pwdInput && capsWarning) {
            pwdInput.addEventListener('keyup', function (e) {
                capsWarning.classList.toggle('is-visible', e.getModifierState && e.getModifierState('CapsLock'));
            });
            pwdInput.addEventListener('blur', function () {
                capsWarning.classList.remove('is-visible');
            });
        }

        // Loading state on form submit
        var form = document.getElementById('loginForm');
        var btn = document.getElementById('submitBtn');
        if (form && btn) {
            form.addEventListener('submit', function () {
                btn.disabled = true;
                btn.classList.add('is-loading');
            });
        }

        // Inline validation feedback
        var fields = form ? form.querySelectorAll('.fc-floating-input[required]') : [];
        fields.forEach(function (field) {
            field.addEventListener('invalid', function (e) {
                e.preventDefault();
                field.classList.add('is-invalid');
            });
            field.addEventListener('input', function () {
                if (field.classList.contains('is-invalid') && field.value.trim()) {
                    field.classList.remove('is-invalid');
                }
            });
        });
    })();
</script>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    private string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "reset")]
    private string? Reset { get; set; }

    [SupplyParameterFromQuery(Name = "mfa")]
    private string? Mfa { get; set; }

    [SupplyParameterFromQuery(Name = "challenge")]
    private string? Challenge { get; set; }

    private bool _resetSuccess => Reset == "success";
    private bool _hasError => !string.IsNullOrEmpty(Error);
    private BrandingConfig _branding = BrandingConfig.WithDefaults();
    private bool _showMfaChallenge;
    private string? _challenge;

    protected override async Task OnInitializedAsync()
    {
        _showMfaChallenge = string.Equals(Mfa, "required", StringComparison.OrdinalIgnoreCase);
        _challenge = Challenge;

        if (TenantContext.CurrentTenantId.HasValue)
        {
            _branding = await BrandingService.GetBrandingConfig(TenantContext.CurrentTenantId.Value);
        }
    }

    private string _errorMessage => Error switch
    {
        "invalid" => "Invalid username or password. Please try again.",
        "locked" => "This account has been temporarily locked due to too many failed attempts. Try again in 15 minutes.",
        "expired" => "Your session has expired. Please sign in again.",
        "denied" => "Access denied. You do not have permission to access this system.",
        "mfa-invalid" => "Invalid MFA or backup code. Please try again.",
        "mfa-expired" => "MFA challenge expired. Sign in again.",
        _ => "An error occurred during sign in. Please try again."
    };
}
