@page "/billing/revenue"
@using Microsoft.AspNetCore.Authorization
@using FC.Engine.Domain.Enums
@using FC.Engine.Infrastructure.Metadata
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Policy = "PlatformAdmin")]
@inject MetadataDbContext Db

<PageTitle>Revenue Dashboard</PageTitle>

<PageHeader Title="Revenue Dashboard"
            Subtitle="Track MRR, collections, plan mix, and top-performing tenants in one view." />

<div class="fc-page fc-revenue-page">

    @if (_loading)
    {
        <section class="fc-billing-hero fc-revenue-hero">
            <div class="fc-revenue-hero-copy">
                <div class="fc-skel fc-skel-text" style="width:8rem;height:.7rem"></div>
                <div class="fc-skel fc-skel-text" style="width:16rem;height:1.9rem;margin-top:.75rem"></div>
                <div class="fc-skel fc-skel-text" style="width:100%;height:.8rem;margin-top:.75rem"></div>
                <div class="fc-skel fc-skel-text" style="width:75%;height:.8rem;margin-top:.45rem"></div>
                <div class="fc-chip-group" style="margin-top:1rem;">
                    <div class="fc-chip"><div class="fc-skel fc-skel-text" style="width:10rem;height:.65rem"></div></div>
                    <div class="fc-chip"><div class="fc-skel fc-skel-text" style="width:8rem;height:.65rem"></div></div>
                </div>
            </div>
            <aside class="fc-revenue-hero-panel">
                <div class="fc-skel fc-skel-text" style="width:8rem;height:.75rem"></div>
                <div class="fc-skel fc-skel-text" style="width:7rem;height:2rem;margin-top:.75rem"></div>
                <div class="fc-skel fc-skel-text" style="width:100%;height:.7rem;margin-top:.75rem"></div>
            </aside>
        </section>

        <section class="fc-billing-metrics fc-revenue-metrics">
            @for (var i = 0; i < 4; i++)
            {
                <article class="fc-billing-metric-card">
                    <div class="fc-skel fc-skel-text" style="width:60%;height:.75rem"></div>
                    <div class="fc-skel fc-skel-text" style="width:70%;height:1.75rem;margin-top:.75rem"></div>
                    <div class="fc-skel fc-skel-text" style="width:85%;height:.7rem;margin-top:.75rem"></div>
                </article>
            }
        </section>

        <section class="fc-billing-layout">
            <div class="fc-card">
                <div class="fc-card__body">
                    <div class="fc-skel fc-skel-text" style="width:55%;height:.9rem;margin-bottom:1rem"></div>
                    <div class="fc-skel fc-skel-text" style="width:100%;height:.75rem;margin-bottom:.6rem"></div>
                    <div class="fc-skel fc-skel-text" style="width:95%;height:.75rem;margin-bottom:.6rem"></div>
                    <div class="fc-skel fc-skel-text" style="width:90%;height:.75rem"></div>
                </div>
            </div>
            <div class="fc-card">
                <div class="fc-card__body">
                    <div class="fc-skel fc-skel-text" style="width:45%;height:.9rem;margin-bottom:1rem"></div>
                    <div class="fc-skel fc-skel-text" style="width:100%;height:.75rem;margin-bottom:.6rem"></div>
                    <div class="fc-skel fc-skel-text" style="width:90%;height:.75rem;margin-bottom:.6rem"></div>
                    <div class="fc-skel fc-skel-text" style="width:85%;height:.75rem"></div>
                </div>
            </div>
        </section>

        <section class="fc-card">
            <div class="fc-card__body">
                <div class="fc-skel fc-skel-text" style="width:45%;height:.9rem;margin-bottom:1rem"></div>
                <div class="fc-skel fc-skel-text" style="width:100%;height:.75rem;margin-bottom:.6rem"></div>
                <div class="fc-skel fc-skel-text" style="width:100%;height:.75rem;margin-bottom:.6rem"></div>
                <div class="fc-skel fc-skel-text" style="width:100%;height:.75rem;margin-bottom:.6rem"></div>
                <div class="fc-skel fc-skel-text" style="width:100%;height:.75rem"></div>
            </div>
        </section>
    }
    else
    {
        <section class="fc-billing-shell fc-revenue-shell">
            <section class="fc-billing-hero fc-revenue-hero">
                <div class="fc-revenue-hero-copy">
                    <p class="fc-billing-kicker">Billing Intelligence</p>
                    <h2 class="fc-revenue-hero-title">Revenue Pulse and Collections Health</h2>
                    <p class="fc-revenue-hero-subtitle">
                        Track run-rate, payment velocity, and concentration risk with a live billing snapshot across all tenants.
                    </p>
                    <div class="fc-revenue-hero-chips">
                        <span class="fc-chip">
                            <span class="fc-chip__dot fc-chip__dot--active" aria-hidden="true"></span>
                            Snapshot @FormatUtc(_snapshotUtc)
                        </span>
                        <span class="fc-chip">Paid invoices (YTD): @_paidInvoiceCount</span>
                        <span class="fc-chip">Active subscriptions: @_activeSubscriptionCount</span>
                    </div>
                </div>
                <aside class="fc-revenue-hero-panel">
                    <p class="fc-revenue-hero-panel-label">Collection Efficiency</p>
                    <p class="fc-revenue-hero-panel-value">@FormatPercent(CollectionsEfficiencyPercent)</p>
                    <p class="fc-revenue-hero-panel-note">
                        @FormatCurrency(_paidThisMonth) paid this month against @FormatCurrency(_outstanding) still open.
                    </p>
                    <div class="fc-revenue-hero-panel-track">
                        <span class="fc-revenue-hero-panel-fill" style="width:@($"{CollectionsEfficiencyPercent:0.##}%")"></span>
                    </div>
                </aside>
            </section>

            <section class="fc-billing-metrics fc-revenue-metrics">
                <article class="fc-billing-metric-card fc-revenue-metric-card fc-revenue-metric-card--mrr">
                    <div class="fc-revenue-metric-head">
                        <p class="fc-billing-metric-label">Monthly Recurring Revenue</p>
                        <span class="fc-revenue-metric-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="12" y1="1" x2="12" y2="23" />
                                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                            </svg>
                        </span>
                    </div>
                    <p class="fc-billing-metric-value">@FormatCurrency(_mrr)</p>
                    <p class="fc-billing-metric-sub">Average @FormatCurrency(AverageMrrPerTenant) per active tenant.</p>
                </article>

                <article class="fc-billing-metric-card fc-revenue-metric-card fc-revenue-metric-card--arr">
                    <div class="fc-revenue-metric-head">
                        <p class="fc-billing-metric-label">Annual Run Rate</p>
                        <span class="fc-revenue-metric-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="22 7 13.5 15.5 8.5 10.5 2 17" />
                                <polyline points="16 7 22 7 22 13" />
                            </svg>
                        </span>
                    </div>
                    <p class="fc-billing-metric-value">@FormatCurrency(_arr)</p>
                    <p class="fc-billing-metric-sub">Projected annualized revenue at current subscription levels.</p>
                </article>

                <article class="fc-billing-metric-card fc-revenue-metric-card fc-revenue-metric-card--paid">
                    <div class="fc-revenue-metric-head">
                        <p class="fc-billing-metric-label">Paid This Month</p>
                        <span class="fc-revenue-metric-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9 11l3 3L22 4" />
                                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                            </svg>
                        </span>
                    </div>
                    <p class="fc-billing-metric-value">@FormatCurrency(_paidThisMonth)</p>
                    <p class="fc-billing-metric-sub">@MonthOverMonthSummary.</p>
                </article>

                <article class="fc-billing-metric-card fc-revenue-metric-card fc-revenue-metric-card--outstanding">
                    <div class="fc-revenue-metric-head">
                        <p class="fc-billing-metric-label">Outstanding Exposure</p>
                        <span class="fc-revenue-metric-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10" />
                                <line x1="12" y1="8" x2="12" y2="12" />
                                <line x1="12" y1="16" x2="12.01" y2="16" />
                            </svg>
                        </span>
                    </div>
                    <p class="fc-billing-metric-value">@FormatCurrency(_outstanding)</p>
                    <p class="fc-billing-metric-sub">@FormatPercent(OutstandingSharePercent) of active billing exposure.</p>
                </article>
            </section>

            <section class="fc-billing-layout fc-revenue-layout">
                <article class="fc-card fc-revenue-card">
                    <div class="fc-card__header fc-revenue-card-header">
                        <div>
                            <h2 class="fc-card__title">Collections Trend (Last 6 Months)</h2>
                            <p class="fc-revenue-card-note">Month-on-month movement: @MonthOverMonthSummary.</p>
                        </div>
                        <span class="fc-revenue-pill">Peak: @FormatCompactCurrency(_trendMaxAmount)</span>
                    </div>
                    <div class="fc-card__body">
                        @if (!_monthlyTrend.Any())
                        {
                            <p class="fc-page-header-subtitle">No paid invoice activity in the selected window.</p>
                        }
                        else
                        {
                            <div class="fc-billing-chart-list">
                                @foreach (var point in _monthlyTrend)
                                {
                                    var width = _trendMaxAmount <= 0m ? 0m : Math.Clamp((point.Amount / _trendMaxAmount) * 100m, 0m, 100m);
                                    <div class="fc-billing-chart-row fc-revenue-chart-row">
                                        <div class="fc-billing-chart-label">@point.Label</div>
                                        <div class="fc-billing-chart-track">
                                            <div class="fc-billing-chart-fill" style="width:@($"{width:0.##}%")"></div>
                                        </div>
                                        <div class="fc-billing-chart-value">@FormatCurrency(point.Amount)</div>
                                        <div class="fc-revenue-chart-percent">@FormatPercent(width)</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </article>

                <article class="fc-card fc-revenue-card">
                    <div class="fc-card__header fc-revenue-card-header">
                        <div>
                            <h2 class="fc-card__title">Plan Mix and Revenue Weight</h2>
                            <p class="fc-revenue-card-note">Contribution split by active subscription plans.</p>
                        </div>
                        <span class="fc-revenue-pill">
                            Top plan: @(TopPlanByRevenue?.PlanCode ?? "N/A") (@FormatPercent(TopPlanSharePercent))
                        </span>
                    </div>
                    <div class="fc-card__body">
                        @if (!_planMix.Any())
                        {
                            <p class="fc-page-header-subtitle">No active subscriptions found.</p>
                        }
                        else
                        {
                            <div class="fc-billing-planmix-list">
                                @foreach (var plan in _planMix)
                                {
                                    var tenantShare = _activeSubscriptionCount == 0 ? 0m : (decimal)plan.Count / _activeSubscriptionCount * 100m;
                                    var revenueShare = PlanMixMonthlyTotal <= 0m ? 0m : plan.MonthlyRevenue / PlanMixMonthlyTotal * 100m;
                                    <div class="fc-billing-planmix-row">
                                        <div class="fc-billing-planmix-head">
                                            <span>@plan.PlanCode</span>
                                            <span>@plan.Count tenant(s) and @FormatPercent(tenantShare) of active base</span>
                                        </div>
                                        <div class="fc-billing-chart-track">
                                            <div class="fc-billing-chart-fill fc-billing-chart-fill-accent" style="width:@($"{tenantShare:0.##}%")"></div>
                                        </div>
                                        <div class="fc-billing-planmix-foot">
                                            <span>Monthly contribution</span>
                                            <strong>@FormatCurrency(plan.MonthlyRevenue) and @FormatPercent(revenueShare)</strong>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </article>
            </section>

            <section class="fc-revenue-insight-grid">
                <article class="fc-card">
                    <div class="fc-card__header">
                        <h2 class="fc-card__title">Collections Quality</h2>
                    </div>
                    <div class="fc-card__body">
                        <div class="fc-revenue-health-grid">
                            <div class="fc-revenue-health-item">
                                <p>Paid Invoices (YTD)</p>
                                <strong>@_paidInvoiceCount</strong>
                            </div>
                            <div class="fc-revenue-health-item">
                                <p>YTD Paid Revenue</p>
                                <strong>@FormatCurrency(_ytdPaid)</strong>
                            </div>
                            <div class="fc-revenue-health-item">
                                <p>Collection Efficiency</p>
                                <strong>@FormatPercent(CollectionsEfficiencyPercent)</strong>
                            </div>
                            <div class="fc-revenue-health-item">
                                <p>Outstanding Share</p>
                                <strong>@FormatPercent(OutstandingSharePercent)</strong>
                            </div>
                        </div>
                    </div>
                </article>

                <article class="fc-card">
                    <div class="fc-card__header">
                        <h2 class="fc-card__title">Concentration Signals</h2>
                    </div>
                    <div class="fc-card__body">
                        <div class="fc-revenue-signal-row">
                            <span>Top tenant contribution</span>
                            <strong>@FormatPercent(TopTenantSharePercent)</strong>
                        </div>
                        <div class="fc-revenue-signal-track">
                            <span style="width:@($"{TopTenantSharePercent:0.##}%")"></span>
                        </div>

                        <div class="fc-revenue-signal-row">
                            <span>Largest plan contribution</span>
                            <strong>@FormatPercent(TopPlanSharePercent)</strong>
                        </div>
                        <div class="fc-revenue-signal-track fc-revenue-signal-track--accent">
                            <span style="width:@($"{TopPlanSharePercent:0.##}%")"></span>
                        </div>

                        <p class="fc-revenue-signal-note">
                            Higher concentration means a larger share of revenue depends on fewer tenants or plans.
                        </p>
                    </div>
                </article>
            </section>

            <section class="fc-card fc-revenue-table-card">
                <div class="fc-card__header fc-revenue-card-header">
                    <div>
                        <h2 class="fc-card__title">Top Tenants by Paid Revenue (YTD)</h2>
                        <p class="fc-revenue-card-note">Ranked by paid invoice totals in the current year.</p>
                    </div>
                    <span class="fc-revenue-pill">YTD total: @FormatCurrency(_ytdPaid)</span>
                </div>
                <div class="fc-card__body">
                    @if (!_topTenants.Any())
                    {
                        <div class="fc-empty">
                            <div class="fc-empty-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                    <polyline points="14 2 14 8 20 8" />
                                    <line x1="16" y1="13" x2="8" y2="13" />
                                    <line x1="16" y1="17" x2="8" y2="17" />
                                </svg>
                            </div>
                            <p class="fc-empty-title">No paid invoices yet</p>
                            <p class="fc-empty-text">Paid invoices for this year will appear here once tenants begin settling their bills.</p>
                        </div>
                    }
                    else
                    {
                        <div class="fc-revenue-table-wrap">
                            <table class="fc-table fc-revenue-table">
                                <thead>
                                    <tr>
                                        <th style="width:72px;">Rank</th>
                                        <th>Tenant</th>
                                        <th>Total Paid</th>
                                        <th>Invoice Count</th>
                                        <th>Contribution</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < _topTenants.Count; i++)
                                    {
                                        var tenant = _topTenants[i];
                                        var contribution = _ytdPaid <= 0m ? 0m : Math.Clamp(tenant.TotalPaid / _ytdPaid * 100m, 0m, 100m);
                                        <tr>
                                            <td>
                                                <span class="fc-revenue-rank">#@(i + 1)</span>
                                            </td>
                                            <td>
                                                <div class="fc-revenue-tenant-name">@tenant.TenantName</div>
                                                <div class="fc-revenue-tenant-slug">@tenant.TenantSlug</div>
                                            </td>
                                            <td class="fc-revenue-paid-value">@FormatCurrency(tenant.TotalPaid)</td>
                                            <td>@tenant.InvoiceCount</td>
                                            <td>
                                                <div class="fc-revenue-contribution">
                                                    <div class="fc-revenue-contribution-track">
                                                        <span style="width:@($"{contribution:0.##}%")"></span>
                                                    </div>
                                                    <span class="fc-revenue-contribution-value">@FormatPercent(contribution)</span>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </section>
        </section>
    }
</div>

@code {
    private bool _loading = true;
    private decimal _mrr;
    private decimal _arr;
    private decimal _paidThisMonth;
    private decimal _outstanding;
    private decimal _ytdPaid;
    private int _paidInvoiceCount;
    private int _activeSubscriptionCount;
    private decimal _trendMaxAmount;
    private DateTime _snapshotUtc = DateTime.UtcNow;

    private List<MonthlyTrendPoint> _monthlyTrend = new();
    private List<PlanMixPoint> _planMix = new();
    private List<TenantRevenuePoint> _topTenants = new();

    private decimal AverageMrrPerTenant => _activeSubscriptionCount == 0 ? 0m : _mrr / _activeSubscriptionCount;

    private decimal CollectionsEfficiencyPercent =>
        _paidThisMonth + _outstanding <= 0m ? 0m : _paidThisMonth / (_paidThisMonth + _outstanding) * 100m;

    private decimal OutstandingSharePercent =>
        _paidThisMonth + _outstanding <= 0m ? 0m : _outstanding / (_paidThisMonth + _outstanding) * 100m;

    private decimal PlanMixMonthlyTotal => _planMix.Sum(x => x.MonthlyRevenue);

    private PlanMixPoint? TopPlanByRevenue => _planMix.OrderByDescending(x => x.MonthlyRevenue).FirstOrDefault();

    private decimal TopPlanSharePercent =>
        TopPlanByRevenue is null || PlanMixMonthlyTotal <= 0m
            ? 0m
            : TopPlanByRevenue.MonthlyRevenue / PlanMixMonthlyTotal * 100m;

    private decimal TopTenantSharePercent =>
        !_topTenants.Any() || _ytdPaid <= 0m
            ? 0m
            : _topTenants[0].TotalPaid / _ytdPaid * 100m;

    private decimal MonthOverMonthPercent
    {
        get
        {
            if (_monthlyTrend.Count == 0) return 0m;

            var current = _monthlyTrend[_monthlyTrend.Count - 1].Amount;
            if (_monthlyTrend.Count == 1)
            {
                return current > 0m ? 100m : 0m;
            }

            var previous = _monthlyTrend[_monthlyTrend.Count - 2].Amount;
            if (previous <= 0m)
            {
                return current > 0m ? 100m : 0m;
            }

            return (current - previous) / previous * 100m;
        }
    }

    private string MonthOverMonthSummary =>
        $"{(MonthOverMonthPercent >= 0m ? "+" : string.Empty)}{MonthOverMonthPercent:0.##}% vs previous month";

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboard();
        _loading = false;
    }

    private async Task LoadDashboard()
    {
        var revenueStatuses = new[]
        {
            SubscriptionStatus.Active,
            SubscriptionStatus.PastDue,
            SubscriptionStatus.Suspended,
            SubscriptionStatus.Trial
        };

        _mrr = await Db.Subscriptions
            .AsNoTracking()
            .Where(s => revenueStatuses.Contains(s.Status))
            .Join(Db.SubscriptionPlans, s => s.PlanId, p => p.Id, (_, p) => (decimal?)p.BasePriceMonthly)
            .SumAsync(x => x ?? 0m);

        _arr = _mrr * 12;

        var monthStart = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
        _paidThisMonth = await Db.Invoices
            .AsNoTracking()
            .Where(i => i.Status == InvoiceStatus.Paid && i.PaidAt.HasValue && i.PaidAt.Value >= monthStart)
            .SumAsync(i => (decimal?)i.TotalAmount) ?? 0m;

        _outstanding = await Db.Invoices
            .AsNoTracking()
            .Where(i => i.Status == InvoiceStatus.Issued || i.Status == InvoiceStatus.Overdue)
            .SumAsync(i => (decimal?)i.TotalAmount) ?? 0m;

        var yearStart = new DateTime(DateTime.UtcNow.Year, 1, 1);
        _ytdPaid = await Db.Invoices
            .AsNoTracking()
            .Where(i => i.Status == InvoiceStatus.Paid && i.PaidAt.HasValue && i.PaidAt.Value >= yearStart)
            .SumAsync(i => (decimal?)i.TotalAmount) ?? 0m;

        _paidInvoiceCount = await Db.Invoices
            .AsNoTracking()
            .CountAsync(i => i.Status == InvoiceStatus.Paid && i.PaidAt.HasValue && i.PaidAt.Value >= yearStart);

        _activeSubscriptionCount = await Db.Subscriptions
            .AsNoTracking()
            .CountAsync(s => s.Status != SubscriptionStatus.Cancelled && s.Status != SubscriptionStatus.Expired);

        await LoadMonthlyTrend();
        await LoadPlanMix();
        await LoadTopTenants(yearStart);

        _snapshotUtc = DateTime.UtcNow;
    }

    private async Task LoadMonthlyTrend()
    {
        var currentMonth = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
        var firstMonth = currentMonth.AddMonths(-5);

        var paidRows = await Db.Invoices
            .AsNoTracking()
            .Where(i => i.Status == InvoiceStatus.Paid
                && i.PaidAt.HasValue
                && i.PaidAt.Value >= firstMonth)
            .Select(i => new { i.PaidAt!.Value.Year, i.PaidAt!.Value.Month, i.TotalAmount })
            .ToListAsync();

        _monthlyTrend = new List<MonthlyTrendPoint>();
        for (var i = 0; i < 6; i++)
        {
            var bucket = firstMonth.AddMonths(i);
            var amount = paidRows
                .Where(r => r.Year == bucket.Year && r.Month == bucket.Month)
                .Sum(r => r.TotalAmount);

            _monthlyTrend.Add(new MonthlyTrendPoint
            {
                Label = bucket.ToString("MMM yyyy"),
                Amount = amount
            });
        }

        _trendMaxAmount = _monthlyTrend.Any() ? _monthlyTrend.Max(t => t.Amount) : 0;
    }

    private async Task LoadPlanMix()
    {
        _planMix = await Db.Subscriptions
            .AsNoTracking()
            .Where(s => s.Status != SubscriptionStatus.Cancelled && s.Status != SubscriptionStatus.Expired)
            .Join(Db.SubscriptionPlans,
                s => s.PlanId,
                p => p.Id,
                (_, p) => new { p.PlanCode, p.BasePriceMonthly })
            .GroupBy(x => x.PlanCode)
            .Select(g => new PlanMixPoint
            {
                PlanCode = g.Key,
                Count = g.Count(),
                MonthlyRevenue = g.Sum(x => x.BasePriceMonthly)
            })
            .OrderByDescending(x => x.Count)
            .ToListAsync();
    }

    private async Task LoadTopTenants(DateTime yearStart)
    {
        _topTenants = await Db.Invoices
            .AsNoTracking()
            .Where(i => i.Status == InvoiceStatus.Paid && i.PaidAt.HasValue && i.PaidAt.Value >= yearStart)
            .Join(Db.Tenants,
                i => i.TenantId,
                t => t.TenantId,
                (i, t) => new { t.TenantName, t.TenantSlug, i.TotalAmount })
            .GroupBy(x => new { x.TenantName, x.TenantSlug })
            .Select(g => new TenantRevenuePoint
            {
                TenantName = g.Key.TenantName,
                TenantSlug = g.Key.TenantSlug,
                TotalPaid = g.Sum(x => x.TotalAmount),
                InvoiceCount = g.Count()
            })
            .OrderByDescending(x => x.TotalPaid)
            .Take(10)
            .ToListAsync();
    }

    private static string FormatCurrency(decimal value) => $"NGN {value:N2}";

    private static string FormatCompactCurrency(decimal value)
    {
        var absolute = Math.Abs(value);
        if (absolute >= 1_000_000_000m) return $"NGN {value / 1_000_000_000m:0.##}B";
        if (absolute >= 1_000_000m) return $"NGN {value / 1_000_000m:0.##}M";
        if (absolute >= 1_000m) return $"NGN {value / 1_000m:0.##}K";
        return FormatCurrency(value);
    }

    private static string FormatPercent(decimal value) => $"{value:0.##}%";

    private static string FormatUtc(DateTime value) => $"{value:dd MMM yyyy, HH:mm} UTC";

    private sealed class MonthlyTrendPoint
    {
        public string Label { get; set; } = string.Empty;
        public decimal Amount { get; set; }
    }

    private sealed class PlanMixPoint
