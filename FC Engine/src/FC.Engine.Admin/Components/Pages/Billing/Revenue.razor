@page "/billing/revenue"
@using Microsoft.AspNetCore.Authorization
@using FC.Engine.Domain.Enums
@using FC.Engine.Infrastructure.Metadata
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Policy = "PlatformAdmin")]
@inject MetadataDbContext Db

<PageTitle>Revenue Dashboard</PageTitle>

<div class="fc-page">

    <nav class="fc-breadcrumb">
        <a href="/">Dashboard</a>
        <span class="fc-breadcrumb-sep">/</span>
        <a href="/billing">Billing</a>
        <span class="fc-breadcrumb-sep">/</span>
        <span class="fc-breadcrumb-current">Revenue</span>
    </nav>

    <header class="fc-page-header">
        <div class="fc-page-header-top">
            <h1>Revenue Dashboard</h1>
            <div>
                <span class="fc-badge fc-badge--neutral">Finance Snapshot</span>
                <span>@DateTime.UtcNow.ToString("dd MMM yyyy HH:mm") UTC</span>
            </div>
        </div>
        <p class="fc-page-header-subtitle">Track MRR, collections, plan mix, and top-performing tenants in one view.</p>
    </header>

    @if (_loading)
    {
        <section class="fc-chip-group">
            <div class="fc-chip">
                <div class="skel fc-skel-text" style="width:4rem;height:.75rem"></div>
                <div class="skel fc-skel-text" style="width:6rem;height:1.5rem;margin-top:.5rem"></div>
            </div>
            <div class="fc-chip">
                <div class="skel fc-skel-text" style="width:4rem;height:.75rem"></div>
                <div class="skel fc-skel-text" style="width:6rem;height:1.5rem;margin-top:.5rem"></div>
            </div>
            <div class="fc-chip">
                <div class="skel fc-skel-text" style="width:5rem;height:.75rem"></div>
                <div class="skel fc-skel-text" style="width:6rem;height:1.5rem;margin-top:.5rem"></div>
            </div>
            <div class="fc-chip">
                <div class="skel fc-skel-text" style="width:5rem;height:.75rem"></div>
                <div class="skel fc-skel-text" style="width:6rem;height:1.5rem;margin-top:.5rem"></div>
            </div>
        </section>

        <section class="fc-billing-layout">
            <div class="fc-card">
                <div class="fc-card__body">
                    <div class="skel fc-skel-text" style="width:60%;height:1rem;margin-bottom:1rem"></div>
                    <div class="skel fc-skel-text" style="width:100%;height:.75rem;margin-bottom:.5rem"></div>
                    <div class="skel fc-skel-text" style="width:90%;height:.75rem;margin-bottom:.5rem"></div>
                    <div class="skel fc-skel-text" style="width:80%;height:.75rem;margin-bottom:.5rem"></div>
                </div>
            </div>
            <div class="fc-card">
                <div class="fc-card__body">
                    <div class="skel fc-skel-text" style="width:40%;height:1rem;margin-bottom:1rem"></div>
                    <div class="skel fc-skel-text" style="width:100%;height:.75rem;margin-bottom:.5rem"></div>
                    <div class="skel fc-skel-text" style="width:85%;height:.75rem;margin-bottom:.5rem"></div>
                </div>
            </div>
        </section>

        <div class="fc-card">
            <div class="fc-card__body">
                <div class="skel fc-skel-text" style="width:50%;height:1rem;margin-bottom:1rem"></div>
                <div class="skel fc-skel-text" style="width:100%;height:.75rem;margin-bottom:.5rem"></div>
                <div class="skel fc-skel-text" style="width:100%;height:.75rem;margin-bottom:.5rem"></div>
                <div class="skel fc-skel-text" style="width:100%;height:.75rem;margin-bottom:.5rem"></div>
            </div>
        </div>
    }
    else
    {
        <section class="fc-chip-group">
            <article class="fc-chip">
                <p>MRR</p>
                <p class="fc-chip__count">@FormatCurrency(_mrr)</p>
            </article>
            <article class="fc-chip">
                <p>ARR</p>
                <p class="fc-chip__count">@FormatCurrency(_arr)</p>
            </article>
            <article class="fc-chip">
                <p>Paid This Month</p>
                <p class="fc-chip__count">@FormatCurrency(_paidThisMonth)</p>
            </article>
            <article class="fc-chip">
                <p>Outstanding</p>
                <p class="fc-chip__count">@FormatCurrency(_outstanding)</p>
            </article>
        </section>

        <section class="fc-billing-layout">
            <div class="fc-card">
                <div class="fc-card__header">
                    <h2 class="fc-card__title">Collections Trend (Last 6 Months)</h2>
                </div>
                <div class="fc-card__body">
                    @if (!_monthlyTrend.Any())
                    {
                        <p class="fc-page-header-subtitle">No paid invoice activity in the selected window.</p>
                    }
                    else
                    {
                        <div class="fc-billing-chart-list">
                            @foreach (var point in _monthlyTrend)
                            {
                                var width = _trendMaxAmount <= 0 ? 0 : Math.Clamp((point.Amount / _trendMaxAmount) * 100m, 0m, 100m);
                                <div class="fc-billing-chart-row">
                                    <div class="fc-billing-chart-label">@point.Label</div>
                                    <div class="fc-billing-chart-track">
                                        <div class="fc-billing-chart-fill" style="width:@($"{width:0.##}%")"></div>
                                    </div>
                                    <div class="fc-billing-chart-value">@FormatCurrency(point.Amount)</div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="fc-card">
                <div class="fc-card__header">
                    <h2 class="fc-card__title">Plan Mix</h2>
                </div>
                <div class="fc-card__body">
                    @if (!_planMix.Any())
                    {
                        <p class="fc-page-header-subtitle">No active subscriptions found.</p>
                    }
                    else
                    {
                        <div class="fc-billing-planmix-list">
                            @foreach (var plan in _planMix)
                            {
                                var ratio = _activeSubscriptionCount == 0 ? 0 : (decimal)plan.Count / _activeSubscriptionCount * 100m;
                                <div class="fc-billing-planmix-row">
                                    <div class="fc-billing-planmix-head">
                                        <span>@plan.PlanCode</span>
                                        <span>@plan.Count tenant(s)</span>
                                    </div>
                                    <div class="fc-billing-chart-track">
                                        <div class="fc-billing-chart-fill fc-billing-chart-fill-accent" style="width:@($"{ratio:0.##}%")"></div>
                                    </div>
                                    <div class="fc-billing-planmix-foot">Monthly contribution: @FormatCurrency(plan.MonthlyRevenue)</div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </section>

        <div class="fc-card">
            <div class="fc-card__header">
                <h2 class="fc-card__title">Top Tenants by Paid Revenue (YTD)</h2>
            </div>
            <div class="fc-card__body">
                @if (!_topTenants.Any())
                {
                    <div class="fc-empty">
                        <div class="fc-empty-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                                <line x1="16" y1="13" x2="8" y2="13"/>
                                <line x1="16" y1="17" x2="8" y2="17"/>
                            </svg>
                        </div>
                        <p class="fc-empty-title">No paid invoices yet</p>
                        <p class="fc-empty-text">Paid invoices for this year will appear here once tenants begin settling their bills.</p>
                    </div>
                }
                else
                {
                    <table class="fc-table">
                        <thead>
                            <tr>
                                <th>Tenant</th>
                                <th>Total Paid (NGN)</th>
                                <th>Invoice Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tenant in _topTenants)
                            {
                                <tr>
                                    <td>
                                        <div><strong>@tenant.TenantName</strong></div>
                                        <div class="fc-page-header-subtitle">@tenant.TenantSlug</div>
                                    </td>
                                    <td>@FormatCurrency(tenant.TotalPaid)</td>
                                    <td>@tenant.InvoiceCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private decimal _mrr;
    private decimal _arr;
    private decimal _paidThisMonth;
    private decimal _outstanding;
    private int _activeSubscriptionCount;
    private decimal _trendMaxAmount;

    private List<MonthlyTrendPoint> _monthlyTrend = new();
    private List<PlanMixPoint> _planMix = new();
    private List<TenantRevenuePoint> _topTenants = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboard();
        _loading = false;
    }

    private async Task LoadDashboard()
    {
        var revenueStatuses = new[]
        {
            SubscriptionStatus.Active,
            SubscriptionStatus.PastDue,
            SubscriptionStatus.Suspended,
            SubscriptionStatus.Trial
        };

        _mrr = await Db.Subscriptions
            .AsNoTracking()
            .Where(s => revenueStatuses.Contains(s.Status))
            .Join(Db.SubscriptionPlans, s => s.PlanId, p => p.Id, (_, p) => (decimal?)p.BasePriceMonthly)
            .SumAsync(x => x ?? 0m);

        _arr = _mrr * 12;

        var monthStart = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
        _paidThisMonth = await Db.Invoices
            .AsNoTracking()
            .Where(i => i.Status == InvoiceStatus.Paid && i.PaidAt.HasValue && i.PaidAt.Value >= monthStart)
            .SumAsync(i => (decimal?)i.TotalAmount) ?? 0m;

        _outstanding = await Db.Invoices
            .AsNoTracking()
            .Where(i => i.Status == InvoiceStatus.Issued || i.Status == InvoiceStatus.Overdue)
            .SumAsync(i => (decimal?)i.TotalAmount) ?? 0m;

        _activeSubscriptionCount = await Db.Subscriptions
            .AsNoTracking()
            .CountAsync(s => s.Status != SubscriptionStatus.Cancelled && s.Status != SubscriptionStatus.Expired);

        await LoadMonthlyTrend();
        await LoadPlanMix();
        await LoadTopTenants();
    }

    private async Task LoadMonthlyTrend()
    {
        var currentMonth = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
        var firstMonth = currentMonth.AddMonths(-5);

        var paidRows = await Db.Invoices
            .AsNoTracking()
            .Where(i => i.Status == InvoiceStatus.Paid
                && i.PaidAt.HasValue
                && i.PaidAt.Value >= firstMonth)
            .Select(i => new { i.PaidAt!.Value.Year, i.PaidAt!.Value.Month, i.TotalAmount })
            .ToListAsync();

        _monthlyTrend = new List<MonthlyTrendPoint>();
        for (var i = 0; i < 6; i++)
        {
            var bucket = firstMonth.AddMonths(i);
            var amount = paidRows
                .Where(r => r.Year == bucket.Year && r.Month == bucket.Month)
                .Sum(r => r.TotalAmount);

            _monthlyTrend.Add(new MonthlyTrendPoint
            {
                Label = bucket.ToString("MMM yyyy"),
                Amount = amount
            });
        }

        _trendMaxAmount = _monthlyTrend.Any() ? _monthlyTrend.Max(t => t.Amount) : 0;
    }

    private async Task LoadPlanMix()
    {
        _planMix = await Db.Subscriptions
            .AsNoTracking()
            .Where(s => s.Status != SubscriptionStatus.Cancelled && s.Status != SubscriptionStatus.Expired)
            .Join(Db.SubscriptionPlans,
                s => s.PlanId,
                p => p.Id,
                (_, p) => new { p.PlanCode, p.BasePriceMonthly })
            .GroupBy(x => x.PlanCode)
            .Select(g => new PlanMixPoint
            {
                PlanCode = g.Key,
                Count = g.Count(),
                MonthlyRevenue = g.Sum(x => x.BasePriceMonthly)
            })
            .OrderByDescending(x => x.Count)
            .ToListAsync();
    }

    private async Task LoadTopTenants()
    {
        var yearStart = new DateTime(DateTime.UtcNow.Year, 1, 1);

        _topTenants = await Db.Invoices
            .AsNoTracking()
            .Where(i => i.Status == InvoiceStatus.Paid && i.PaidAt.HasValue && i.PaidAt.Value >= yearStart)
            .Join(Db.Tenants,
                i => i.TenantId,
                t => t.TenantId,
                (i, t) => new { t.TenantName, t.TenantSlug, i.TotalAmount })
            .GroupBy(x => new { x.TenantName, x.TenantSlug })
            .Select(g => new TenantRevenuePoint
            {
                TenantName = g.Key.TenantName,
                TenantSlug = g.Key.TenantSlug,
                TotalPaid = g.Sum(x => x.TotalAmount),
                InvoiceCount = g.Count()
            })
            .OrderByDescending(x => x.TotalPaid)
            .Take(10)
            .ToListAsync();
    }

    private static string FormatCurrency(decimal value) => value.ToString("N2");

    private sealed class MonthlyTrendPoint
    {
        public string Label { get; set; } = string.Empty;
        public decimal Amount { get; set; }
    }

    private sealed class PlanMixPoint
    {
        public string PlanCode { get; set; } = string.Empty;
        public int Count { get; set; }
        public decimal MonthlyRevenue { get; set; }
    }

    private sealed class TenantRevenuePoint
    {
        public string TenantName { get; set; } = string.Empty;
        public string TenantSlug { get; set; } = string.Empty;
        public decimal TotalPaid { get; set; }
        public int InvoiceCount { get; set; }
    }
}
