    private static string FormatCurrency(decimal value) => $"NGN {value:N2}";

    private static string FormatCompactCurrency(decimal value)
    {
        var absolute = Math.Abs(value);
        if (absolute >= 1_000_000_000m) return $"NGN {value / 1_000_000_000m:0.##}B";
        if (absolute >= 1_000_000m) return $"NGN {value / 1_000_000m:0.##}M";
        if (absolute >= 1_000m) return $"NGN {value / 1_000m:0.##}K";
        return FormatCurrency(value);
    }

    private static string FormatPercent(decimal value) => $"{value:0.##}%";

    private static string FormatUtc(DateTime value) => $"{value:dd MMM yyyy, HH:mm} UTC";

