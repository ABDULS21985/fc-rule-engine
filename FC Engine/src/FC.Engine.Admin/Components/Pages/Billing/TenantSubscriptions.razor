@page "/billing/subscriptions"
@using Microsoft.AspNetCore.Authorization
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Entities
@using FC.Engine.Domain.Enums
@using FC.Engine.Infrastructure.Metadata
@using FC.Engine.Admin.Services
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Policy = "PlatformAdmin")]
@inject MetadataDbContext Db
@inject ISubscriptionService SubscriptionService
@inject ToastService Toast
@inject DialogService Dialog

<PageTitle>Tenant Subscriptions</PageTitle>

<div class="admin-page">

    <!-- Breadcrumb -->
    <nav class="detail-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Dashboard</a>
        <span class="detail-breadcrumb-sep" aria-hidden="true">/</span>
        <a href="/billing/plans">Billing</a>
        <span class="detail-breadcrumb-sep" aria-hidden="true">/</span>
        <span class="detail-breadcrumb-current">Subscriptions</span>
    </nav>

    <!-- Page Header -->
    <div class="admin-header">
        <div class="admin-header-top">
            <div>
                <h1>Tenant Subscriptions</h1>
                <p class="admin-header-subtitle">Monitor lifecycle status, adjust plans, and manage subscription operations across all tenants.</p>
            </div>
        </div>

        @if (!_loading && _subscriptions.Any())
        {
            <div class="fc-chip-group">
                <span class="fc-chip">
                    <span class="fc-chip__count">@_subscriptions.Count</span> Total
                </span>
                <span class="fc-chip">
                    <span class="fc-chip__dot fc-chip__dot--active" aria-hidden="true"></span>
                    <span class="fc-chip__count">@_subscriptions.Count(s => s.Status == SubscriptionStatus.Active)</span> Active
                </span>
                <span class="fc-chip">
                    <span class="fc-chip__dot" style="background:#f59e0b;" aria-hidden="true"></span>
                    <span class="fc-chip__count">@_subscriptions.Count(s => s.Status == SubscriptionStatus.PastDue)</span> Past Due
                </span>
                <span class="fc-chip">
                    <span class="fc-chip__dot fc-chip__dot--inactive" aria-hidden="true"></span>
                    <span class="fc-chip__count">@_subscriptions.Count(s => s.Status is SubscriptionStatus.Suspended or SubscriptionStatus.Cancelled)</span> Suspended/Cancelled
                </span>
            </div>
        }
    </div>

    <!-- Toolbar -->
    <div class="admin-toolbar">
        <div class="admin-toolbar-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" placeholder="Search tenant or plan..." @bind="_searchTerm" @bind:event="oninput" aria-label="Search subscriptions" />
        </div>
        <div class="admin-toolbar-filter">
            <select @bind="_statusFilter" aria-label="Filter by status">
                <option value="ALL">All Statuses</option>
                @foreach (var status in Enum.GetValues<SubscriptionStatus>())
                {
                    <option value="@status.ToString()">@status</option>
                }
            </select>
            <select @bind="_planFilter" aria-label="Filter by plan">
                <option value="ALL">All Plans</option>
                @foreach (var plan in _planOptions)
                {
                    <option value="@plan.PlanCode">@plan.PlanName (@plan.PlanCode)</option>
                }
            </select>
            <button class="fc-btn fc-btn--outline" @onclick="ClearFilters" type="button">Clear</button>
        </div>
    </div>

    <!-- Content -->
    @if (_loading)
    {
        <div class="fc-card">
            <div class="fc-card__body" style="padding:0;overflow:auto;">
                <table class="portal-table">
                    <thead>
                        <tr>
                            <th>Tenant</th>
                            <th>Current Plan</th>
                            <th>Status</th>
                            <th>Frequency</th>
                            <th>Period</th>
                            <th>Active Modules</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < 5; i++)
                        {
                            <tr>
                                <td><div class="skel skel-text" style="width:130px;"></div><div class="skel skel-text" style="width:80px;margin-top:4px;"></div></td>
                                <td><div class="skel skel-text" style="width:80px;"></div><div class="skel skel-text" style="width:50px;margin-top:4px;"></div></td>
                                <td><div class="skel" style="width:60px;height:20px;border-radius:var(--radius-pill);"></div></td>
                                <td><div class="skel skel-text" style="width:60px;"></div></td>
                                <td><div class="skel skel-text" style="width:80px;"></div><div class="skel skel-text" style="width:80px;margin-top:4px;"></div></td>
                                <td><div class="skel skel-text" style="width:24px;"></div></td>
                                <td><div class="skel" style="width:140px;height:28px;border-radius:6px;"></div></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (!FilteredSubscriptions.Any())
    {
        <div class="admin-empty">
            <div class="admin-empty-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            </div>
            @if (_searchTerm == string.Empty && _statusFilter == "ALL" && _planFilter == "ALL")
            {
                <h3 class="admin-empty-title">No subscriptions found</h3>
                <p class="admin-empty-text">Tenant subscriptions will appear here once tenants are onboarded.</p>
            }
            else
            {
                <h3 class="admin-empty-title">No matching subscriptions</h3>
                <p class="admin-empty-text">Try adjusting your search or filters.</p>
            }
        </div>
    }
    else
    {
        <div class="fc-card">
            <div class="fc-card__body" style="padding:0;overflow:auto;">
                <table class="portal-table">
                    <thead>
                        <tr>
                            <th>Tenant</th>
                            <th>Current Plan</th>
                            <th>Status</th>
                            <th>Frequency</th>
                            <th>Period</th>
                            <th>Active Modules</th>
                            <th style="text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in FilteredSubscriptions)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight:600;">@row.TenantName</div>
                                    <small style="color:#64748b;">@row.TenantSlug</small>
                                </td>
                                <td>
                                    <div style="font-weight:500;">@row.PlanCode</div>
                                    <small style="color:#64748b;">Tier @row.PlanTier</small>
                                </td>
                                <td>
                                    <span class="fc-badge @GetStatusBadgeClass(row.Status)">@row.Status</span>
                                </td>
                                <td>@row.BillingFrequency</td>
                                <td>
                                    <div>@row.CurrentPeriodStart.ToString("yyyy-MM-dd")</div>
                                    <small style="color:#64748b;">to @row.CurrentPeriodEnd.ToString("yyyy-MM-dd")</small>
                                </td>
                                <td>@row.ActiveModuleCount</td>
                                <td>
                                    <div style="display:flex;gap:0.35rem;justify-content:flex-end;align-items:center;">
                                        <select class="admin-form-input" style="width:auto;min-width:100px;padding:0.25rem 0.5rem;font-size:0.8rem;" @bind="row.TargetPlanCode">
                                            @foreach (var plan in _planOptions)
                                            {
                                                <option value="@plan.PlanCode">@plan.PlanCode</option>
                                            }
                                        </select>
                                        <button class="fc-btn fc-btn--ghost"
                                                disabled="@(_busySubscriptionId == row.SubscriptionId)"
                                                @onclick="() => ChangePlan(row)" type="button">
                                            Apply Plan
                                        </button>
                                        <button class="fc-btn fc-btn--ghost fc-btn--danger"
                                                disabled="@(_busySubscriptionId == row.SubscriptionId || row.Status is SubscriptionStatus.Cancelled or SubscriptionStatus.Expired)"
                                                @onclick="() => CancelSubscription(row)" type="button">
                                            Cancel
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private string _searchTerm = string.Empty;
    private string _statusFilter = "ALL";
    private string _planFilter = "ALL";
    private int? _busySubscriptionId;

    private List<SubscriptionRow> _subscriptions = new();
    private List<PlanOption> _planOptions = new();

    private IEnumerable<SubscriptionRow> FilteredSubscriptions => _subscriptions
        .Where(s => string.IsNullOrWhiteSpace(_searchTerm)
            || s.TenantName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)
            || s.TenantSlug.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)
            || s.PlanCode.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(s => _statusFilter == "ALL" || s.Status.ToString() == _statusFilter)
        .Where(s => _planFilter == "ALL" || s.PlanCode == _planFilter)
        .OrderByDescending(s => s.UpdatedAt)
        .ThenBy(s => s.TenantName);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _loading = false;
    }

    private async Task LoadData()
    {
        _planOptions = await Db.SubscriptionPlans
            .AsNoTracking()
            .Where(p => p.IsActive)
            .OrderBy(p => p.Tier)
            .ThenBy(p => p.DisplayOrder)
            .ThenBy(p => p.PlanCode)
            .Select(p => new PlanOption
            {
                PlanCode = p.PlanCode,
                PlanName = p.PlanName,
                Tier = p.Tier
            })
            .ToListAsync();

        _subscriptions = await Db.Subscriptions
            .AsNoTracking()
            .Include(s => s.Tenant)
            .Include(s => s.Plan)
            .Select(s => new SubscriptionRow
            {
                SubscriptionId = s.Id,
                TenantId = s.TenantId,
                TenantName = s.Tenant != null ? s.Tenant.TenantName : "Unknown",
                TenantSlug = s.Tenant != null ? s.Tenant.TenantSlug : string.Empty,
                PlanCode = s.Plan != null ? s.Plan.PlanCode : "N/A",
                PlanTier = s.Plan != null ? s.Plan.Tier : 0,
                Status = s.Status,
                BillingFrequency = s.BillingFrequency,
                CurrentPeriodStart = s.CurrentPeriodStart,
                CurrentPeriodEnd = s.CurrentPeriodEnd,
                ActiveModuleCount = Db.SubscriptionModules.Count(sm => sm.SubscriptionId == s.Id && sm.IsActive),
                UpdatedAt = s.UpdatedAt
            })
            .ToListAsync();

        foreach (var row in _subscriptions)
        {
            row.TargetPlanCode = row.PlanCode;
        }
    }

    private void ClearFilters()
    {
        _searchTerm = string.Empty;
        _statusFilter = "ALL";
        _planFilter = "ALL";
    }

    private async Task ChangePlan(SubscriptionRow row)
    {
        if (string.IsNullOrWhiteSpace(row.TargetPlanCode) || row.TargetPlanCode == row.PlanCode)
        {
            Toast.Warning("Select a different target plan before applying.");
            return;
        }

        var target = _planOptions.FirstOrDefault(p => p.PlanCode == row.TargetPlanCode);
        if (target is null)
        {
            Toast.Error($"Target plan {row.TargetPlanCode} is not available.");
            return;
        }

        _busySubscriptionId = row.SubscriptionId;

        try
        {
            if (target.Tier > row.PlanTier)
            {
                await SubscriptionService.UpgradePlan(row.TenantId, row.TargetPlanCode);
            }
            else if (target.Tier < row.PlanTier)
            {
                await SubscriptionService.DowngradePlan(row.TenantId, row.TargetPlanCode);
            }
            else
            {
                throw new InvalidOperationException("Switching plans on the same tier is not supported by the subscription service.");
            }

            Toast.Success($"Updated {row.TenantName} to {row.TargetPlanCode}.");
            await LoadData();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message);
        }
        finally
        {
            _busySubscriptionId = null;
        }
    }

    private async Task CancelSubscription(SubscriptionRow row)
    {
        var confirmed = await Dialog.Confirm(new ConfirmRequest
        {
            Title = "Cancel Subscription",
            Message = $"Cancel the subscription for {row.TenantName}? This will terminate their active billing cycle and revoke access to subscribed modules.",
            ConfirmText = "Cancel Subscription",
            IsDestructive = true,
            Icon = "archive"
        });

        if (!confirmed) return;

        _busySubscriptionId = row.SubscriptionId;

        try
        {
            await SubscriptionService.CancelSubscription(row.TenantId, "Cancelled by platform administrator");
            Toast.Success($"Cancelled subscription for {row.TenantName}.");
            await LoadData();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message);
        }
        finally
        {
            _busySubscriptionId = null;
        }
    }

    private static string GetStatusBadgeClass(SubscriptionStatus status) => status switch
    {
        SubscriptionStatus.Active => "fc-badge--success",
        SubscriptionStatus.Trial => "fc-badge--warning",
        SubscriptionStatus.PastDue => "fc-badge--warning",
        SubscriptionStatus.Suspended => "fc-badge--danger",
        SubscriptionStatus.Cancelled => "fc-badge--danger",
        SubscriptionStatus.Expired => "fc-badge--neutral",
        _ => "fc-badge--neutral"
    };

    private sealed class PlanOption
    {
        public string PlanCode { get; set; } = string.Empty;
        public string PlanName { get; set; } = string.Empty;
        public int Tier { get; set; }
    }

    private sealed class SubscriptionRow
    {
        public int SubscriptionId { get; set; }
        public Guid TenantId { get; set; }
        public string TenantName { get; set; } = string.Empty;
        public string TenantSlug { get; set; } = string.Empty;
        public string PlanCode { get; set; } = string.Empty;
        public int PlanTier { get; set; }
        public string TargetPlanCode { get; set; } = string.Empty;
        public SubscriptionStatus Status { get; set; }
        public BillingFrequency BillingFrequency { get; set; }
        public DateTime CurrentPeriodStart { get; set; }
        public DateTime CurrentPeriodEnd { get; set; }
        public int ActiveModuleCount { get; set; }
        public DateTime UpdatedAt { get; set; }
    }
}
