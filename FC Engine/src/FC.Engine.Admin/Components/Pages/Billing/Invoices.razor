@page "/billing/invoices"
@using Microsoft.AspNetCore.Authorization
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Enums
@using FC.Engine.Infrastructure.Metadata
@using FC.Engine.Admin.Services
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Policy = "PlatformAdmin")]
@inject MetadataDbContext Db
@inject ISubscriptionService SubscriptionService
@inject ToastService Toast
@inject DialogService Dialog

<PageTitle>Invoices</PageTitle>

<PageHeader Title="Invoices &amp; Collections"
            Subtitle="Issue invoices, capture payments, and manage overdue exposure across tenants." />

<div class="fc-page">

    @if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <AppAlert Variant="AppAlert.AlertVariant.Error"
                  Message="@_loadError"
                  Dismissible="true"
                  OnDismiss="() => _loadError = null" />
        <div style="margin-bottom:var(--space-4);">
            <button class="fc-btn fc-btn--outline" @onclick="ReloadPageData" type="button">
                Retry Loading Data
            </button>
        </div>
    }

    <!-- Generate Invoice -->
    @if (!_loading)
    {
        <div class="fc-card">
            <div class="fc-card__header">
                <h2 class="fc-card__title">Generate Invoice</h2>
            </div>
            <div class="fc-card__body">
                <div style="display:flex;gap:1rem;align-items:flex-end;flex-wrap:wrap;">
                    <div class="fc-form-group" style="flex:1;min-width:240px;">
                        <label class="fc-form-label">Tenant</label>
                        <select class="fc-form-input" @bind="_selectedTenantId">
                            <option value="">Select tenant</option>
                            @foreach (var tenant in _tenantOptions)
                            {
                                <option value="@tenant.TenantId.ToString()">@tenant.TenantName (@tenant.PlanCode)</option>
                            }
                        </select>
                    </div>
                    <button class="fc-btn fc-btn--primary"
                            disabled="@(_busyInvoiceId.HasValue || string.IsNullOrWhiteSpace(_selectedTenantId))"
                            @onclick="GenerateForTenant"
                            type="button">
                        Generate Draft
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- Invoice Table -->
    <DataTable TItem="InvoiceRow"
               Items="@FilteredInvoices"
               Loading="_loading"
               Sortable="true"
               ShowPagination="true"
               PageSize="25"
               EmptyTitle="@(string.IsNullOrWhiteSpace(_searchTerm) && _statusFilter == "ALL" ? "No invoices yet" : "No matching invoices")"
               EmptyText="@(string.IsNullOrWhiteSpace(_searchTerm) && _statusFilter == "ALL" ? "Generate your first invoice using the form above." : "Try adjusting your search or filters.")"
               SkeletonRows="5">
        <ToolbarContent>
            <div class="fc-toolbar-search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="search"
                       placeholder="Search invoice or tenant..."
                       @bind="_searchTerm"
                       @bind:event="oninput"
                       aria-label="Search invoices" />
            </div>
            <div class="fc-toolbar-filter">
                <select @bind="_statusFilter" aria-label="Filter by status">
                    <option value="ALL">All statuses</option>
                    @foreach (var status in Enum.GetValues<InvoiceStatus>())
                    {
                        <option value="@status.ToString()">@status</option>
                    }
                </select>
                <button class="fc-btn fc-btn--outline" @onclick="ClearFilters" type="button">Clear</button>
            </div>
        </ToolbarContent>
        <ChildContent>
            <DataColumn TItem="InvoiceRow" Title="Invoice" SortKey="i => i.InvoiceNumber">
                <CellTemplate>
                    <div style="font-weight:600;">@context.InvoiceNumber</div>
                    <small style="color:#64748b;">Created @context.CreatedAt.ToString("yyyy-MM-dd")</small>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="InvoiceRow" Title="Tenant" SortKey="i => i.TenantName">
                <CellTemplate>
                    <div style="font-weight:600;">@context.TenantName</div>
                    <small style="color:#64748b;">@context.TenantSlug</small>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="InvoiceRow" Title="Status" Width="120px">
                <CellTemplate>
                    <span class="fc-badge @GetInvoiceBadgeClass(context.Status)">@context.Status</span>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="InvoiceRow" Title="Period" Width="160px">
                <CellTemplate>
                    <div>@context.PeriodStart.ToString("yyyy-MM-dd")</div>
                    <small style="color:#64748b;">to @context.PeriodEnd.ToString("yyyy-MM-dd")</small>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="InvoiceRow" Title="Total (NGN)" SortKey="i => i.TotalAmount" Width="130px">
                <CellTemplate>@FormatCurrency(context.TotalAmount)</CellTemplate>
            </DataColumn>
            <DataColumn TItem="InvoiceRow" Title="Due" Width="120px">
                <CellTemplate>
                    @if (context.DueDate.HasValue)
                    {
                        <span>@context.DueDate.Value.ToString("yyyy-MM-dd")</span>
                    }
                    else
                    {
                        <span style="color:#94a3b8;">-</span>
                    }
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="InvoiceRow" Title="Actions" Align="right" Width="200px">
                <CellTemplate>
                    <div style="display:flex;gap:0.35rem;flex-wrap:wrap;justify-content:flex-end;">
                        @if (context.Status == InvoiceStatus.Draft)
                        {
                            <button class="fc-btn fc-btn--ghost"
                                    disabled="@(_busyInvoiceId == context.Id)"
                                    @onclick="() => IssueInvoice(context.Id)"
                                    @onclick:stopPropagation="true"
                                    type="button">
                                Issue
                            </button>
                        }
                        @if (context.Status is InvoiceStatus.Issued or InvoiceStatus.Overdue)
                        {
                            <button class="fc-btn fc-btn--ghost"
                                    disabled="@(_busyInvoiceId == context.Id)"
                                    @onclick="() => RecordManualPayment(context)"
                                    @onclick:stopPropagation="true"
                                    type="button">
                                Mark Paid
                            </button>
                        }
                        @if (context.Status is InvoiceStatus.Draft or InvoiceStatus.Issued or InvoiceStatus.Overdue)
                        {
                            <button class="fc-btn fc-btn--ghost fc-btn--danger"
                                    disabled="@(_busyInvoiceId == context.Id)"
                                    @onclick="() => VoidInvoice(context.Id)"
                                    @onclick:stopPropagation="true"
                                    type="button">
                                Void
                            </button>
                        }
                    </div>
                </CellTemplate>
            </DataColumn>
        </ChildContent>
    </DataTable>

</div>

@code {
    private bool _loading = true;
    private string? _loadError;
    private string _searchTerm = string.Empty;
    private string _statusFilter = "ALL";
    private string? _selectedTenantId;
    private int? _busyInvoiceId;

    private decimal _outstandingAmount;
    private decimal _paidThisMonth;

    private List<InvoiceRow> _invoices = new();
    private List<TenantOption> _tenantOptions = new();

    private IReadOnlyList<InvoiceRow> FilteredInvoices => _invoices
        .Where(i => string.IsNullOrWhiteSpace(_searchTerm)
            || (i.InvoiceNumber ?? string.Empty).Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)
            || (i.TenantName ?? string.Empty).Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)
            || (i.TenantSlug ?? string.Empty).Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(i => _statusFilter == "ALL" || i.Status.ToString() == _statusFilter)
        .OrderByDescending(i => i.CreatedAt)
        .ThenByDescending(i => i.InvoiceNumber)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await ReloadPageData();
    }

    private async Task ReloadPageData()
    {
        _loading = true;
        _loadError = null;
        try
        {
            await LoadData();
        }
        catch (Exception ex)
        {
            _invoices = new();
            _tenantOptions = new();
            _loadError = $"Failed to load invoice data. {ex.Message}";
            Toast.Error(_loadError);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadData()
    {
        _invoices = await Db.Invoices
            .AsNoTracking()
            .Join(Db.Tenants,
                i => i.TenantId,
                t => t.TenantId,
                (i, t) => new InvoiceRow
                {
                    Id = i.Id,
                    TenantId = i.TenantId,
                    InvoiceNumber = i.InvoiceNumber ?? string.Empty,
                    TenantName = t.TenantName ?? "Unknown",
                    TenantSlug = t.TenantSlug ?? string.Empty,
                    Status = i.Status,
                    PeriodStart = i.PeriodStart,
                    PeriodEnd = i.PeriodEnd,
                    TotalAmount = i.TotalAmount,
                    Currency = i.Currency,
                    DueDate = i.DueDate,
                    PaidAt = i.PaidAt,
                    CreatedAt = i.CreatedAt
                })
            .ToListAsync();

        var monthStart = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
        _paidThisMonth = _invoices
            .Where(i => i.Status == InvoiceStatus.Paid && i.PaidAt.HasValue && i.PaidAt.Value >= monthStart)
            .Sum(i => i.TotalAmount);

        _outstandingAmount = _invoices
            .Where(i => i.Status is InvoiceStatus.Issued or InvoiceStatus.Overdue)
            .Sum(i => i.TotalAmount);

        var tenantRows = await Db.Subscriptions
            .AsNoTracking()
            .Include(s => s.Tenant)
            .Include(s => s.Plan)
            .Where(s => s.Status != SubscriptionStatus.Cancelled && s.Status != SubscriptionStatus.Expired)
            .Select(s => new TenantOption
            {
                TenantId = s.TenantId,
                TenantName = s.Tenant != null ? (s.Tenant.TenantName ?? "Unknown") : "Unknown",
                PlanCode = s.Plan != null ? (s.Plan.PlanCode ?? "N/A") : "N/A",
                UpdatedAt = s.UpdatedAt
            })
            .ToListAsync();

        _tenantOptions = tenantRows
            .GroupBy(t => t.TenantId)
            .Select(g => g.OrderByDescending(x => x.UpdatedAt).First())
            .OrderBy(t => t.TenantName)
            .ToList();
    }

    private void ClearFilters()
    {
        _searchTerm = string.Empty;
        _statusFilter = "ALL";
    }

    private async Task GenerateForTenant()
    {
        if (!Guid.TryParse(_selectedTenantId, out var tenantId))
        {
            Toast.Error("Select a tenant with an active subscription first.");
            return;
        }

        _busyInvoiceId = -1;

        try
        {
            var invoice = await SubscriptionService.GenerateInvoice(tenantId);
            Toast.Success($"Generated draft invoice {invoice.InvoiceNumber}.");
            await LoadData();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message);
        }
        finally
        {
            _busyInvoiceId = null;
        }
    }

    private async Task IssueInvoice(int invoiceId)
    {
        _busyInvoiceId = invoiceId;

        try
        {
            var invoice = await SubscriptionService.IssueInvoice(invoiceId);
            Toast.Success($"Issued invoice {invoice.InvoiceNumber}.");
            await LoadData();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message);
        }
        finally
        {
            _busyInvoiceId = null;
        }
    }

    private async Task RecordManualPayment(InvoiceRow invoice)
    {
        var confirmed = await Dialog.Confirm(new ConfirmRequest
        {
            Title = "Record Manual Payment",
            Message = $"Mark invoice {invoice.InvoiceNumber} as paid ({FormatCurrency(invoice.TotalAmount)} {invoice.Currency})? This action will record a manual payment entry.",
            ConfirmText = "Mark Paid",
            IsDestructive = false,
            Icon = "publish"
        });

        if (!confirmed) return;

        _busyInvoiceId = invoice.Id;

        try
        {
            await SubscriptionService.RecordPayment(invoice.Id, new RecordPaymentRequest
            {
                Amount = invoice.TotalAmount,
                Currency = invoice.Currency,
                PaymentMethod = "Manual",
                PaymentReference = $"ADMIN-{DateTime.UtcNow:yyyyMMddHHmmss}",
                ProviderName = "PlatformAdmin",
                IsSuccessful = true
            });

            Toast.Success($"Recorded payment for {invoice.InvoiceNumber}.");
            await LoadData();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message);
        }
        finally
        {
            _busyInvoiceId = null;
        }
    }

    private async Task VoidInvoice(int invoiceId)
    {
        var confirmed = await Dialog.Confirm(new ConfirmRequest
        {
            Title = "Void Invoice",
            Message = $"Void invoice ID {invoiceId}? This action cannot be undone and the invoice will be permanently marked as voided.",
            ConfirmText = "Void",
            IsDestructive = true,
            Icon = "delete"
        });

        if (!confirmed) return;

        _busyInvoiceId = invoiceId;

        try
        {
            await SubscriptionService.VoidInvoice(invoiceId, "Voided by platform administrator");
            Toast.Success($"Voided invoice ID {invoiceId}.");
            await LoadData();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message);
        }
        finally
        {
            _busyInvoiceId = null;
        }
    }

    private static string FormatCurrency(decimal value) => value.ToString("N2");

    private static string GetInvoiceBadgeClass(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => "fc-badge--neutral",
        InvoiceStatus.Issued => "fc-badge--warning",
        InvoiceStatus.Overdue => "fc-badge--danger",
        InvoiceStatus.Paid => "fc-badge--success",
        InvoiceStatus.Voided => "fc-badge--danger",
        _ => "fc-badge--neutral"
    };

    private sealed class InvoiceRow
    {
        public int Id { get; set; }
        public Guid TenantId { get; set; }
        public string InvoiceNumber { get; set; } = string.Empty;
        public string TenantName { get; set; } = string.Empty;
        public string TenantSlug { get; set; } = string.Empty;
        public InvoiceStatus Status { get; set; }
        public DateOnly PeriodStart { get; set; }
        public DateOnly PeriodEnd { get; set; }
        public decimal TotalAmount { get; set; }
        public string Currency { get; set; } = "NGN";
        public DateOnly? DueDate { get; set; }
        public DateTime? PaidAt { get; set; }
        public DateTime CreatedAt { get; set; }
    }

    private sealed class TenantOption
    {
        public Guid TenantId { get; set; }
        public string TenantName { get; set; } = string.Empty;
        public string PlanCode { get; set; } = string.Empty;
        public DateTime UpdatedAt { get; set; }
    }
}
