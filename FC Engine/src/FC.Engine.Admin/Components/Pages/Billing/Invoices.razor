@page "/billing/invoices"
@using Microsoft.AspNetCore.Authorization
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Enums
@using FC.Engine.Infrastructure.Metadata
@using FC.Engine.Admin.Services
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Policy = "PlatformAdmin")]
@inject MetadataDbContext Db
@inject ISubscriptionService SubscriptionService
@inject ToastService Toast
@inject DialogService Dialog

<PageTitle>Invoices</PageTitle>

<div class="admin-page">

    <!-- Breadcrumb -->
    <nav class="detail-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Dashboard</a>
        <span class="detail-breadcrumb-sep" aria-hidden="true">/</span>
        <a href="/billing/plans">Billing</a>
        <span class="detail-breadcrumb-sep" aria-hidden="true">/</span>
        <span class="detail-breadcrumb-current">Invoices</span>
    </nav>

    <!-- Page Header -->
    <div class="admin-header">
        <div class="admin-header-top">
            <div>
                <h1>Invoices &amp; Collections</h1>
                <p class="admin-header-subtitle">Issue invoices, capture payments, and manage overdue exposure across tenants.</p>
            </div>
        </div>

        @if (!_loading)
        {
            <!-- Summary Chips -->
            <div class="fc-chip-group">
                <span class="fc-chip">
                    <span class="fc-chip__count">@FormatCurrency(_outstandingAmount)</span> Outstanding Amount
                </span>
                <span class="fc-chip">
                    <span class="fc-chip__count">@FormatCurrency(_paidThisMonth)</span> Paid This Month
                </span>
                <span class="fc-chip">
                    <span class="fc-chip__count">@_invoices.Count(i => i.Status == InvoiceStatus.Overdue)</span> Overdue
                </span>
                <span class="fc-chip">
                    <span class="fc-chip__count">@_invoices.Count(i => i.Status == InvoiceStatus.Draft)</span> Drafts
                </span>
            </div>
        }
    </div>

    @if (_loading)
    {
        <!-- Skeleton Loading State -->
        <div class="fc-card">
            <div class="fc-card__body">
                <div class="skel skel-text" style="width:200px;margin-bottom:1rem;"></div>
                <div class="skel skel-text" style="width:100%;height:40px;margin-bottom:0.75rem;"></div>
                @for (var i = 0; i < 5; i++)
                {
                    <div style="display:flex;gap:1rem;margin-bottom:0.75rem;">
                        <div class="skel skel-text" style="width:15%;"></div>
                        <div class="skel skel-text" style="width:20%;"></div>
                        <div class="skel skel-text" style="width:10%;"></div>
                        <div class="skel skel-text" style="width:18%;"></div>
                        <div class="skel skel-text" style="width:12%;"></div>
                        <div class="skel skel-text" style="width:12%;"></div>
                        <div class="skel skel-text" style="width:13%;"></div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <!-- Generate Invoice -->
        <div class="fc-card">
            <div class="fc-card__header">
                <h2 class="fc-card__title">Generate Invoice</h2>
            </div>
            <div class="fc-card__body">
                <div style="display:flex;gap:1rem;align-items:flex-end;flex-wrap:wrap;">
                    <div class="admin-form-group" style="flex:1;min-width:240px;">
                        <label class="admin-form-label">Tenant</label>
                        <select class="admin-form-input" @bind="_selectedTenantId">
                            <option value="">Select tenant</option>
                            @foreach (var tenant in _tenantOptions)
                            {
                                <option value="@tenant.TenantId.ToString()">@tenant.TenantName (@tenant.PlanCode)</option>
                            }
                        </select>
                    </div>
                    <button class="fc-btn fc-btn--primary"
                            disabled="@(_busyInvoiceId.HasValue || string.IsNullOrWhiteSpace(_selectedTenantId))"
                            @onclick="GenerateForTenant"
                            type="button">
                        Generate Draft
                    </button>
                </div>
            </div>
        </div>

        <!-- Toolbar -->
        <div class="admin-toolbar">
            <div class="admin-toolbar-search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="search"
                       placeholder="Search invoice or tenant..."
                       @bind="_searchTerm"
                       @bind:event="oninput"
                       aria-label="Search invoices" />
            </div>
            <div class="admin-toolbar-filter">
                <select @bind="_statusFilter" aria-label="Filter by status">
                    <option value="ALL">All statuses</option>
                    @foreach (var status in Enum.GetValues<InvoiceStatus>())
                    {
                        <option value="@status.ToString()">@status</option>
                    }
                </select>
                <button class="fc-btn fc-btn--outline" @onclick="ClearFilters" type="button">Clear</button>
            </div>
        </div>

        <!-- Invoice Table -->
        <div class="fc-card">
            <div class="fc-card__header">
                <h2 class="fc-card__title">Invoices</h2>
            </div>
            <div class="fc-card__body" style="padding:0;overflow:auto;">
                @if (!FilteredInvoices.Any())
                {
                    <div class="admin-empty">
                        <div class="admin-empty-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                        </div>
                        @if (string.IsNullOrWhiteSpace(_searchTerm) && _statusFilter == "ALL")
                        {
                            <h3 class="admin-empty-title">No invoices yet</h3>
                            <p class="admin-empty-text">Generate your first invoice using the form above.</p>
                        }
                        else
                        {
                            <h3 class="admin-empty-title">No matching invoices</h3>
                            <p class="admin-empty-text">Try adjusting your search or filters.</p>
                        }
                    </div>
                }
                else
                {
                    <table class="portal-table">
                        <thead>
                            <tr>
                                <th>Invoice</th>
                                <th>Tenant</th>
                                <th>Status</th>
                                <th>Period</th>
                                <th>Total (NGN)</th>
                                <th>Due</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var invoice in FilteredInvoices)
                            {
                                <tr>
                                    <td>
                                        <div style="font-weight:600;">@invoice.InvoiceNumber</div>
                                        <small style="color:#64748b;">Created @invoice.CreatedAt.ToString("yyyy-MM-dd")</small>
                                    </td>
                                    <td>
                                        <div style="font-weight:600;">@invoice.TenantName</div>
                                        <small style="color:#64748b;">@invoice.TenantSlug</small>
                                    </td>
                                    <td>
                                        <span class="fc-badge @GetInvoiceBadgeClass(invoice.Status)">@invoice.Status</span>
                                    </td>
                                    <td>
                                        <div>@invoice.PeriodStart.ToString("yyyy-MM-dd")</div>
                                        <small style="color:#64748b;">to @invoice.PeriodEnd.ToString("yyyy-MM-dd")</small>
                                    </td>
                                    <td>@FormatCurrency(invoice.TotalAmount)</td>
                                    <td>
                                        @if (invoice.DueDate.HasValue)
                                        {
                                            <span>@invoice.DueDate.Value.ToString("yyyy-MM-dd")</span>
                                        }
                                        else
                                        {
                                            <span style="color:#94a3b8;">-</span>
                                        }
                                    </td>
                                    <td>
                                        <div style="display:flex;gap:0.35rem;flex-wrap:wrap;">
                                            @if (invoice.Status == InvoiceStatus.Draft)
                                            {
                                                <button class="fc-btn fc-btn--ghost"
                                                        disabled="@(_busyInvoiceId == invoice.Id)"
                                                        @onclick="() => IssueInvoice(invoice.Id)"
                                                        type="button">
                                                    Issue
                                                </button>
                                            }
                                            @if (invoice.Status is InvoiceStatus.Issued or InvoiceStatus.Overdue)
                                            {
                                                <button class="fc-btn fc-btn--ghost"
                                                        disabled="@(_busyInvoiceId == invoice.Id)"
                                                        @onclick="() => RecordManualPayment(invoice)"
                                                        type="button">
                                                    Mark Paid
                                                </button>
                                            }
                                            @if (invoice.Status is InvoiceStatus.Draft or InvoiceStatus.Issued or InvoiceStatus.Overdue)
                                            {
                                                <button class="fc-btn fc-btn--ghost fc-btn--danger"
                                                        disabled="@(_busyInvoiceId == invoice.Id)"
                                                        @onclick="() => VoidInvoice(invoice.Id)"
                                                        type="button">
                                                    Void
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private string _searchTerm = string.Empty;
    private string _statusFilter = "ALL";
    private string? _selectedTenantId;
    private int? _busyInvoiceId;

    private decimal _outstandingAmount;
    private decimal _paidThisMonth;

    private List<InvoiceRow> _invoices = new();
    private List<TenantOption> _tenantOptions = new();

    private IEnumerable<InvoiceRow> FilteredInvoices => _invoices
        .Where(i => string.IsNullOrWhiteSpace(_searchTerm)
            || i.InvoiceNumber.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)
            || i.TenantName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)
            || i.TenantSlug.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(i => _statusFilter == "ALL" || i.Status.ToString() == _statusFilter)
        .OrderByDescending(i => i.CreatedAt)
        .ThenByDescending(i => i.InvoiceNumber);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _loading = false;
    }

    private async Task LoadData()
    {
        _invoices = await Db.Invoices
            .AsNoTracking()
            .Join(Db.Tenants,
                i => i.TenantId,
                t => t.TenantId,
                (i, t) => new InvoiceRow
                {
                    Id = i.Id,
                    TenantId = i.TenantId,
                    InvoiceNumber = i.InvoiceNumber,
                    TenantName = t.TenantName,
                    TenantSlug = t.TenantSlug,
                    Status = i.Status,
                    PeriodStart = i.PeriodStart,
                    PeriodEnd = i.PeriodEnd,
                    TotalAmount = i.TotalAmount,
                    Currency = i.Currency,
                    DueDate = i.DueDate,
                    PaidAt = i.PaidAt,
                    CreatedAt = i.CreatedAt
                })
            .ToListAsync();

        var monthStart = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
        _paidThisMonth = _invoices
            .Where(i => i.Status == InvoiceStatus.Paid && i.PaidAt.HasValue && i.PaidAt.Value >= monthStart)
            .Sum(i => i.TotalAmount);

        _outstandingAmount = _invoices
            .Where(i => i.Status is InvoiceStatus.Issued or InvoiceStatus.Overdue)
            .Sum(i => i.TotalAmount);

        _tenantOptions = await Db.Subscriptions
            .AsNoTracking()
            .Include(s => s.Tenant)
            .Include(s => s.Plan)
            .Where(s => s.Status != SubscriptionStatus.Cancelled && s.Status != SubscriptionStatus.Expired)
            .Select(s => new TenantOption
            {
                TenantId = s.TenantId,
                TenantName = s.Tenant != null ? s.Tenant.TenantName : "Unknown",
                PlanCode = s.Plan != null ? s.Plan.PlanCode : "N/A"
            })
            .GroupBy(t => t.TenantId)
            .Select(g => g.First())
            .OrderBy(t => t.TenantName)
            .ToListAsync();
    }

    private void ClearFilters()
    {
        _searchTerm = string.Empty;
        _statusFilter = "ALL";
    }

    private async Task GenerateForTenant()
    {
        if (!Guid.TryParse(_selectedTenantId, out var tenantId))
        {
            Toast.Error("Select a tenant with an active subscription first.");
            return;
        }

        _busyInvoiceId = -1;

        try
        {
            var invoice = await SubscriptionService.GenerateInvoice(tenantId);
            Toast.Success($"Generated draft invoice {invoice.InvoiceNumber}.");
            await LoadData();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message);
        }
        finally
        {
            _busyInvoiceId = null;
        }
    }

    private async Task IssueInvoice(int invoiceId)
    {
        _busyInvoiceId = invoiceId;

        try
        {
            var invoice = await SubscriptionService.IssueInvoice(invoiceId);
            Toast.Success($"Issued invoice {invoice.InvoiceNumber}.");
            await LoadData();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message);
        }
        finally
        {
            _busyInvoiceId = null;
        }
    }

    private async Task RecordManualPayment(InvoiceRow invoice)
    {
        var confirmed = await Dialog.Confirm(new ConfirmRequest
        {
            Title = "Record Manual Payment",
            Message = $"Mark invoice {invoice.InvoiceNumber} as paid ({FormatCurrency(invoice.TotalAmount)} {invoice.Currency})? This action will record a manual payment entry.",
            ConfirmText = "Mark Paid",
            IsDestructive = false,
            Icon = "publish"
        });

        if (!confirmed) return;

        _busyInvoiceId = invoice.Id;

        try
        {
            await SubscriptionService.RecordPayment(invoice.Id, new RecordPaymentRequest
            {
                Amount = invoice.TotalAmount,
                Currency = invoice.Currency,
                PaymentMethod = "Manual",
                PaymentReference = $"ADMIN-{DateTime.UtcNow:yyyyMMddHHmmss}",
                ProviderName = "PlatformAdmin",
                IsSuccessful = true
            });

            Toast.Success($"Recorded payment for {invoice.InvoiceNumber}.");
            await LoadData();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message);
        }
        finally
        {
            _busyInvoiceId = null;
        }
    }

    private async Task VoidInvoice(int invoiceId)
    {
        var confirmed = await Dialog.Confirm(new ConfirmRequest
        {
            Title = "Void Invoice",
            Message = $"Void invoice ID {invoiceId}? This action cannot be undone and the invoice will be permanently marked as voided.",
            ConfirmText = "Void",
            IsDestructive = true,
            Icon = "delete"
        });

        if (!confirmed) return;

        _busyInvoiceId = invoiceId;

        try
        {
            await SubscriptionService.VoidInvoice(invoiceId, "Voided by platform administrator");
            Toast.Success($"Voided invoice ID {invoiceId}.");
            await LoadData();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message);
        }
        finally
        {
            _busyInvoiceId = null;
        }
    }

    private static string FormatCurrency(decimal value) => value.ToString("N2");

    private static string GetInvoiceBadgeClass(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => "fc-badge--neutral",
        InvoiceStatus.Issued => "fc-badge--warning",
        InvoiceStatus.Overdue => "fc-badge--danger",
        InvoiceStatus.Paid => "fc-badge--success",
        InvoiceStatus.Voided => "fc-badge--danger",
        _ => "fc-badge--neutral"
    };

    private sealed class InvoiceRow
    {
        public int Id { get; set; }
        public Guid TenantId { get; set; }
        public string InvoiceNumber { get; set; } = string.Empty;
        public string TenantName { get; set; } = string.Empty;
        public string TenantSlug { get; set; } = string.Empty;
        public InvoiceStatus Status { get; set; }
        public DateOnly PeriodStart { get; set; }
        public DateOnly PeriodEnd { get; set; }
        public decimal TotalAmount { get; set; }
        public string Currency { get; set; } = "NGN";
        public DateOnly? DueDate { get; set; }
        public DateTime? PaidAt { get; set; }
        public DateTime CreatedAt { get; set; }
    }

    private sealed class TenantOption
    {
        public Guid TenantId { get; set; }
        public string TenantName { get; set; } = string.Empty;
        public string PlanCode { get; set; } = string.Empty;
    }
}
