@page "/privacy/dpo"
@attribute [Authorize(Policy = "AdminOnly")]
@using Microsoft.AspNetCore.Authorization
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Enums
@using FC.Engine.Domain.Models
@using FC.Engine.Infrastructure.Charts
@inject IPrivacyDashboardService PrivacyDashboardService
@inject ITenantContext TenantContext
@inject ChartJsInterop Charts

<PageTitle>DPO Dashboard — RegOS™</PageTitle>

<PageHeader Title="DPO Dashboard"
            Subtitle="NDPR/NDPA privacy compliance posture and data subject request tracking."
            StatusBadge="@(_data is not null ? _privacyRating : null)"
            StatusVariant="@_ratingVariant" />

<div class="fc-page">

    @if (_loading)
    {
        <!-- Score Banner Skeleton -->
        <div class="fc-card fc-card--mb">
            <div class="fc-card__body" style="display:flex;align-items:center;gap:24px;padding:24px">
                <div class="fc-skel" style="--skel-w:100px;--skel-h:100px;border-radius:50%"></div>
                <div style="flex:1">
                    <div class="fc-skel fc-skel-text" style="--skel-w:180px;--skel-h:14px"></div>
                    <div class="fc-skel fc-skel-text" style="--skel-w:100px;--skel-h:28px;margin-top:8px"></div>
                    <div style="display:flex;gap:8px;margin-top:12px">
                        <div class="fc-skel" style="--skel-w:90px;--skel-h:24px;border-radius:100px"></div>
                        <div class="fc-skel" style="--skel-w:90px;--skel-h:24px;border-radius:100px"></div>
                        <div class="fc-skel" style="--skel-w:90px;--skel-h:24px;border-radius:100px"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- KPI Skeleton -->
        <div class="fc-dpo-kpi-grid">
            @for (var i = 0; i < 5; i++)
            {
                <div class="fc-card" style="padding:20px">
                    <div class="fc-skel fc-skel-text" style="--skel-w:70px;--skel-h:11px"></div>
                    <div class="fc-skel fc-skel-text" style="--skel-w:60px;--skel-h:26px;margin-top:8px"></div>
                    <div class="fc-skel fc-skel-text" style="--skel-w:100px;--skel-h:10px;margin-top:6px"></div>
                </div>
            }
        </div>

        <!-- Chart Skeleton -->
        <div class="fc-dpo-chart-row" style="margin-top:20px">
            <div class="fc-card" style="padding:20px">
                <div class="fc-skel fc-skel-text" style="--skel-w:160px;--skel-h:13px"></div>
                <div class="fc-skel" style="--skel-w:100%;--skel-h:220px;margin-top:12px;border-radius:8px"></div>
            </div>
            <div class="fc-card" style="padding:20px">
                <div class="fc-skel fc-skel-text" style="--skel-w:160px;--skel-h:13px"></div>
                <div class="fc-skel" style="--skel-w:100%;--skel-h:220px;margin-top:12px;border-radius:8px"></div>
            </div>
        </div>

        <!-- Section Skeletons -->
        @for (var s = 0; s < 3; s++)
        {
            <div class="fc-card fc-card--mb" style="margin-top:20px;padding:20px">
                <div class="fc-skel fc-skel-text" style="--skel-w:180px;--skel-h:14px"></div>
                <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:16px">
                    @for (var c = 0; c < 3; c++)
                    {
                        <div class="fc-skel" style="--skel-w:100%;--skel-h:80px;border-radius:8px"></div>
                    }
                </div>
            </div>
        }
    }
    else if (_loadException is not null)
    {
        <SectionErrorBoundary Title="Failed to load privacy dashboard" ExternalError="@_loadException" OnRetry="LoadAsync" />
    }
    else if (_data is not null)
    {
        var dsarBacklog = _pipelineStages
            .Where(x => x.Status is not DataSubjectRequestStatus.Completed and not DataSubjectRequestStatus.Rejected)
            .Sum(x => x.Count);
        var imminentNotifications = _data.BreachCountdowns.Count(x => x.HoursRemaining <= 24);
        var pendingPias = _data.PrivacyImpactStatusByModule.Count(x => !string.Equals(x.Status, "Complete", StringComparison.OrdinalIgnoreCase));
        var leadActivity = _data.ActivityCountsByModule.OrderByDescending(x => x.ActivityCount).FirstOrDefault();
        var bannerTone = ResolvePrivacyBannerTone(_privacyScore, _data.OpenBreachCount, imminentNotifications);

        <div class="rg-premium-flow">
            <section class="rg-premium-banner rg-premium-banner--@bannerTone">
                <div class="rg-premium-banner__grid">
                    <div>
                        <span class="rg-premium-banner__eyebrow">Privacy pulse</span>
                        <h2 class="rg-premium-banner__headline">@BuildPrivacyBannerHeadline(_privacyScore, _data.OpenBreachCount, imminentNotifications)</h2>
                        <p class="rg-premium-banner__detail">@BuildPrivacyBannerDetail(dsarBacklog, pendingPias, leadActivity?.ModuleCode)</p>
                    </div>
                    <div class="rg-premium-banner__meta">
                        <span class="rg-premium-banner__meta-label">Current posture</span>
                        <strong class="rg-premium-banner__meta-value">@_privacyScore.ToString("0") / 100</strong>
                        <span class="rg-premium-banner__meta-copy">@_privacyRating rating · Updated @_data.GeneratedAt.ToString("dd MMM HH:mm") UTC</span>
                    </div>
                </div>
            </section>

            <section class="rg-premium-hero">
                <div class="rg-premium-hero__grid">
                    <div>
                        <span class="rg-premium-hero__eyebrow">DPO command narrative</span>
                        <h2 class="rg-premium-hero__title">Treat privacy operations as a live control system, not a yearly compliance checklist.</h2>
                        <p class="rg-premium-hero__subtitle">
                            This dashboard merges DSAR execution, consent posture, breach timeliness, retention pressure, and impact-assessment
                            coverage so the DPO can intervene before NDPA exposure becomes a supervisory problem.
                        </p>
                        <div class="rg-premium-badge-row">
                            <span class="rg-premium-chip rg-premium-chip--@(dsarBacklog > 0 ? "warning" : "success")">@dsarBacklog active DSAR item@(dsarBacklog == 1 ? "" : "s")</span>
                            <span class="rg-premium-chip rg-premium-chip--@(_data.OpenBreachCount > 0 ? "danger" : "success")">@_data.OpenBreachCount open breach@(_data.OpenBreachCount == 1 ? "" : "es")</span>
                            <span class="rg-premium-chip rg-premium-chip--@(pendingPias > 0 ? "warning" : "success")">@pendingPias PIA item@(pendingPias == 1 ? "" : "s") pending</span>
                        </div>
                    </div>
                    <aside class="rg-premium-hero__aside">
                        <div class="rg-premium-note">
                            <span class="rg-premium-note__label">Lead activity domain</span>
                            <strong class="rg-premium-note__value">@(leadActivity?.ModuleCode ?? "N/A")</strong>
                            <span class="rg-premium-note__copy">@(leadActivity is null ? "No processing activity count is currently available." : $"{leadActivity.ActivityCount} processing activit{(leadActivity.ActivityCount == 1 ? "y" : "ies")} mapped to the busiest module.")</span>
                        </div>
                        <div class="rg-premium-note">
                            <span class="rg-premium-note__label">Notification urgency</span>
                            <strong class="rg-premium-note__value">@imminentNotifications due in 24h</strong>
                            <span class="rg-premium-note__copy">Incidents nearing the NITDA notification window should be treated as active response work.</span>
                        </div>
                    </aside>
                </div>
            </section>

            <section class="rg-premium-stat-grid" aria-label="Privacy control metrics">
                <article class="rg-premium-stat">
                    <span class="rg-premium-stat__label">DSAR backlog</span>
                    <strong class="rg-premium-stat__value @(dsarBacklog > 0 ? "rg-premium-stat__value--warning" : "rg-premium-stat__value--success")">@dsarBacklog</strong>
                    <p class="rg-premium-stat__note">Requests still flowing through received, in-progress, or approval stages.</p>
                </article>
                <article class="rg-premium-stat">
                    <span class="rg-premium-stat__label">Imminent notifications</span>
                    <strong class="rg-premium-stat__value @(imminentNotifications > 0 ? "rg-premium-stat__value--danger" : "rg-premium-stat__value--success")">@imminentNotifications</strong>
                    <p class="rg-premium-stat__note">Incidents within twenty-four hours of the notification deadline.</p>
                </article>
                <article class="rg-premium-stat">
                    <span class="rg-premium-stat__label">Retention due</span>
                    <strong class="rg-premium-stat__value rg-premium-stat__value--info">@_data.RetentionDueThisMonth</strong>
                    <p class="rg-premium-stat__note">Records entering retention-review or disposal windows this month.</p>
                </article>
                <article class="rg-premium-stat">
                    <span class="rg-premium-stat__label">Pending PIAs</span>
                    <strong class="rg-premium-stat__value @(pendingPias > 0 ? "rg-premium-stat__value--warning" : "rg-premium-stat__value--success")">@pendingPias</strong>
                    <p class="rg-premium-stat__note">Module assessments not yet marked complete in the current register.</p>
                </article>
            </section>
        </div>

        @* ══════════════════════════════════════════════════════════
           §1  Privacy Compliance Score Banner
           ══════════════════════════════════════════════════════════ *@
        <div class="fc-card fc-card--mb fc-dpo-score-banner">
            <div class="fc-dpo-score-ring">
                <svg viewBox="0 0 120 120" class="fc-dpo-score-svg">
                    <circle cx="60" cy="60" r="52" fill="none" stroke="#e2e8f0" stroke-width="8" />
                    <circle cx="60" cy="60" r="52" fill="none"
                            stroke="@ScoreColor(_privacyScore)"
                            stroke-width="8" stroke-linecap="round"
                            stroke-dasharray="@ScoreArc(_privacyScore)"
                            transform="rotate(-90 60 60)"
                            class="fc-dpo-score-arc" />
                </svg>
                <div class="fc-dpo-score-inner">
                    <span class="fc-dpo-score-value">@_privacyScore.ToString("0")</span>
                    <span class="fc-dpo-score-unit">/100</span>
                </div>
            </div>
            <div class="fc-dpo-score-detail">
                <div class="fc-dpo-score-headline">
                    <span class="fc-badge @RatingBadge(_privacyScore)">@_privacyRating</span>
                    <span class="fc-dpo-score-label">Privacy Compliance Posture</span>
                </div>
                <div class="fc-dpo-score-breakdown">
                    @{
                        var dsarContrib = Math.Round(_data.DsarSlaWithinDeadlinePercent * 0.3m, 1);
                        var consentContrib = Math.Round(_data.ConsentRateCurrentPolicyPercent * 0.3m, 1);
                        var breachFactor = Math.Max(0m, 100m - _data.OpenBreachCount * 25m);
                        var breachContrib = Math.Round(breachFactor * 0.4m, 1);
                    }
                    <div class="fc-dpo-factor fc-dpo-factor--@(ThresholdKey(_data.DsarSlaWithinDeadlinePercent, 90, 70))">
                        <div class="fc-dpo-factor-header">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            <span class="fc-dpo-factor-name">DSAR SLA</span>
                            <span class="fc-dpo-factor-weight">30% weight</span>
                        </div>
                        <div class="fc-dpo-factor-bar">
                            <div class="fc-dpo-factor-bar-fill" style="width:@(dsarContrib > 0 ? (dsarContrib / 30m * 100m).ToString("0", System.Globalization.CultureInfo.InvariantCulture) : "0")%"></div>
                        </div>
                        <div class="fc-dpo-factor-value">
                            <span class="fc-dpo-factor-pts">@dsarContrib.ToString("0.#")</span><span class="fc-dpo-factor-max"> / 30 pts</span>
                            <span class="fc-dpo-factor-raw">(@_data.DsarSlaWithinDeadlinePercent.ToString("0.#")% on-time)</span>
                        </div>
                    </div>
                    <div class="fc-dpo-factor fc-dpo-factor--@(ThresholdKey(_data.ConsentRateCurrentPolicyPercent, 85, 60))">
                        <div class="fc-dpo-factor-header">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            <span class="fc-dpo-factor-name">Consent Rate</span>
                            <span class="fc-dpo-factor-weight">30% weight</span>
                        </div>
                        <div class="fc-dpo-factor-bar">
                            <div class="fc-dpo-factor-bar-fill" style="width:@(consentContrib > 0 ? (consentContrib / 30m * 100m).ToString("0", System.Globalization.CultureInfo.InvariantCulture) : "0")%"></div>
                        </div>
                        <div class="fc-dpo-factor-value">
                            <span class="fc-dpo-factor-pts">@consentContrib.ToString("0.#")</span><span class="fc-dpo-factor-max"> / 30 pts</span>
                            <span class="fc-dpo-factor-raw">(@_data.ConsentRateCurrentPolicyPercent.ToString("0.#")% consented)</span>
                        </div>
                    </div>
                    <div class="fc-dpo-factor fc-dpo-factor--@(_data.OpenBreachCount == 0 ? "green" : _data.OpenBreachCount <= 2 ? "amber" : "red")">
                        <div class="fc-dpo-factor-header">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                            <span class="fc-dpo-factor-name">Breach Factor</span>
                            <span class="fc-dpo-factor-weight">40% weight</span>
                        </div>
                        <div class="fc-dpo-factor-bar">
                            <div class="fc-dpo-factor-bar-fill" style="width:@(breachContrib > 0 ? (breachContrib / 40m * 100m).ToString("0", System.Globalization.CultureInfo.InvariantCulture) : "0")%"></div>
                        </div>
                        <div class="fc-dpo-factor-value">
                            <span class="fc-dpo-factor-pts">@breachContrib.ToString("0.#")</span><span class="fc-dpo-factor-max"> / 40 pts</span>
                            <span class="fc-dpo-factor-raw">(@_data.OpenBreachCount breach@(_data.OpenBreachCount != 1 ? "es" : "") — factor @breachFactor.ToString("0")%)</span>
                        </div>
                    </div>
                </div>
                <div class="fc-dpo-score-formula">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                    Score = DSAR SLA (@_data.DsarSlaWithinDeadlinePercent.ToString("0.#")% × 0.3) + Consent (@_data.ConsentRateCurrentPolicyPercent.ToString("0.#")% × 0.3) + Breach (@breachFactor.ToString("0")% × 0.4) = <strong>@_privacyScore.ToString("0")</strong>
                </div>
                <div class="fc-dpo-score-timestamp">
                    Updated @_data.GeneratedAt.ToString("dd MMM yyyy, HH:mm") UTC
                </div>
            </div>
        </div>

        @* ══════════════════════════════════════════════════════════
           §2  KPI Card Grid
           ══════════════════════════════════════════════════════════ *@
        <div class="fc-dpo-kpi-grid">
            @* DSAR SLA *@
            <div class="fc-card fc-dpo-kpi fc-dpo-kpi--@(ThresholdKey(_data.DsarSlaWithinDeadlinePercent, 90, 70))">
                <div class="fc-dpo-kpi-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <div class="fc-dpo-kpi-body">
                    <div class="fc-dpo-kpi-label">DSAR SLA</div>
                    <div class="fc-dpo-kpi-row">
                        <div class="fc-dpo-kpi-number">@_data.DsarSlaWithinDeadlinePercent.ToString("0.#")%</div>
                        <svg viewBox="0 0 36 36" class="fc-dpo-kpi-ring">
                            <circle cx="18" cy="18" r="15.9" fill="none" stroke="#e2e8f0" stroke-width="3" />
                            <circle cx="18" cy="18" r="15.9" fill="none"
                                    stroke="@ThresholdColor(_data.DsarSlaWithinDeadlinePercent, 90, 70)"
                                    stroke-width="3" stroke-linecap="round"
                                    stroke-dasharray="@RingDash(_data.DsarSlaWithinDeadlinePercent)"
                                    transform="rotate(-90 18 18)"
                                    class="fc-dpo-kpi-ring-arc" />
                        </svg>
                    </div>
                    <div class="fc-dpo-kpi-sub">within 30-day deadline</div>
                </div>
            </div>

            @* Consent Rate *@
            <div class="fc-card fc-dpo-kpi fc-dpo-kpi--@(ThresholdKey(_data.ConsentRateCurrentPolicyPercent, 85, 60))">
                <div class="fc-dpo-kpi-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <div class="fc-dpo-kpi-body">
                    <div class="fc-dpo-kpi-label">Consent Rate</div>
                    <div class="fc-dpo-kpi-row">
                        <div class="fc-dpo-kpi-number">@_data.ConsentRateCurrentPolicyPercent.ToString("0.#")%</div>
                        <svg viewBox="0 0 36 36" class="fc-dpo-kpi-ring">
                            <circle cx="18" cy="18" r="15.9" fill="none" stroke="#e2e8f0" stroke-width="3" />
                            <circle cx="18" cy="18" r="15.9" fill="none"
                                    stroke="@ThresholdColor(_data.ConsentRateCurrentPolicyPercent, 85, 60)"
                                    stroke-width="3" stroke-linecap="round"
                                    stroke-dasharray="@RingDash(_data.ConsentRateCurrentPolicyPercent)"
                                    transform="rotate(-90 18 18)"
                                    class="fc-dpo-kpi-ring-arc" />
                        </svg>
                    </div>
                    <div class="fc-dpo-kpi-sub">current policy version</div>
                </div>
            </div>

            @* Open Breaches *@
            <div class="fc-card fc-dpo-kpi fc-dpo-kpi--@(_data.OpenBreachCount == 0 ? "green" : _data.OpenBreachCount <= 2 ? "amber" : "red")">
                <div class="fc-dpo-kpi-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                </div>
                <div class="fc-dpo-kpi-body">
                    <div class="fc-dpo-kpi-label">Open Breaches</div>
                    <div class="fc-dpo-kpi-number"><AnimatedCounter Value="@_data.OpenBreachCount" /></div>
                    <div class="fc-dpo-kpi-sub">active incidents</div>
                </div>
            </div>

            @* Pending NITDA *@
            <div class="fc-card fc-dpo-kpi fc-dpo-kpi--@(_data.PendingNitdaNotifications == 0 ? "green" : "red")">
                <div class="fc-dpo-kpi-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 17H2a3 3 0 006 0h8a3 3 0 006 0z"/><path d="M5.45 5.11L2 12v6h20v-6l-3.45-6.89A2 2 0 0016.76 4H7.24a2 2 0 00-1.79 1.11z"/></svg>
                </div>
                <div class="fc-dpo-kpi-body">
                    <div class="fc-dpo-kpi-label">Pending NITDA</div>
                    <div class="fc-dpo-kpi-number"><AnimatedCounter Value="@_data.PendingNitdaNotifications" /></div>
                    <div class="fc-dpo-kpi-sub">awaiting notification</div>
                </div>
            </div>

            @* Retention Due *@
            <div class="fc-card fc-dpo-kpi fc-dpo-kpi--slate">
                <div class="fc-dpo-kpi-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </div>
                <div class="fc-dpo-kpi-body">
                    <div class="fc-dpo-kpi-label">Retention Due</div>
                    <div class="fc-dpo-kpi-number"><AnimatedCounter Value="@_data.RetentionDueThisMonth" /></div>
                    <div class="fc-dpo-kpi-sub">records this month</div>
                </div>
            </div>
        </div>

        @* ══════════════════════════════════════════════════════════
           §3  Charts Row
           ══════════════════════════════════════════════════════════ *@
        <div class="fc-dpo-chart-row">
            <div class="fc-card fc-dpo-chart-card">
                <div class="fc-card__header">
                    <h2 class="fc-card__title">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.21 15.89A10 10 0 118 2.83"/><path d="M22 12A10 10 0 0012 2v10z"/></svg>
                        DSAR Status Distribution
                    </h2>
                </div>
                <div class="fc-card__body">
                    <div class="fc-dpo-chart-canvas"><canvas id="dpo-dsar-donut"></canvas></div>
                </div>
            </div>
            <div class="fc-card fc-dpo-chart-card">
                <div class="fc-card__header">
                    <h2 class="fc-card__title">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                        Processing Activities by Module
                    </h2>
                </div>
                <div class="fc-card__body">
                    <div class="fc-dpo-chart-canvas"><canvas id="dpo-module-bar"></canvas></div>
                </div>
            </div>
        </div>

        @* ══════════════════════════════════════════════════════════
           §4  Breach Alert Board
           ══════════════════════════════════════════════════════════ *@
        <div class="fc-card fc-card--mb">
            <div class="fc-card__header">
                <h2 class="fc-card__title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
                    Breach Alert Board
                </h2>
                @if (_data.BreachCountdowns.Count > 0)
                {
                    <span class="fc-badge fc-badge--danger">@_data.BreachCountdowns.Count active</span>
                }
            </div>
            <div class="fc-card__body">
                @if (_data.BreachCountdowns.Count == 0)
                {
                    <div class="fc-dpo-breach-clear">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="1.5">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            <polyline points="9 12 11 14 15 10"/>
                        </svg>
                        <div class="fc-dpo-breach-clear-title">All Clear</div>
                        <div class="fc-dpo-breach-clear-desc">No active breach incidents requiring attention.</div>
                    </div>
                }
                else
                {
                    <div class="fc-dpo-breach-grid">
                        @foreach (var breach in _data.BreachCountdowns)
                        {
                            var urgency = BreachUrgency(breach.HoursRemaining);
                            var pct = Math.Max(0, Math.Min(100, (72.0 - breach.HoursRemaining) / 72.0 * 100.0));

                            <div class="fc-dpo-breach-card fc-dpo-breach-card--@SeverityKey(breach.Severity)">
                                <div class="fc-dpo-breach-top">
                                    <span class="fc-dpo-severity-pill fc-dpo-severity-pill--@SeverityKey(breach.Severity)">@breach.Severity</span>
                                    <span class="fc-dpo-breach-id">#@breach.IncidentId</span>
                                </div>
                                <div class="fc-dpo-breach-title">@breach.Title</div>
                                <div class="fc-dpo-breach-meta">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                    Detected @breach.DetectedAt.ToString("dd MMM, HH:mm")
                                </div>
                                <div class="fc-dpo-breach-countdown">
                                    <div class="fc-dpo-breach-countdown-label">NITDA 72h Countdown</div>
                                    <div class="fc-dpo-breach-bar">
                                        <div class="fc-dpo-breach-bar-fill fc-dpo-breach-bar-fill--@urgency"
                                             style="width:@(pct.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                                    </div>
                                    <div class="fc-dpo-breach-hours fc-dpo-breach-hours--@urgency">
                                        @if (breach.HoursRemaining <= 0)
                                        {
                                            <span>OVERDUE</span>
                                        }
                                        else
                                        {
                                            <span>@breach.HoursRemaining.ToString("0.0")h remaining</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        @* ══════════════════════════════════════════════════════════
           §5  DSAR Pipeline
           ══════════════════════════════════════════════════════════ *@
        <div class="fc-card fc-card--mb">
            <div class="fc-card__header">
                <h2 class="fc-card__title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                    DSAR Pipeline
                </h2>
            </div>
            <div class="fc-card__body">
                <div class="fc-dpo-pipeline">
                    @foreach (var stage in _pipelineStages)
                    {
                        @if (stage.Status != DataSubjectRequestStatus.Received)
                        {
                            <div class="fc-dpo-pipeline-arrow">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                            </div>
                        }
                        <div class="fc-dpo-pipeline-stage fc-dpo-pipeline-stage--@stage.Key">
                            <div class="fc-dpo-pipeline-count"><AnimatedCounter Value="@stage.Count" /></div>
                            <div class="fc-dpo-pipeline-label">@stage.Label</div>
                        </div>
                    }
                </div>

                @* Per-type breakdown *@
                @if (_dsarByType.Count > 0)
                {
                    <div class="fc-dpo-pipeline-types">
                        <h3 class="fc-dpo-pipeline-types-title">By Request Type</h3>
                        @foreach (var typeGroup in _dsarByType)
                        {
                            var total = typeGroup.Value.Values.Sum();
                            <div class="fc-dpo-pipeline-type-row">
                                <span class="fc-dpo-pipeline-type-label">@typeGroup.Key</span>
                                <div class="fc-dpo-pipeline-type-bar">
                                    @foreach (var seg in typeGroup.Value)
                                    {
                                        @if (seg.Value > 0)
                                        {
                                            var segPct = total > 0 ? (double)seg.Value / total * 100.0 : 0;
                                            <div class="fc-dpo-pipeline-seg fc-dpo-pipeline-seg--@StatusKey(seg.Key)"
                                                 style="width:@(segPct.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%"
                                                 title="@seg.Key: @seg.Value"></div>
                                        }
                                    }
                                </div>
                                <span class="fc-dpo-pipeline-type-total">@total</span>
                            </div>
                        }
                        <div class="fc-dpo-pipeline-legend">
                            <span class="fc-dpo-pipeline-legend-item"><span class="fc-dpo-legend-dot fc-dpo-legend-dot--received"></span> Received</span>
                            <span class="fc-dpo-pipeline-legend-item"><span class="fc-dpo-legend-dot fc-dpo-legend-dot--inprogress"></span> In Progress</span>
                            <span class="fc-dpo-pipeline-legend-item"><span class="fc-dpo-legend-dot fc-dpo-legend-dot--pending"></span> Pending</span>
                            <span class="fc-dpo-pipeline-legend-item"><span class="fc-dpo-legend-dot fc-dpo-legend-dot--completed"></span> Completed</span>
                            <span class="fc-dpo-pipeline-legend-item"><span class="fc-dpo-legend-dot fc-dpo-legend-dot--rejected"></span> Rejected</span>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* ══════════════════════════════════════════════════════════
           §6  PIA Status Grid
           ══════════════════════════════════════════════════════════ *@
        @if (_data.PrivacyImpactStatusByModule.Count > 0)
        {
            <div class="fc-card fc-card--mb">
                <div class="fc-card__header">
                    <h2 class="fc-card__title">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                        Privacy Impact Assessments
                    </h2>
                    <span class="fc-badge fc-badge--neutral">@_data.PrivacyImpactStatusByModule.Count modules</span>
                </div>
                <div class="fc-card__body">
                    <div class="fc-dpo-pia-grid">
                        @foreach (var pia in _data.PrivacyImpactStatusByModule)
                        {
                            var piaKey = PiaKey(pia.Status);
                            var piaPct = piaKey == "complete" ? 100 : piaKey == "inprogress" ? 50 : 0;

                            <div class="fc-dpo-pia-card">
                                <div class="fc-dpo-pia-header">
                                    <span class="fc-dpo-pia-dot fc-dpo-pia-dot--@piaKey"></span>
                                    <span class="fc-dpo-pia-module">@pia.ModuleCode</span>
                                </div>
                                <div class="fc-dpo-pia-body">
                                    <div class="fc-dpo-pia-count">@pia.ActivityCount <span class="fc-dpo-pia-count-label">activities</span></div>
                                    <span class="fc-dpo-pia-status fc-dpo-pia-status--@piaKey">@pia.Status</span>
                                </div>
                                <div class="fc-dpo-pia-bar">
                                    <div class="fc-dpo-pia-bar-fill fc-dpo-pia-bar-fill--@piaKey" style="width:@piaPct%"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private DpoDashboardData? _data;
    private bool _loading = true;
    private Exception? _loadException;
    private bool _chartsRendered;
    private decimal _privacyScore;
    private string _privacyRating = "";
    private string _ratingVariant = "neutral";

    // Pipeline aggregation
    private List<PipelineStage> _pipelineStages = new();
    private Dictionary<string, Dictionary<DataSubjectRequestStatus, int>> _dsarByType = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _loadException = null;
        StateHasChanged();

        try
        {
            _data = await PrivacyDashboardService.GetDashboard(TenantContext.CurrentTenantId);
            ComputePrivacyScore();
            BuildPipeline();
        }
        catch (Exception ex)
        {
            _loadException = ex;
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_data is null || _chartsRendered) return;

        try
        {
            // DSAR status doughnut
            var statusGroups = _data.DsarMetrics
                .GroupBy(m => m.Status)
                .Select(g => new { Status = g.Key, Count = g.Sum(x => x.Count) })
                .Where(g => g.Count > 0)
                .ToList();

            if (statusGroups.Count > 0)
            {
                var labels = statusGroups.Select(g => FormatStatus(g.Status)).ToArray();
                var values = statusGroups.Select(g => (decimal)g.Count).ToArray();
                var colors = statusGroups.Select(g => StatusColor(g.Status)).ToArray();
                await Charts.RenderDonutWithColors("dpo-dsar-donut", labels, values, colors);
            }

            // Module activities bar chart
            if (_data.ActivityCountsByModule.Count > 0)
            {
                await Charts.RenderBarChart("dpo-module-bar", new TrendData
                {
                    Title = "Activities by Module",
                    Labels = _data.ActivityCountsByModule.Select(a => a.ModuleCode).ToList(),
                    Datasets =
                    {
                        new TrendDataset
                        {
                            Label = "Processing Activities",
                            Data = _data.ActivityCountsByModule.Select(a => (decimal)a.ActivityCount).ToList(),
                            BackgroundColor = "#0f766e",
                            BorderColor = "#0f766e"
                        }
                    }
                });
            }

            _chartsRendered = true;
        }
        catch { /* Chart rendering is non-critical */ }
    }

    private void ComputePrivacyScore()
    {
        if (_data is null) return;
        var breachFactor = Math.Max(0m, 100m - _data.OpenBreachCount * 25m);
        _privacyScore = Math.Round(
            _data.DsarSlaWithinDeadlinePercent * 0.3m +
            _data.ConsentRateCurrentPolicyPercent * 0.3m +
            breachFactor * 0.4m, 1);
        _privacyRating = _privacyScore switch
        {
            >= 90m => "Excellent",
            >= 75m => "Good",
            >= 60m => "Fair",
            >= 40m => "Poor",
            _ => "Critical"
        };
        _ratingVariant = _privacyScore switch
        {
            >= 90m => "success",
            >= 75m => "success",
            >= 60m => "warning",
            >= 40m => "warning",
            _ => "danger"
        };
    }

    private void BuildPipeline()
    {
        if (_data is null) return;

        _pipelineStages = Enum.GetValues<DataSubjectRequestStatus>()
            .Select(s => new PipelineStage
            {
                Status = s,
                Key = StatusKey(s),
                Label = FormatStatus(s),
                Count = _data.DsarMetrics.Where(m => m.Status == s).Sum(m => m.Count)
            })
            .ToList();

        _dsarByType = new();
        foreach (var typeGroup in _data.DsarMetrics.GroupBy(m => m.RequestType))
        {
            var statusCounts = new Dictionary<DataSubjectRequestStatus, int>();
            foreach (var status in Enum.GetValues<DataSubjectRequestStatus>())
                statusCounts[status] = typeGroup.Where(m => m.Status == status).Sum(m => m.Count);
            _dsarByType[typeGroup.Key.ToString()] = statusCounts;
        }
    }

    // ── Helpers ──────────────────────────────────────────────
    private static string ScoreColor(decimal score) => score switch
    {
        >= 90m => "#10b981",
        >= 75m => "#0d9488",
        >= 60m => "#f59e0b",
        >= 40m => "#ea580c",
        _ => "#ef4444"
    };

    private static string ScoreArc(decimal score)
    {
        const double circumference = 326.73; // 2π × 52
        var filled = circumference * (double)Math.Min(score, 100m) / 100.0;
        return $"{filled.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)} {circumference.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}";
    }

    private static string RingDash(decimal pct)
    {
        const double circumference = 99.9; // 2π × 15.9
        var filled = circumference * (double)Math.Min(pct, 100m) / 100.0;
        return $"{filled.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)} {circumference.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}";
    }

    private static string RatingBadge(decimal score) => score switch
    {
        >= 75m => "fc-badge--success",
        >= 60m => "fc-badge--warning",
        _ => "fc-badge--danger"
    };

    private static string ThresholdKey(decimal val, decimal good, decimal fair)
        => val >= good ? "green" : val >= fair ? "amber" : "red";

    private static string ThresholdColor(decimal val, decimal good, decimal fair)
        => val >= good ? "#10b981" : val >= fair ? "#f59e0b" : "#ef4444";

    private static string BreachUrgency(double hoursRemaining) => hoursRemaining switch
    {
        <= 0 => "critical",
        < 12 => "critical",
        < 24 => "warning",
        _ => "safe"
    };

    private static string SeverityKey(DataBreachSeverity s) => s switch
    {
        DataBreachSeverity.CRITICAL => "critical",
        DataBreachSeverity.HIGH => "high",
        DataBreachSeverity.MEDIUM => "medium",
        _ => "low"
    };

    private static string StatusKey(DataSubjectRequestStatus s) => s switch
    {
        DataSubjectRequestStatus.Received => "received",
        DataSubjectRequestStatus.InProgress => "inprogress",
        DataSubjectRequestStatus.PendingApproval => "pending",
        DataSubjectRequestStatus.Completed => "completed",
        DataSubjectRequestStatus.Rejected => "rejected",
        _ => "received"
    };

    private static string FormatStatus(DataSubjectRequestStatus s) => s switch
    {
        DataSubjectRequestStatus.InProgress => "In Progress",
        DataSubjectRequestStatus.PendingApproval => "Pending Approval",
        _ => s.ToString()
    };

    private static string StatusColor(DataSubjectRequestStatus s) => s switch
    {
        DataSubjectRequestStatus.Received => "#64748b",
        DataSubjectRequestStatus.InProgress => "#2563eb",
        DataSubjectRequestStatus.PendingApproval => "#f59e0b",
        DataSubjectRequestStatus.Completed => "#10b981",
        DataSubjectRequestStatus.Rejected => "#ef4444",
        _ => "#94a3b8"
    };

    private static string PiaKey(string status) => status.ToLowerInvariant() switch
    {
        "complete" => "complete",
        "inprogress" => "inprogress",
        _ => "pending"
    };

    private sealed class PipelineStage
    {
        public DataSubjectRequestStatus Status { get; set; }
        public string Key { get; set; } = "";
        public string Label { get; set; } = "";
        public int Count { get; set; }
    }

    private static string ResolvePrivacyBannerTone(decimal privacyScore, int openBreaches, int imminentNotifications)
    {
        if (openBreaches > 0 || imminentNotifications > 0 || privacyScore < 60m) return "danger";
        if (privacyScore < 75m) return "warning";
        return "success";
    }

    private static string BuildPrivacyBannerHeadline(decimal privacyScore, int openBreaches, int imminentNotifications)
    {
        if (openBreaches > 0)
            return $"{openBreaches} open breach{(openBreaches == 1 ? "" : "es")} are shaping the current privacy control posture.";

        if (imminentNotifications > 0)
            return $"{imminentNotifications} incident{(imminentNotifications == 1 ? "" : "s")} are nearing the notification deadline.";

        if (privacyScore < 75m)
            return "Privacy posture is serviceable, but the operating margin is too thin for comfort.";

        return "Privacy controls are currently inside the preferred operating band.";
    }

    private static string BuildPrivacyBannerDetail(int dsarBacklog, int pendingPias, string? leadModuleCode)
    {
        var moduleLabel = string.IsNullOrWhiteSpace(leadModuleCode) ? "the current processing estate" : leadModuleCode;
        return $"{dsarBacklog} active DSAR item{(dsarBacklog == 1 ? "" : "s")} and {pendingPias} pending privacy assessment{(pendingPias == 1 ? "" : "s")} remain in flight, with {moduleLabel} currently carrying the heaviest processing footprint.";
    }
}
