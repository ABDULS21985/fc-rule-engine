@page "/privacy/dpo"
@attribute [Authorize(Policy = "AdminOnly")]
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Models
@inject IPrivacyDashboardService PrivacyDashboardService
@inject ITenantContext TenantContext

<PageTitle>DPO Dashboard</PageTitle>

<PageHeader Title="DPO Dashboard"
            Subtitle="NDPR/NDPA privacy compliance posture and data subject request tracking." />

@if (_loading)
{
    <div class="fc-dash17-loading">Loading privacy dashboard...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="fc-dash17-error">@_error</div>
}
else if (_data is not null)
{
    <div class="fc-dash17-platform">
        <section class="fc-dash17-kpi-grid">
            <article class="fc-dash17-kpi-card">
                <h3>DSAR SLA</h3>
                <div class="fc-dash17-kpi-value">@_data.DsarSlaWithinDeadlinePercent.ToString("0.##")%</div>
                <p>Completed within 30-day deadline</p>
            </article>
            <article class="fc-dash17-kpi-card">
                <h3>Current Consent Rate</h3>
                <div class="fc-dash17-kpi-value">@_data.ConsentRateCurrentPolicyPercent.ToString("0.##")%</div>
                <p>Users with current policy consent</p>
            </article>
            <article class="fc-dash17-kpi-card">
                <h3>Open Breaches</h3>
                <div class="fc-dash17-kpi-value">@_data.OpenBreachCount</div>
                <p>@_data.PendingNitdaNotifications pending NITDA notification</p>
            </article>
            <article class="fc-dash17-kpi-card">
                <h3>Retention Due</h3>
                <div class="fc-dash17-kpi-value">@_data.RetentionDueThisMonth</div>
                <p>Records due for anonymisation</p>
            </article>
        </section>

        <section class="fc-dash17-table-wrap">
            <h3>DSAR Workload</h3>
            <table class="fc-dash17-table" aria-label="DSAR workload">
                <thead>
                    <tr>
                        <th>Request Type</th>
                        <th>Status</th>
                        <th>Count</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _data.DsarMetrics)
                    {
                        <tr>
                            <td>@row.RequestType</td>
                            <td>@row.Status</td>
                            <td>@row.Count</td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>

        <section class="fc-dash17-table-wrap">
            <h3>Breach Countdown (72-hour Rule)</h3>
            <table class="fc-dash17-table" aria-label="Breach countdowns">
                <thead>
                    <tr>
                        <th>Incident</th>
                        <th>Severity</th>
                        <th>Detected</th>
                        <th>Hours Remaining</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _data.BreachCountdowns)
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td>@item.Severity</td>
                            <td>@item.DetectedAt.ToString("dd MMM yyyy HH:mm")</td>
                            <td>@item.HoursRemaining.ToString("0.0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>

        <section class="fc-dash17-table-wrap">
            <h3>Data Processing Register</h3>
            <table class="fc-dash17-table" aria-label="Processing activity counts">
                <thead>
                    <tr>
                        <th>Module</th>
                        <th>Activities</th>
                        <th>PIA Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var module in _data.ActivityCountsByModule)
                    {
                        var pia = _data.PrivacyImpactStatusByModule.FirstOrDefault(x => x.ModuleCode == module.ModuleCode);
                        <tr>
                            <td>@module.ModuleCode</td>
                            <td>@module.ActivityCount</td>
                            <td>@(pia?.Status ?? "Pending")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    </div>
}

@code {
    private DpoDashboardData? _data;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _data = await PrivacyDashboardService.GetDashboard(TenantContext.CurrentTenantId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
