@page "/cross-sheet-rules"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Enums
@using FC.Engine.Domain.Validation
@using FC.Engine.Application.Services
@inject IFormulaRepository FormulaRepo
@inject FormulaService FormulaService
@inject ITemplateMetadataCache Cache
@inject ToastService Toast

<div class="fc-list-page">
    <div class="fc-list-page-header">
        <div class="fc-list-page-header-text">
            <h1>
                Cross-Sheet Validation Rules
                @if (!_loading)
                {
                    <span class="fc-list-count-chip">@_rules.Count</span>
                }
            </h1>
            <p>Rules that validate relationships between different return templates</p>
        </div>
    </div>

    <div class="fc-list-card">
        <div class="fc-list-toolbar">
            <div class="fc-list-toolbar-filters">
                <div class="fc-list-search-wrap">
                    <svg class="fc-list-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    <input class="fc-list-search-input" placeholder="Search by rule code, name, or description..." @bind="_search" @bind:event="oninput" />
                </div>
                <select class="fc-list-filter-select" @bind="_severityFilter">
                    <option value="">All Severities</option>
                    @foreach (var s in Enum.GetValues<ValidationSeverity>())
                    {
                        <option value="@s">@s</option>
                    }
                </select>
                <select class="fc-list-filter-select" @bind="_statusFilter">
                    <option value="">All Statuses</option>
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                </select>
            </div>
            <div class="fc-list-toolbar-actions">
                <AuthorizeView Roles="Admin">
                    <Authorized Context="addAuth">
                        <button class="fc-btn fc-btn--gold" @onclick="ShowAddRule">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                            New Cross-Sheet Rule
                        </button>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>

        @if (_showAddForm)
        {
            <div class="fc-list-inline-form">
                <h3>Add Cross-Sheet Rule</h3>
                <div class="grid-2">
                    <div class="form-group">
                        <label>Rule Code</label>
                        <input class="form-control" @bind="_addCode" placeholder="e.g. XS-100" />
                    </div>
                    <div class="form-group">
                        <label>Rule Name</label>
                        <input class="form-control" @bind="_addName" placeholder="e.g. Loan Reconciliation" />
                    </div>
                    <div class="form-group" style="grid-column:1/-1;">
                        <label>Description</label>
                        <input class="form-control" @bind="_addDescription" placeholder="Description of the validation rule" />
                    </div>
                </div>

                <h4 style="margin-top:var(--space-4);font-size:var(--text-h4);font-weight:var(--font-weight-semibold);color:var(--cbn-text);">Operands</h4>
                @for (int i = 0; i < _addOperands.Count; i++)
                {
                    var idx = i;
                    <div class="grid-2" style="margin-bottom:var(--space-2);padding:var(--space-3);background:var(--cbn-surface-elevated);border:1px solid var(--cbn-border);border-radius:var(--radius-sm);">
                        <div class="form-group">
                            <label>Alias</label>
                            <input class="form-control" @bind="_addOperands[idx].Alias" placeholder="A, B, C..." />
                        </div>
                        <div class="form-group">
                            <label>Template Return Code</label>
                            <input class="form-control" @bind="_addOperands[idx].ReturnCode" placeholder="e.g. MFCR 300" />
                        </div>
                        <div class="form-group">
                            <label>Field Name</label>
                            <input class="form-control" @bind="_addOperands[idx].FieldName" placeholder="e.g. total_assets" />
                        </div>
                        <div class="form-group">
                            <label>Aggregate (optional)</label>
                            <select class="form-control" @bind="_addOperands[idx].Aggregate">
                                <option value="">None</option>
                                <option value="SUM">SUM</option>
                                <option value="COUNT">COUNT</option>
                                <option value="MAX">MAX</option>
                                <option value="MIN">MIN</option>
                                <option value="AVG">AVG</option>
                            </select>
                        </div>
                    </div>
                }
                <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="AddOperandRow" style="margin-top:var(--space-2);">+ Add Operand</button>

                <h4 style="margin-top:var(--space-4);font-size:var(--text-h4);font-weight:var(--font-weight-semibold);color:var(--cbn-text);">Expression</h4>
                <div class="grid-2">
                    <div class="form-group">
                        <label>Expression</label>
                        <input class="form-control" @bind="_addExpression" placeholder="e.g. A = B + C" />
                    </div>
                    <div class="form-group">
                        <label>Tolerance</label>
                        <input type="number" step="0.01" class="form-control" @bind="_addTolerance" />
                    </div>
                    <div class="form-group">
                        <label>Severity</label>
                        <select class="form-control" @bind="_addSeverity">
                            @foreach (var s in Enum.GetValues<ValidationSeverity>())
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Error Message</label>
                        <input class="form-control" @bind="_addErrorMessage" placeholder="e.g. Balance sheet does not balance" />
                    </div>
                </div>
                <div class="fc-list-form-actions">
                    <button class="fc-btn fc-btn--primary fc-btn--sm" @onclick="AddRule">Create Rule</button>
                    <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="CancelAdd">Cancel</button>
                </div>
            </div>
        }

        @if (_loading)
        {
            <div class="fc-list-skeleton">
                @for (var i = 0; i < 5; i++)
                {
                    <div class="fc-list-skeleton-row">
                        <div class="fc-list-skeleton-cell" style="width:80px;"></div>
                        <div class="fc-list-skeleton-cell" style="flex:1;"></div>
                        <div class="fc-list-skeleton-cell" style="width:200px;"></div>
                        <div class="fc-list-skeleton-cell" style="width:120px;"></div>
                        <div class="fc-list-skeleton-cell" style="width:60px;"></div>
                    </div>
                }
            </div>
        }
        else if (!FilteredRules.Any())
        {
            <div class="fc-list-empty">
                <svg class="fc-list-empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8Z"/><path d="M15 3v4a2 2 0 0 0 2 2h4"/></svg>
                <h3 class="fc-list-empty-title">No cross-sheet rules found</h3>
                <p class="fc-list-empty-text">No rules match your current filters. Try adjusting your search or create a new cross-sheet validation rule.</p>
            </div>
        }
        else
        {
            <div class="fc-table-wrap">
                <table class="fc-table" role="table">
                    <thead>
                        <tr>
                            <th scope="col">Rule Code</th>
                            <th scope="col">Name</th>
                            <th scope="col">Description</th>
                            <th scope="col">Operands</th>
                            <th scope="col">Expression</th>
                            <th scope="col">Severity</th>
                            <th scope="col">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rule in FilteredRules)
                        {
                            <tr>
                                <td class="fc-list-cell-code">
                                    <a class="fc-list-cell-link" href="/cross-sheet-rules/@rule.Id">@rule.RuleCode</a>
                                </td>
                                <td class="fc-list-cell-strong">
                                    <a class="fc-list-cell-link" style="color:inherit;font-weight:inherit;" href="/cross-sheet-rules/@rule.Id">@rule.RuleName</a>
                                </td>
                                <td class="fc-list-cell-truncate fc-list-cell-muted" title="@rule.Description">@(rule.Description ?? "—")</td>
                                <td>
                                    @foreach (var op in rule.Operands)
                                    {
                                        <div style="font-size:var(--text-body-sm);margin-bottom:2px;">
                                            <span class="fc-list-cell-code">@op.OperandAlias</span>
                                            <span class="fc-list-cell-muted"> = @op.TemplateReturnCode.@op.FieldName</span>
                                            @if (!string.IsNullOrEmpty(op.AggregateFunction))
                                            {
                                                <span class="fc-badge fc-badge--info" style="font-size:10px;padding:1px 6px;margin-left:4px;">@op.AggregateFunction</span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td class="fc-list-cell-code">@rule.Expression?.Expression</td>
                                <td>
                                    <span class="fc-badge @StatusBadge(rule.Severity.ToString())">@rule.Severity</span>
                                </td>
                                <td>
                                    @if (rule.IsActive)
                                    {
                                        <span class="fc-badge fc-badge--success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="fc-badge fc-badge--muted">Inactive</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="fc-list-footer">
                <div class="fc-list-footer-summary">
                    Showing <strong>@FilteredRules.Count()</strong> of <strong>@_rules.Count</strong> cross-sheet rules
                    &mdash; <strong>@_rules.Count(r => r.IsActive)</strong> active
                </div>
            </div>
        }
    </div>
</div>

@code {
    private bool _loading = true;
    private IReadOnlyList<CrossSheetRule> _rules = Array.Empty<CrossSheetRule>();
    private string _search = "", _severityFilter = "", _statusFilter = "";

    // Add form
    private bool _showAddForm;
    private string _addCode = "", _addName = "", _addDescription = "";
    private string _addExpression = "", _addErrorMessage = "";
    private decimal _addTolerance = 0.01m;
    private ValidationSeverity _addSeverity = ValidationSeverity.Error;
    private List<OperandModel> _addOperands = new();

    private IEnumerable<CrossSheetRule> FilteredRules => _rules
        .Where(r => string.IsNullOrEmpty(_search) ||
                    r.RuleCode.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                    r.RuleName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                    (r.Description?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(r => string.IsNullOrEmpty(_severityFilter) || r.Severity.ToString() == _severityFilter)
        .Where(r => string.IsNullOrEmpty(_statusFilter) ||
                    (_statusFilter == "Active" && r.IsActive) ||
                    (_statusFilter == "Inactive" && !r.IsActive));

    protected override async Task OnInitializedAsync()
    {
        _rules = await FormulaRepo.GetAllActiveCrossSheetRules();
        _loading = false;
    }

    private void ShowAddRule()
    {
        _showAddForm = true;
        _addOperands = new List<OperandModel>
        {
            new() { Alias = "A" },
            new() { Alias = "B" }
        };
    }

    private void CancelAdd() => _showAddForm = false;

    private void AddOperandRow()
    {
        var nextAlias = ((char)('A' + _addOperands.Count)).ToString();
        _addOperands.Add(new OperandModel { Alias = nextAlias });
    }

    private async Task AddRule()
    {
        try
        {
            var operands = _addOperands.Select((o, i) => new CrossSheetRuleOperand
            {
                OperandAlias = o.Alias,
                TemplateReturnCode = o.ReturnCode,
                FieldName = o.FieldName,
                AggregateFunction = string.IsNullOrEmpty(o.Aggregate) ? null : o.Aggregate,
                SortOrder = i + 1
            }).ToList();

            var expression = new CrossSheetRuleExpression
            {
                Expression = _addExpression,
                ToleranceAmount = _addTolerance,
                ErrorMessage = _addErrorMessage
            };

            await FormulaService.AddCrossSheetRule(
                _addCode, _addName, _addDescription,
                operands, expression, _addSeverity, "system");

            Toast.Success($"Rule '{_addCode}' created successfully.", "Rule Created");
            _showAddForm = false;
            _rules = await FormulaRepo.GetAllActiveCrossSheetRules();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message, "Create Failed");
        }
    }

    private static string StatusBadge(string status) => status.ToLowerInvariant() switch
    {
        "published" or "active" or "accepted" => "fc-badge--success",
        "draft" or "pending" => "fc-badge--warning",
        "review" or "inreview" => "fc-badge--review",
        "deprecated" or "retired" or "disabled" or "archived" => "fc-badge--muted",
        "rejected" or "failed" or "error" => "fc-badge--danger",
        "processing" or "validating" or "parsing" => "fc-badge--info",
        "acceptedwithwarnings" or "warnings" or "warning" => "fc-badge--warning",
        _ => "fc-badge--neutral"
    };

    private class OperandModel
    {
        public string Alias { get; set; } = "";
        public string ReturnCode { get; set; } = "";
        public string FieldName { get; set; } = "";
        public string Aggregate { get; set; } = "";
    }
}
