@page "/not-found"
@layout FC.Engine.Admin.Components.Layout.MainLayout
@inject NavigationManager Navigation
@inject CommandPaletteService PaletteService

<PageTitle>404 — Page Not Found | RegOS</PageTitle>

<div class="fc-error-page">

    @* ── Code badge ──────────────────────────────────── *@
    <div class="fc-error-page__code" aria-hidden="true">404</div>

    @* ── Compass illustration ────────────────────────── *@
    <div class="fc-error-page__illu" aria-hidden="true">
        <svg viewBox="0 0 140 140" fill="none" stroke="currentColor" stroke-width="3"
             stroke-linecap="round" stroke-linejoin="round" width="140" height="140">
            <!-- Outer compass circle -->
            <circle cx="70" cy="70" r="56"/>
            <!-- Inner ring -->
            <circle cx="70" cy="70" r="8" fill="currentColor" opacity="0.15" stroke="none"/>
            <circle cx="70" cy="70" r="8"/>
            <!-- North needle (gold) -->
            <polygon points="70,22 64,70 76,70" fill="var(--cbn-accent,#C8A415)" stroke="var(--cbn-accent,#C8A415)" stroke-width="1.5"/>
            <!-- South needle -->
            <polygon points="70,118 76,70 64,70" fill="currentColor" opacity="0.25" stroke="currentColor" stroke-width="1.5"/>
            <!-- Cardinal ticks -->
            <line x1="70" y1="14" x2="70" y2="22"/>
            <line x1="70" y1="118" x2="70" y2="126"/>
            <line x1="14" y1="70" x2="22" y2="70"/>
            <line x1="118" y1="70" x2="126" y2="70"/>
            <!-- Cardinal labels (N E S W as small lines) -->
            <text x="67" y="12" font-size="10" font-weight="700" fill="currentColor" stroke="none" font-family="sans-serif">N</text>
            <text x="128" y="73" font-size="10" font-weight="700" fill="currentColor" stroke="none" font-family="sans-serif">E</text>
            <text x="67" y="135" font-size="10" font-weight="700" fill="currentColor" stroke="none" font-family="sans-serif">S</text>
            <text x="4"  y="73" font-size="10" font-weight="700" fill="currentColor" stroke="none" font-family="sans-serif">W</text>
        </svg>
    </div>

    @* ── Heading ─────────────────────────────────────── *@
    <h1 class="fc-error-page__heading">Page not found</h1>
    <p class="fc-error-page__desc">
        The page you're looking for doesn't exist or may have moved.
        Try one of these instead, or search for what you need.
    </p>

    @* ── Search trigger ──────────────────────────────── *@
    <button class="fc-error-page__search-trigger" @onclick="PaletteService.Open"
            aria-label="Open search">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true">
            <circle cx="7" cy="7" r="5"/>
            <line x1="12" y1="12" x2="15" y2="15"/>
        </svg>
        Search for a page…
        <kbd>⌘K</kbd>
    </button>

    @* ── Quick links ─────────────────────────────────── *@
    <div class="fc-error-page__quick-links">
        <a href="/" class="fc-error-page__quick-link">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"
                 stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                <path d="M3 9l7-7 7 7v9a1 1 0 01-1 1H4a1 1 0 01-1-1z"/>
                <polyline points="7,19 7,13 13,13 13,19"/>
            </svg>
            Dashboard
        </a>
        <a href="/templates" class="fc-error-page__quick-link">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"
                 stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                <path d="M4 4h7l5 5v9a1 1 0 01-1 1H4a1 1 0 01-1-1V5a1 1 0 011-1z"/>
                <polyline points="11,4 11,9 16,9"/>
            </svg>
            Templates
        </a>
        <a href="/submissions" class="fc-error-page__quick-link">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"
                 stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                <polyline points="2,15 5,18 10,10 15,13 18,7"/>
                <rect x="2" y="2" width="16" height="16" rx="2"/>
            </svg>
            Submissions
        </a>
        <a href="/users" class="fc-error-page__quick-link">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"
                 stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                <circle cx="8" cy="7" r="4"/>
                <path d="M2 18a6 6 0 0112 0"/>
                <line x1="16" y1="11" x2="16" y2="17"/>
                <line x1="13" y1="14" x2="19" y2="14"/>
            </svg>
            Users
        </a>
    </div>

    @* ── Back link ───────────────────────────────────── *@
    <button class="fc-btn fc-btn--ghost" @onclick="GoBack">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true">
            <polyline points="10,3 5,8 10,13"/>
        </svg>
        Go back
    </button>

</div>

@code {
    private void GoBack() => Navigation.NavigateTo("/");
}
