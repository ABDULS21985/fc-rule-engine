@page "/"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Entities
@using FC.Engine.Domain.Enums
@inject ITemplateMetadataCache Cache
@inject ISubmissionRepository SubmissionRepo
@inject ITemplateRepository TemplateRepo
@inject IFormulaRepository FormulaRepo
@inject NavigationManager Nav

<!-- Executive Page Header -->
<header class="fc-dash-header" role="banner">
    <div class="fc-dash-header-text">
        <h1>Executive Dashboard</h1>
        <p>Financial Returns Collection &amp; Analysis System — Operational Overview</p>
    </div>
    <div class="fc-dash-header-meta">
        <time class="fc-dash-header-date" datetime="@DateTime.UtcNow.ToString("yyyy-MM-dd")">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            @DateTime.UtcNow.ToString("dddd, d MMMM yyyy")
        </time>
        <div class="fc-dash-header-status" aria-label="System status: operational">
            <span class="fc-dash-status-dot" aria-hidden="true"></span>
            System Operational
        </div>
    </div>
</header>

@if (_loading)
{
    <div class="fc-skel-dashboard" role="status" aria-label="Loading dashboard">
        <div class="fc-skel-stats-row">
            @for (var i = 0; i < 4; i++)
            {
                <div class="fc-skel-stat-card">
                    <div class="skel fc-skel-icon" style="width:44px;height:44px;border-radius:var(--radius-md);"></div>
                    <div class="skel fc-skel-number" style="width:60px;height:28px;"></div>
                    <div class="skel fc-skel-label" style="width:100px;height:12px;"></div>
                </div>
            }
        </div>
        <div class="fc-skel-content-grid">
            <div class="fc-skel-card">
                <div class="fc-skel-card-header">
                    <div class="skel fc-skel-card-title" style="width:140px;height:18px;"></div>
                    <div class="skel" style="width:60px;height:14px;"></div>
                </div>
                @for (var i = 0; i < 5; i++)
                {
                    <div class="fc-skel-table-row">
                        <div class="skel" style="width:70px;height:12px;"></div>
                        <div class="skel" style="flex:1;height:12px;"></div>
                        <div class="skel" style="width:60px;height:12px;"></div>
                        <div class="skel" style="width:50px;height:12px;"></div>
                    </div>
                }
            </div>
            <div class="fc-skel-card">
                <div class="fc-skel-card-header">
                    <div class="skel fc-skel-card-title" style="width:130px;height:18px;"></div>
                    <div class="skel" style="width:60px;height:14px;"></div>
                </div>
                @for (var i = 0; i < 3; i++)
                {
                    <div style="margin-bottom:var(--space-4);">
                        <div class="skel" style="width:80px;height:10px;margin-bottom:var(--space-2);"></div>
                        <div class="skel fc-skel-block" style="width:100%;height:8px;"></div>
                    </div>
                }
            </div>
        </div>
    </div>
}
else
{
    <!-- Stat Cards Row -->
    <div class="fc-dash-stats-row" role="region" aria-label="Key metrics">
        <!-- Card 1: Active Templates -->
        <div class="fc-dash-stat-card fc-dash-stat-green" style="animation-delay: 0ms;">
            <div class="fc-dash-stat-accent"></div>
            <div class="fc-dash-stat-body">
                <div class="fc-dash-stat-icon-wrap fc-dash-icon-green">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <polyline points="10 9 9 9 8 9"/>
                    </svg>
                </div>
                <div class="fc-dash-stat-data">
                    <span class="fc-dash-stat-number">@_templateCount</span>
                    <span class="fc-dash-stat-label">Active Templates</span>
                </div>
                <div class="fc-dash-stat-change fc-dash-change-neutral">
                    <span>@_totalFields fields configured</span>
                </div>
            </div>
        </div>

        <!-- Card 2: Pending Review -->
        <div class="fc-dash-stat-card fc-dash-stat-gold" style="animation-delay: 80ms;">
            <div class="fc-dash-stat-accent"></div>
            <div class="fc-dash-stat-body">
                <div class="fc-dash-stat-icon-wrap fc-dash-icon-gold">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                </div>
                <div class="fc-dash-stat-data">
                    <span class="fc-dash-stat-number">@(_pendingReviewCount + _draftCount)</span>
                    <span class="fc-dash-stat-label">Awaiting Action</span>
                </div>
                <div class="fc-dash-stat-change fc-dash-change-neutral">
                    @if (_pendingReviewCount > 0 || _draftCount > 0)
                    {
                        <span>@_pendingReviewCount in review, @_draftCount drafts</span>
                    }
                    else
                    {
                        <span>all versions published</span>
                    }
                </div>
            </div>
        </div>

        <!-- Card 3: Validation Rules -->
        <div class="fc-dash-stat-card fc-dash-stat-blue" style="animation-delay: 160ms;">
            <div class="fc-dash-stat-accent"></div>
            <div class="fc-dash-stat-body">
                <div class="fc-dash-stat-icon-wrap fc-dash-icon-blue">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                </div>
                <div class="fc-dash-stat-data">
                    <span class="fc-dash-stat-number">@_totalRules</span>
                    <span class="fc-dash-stat-label">Validation Rules</span>
                </div>
                <div class="fc-dash-stat-change fc-dash-change-neutral">
                    <span>@_totalFormulas intra-sheet, @_crossSheetRuleCount cross-sheet, @_businessRuleCount business</span>
                </div>
            </div>
        </div>

        <!-- Card 4: Total Submissions -->
        <div class="fc-dash-stat-card fc-dash-stat-green" style="animation-delay: 240ms;">
            <div class="fc-dash-stat-accent"></div>
            <div class="fc-dash-stat-body">
                <div class="fc-dash-stat-icon-wrap fc-dash-icon-green">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
                        <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
                        <path d="M5.45 5.11L2 12v6a2 2 0 002 2h16a2 2 0 002-2v-6l-3.45-6.89A2 2 0 0016.76 4H7.24a2 2 0 00-1.79 1.11z"/>
                    </svg>
                </div>
                <div class="fc-dash-stat-data">
                    <span class="fc-dash-stat-number">@_totalSubmissions</span>
                    <span class="fc-dash-stat-label">Total Submissions</span>
                </div>
                <div class="fc-dash-stat-change @(_acceptanceRate > 0 ? "fc-dash-change-up" : "fc-dash-change-neutral")">
                    @if (_totalSubmissions > 0)
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true">
                            <polyline points="22 4 12 14.01 9 11.01"/>
                        </svg>
                        <span>@_acceptanceRate% acceptance rate</span>
                    }
                    else
                    {
                        <span>no submissions yet</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Two-Column Content Grid -->
    <div class="fc-dash-content-grid">
        <!-- Left: Recent Submissions -->
        <div class="fc-card" style="animation-delay: 320ms;">
            <div class="fc-card__header">
                <h2>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                        <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
                        <path d="M5.45 5.11L2 12v6a2 2 0 002 2h16a2 2 0 002-2v-6l-3.45-6.89A2 2 0 0016.76 4H7.24a2 2 0 00-1.79 1.11z"/>
                    </svg>
                    Recent Submissions
                </h2>
                <a href="/submissions" class="fc-card__link">View all</a>
            </div>
            <div class="fc-card__body">
                @if (_recentSubmissions.Count == 0)
                {
                    <div class="fc-dash-empty-state">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40" style="color: var(--cbn-gray-300);" aria-hidden="true">
                            <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
                            <path d="M5.45 5.11L2 12v6a2 2 0 002 2h16a2 2 0 002-2v-6l-3.45-6.89A2 2 0 0016.76 4H7.24a2 2 0 00-1.79 1.11z"/>
                        </svg>
                        <p>No submissions recorded yet</p>
                    </div>
                }
                else
                {
                    <table class="fc-dash-mini-table" aria-label="Recent submissions">
                        <thead>
                            <tr>
                                <th scope="col">Return Code</th>
                                <th scope="col">Institution</th>
                                <th scope="col">Status</th>
                                <th scope="col">Submitted</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sub in _recentSubmissions)
                            {
                                <tr @onclick="() => NavigateToSubmission(sub.Id)" class="fc-dash-row-clickable" tabindex="0" role="link" @onkeydown="(e) => HandleRowKey(e, sub.Id)">
                                    <td class="fc-dash-cell-code">@sub.ReturnCode</td>
                                    <td>@(sub.Institution?.InstitutionName ?? "\u2014")</td>
                                    <td>
                                        <span class="fc-dash-status-badge fc-dash-status-@sub.Status.ToString().ToLowerInvariant()">
                                            @FormatStatus(sub.Status)
                                        </span>
                                    </td>
                                    <td class="fc-dash-cell-time">@FormatTimeAgo(sub.SubmittedAt)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <!-- Right: Template Health -->
        <div class="fc-card" style="animation-delay: 400ms;">
            <div class="fc-card__header">
                <h2>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                        <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                        <polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                    Template Health
                </h2>
                <a href="/templates" class="fc-card__link">Manage</a>
            </div>
            <div class="fc-card__body">
                <!-- Structural Category Breakdown -->
                <div class="fc-dash-health-section" role="group" aria-label="Templates by structure">
                    <div class="fc-dash-health-label">By Structure</div>
                    @foreach (var (cat, count) in _categoryBreakdown)
                    {
                        var pct = _templateCount > 0 ? (double)count / _templateCount * 100 : 0;
                        <div class="fc-dash-progress-row">
                            <div class="fc-dash-progress-info">
                                <span class="fc-dash-progress-name">@cat</span>
                                <span class="fc-dash-progress-count">@count</span>
                            </div>
                            <div class="fc-dash-progress-track" role="progressbar" aria-valuenow="@pct.ToString("F0")" aria-valuemin="0" aria-valuemax="100" aria-label="@cat: @count templates">
                                <div class="fc-dash-progress-fill fc-dash-fill-@cat.ToLowerInvariant()" style="width: @pct.ToString("F0")%"></div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Frequency Breakdown -->
                <div class="fc-dash-health-section" role="group" aria-label="Templates by frequency">
                    <div class="fc-dash-health-label">By Frequency</div>
                    @foreach (var (freq, count) in _frequencyBreakdown)
                    {
                        var pct = _templateCount > 0 ? (double)count / _templateCount * 100 : 0;
                        <div class="fc-dash-progress-row">
                            <div class="fc-dash-progress-info">
                                <span class="fc-dash-progress-name">@freq</span>
                                <span class="fc-dash-progress-count">@count</span>
                            </div>
                            <div class="fc-dash-progress-track" role="progressbar" aria-valuenow="@pct.ToString("F0")" aria-valuemin="0" aria-valuemax="100" aria-label="@freq: @count templates">
                                <div class="fc-dash-progress-fill fc-dash-fill-freq" style="width: @pct.ToString("F0")%"></div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Version Status Summary -->
                <div class="fc-dash-health-section" role="group" aria-label="Template version status">
                    <div class="fc-dash-health-label">Version Status</div>
                    <div class="fc-dash-version-chips">
                        <div class="fc-dash-chip fc-dash-chip-published">
                            <span class="fc-dash-chip-dot" aria-hidden="true"></span>
                            <span>@_publishedVersionCount Published</span>
                        </div>
                        <div class="fc-dash-chip fc-dash-chip-review">
                            <span class="fc-dash-chip-dot" aria-hidden="true"></span>
                            <span>@_pendingReviewCount In Review</span>
                        </div>
                        <div class="fc-dash-chip fc-dash-chip-draft">
                            <span class="fc-dash-chip-dot" aria-hidden="true"></span>
                            <span>@_draftCount Drafts</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="fc-card fc-card--actions" style="animation-delay: 480ms;" role="region" aria-label="Quick actions">
        <div class="fc-card__header">
            <h2>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
                Quick Actions
            </h2>
        </div>
        <div class="fc-dash-actions-grid">
            <a href="/templates" class="fc-btn fc-btn--action-card">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="12" y1="18" x2="12" y2="12"/>
                    <line x1="9" y1="15" x2="15" y2="15"/>
                </svg>
                <span>New Template</span>
            </a>
            <a href="/submissions" class="fc-btn fc-btn--action-card">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
                    <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
                    <path d="M5.45 5.11L2 12v6a2 2 0 002 2h16a2 2 0 002-2v-6l-3.45-6.89A2 2 0 0016.76 4H7.24a2 2 0 00-1.79 1.11z"/>
                </svg>
                <span>Review Submissions</span>
            </a>
            <a href="/formulas" class="fc-btn fc-btn--action-card">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                <span>Manage Rules</span>
            </a>
            <a href="/audit" class="fc-btn fc-btn--action-card">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
                    <path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/>
                    <rect x="8" y="2" width="8" height="4" rx="1" ry="1"/>
                    <line x1="8" y1="10" x2="16" y2="10"/>
                    <line x1="8" y1="14" x2="16" y2="14"/>
                    <line x1="8" y1="18" x2="12" y2="18"/>
                </svg>
                <span>View Audit Log</span>
            </a>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private int _templateCount, _totalFields, _totalFormulas;
    private int _totalSubmissions, _acceptedCount, _rejectedCount;
    private int _publishedVersionCount, _pendingReviewCount, _draftCount;
    private int _crossSheetRuleCount, _businessRuleCount, _totalRules;
    private int _acceptanceRate;
    private List<(string Freq, int Count)> _frequencyBreakdown = new();
    private List<(string Cat, int Count)> _categoryBreakdown = new();
    private List<Submission> _recentSubmissions = new();

    protected override async Task OnInitializedAsync()
    {
        // Load templates from cache
        var templates = await Cache.GetAllPublishedTemplates();

        _templateCount = templates.Count;
        _totalFields = templates.Sum(t => t.CurrentVersion.Fields.Count);
        _totalFormulas = templates.Sum(t => t.CurrentVersion.IntraSheetFormulas.Count);

        // Frequency breakdown
        _frequencyBreakdown = templates
            .GroupBy(t => t.ReturnCode.StartsWith("MFCR") ? "Monthly" :
                          t.ReturnCode.StartsWith("QFCR") ? "Quarterly" :
                          t.ReturnCode.StartsWith("SFCR") ? "Semi-Annual" : "Computed")
            .Select(g => (g.Key, g.Count()))
            .OrderByDescending(x => x.Item2)
            .ToList();

        // Category breakdown
        _categoryBreakdown = templates
            .GroupBy(t => t.StructuralCategory)
            .Select(g => (g.Key, g.Count()))
            .OrderByDescending(x => x.Item2)
            .ToList();

        // Template version status counts
        try
        {
            var allTemplates = await TemplateRepo.GetAll();
            var allVersions = allTemplates.SelectMany(t => t.Versions).ToList();
            _publishedVersionCount = allVersions.Count(v => v.Status == TemplateStatus.Published);
            _pendingReviewCount = allVersions.Count(v => v.Status == TemplateStatus.Review);
            _draftCount = allVersions.Count(v => v.Status == TemplateStatus.Draft);
        }
        catch
        {
            _publishedVersionCount = _templateCount;
        }

        // Validation rule counts
        try
        {
            var crossSheetRules = await FormulaRepo.GetAllActiveCrossSheetRules();
            _crossSheetRuleCount = crossSheetRules.Count;

            var businessRules = await FormulaRepo.GetActiveBusinessRules();
            _businessRuleCount = businessRules.Count;
        }
        catch
        {
            // Formula tables may not be populated yet
        }

        _totalRules = _totalFormulas + _crossSheetRuleCount + _businessRuleCount;

        // Submission stats
        try
        {
            _totalSubmissions = await SubmissionRepo.GetTotalCount();
            _acceptedCount = await SubmissionRepo.GetCountByStatus(SubmissionStatus.Accepted)
                           + await SubmissionRepo.GetCountByStatus(SubmissionStatus.AcceptedWithWarnings);
            _rejectedCount = await SubmissionRepo.GetCountByStatus(SubmissionStatus.Rejected);
            _recentSubmissions = (await SubmissionRepo.GetRecent(8)).ToList();
            _acceptanceRate = _totalSubmissions > 0
                ? (int)Math.Round((double)_acceptedCount / _totalSubmissions * 100)
                : 0;
        }
        catch
        {
            // Submissions table may not have data yet
        }

        _loading = false;
    }

    private void NavigateToSubmission(int id) => Nav.NavigateTo($"/submissions/{id}");

    private void HandleRowKey(KeyboardEventArgs e, int id)
    {
        if (e.Key is "Enter" or " ")
            NavigateToSubmission(id);
    }

    private static string FormatStatus(SubmissionStatus status) => status switch
    {
        SubmissionStatus.Accepted => "Accepted",
        SubmissionStatus.AcceptedWithWarnings => "Warnings",
        SubmissionStatus.Rejected => "Rejected",
        SubmissionStatus.Validating => "Validating",
        SubmissionStatus.Parsing => "Parsing",
        _ => "Draft"
    };

    private static string FormatTimeAgo(DateTime utcTime)
    {
        var span = DateTime.UtcNow - utcTime;
        if (span.TotalMinutes < 1) return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        if (span.TotalDays < 7) return $"{(int)span.TotalDays}d ago";
        return utcTime.ToString("dd MMM yyyy");
    }
}
