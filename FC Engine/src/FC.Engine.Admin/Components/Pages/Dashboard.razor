@page "/"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Entities
@using FC.Engine.Domain.Enums
@inject ITemplateMetadataCache Cache
@inject ISubmissionRepository SubmissionRepo
@inject ITemplateRepository TemplateRepo
@inject NavigationManager Nav

<div class="page-header">
    <div>
        <h1>Dashboard</h1>
        <p>Executive overview of the Financial Returns Collection &amp; Analysis System</p>
    </div>
</div>

@if (_loading)
{
    <div class="dash-loading">
        <span class="spinner"></span>
        <span>Loading dashboard data...</span>
    </div>
}
else
{
    <!-- Stat Cards Row -->
    <div class="dash-stats-row">
        <div class="dash-stat-card dash-stat-green" style="animation-delay: 0ms;">
            <div class="dash-stat-accent"></div>
            <div class="dash-stat-body">
                <div class="dash-stat-icon-wrap dash-icon-green">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <polyline points="10 9 9 9 8 9"/>
                    </svg>
                </div>
                <div class="dash-stat-data">
                    <span class="dash-stat-number">@_templateCount</span>
                    <span class="dash-stat-label">Active Templates</span>
                </div>
                <div class="dash-stat-change dash-change-neutral">
                    <span>@_totalFields fields</span>
                </div>
            </div>
        </div>

        <div class="dash-stat-card dash-stat-gold" style="animation-delay: 80ms;">
            <div class="dash-stat-accent"></div>
            <div class="dash-stat-body">
                <div class="dash-stat-icon-wrap dash-icon-gold">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                </div>
                <div class="dash-stat-data">
                    <span class="dash-stat-number">@_pendingReviewCount</span>
                    <span class="dash-stat-label">Pending Review</span>
                </div>
                <div class="dash-stat-change dash-change-neutral">
                    <span>@_draftCount drafts</span>
                </div>
            </div>
        </div>

        <div class="dash-stat-card dash-stat-blue" style="animation-delay: 160ms;">
            <div class="dash-stat-accent"></div>
            <div class="dash-stat-body">
                <div class="dash-stat-icon-wrap dash-icon-blue">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                    </svg>
                </div>
                <div class="dash-stat-data">
                    <span class="dash-stat-number">@_totalFormulas</span>
                    <span class="dash-stat-label">Validation Formulas</span>
                </div>
                <div class="dash-stat-change dash-change-neutral">
                    <span>across all templates</span>
                </div>
            </div>
        </div>

        <div class="dash-stat-card dash-stat-red" style="animation-delay: 240ms;">
            <div class="dash-stat-accent"></div>
            <div class="dash-stat-body">
                <div class="dash-stat-icon-wrap dash-icon-red">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="7 10 12 15 17 10"/>
                        <line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                </div>
                <div class="dash-stat-data">
                    <span class="dash-stat-number">@_totalSubmissions</span>
                    <span class="dash-stat-label">Total Submissions</span>
                </div>
                <div class="dash-stat-change @(_acceptedCount > 0 ? "dash-change-up" : "dash-change-neutral")">
                    @if (_totalSubmissions > 0)
                    {
                        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-8.707l-3-3a1 1 0 00-1.414 0l-3 3a1 1 0 001.414 1.414L9 9.414V13a1 1 0 102 0V9.414l1.293 1.293a1 1 0 001.414-1.414z" clip-rule="evenodd"/>
                        </svg>
                        <span>@(Math.Round((double)_acceptedCount / _totalSubmissions * 100))% accepted</span>
                    }
                    else
                    {
                        <span>no submissions yet</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Two-Column Content Grid -->
    <div class="dash-content-grid">
        <!-- Left: Recent Submissions -->
        <div class="dash-card" style="animation-delay: 320ms;">
            <div class="dash-card-header">
                <h2>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="7 10 12 15 17 10"/>
                        <line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                    Recent Submissions
                </h2>
                <a href="/submissions" class="dash-card-link">View all</a>
            </div>
            <div class="dash-card-body">
                @if (_recentSubmissions.Count == 0)
                {
                    <div class="dash-empty-state">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40" style="color: var(--cbn-gray-300);">
                            <path d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        <p>No submissions yet</p>
                    </div>
                }
                else
                {
                    <table class="dash-mini-table">
                        <thead>
                            <tr>
                                <th>Return Code</th>
                                <th>Institution</th>
                                <th>Status</th>
                                <th>Submitted</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sub in _recentSubmissions)
                            {
                                <tr @onclick="() => Nav.NavigateTo($&quot;/submissions/{sub.Id}&quot;)" class="dash-row-clickable">
                                    <td class="dash-cell-code">@sub.ReturnCode</td>
                                    <td>@(sub.Institution?.Name ?? "—")</td>
                                    <td>
                                        <span class="dash-status-badge dash-status-@sub.Status.ToString().ToLowerInvariant()">
                                            @FormatStatus(sub.Status)
                                        </span>
                                    </td>
                                    <td class="dash-cell-time">@FormatTimeAgo(sub.SubmittedAt)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <!-- Right: Template Health -->
        <div class="dash-card" style="animation-delay: 400ms;">
            <div class="dash-card-header">
                <h2>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                        <polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                    Template Health
                </h2>
                <a href="/templates" class="dash-card-link">Manage</a>
            </div>
            <div class="dash-card-body">
                <!-- Structural Category Breakdown -->
                <div class="dash-health-section">
                    <div class="dash-health-label">By Structure</div>
                    @foreach (var (cat, count) in _categoryBreakdown)
                    {
                        var pct = _templateCount > 0 ? (double)count / _templateCount * 100 : 0;
                        <div class="dash-progress-row">
                            <div class="dash-progress-info">
                                <span class="dash-progress-name">@cat</span>
                                <span class="dash-progress-count">@count</span>
                            </div>
                            <div class="dash-progress-track">
                                <div class="dash-progress-fill dash-fill-@cat.ToLowerInvariant()" style="width: @pct.ToString("F0")%"></div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Frequency Breakdown -->
                <div class="dash-health-section">
                    <div class="dash-health-label">By Frequency</div>
                    @foreach (var (freq, count) in _frequencyBreakdown)
                    {
                        var pct = _templateCount > 0 ? (double)count / _templateCount * 100 : 0;
                        <div class="dash-progress-row">
                            <div class="dash-progress-info">
                                <span class="dash-progress-name">@freq</span>
                                <span class="dash-progress-count">@count</span>
                            </div>
                            <div class="dash-progress-track">
                                <div class="dash-progress-fill dash-fill-freq" style="width: @pct.ToString("F0")%"></div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Version Status Summary -->
                <div class="dash-health-section">
                    <div class="dash-health-label">Version Status</div>
                    <div class="dash-version-chips">
                        <div class="dash-chip dash-chip-published">
                            <span class="dash-chip-dot"></span>
                            <span>@_publishedVersionCount Published</span>
                        </div>
                        <div class="dash-chip dash-chip-review">
                            <span class="dash-chip-dot"></span>
                            <span>@_pendingReviewCount In Review</span>
                        </div>
                        <div class="dash-chip dash-chip-draft">
                            <span class="dash-chip-dot"></span>
                            <span>@_draftCount Drafts</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="dash-actions-card" style="animation-delay: 480ms;">
        <div class="dash-card-header">
            <h2>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
                Quick Actions
            </h2>
        </div>
        <div class="dash-actions-grid">
            <a href="/templates/new" class="dash-action-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="12" y1="18" x2="12" y2="12"/>
                    <line x1="9" y1="15" x2="15" y2="15"/>
                </svg>
                <span>New Template</span>
            </a>
            <a href="/submissions" class="dash-action-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                    <path d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <span>Review Submissions</span>
            </a>
            <a href="/formulas" class="dash-action-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                </svg>
                <span>Manage Formulas</span>
            </a>
            <a href="/audit" class="dash-action-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                <span>View Audit Log</span>
            </a>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private int _templateCount, _totalFields, _totalFormulas;
    private int _fixedRowCount, _multiRowCount, _itemCodedCount;
    private int _totalSubmissions, _acceptedCount, _rejectedCount;
    private int _publishedVersionCount, _pendingReviewCount, _draftCount;
    private List<(string Freq, int Count)> _frequencyBreakdown = new();
    private List<(string Cat, int Count)> _categoryBreakdown = new();
    private List<Submission> _recentSubmissions = new();

    protected override async Task OnInitializedAsync()
    {
        // Load templates from cache
        var templates = await Cache.GetAllPublishedTemplates();

        _templateCount = templates.Count;
        _totalFields = templates.Sum(t => t.CurrentVersion.Fields.Count);
        _totalFormulas = templates.Sum(t => t.CurrentVersion.IntraSheetFormulas.Count);

        _fixedRowCount = templates.Count(t => t.StructuralCategory == nameof(StructuralCategory.FixedRow));
        _multiRowCount = templates.Count(t => t.StructuralCategory == nameof(StructuralCategory.MultiRow));
        _itemCodedCount = templates.Count(t => t.StructuralCategory == nameof(StructuralCategory.ItemCoded));

        // Frequency breakdown
        _frequencyBreakdown = templates
            .GroupBy(t => t.ReturnCode.StartsWith("MFCR") ? "Monthly" :
                          t.ReturnCode.StartsWith("QFCR") ? "Quarterly" :
                          t.ReturnCode.StartsWith("SFCR") ? "Semi-Annual" : "Computed")
            .Select(g => (g.Key, g.Count()))
            .OrderByDescending(x => x.Item2)
            .ToList();

        // Category breakdown
        _categoryBreakdown = templates
            .GroupBy(t => t.StructuralCategory)
            .Select(g => (g.Key, g.Count()))
            .OrderByDescending(x => x.Item2)
            .ToList();

        // Template version status counts (from full repo including drafts)
        try
        {
            var allTemplates = await TemplateRepo.GetAll();
            var allVersions = allTemplates.SelectMany(t => t.Versions).ToList();
            _publishedVersionCount = allVersions.Count(v => v.Status == TemplateStatus.Published);
            _pendingReviewCount = allVersions.Count(v => v.Status == TemplateStatus.Review);
            _draftCount = allVersions.Count(v => v.Status == TemplateStatus.Draft);
        }
        catch
        {
            _publishedVersionCount = _templateCount;
        }

        // Submission stats
        try
        {
            _totalSubmissions = await SubmissionRepo.GetTotalCount();
            _acceptedCount = await SubmissionRepo.GetCountByStatus(SubmissionStatus.Accepted)
                           + await SubmissionRepo.GetCountByStatus(SubmissionStatus.AcceptedWithWarnings);
            _rejectedCount = await SubmissionRepo.GetCountByStatus(SubmissionStatus.Rejected);
            _recentSubmissions = (await SubmissionRepo.GetRecent(8)).ToList();
        }
        catch
        {
            // Submissions table may not have data yet
        }

        _loading = false;
    }

    private static string FormatStatus(SubmissionStatus status) => status switch
    {
        SubmissionStatus.Accepted => "Accepted",
        SubmissionStatus.AcceptedWithWarnings => "Warnings",
        SubmissionStatus.Rejected => "Rejected",
        SubmissionStatus.Validating => "Validating",
        SubmissionStatus.Parsing => "Parsing",
        _ => "Draft"
    };

    private static string FormatTimeAgo(DateTime utcTime)
    {
        var span = DateTime.UtcNow - utcTime;
        if (span.TotalMinutes < 1) return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        if (span.TotalDays < 7) return $"{(int)span.TotalDays}d ago";
        return utcTime.ToString("dd MMM yyyy");
    }
}
