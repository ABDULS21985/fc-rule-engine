@page "/"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Entities
@using FC.Engine.Domain.Enums
@inject ITemplateMetadataCache Cache
@inject ISubmissionRepository SubmissionRepo
@inject ITemplateRepository TemplateRepo
@inject IFormulaRepository FormulaRepo

<PageHeader Title="Executive Dashboard"
            Subtitle="Financial Returns Collection & Analysis System operational overview across templates, rules, and submissions."
            StatusBadge="@StatusBadge"
            StatusVariant="@StatusVariant">
    <SecondaryActions>
        <a class="fc-btn fc-btn--outline fc-btn--sm" href="/dashboard/platform">Platform dashboard</a>
    </SecondaryActions>
    <PrimaryAction>
        <time class="fc-ph-date fc-ph-date-meta" datetime="@DateTime.UtcNow.ToString("yyyy-MM-dd")">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            @DateTime.UtcNow.ToString("d MMM yyyy")
        </time>
    </PrimaryAction>
</PageHeader>

@if (_loading)
{
    <div class="rg-premium-flow" role="status" aria-label="Loading dashboard">
        <div class="fc-skel fc-skel-block" style="--skel-w:100%;--skel-h:156px;"></div>
        <div class="fc-skel-stats-row">
            @for (var i = 0; i < 4; i++)
            {
                <div class="fc-skel-card-body">
                    <div class="fc-skel fc-skel-text" style="--skel-w:44%;--skel-h:12px;--skeleton-index:@(i * 3);"></div>
                    <div class="fc-skel fc-skel-text-lg" style="--skel-w:58%;--skel-h:34px;--skeleton-index:@(i * 3 + 1);margin-top:var(--space-3);"></div>
                    <div class="fc-skel fc-skel-text" style="--skel-w:82%;--skel-h:12px;--skeleton-index:@(i * 3 + 2);margin-top:var(--space-3);"></div>
                </div>
            }
        </div>
        <div class="fc-skel-content-grid">
            <div class="fc-skel-card-body">
                <div class="fc-skel fc-skel-block" style="--skel-w:100%;--skel-h:420px;"></div>
            </div>
            <div class="fc-skel-card-body">
                <div class="fc-skel fc-skel-block" style="--skel-w:100%;--skel-h:420px;"></div>
            </div>
        </div>
    </div>
}
else
{
    var workflowPressure = _pendingReviewCount + _draftCount;
    var totalVersions = _publishedVersionCount + _pendingReviewCount + _draftCount;
    var topCategory = _categoryBreakdown.FirstOrDefault();
    var topFrequency = _frequencyBreakdown.FirstOrDefault();

    <div class="fc-page">
        <div class="rg-premium-flow">
            <section class="rg-premium-banner rg-premium-banner--@BuildBannerTone(workflowPressure, _rejectedCount)">
                <div class="rg-premium-banner__grid">
                    <div>
                        <div class="rg-premium-banner__eyebrow">Control posture</div>
                        <h2 class="rg-premium-banner__headline">@BuildBannerHeadline(workflowPressure, _rejectedCount)</h2>
                        <p class="rg-premium-banner__detail">@BuildBannerDetail(workflowPressure, topCategory.Cat, topFrequency.Freq)</p>
                    </div>
                    <div class="rg-premium-banner__meta">
                        <div class="rg-premium-banner__meta-label">Current operating scope</div>
                        <div class="rg-premium-banner__meta-value">@_templateCount template(s), @_totalSubmissions submission(s)</div>
                        <div class="rg-premium-banner__meta-copy">
                            @_totalRules validation rule(s) are currently protecting the live reporting estate, with @_acceptanceRate% submission acceptance across the visible history.
                        </div>
                    </div>
                </div>
            </section>

            <section class="rg-premium-hero">
                <div class="rg-premium-hero__grid">
                    <div>
                        <div class="rg-premium-hero__eyebrow">Governance workspace</div>
                        <h2 class="rg-premium-hero__title">Keep the template estate clean, the validation stack current, and the submission queue moving.</h2>
                        <p class="rg-premium-hero__subtitle">
                            This command surface is built for the core operating layer of the platform: published templates, review bottlenecks,
                            validation coverage, and live submission throughput. It should tell you where the workflow is slowing before users feel it.
                        </p>
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <span class="rg-premium-chip rg-premium-chip--info">@_totalFields configured field(s)</span>
                            <span class="rg-premium-chip rg-premium-chip--warning">@workflowPressure awaiting action</span>
                            <span class="rg-premium-chip rg-premium-chip--success">@_publishedVersionCount published version(s)</span>
                        </div>
                    </div>
                    <div class="rg-premium-hero__aside">
                        <div class="rg-premium-note">
                            <div class="rg-premium-note__label">Top structure</div>
                            <div class="rg-premium-note__value">@(topCategory == default ? "No data" : topCategory.Cat)</div>
                            <div class="rg-premium-note__copy">@(topCategory == default ? "Template categorisation appears once published templates are available." : $"{topCategory.Count} template(s) currently dominate the structural mix.")</div>
                        </div>
                        <div class="rg-premium-note">
                            <div class="rg-premium-note__label">Top frequency</div>
                            <div class="rg-premium-note__value">@(topFrequency == default ? "No data" : topFrequency.Freq)</div>
                            <div class="rg-premium-note__copy">@(topFrequency == default ? "Filing cadence posture will appear once the template estate is populated." : $"{topFrequency.Count} template(s) currently sit in this cadence bucket.")</div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="rg-premium-stat-grid" aria-label="Executive dashboard metrics">
                <article class="rg-premium-stat">
                    <div class="rg-premium-stat__label">Active templates</div>
                    <div class="rg-premium-stat__value">@_templateCount</div>
                    <div class="rg-premium-stat__note">@_totalFields total field(s) configured across the live published estate.</div>
                </article>
                <article class="rg-premium-stat">
                    <div class="rg-premium-stat__label">Awaiting action</div>
                    <div class="rg-premium-stat__value @BuildStatValueClass(workflowPressure > 0 ? "MEDIUM" : "LOW")">@workflowPressure</div>
                    <div class="rg-premium-stat__note">@_pendingReviewCount in review, @_draftCount remaining as drafts.</div>
                </article>
                <article class="rg-premium-stat">
                    <div class="rg-premium-stat__label">Validation rules</div>
                    <div class="rg-premium-stat__value">@_totalRules</div>
                    <div class="rg-premium-stat__note">@_totalFormulas intra-sheet, @_crossSheetRuleCount cross-sheet, @_businessRuleCount business rules.</div>
                </article>
                <article class="rg-premium-stat">
                    <div class="rg-premium-stat__label">Submission acceptance</div>
                    <div class="rg-premium-stat__value @BuildStatValueClass(_acceptanceRate >= 80 ? "LOW" : "HIGH")">@_acceptanceRate%</div>
                    <div class="rg-premium-stat__note">@_acceptedCount accepted, @_rejectedCount rejected from @_totalSubmissions total submission(s).</div>
                </article>
            </section>

            <section class="rg-premium-content-grid">
                <div class="rg-premium-main">
                    <article class="rg-premium-panel">
                        <div class="rg-premium-panel__header">
                            <div>
                                <div class="rg-premium-panel__eyebrow">Live submission lane</div>
                                <h3 class="rg-premium-panel__title">Recent submissions</h3>
                                <p class="rg-premium-panel__subtitle">The newest returns stay visible here so operators can spot acceptance friction, review backlog, and unusual status drift immediately.</p>
                            </div>
                            <div class="rg-premium-panel__metric">
                                <span class="rg-premium-panel__metric-label">Acceptance</span>
                                @_acceptanceRate%
                            </div>
                        </div>
                        <div class="rg-premium-panel__body">
                            @if (_recentSubmissions.Count == 0)
                            {
                                <div class="rg-premium-empty">No submissions are available yet. Once live traffic arrives, the newest returns and their status shifts will appear here.</div>
                            }
                            else
                            {
                                <div class="rg-premium-list">
                                    @foreach (var sub in _recentSubmissions)
                                    {
                                        <a class="rg-premium-list__item text-decoration-none" href="@($"/submissions/{sub.Id}")">
                                            <div class="rg-premium-list__top">
                                                <div>
                                                    <div class="rg-premium-list__heading">@sub.ReturnCode</div>
                                                    <div class="rg-premium-list__meta">@(sub.Institution?.InstitutionName ?? "Institution unavailable")</div>
                                                </div>
                                                <div class="text-end">
                                                    <div class="rg-premium-list__value">@FormatTimeAgo(sub.SubmittedAt)</div>
                                                    <span class="@BuildSubmissionChipClass(sub.Status)">@FormatStatus(sub.Status)</span>
                                                </div>
                                            </div>
                                            <div class="rg-premium-list__meta">Submitted @(sub.SubmittedAt?.ToString("dd MMM yyyy HH:mm") ?? "—") UTC</div>
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    </article>

                    <article class="rg-premium-panel">
                        <div class="rg-premium-panel__header">
                            <div>
                                <div class="rg-premium-panel__eyebrow">Template topology</div>
                                <h3 class="rg-premium-panel__title">Structure and cadence mix</h3>
                                <p class="rg-premium-panel__subtitle">Understand how the reporting estate is distributed across structural categories and return frequencies.</p>
                            </div>
                            <div class="rg-premium-panel__metric">
                                <span class="rg-premium-panel__metric-label">Published versions</span>
                                @_publishedVersionCount
                            </div>
                        </div>
                        <div class="rg-premium-panel__body">
                            <div class="rg-premium-dual-grid">
                                <div class="rg-premium-stack">
                                    <h4 class="rg-premium-section-title">By structure</h4>
                                    <p class="rg-premium-section-copy">The mix below shows which template structures currently dominate the live estate.</p>
                                    @foreach (var item in _categoryBreakdown)
                                    {
                                        var percent = _templateCount == 0 ? 0 : (int)Math.Round((double)item.Count / _templateCount * 100);
                                        <div class="rg-premium-list__item">
                                            <div class="rg-premium-list__top">
                                                <div class="rg-premium-list__heading">@item.Cat</div>
                                                <div class="rg-premium-list__value">@percent%</div>
                                            </div>
                                            <div class="rg-premium-list__meta">@item.Count template(s) in this structural category.</div>
                                        </div>
                                    }
                                </div>
                                <div class="rg-premium-stack">
                                    <h4 class="rg-premium-section-title">By frequency</h4>
                                    <p class="rg-premium-section-copy">Cadence distribution helps reveal where operations will feel the most recurring filing pressure.</p>
                                    @foreach (var item in _frequencyBreakdown)
                                    {
                                        var percent = _templateCount == 0 ? 0 : (int)Math.Round((double)item.Count / _templateCount * 100);
                                        <div class="rg-premium-list__item">
                                            <div class="rg-premium-list__top">
                                                <div class="rg-premium-list__heading">@item.Freq</div>
                                                <div class="rg-premium-list__value">@percent%</div>
                                            </div>
                                            <div class="rg-premium-list__meta">@item.Count template(s) currently sit in this filing cadence.</div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </article>
                </div>

                <div class="rg-premium-side">
                    <article class="rg-premium-panel">
                        <div class="rg-premium-panel__header">
                            <div>
                                <div class="rg-premium-panel__eyebrow">Workflow pressure</div>
                                <h3 class="rg-premium-panel__title">Version and review posture</h3>
                                <p class="rg-premium-panel__subtitle">A compact operating snapshot of where the template and review pipeline currently stands.</p>
                            </div>
                        </div>
                        <div class="rg-premium-panel__body">
                            <div class="rg-premium-stack">
                                <div class="rg-premium-list__item">
                                    <div class="rg-premium-list__top">
                                        <div class="rg-premium-list__heading">Published</div>
                                        <div class="rg-premium-list__value">@_publishedVersionCount</div>
                                    </div>
                                    <div class="rg-premium-list__meta">@totalVersions total version(s) tracked in the template estate.</div>
                                </div>
                                <div class="rg-premium-list__item">
                                    <div class="rg-premium-list__top">
                                        <div class="rg-premium-list__heading">In review</div>
                                        <div class="rg-premium-list__value">@_pendingReviewCount</div>
                                    </div>
                                    <div class="rg-premium-list__meta">Versions awaiting governance review before they can move into production.</div>
                                </div>
                                <div class="rg-premium-list__item">
                                    <div class="rg-premium-list__top">
                                        <div class="rg-premium-list__heading">Drafts</div>
                                        <div class="rg-premium-list__value">@_draftCount</div>
                                    </div>
                                    <div class="rg-premium-list__meta">Draft-only versions still requiring authoring or structural cleanup.</div>
                                </div>
                                <div class="rg-premium-list__item">
                                    <div class="rg-premium-list__top">
                                        <div class="rg-premium-list__heading">Rejected submissions</div>
                                        <div class="rg-premium-list__value">@_rejectedCount</div>
                                    </div>
                                    <div class="rg-premium-list__meta">Recent rejected returns are a fast proxy for downstream quality friction.</div>
                                </div>
                            </div>
                        </div>
                    </article>

                    <article class="rg-premium-panel">
                        <div class="rg-premium-panel__header">
                            <div>
                                <div class="rg-premium-panel__eyebrow">Quick actions</div>
                                <h3 class="rg-premium-panel__title">Move directly to the operational tools</h3>
                                <p class="rg-premium-panel__subtitle">Fast paths for the areas most likely to need intervention from this dashboard.</p>
                            </div>
                        </div>
                        <div class="rg-premium-panel__body">
                            <div class="rg-premium-action-grid">
                                @foreach (var action in QuickActions)
                                {
                                    <a class="rg-premium-link-card" href="@action.Href">
                                        <span class="rg-premium-link-card__icon">@action.Code</span>
                                        <div>
                                            <div class="rg-premium-link-card__title">@action.Title</div>
                                            <div class="rg-premium-link-card__desc">@action.Description</div>
                                        </div>
                                        <span class="rg-premium-link-card__arrow">Go</span>
                                    </a>
                                }
                            </div>
                        </div>
                    </article>
                </div>
            </section>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private int _templateCount, _totalFields, _totalFormulas;
    private int _totalSubmissions, _acceptedCount, _rejectedCount;
    private int _publishedVersionCount, _pendingReviewCount, _draftCount;
    private int _crossSheetRuleCount, _businessRuleCount, _totalRules;
    private int _acceptanceRate;
    private List<(string Freq, int Count)> _frequencyBreakdown = new();
    private List<(string Cat, int Count)> _categoryBreakdown = new();
    private List<Submission> _recentSubmissions = new();
    private List<int> _submissionSparkline = new();

    private string StatusBadge => (_pendingReviewCount + _draftCount, _rejectedCount) switch
    {
        (> 0, _) => $"{_pendingReviewCount + _draftCount} awaiting action",
        (_, > 0) => $"{_rejectedCount} rejected return(s)",
        _ => "System operational"
    };

    private string StatusVariant => _rejectedCount > 0
        ? "danger"
        : _pendingReviewCount + _draftCount > 0
            ? "warning"
            : "success";

    private static readonly IReadOnlyList<ActionCard> QuickActions = new List<ActionCard>
    {
        new("TPL", "Template Console", "Create and refine live reporting templates.", "/templates"),
        new("SUB", "Submissions", "Review incoming returns and their workflow state.", "/submissions"),
        new("VAL", "Validation Rules", "Inspect formula, business, and cross-sheet rules.", "/formulas"),
        new("AUD", "Audit Log", "Track changes, governance events, and user actions.", "/audit")
    };

    protected override async Task OnInitializedAsync()
    {
        var templates = await Cache.GetAllPublishedTemplates();

        _templateCount = templates.Count;
        _totalFields = templates.Sum(t => t.CurrentVersion.Fields.Count);
        _totalFormulas = templates.Sum(t => t.CurrentVersion.IntraSheetFormulas.Count);

        _frequencyBreakdown = templates
            .GroupBy(t => FrequencyLabel(t.Frequency))
            .Select(g => (g.Key, g.Count()))
            .OrderByDescending(x => x.Item2)
            .ToList();

        _categoryBreakdown = templates
            .GroupBy(t => t.StructuralCategory)
            .Select(g => (g.Key, g.Count()))
            .OrderByDescending(x => x.Item2)
            .ToList();

        try
        {
            var allTemplates = await TemplateRepo.GetAll();
            var allVersions = allTemplates.SelectMany(t => t.Versions).ToList();
            _publishedVersionCount = allVersions.Count(v => v.Status == TemplateStatus.Published);
            _pendingReviewCount = allVersions.Count(v => v.Status == TemplateStatus.Review);
            _draftCount = allVersions.Count(v => v.Status == TemplateStatus.Draft);
        }
        catch
        {
            _publishedVersionCount = _templateCount;
        }

        try
        {
            var crossSheetRules = await FormulaRepo.GetAllActiveCrossSheetRules();
            _crossSheetRuleCount = crossSheetRules.Count;

            var businessRules = await FormulaRepo.GetActiveBusinessRules();
            _businessRuleCount = businessRules.Count;
        }
        catch
        {
        }

        _totalRules = _totalFormulas + _crossSheetRuleCount + _businessRuleCount;

        try
        {
            _totalSubmissions = await SubmissionRepo.GetTotalCount();
            _acceptedCount = await SubmissionRepo.GetCountByStatus(SubmissionStatus.Accepted)
                           + await SubmissionRepo.GetCountByStatus(SubmissionStatus.AcceptedWithWarnings);
            _rejectedCount = await SubmissionRepo.GetCountByStatus(SubmissionStatus.Rejected);
            _recentSubmissions = (await SubmissionRepo.GetRecent(8)).ToList();
            _acceptanceRate = _totalSubmissions > 0
                ? (int)Math.Round((double)_acceptedCount / _totalSubmissions * 100)
                : 0;

            var today = DateTime.UtcNow.Date;
            _submissionSparkline = Enumerable.Range(0, 7)
                .Select(i => _recentSubmissions.Count(s => s.SubmittedAt?.Date == today.AddDays(i - 6)))
                .ToList();
        }
        catch
        {
        }

        _loading = false;
    }

    private static string BuildBannerTone(int workflowPressure, int rejectedCount)
    {
        if (rejectedCount > 0)
        {
            return "danger";
        }

        if (workflowPressure > 0)
        {
            return "warning";
        }

        return "success";
    }

    private string BuildBannerHeadline(int workflowPressure, int rejectedCount)
    {
        if (rejectedCount > 0)
        {
            return "Submission quality needs immediate attention.";
        }

        if (workflowPressure > 0)
        {
            return "Template workflow pressure is building.";
        }

        return "Template governance and submission flow are currently stable.";
    }

    private string BuildBannerDetail(int workflowPressure, string categoryLabel, string frequencyLabel)
    {
        if (_rejectedCount > 0)
        {
            return $"{_rejectedCount} rejected submission(s) are currently the strongest operational warning. Review the newest returns and validation coverage before that rejection pattern spreads.";
        }

        if (workflowPressure > 0)
        {
            return $"{workflowPressure} version(s) still need authoring or review. The template estate is currently led by {categoryLabel ?? "the active structural mix"} and {frequencyLabel ?? "the current reporting cadence"} filings.";
        }

        return $"Published templates, rule coverage, and live submissions are moving without obvious pressure. The current estate is led by {categoryLabel ?? "the active structural mix"} and {frequencyLabel ?? "the current reporting cadence"} filings.";
    }

    private static string BuildStatValueClass(string riskBand)
    {
        if (riskBand is "CRITICAL" or "HIGH")
        {
            return "rg-premium-stat__value--danger";
        }

        if (riskBand == "MEDIUM")
        {
            return "rg-premium-stat__value--warning";
        }

        return "rg-premium-stat__value--success";
    }

    private static string BuildSubmissionChipClass(SubmissionStatus status)
    {
        return status switch
        {
            SubmissionStatus.Accepted => "rg-premium-chip rg-premium-chip--success",
            SubmissionStatus.AcceptedWithWarnings => "rg-premium-chip rg-premium-chip--warning",
            SubmissionStatus.Rejected => "rg-premium-chip rg-premium-chip--danger",
            _ => "rg-premium-chip rg-premium-chip--info"
        };
    }

    private static string FormatStatus(SubmissionStatus status) => status switch
    {
        SubmissionStatus.Accepted => "Accepted",
        SubmissionStatus.AcceptedWithWarnings => "Warnings",
        SubmissionStatus.Rejected => "Rejected",
        SubmissionStatus.Validating => "Validating",
        SubmissionStatus.Parsing => "Parsing",
        _ => "Draft"
    };

    private static string FrequencyLabel(ReturnFrequency frequency) => frequency switch
    {
        ReturnFrequency.SemiAnnual => "Semi-Annual",
        _ => frequency.ToString()
    };

    private static string FormatTimeAgo(DateTime? utcTime)
    {
        if (utcTime is null) return "—";
        var span = DateTime.UtcNow - utcTime.Value;
        if (span.TotalMinutes < 1) return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        if (span.TotalDays < 7) return $"{(int)span.TotalDays}d ago";
        return utcTime.Value.ToString("dd MMM yyyy");
    }

    private sealed record ActionCard(string Code, string Title, string Description, string Href);
}
