@page "/impact-analysis"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "ApproverOrAdmin")]
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Enums
@using FC.Engine.Domain.Validation
@using FC.Engine.Application.Services
@inject ITemplateMetadataCache Cache
@inject ITemplateRepository TemplateRepo
@inject IFormulaRepository FormulaRepo
@inject ToastService Toast

<PageHeader Title="Impact Analysis"
            Subtitle="Assess downstream dependencies, formula exposure, and operational risk before publishing template changes.">
    <PrimaryAction>
        @if (_analysis != null)
        {
            <button class="fc-btn fc-btn--outline" @onclick="() => _showPrintView = !_showPrintView">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true">
                    <polyline points="6 9 6 2 18 2 18 9"/>
                    <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
                    <rect x="6" y="14" width="12" height="8"/>
                </svg>
                @(_showPrintView ? "Exit Print View" : "Print Report")
            </button>
        }
    </PrimaryAction>
</PageHeader>

<div class="fc-ia-page">

    <!-- ============================================================
         TEMPLATE SELECTOR
         ============================================================ -->
    <div class="fc-ia-selector-card">
        <div class="fc-ia-selector-inner">
            <div class="fc-ia-selector-label">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/>
                    <path d="M14 2v6h6"/>
                    <path d="M16 13H8"/>
                    <path d="M16 17H8"/>
                    <path d="M10 9H8"/>
                </svg>
                <span>Select Template to Analyze</span>
            </div>
            <select class="fc-ia-selector-select" @bind="_selectedTemplate" @bind:after="AnalyzeTemplate" aria-label="Select a return template">
                <option value="">Choose a return template...</option>
                @foreach (var rc in _returnCodes)
                {
                    <option value="@rc">@rc — @GetTemplateName(rc)</option>
                }
            </select>
        </div>
    </div>

    <!-- ============================================================
         LOADING STATE
         ============================================================ -->
    @if (_analyzing)
    {
        <div class="fc-ia-loading">
            <div class="fc-ia-loading-spinner" aria-hidden="true"></div>
            <div class="fc-ia-loading-text">
                <span class="fc-ia-loading-title">Analyzing Dependencies</span>
                <span class="fc-ia-loading-sub">Scanning formulas, cross-sheet rules, and template relationships...</span>
            </div>
        </div>
    }

    <!-- ============================================================
         EMPTY / INITIAL STATE
         ============================================================ -->
    @if (!_analyzing && _analysis == null && string.IsNullOrEmpty(_selectedTemplate))
    {
        <div class="fc-ia-empty-state">
            <div class="fc-ia-empty-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48">
                    <circle cx="11" cy="11" r="8"/>
                    <path d="m21 21-4.35-4.35"/>
                    <path d="M11 8v6"/>
                    <path d="M8 11h6"/>
                </svg>
            </div>
            <h3>Select a Template to Begin</h3>
            <p>Choose a return template above to analyze its dependencies, formula coverage, cross-sheet relationships, and operational risk exposure.</p>
        </div>
    }

    <!-- ============================================================
         ANALYSIS RESULTS
         ============================================================ -->
    @if (_analysis != null && !_analyzing)
    {
        <!-- SECTION 1: Summary Metrics -->
        <div class="fc-ia-stats-row">
            <div class="fc-ia-stat-card fc-ia-stat-green" style="animation-delay: 0.05s;">
                <div class="fc-ia-stat-accent" aria-hidden="true"></div>
                <div class="fc-ia-stat-body">
                    <div class="fc-ia-stat-icon fc-ia-icon-green" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/>
                            <path d="M14 2v6h6"/>
                        </svg>
                    </div>
                    <div class="fc-ia-stat-data">
                        <span class="fc-ia-stat-number">@_analysis.FieldCount</span>
                        <span class="fc-ia-stat-label">Fields Defined</span>
                    </div>
                </div>
            </div>
            <div class="fc-ia-stat-card fc-ia-stat-gold" style="animation-delay: 0.1s;">
                <div class="fc-ia-stat-accent" aria-hidden="true"></div>
                <div class="fc-ia-stat-body">
                    <div class="fc-ia-stat-icon fc-ia-icon-gold" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                            <path d="M12 20V10"/>
                            <path d="M18 20V4"/>
                            <path d="M6 20v-4"/>
                        </svg>
                    </div>
                    <div class="fc-ia-stat-data">
                        <span class="fc-ia-stat-number">@_analysis.FormulaCount</span>
                        <span class="fc-ia-stat-label">Intra-Sheet Formulas</span>
                    </div>
                </div>
            </div>
            <div class="fc-ia-stat-card fc-ia-stat-blue" style="animation-delay: 0.15s;">
                <div class="fc-ia-stat-accent" aria-hidden="true"></div>
                <div class="fc-ia-stat-body">
                    <div class="fc-ia-stat-icon fc-ia-icon-blue" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                            <path d="M16 3h5v5"/><path d="M8 3H3v5"/>
                            <path d="M12 22v-8.3a4 4 0 0 0-1.172-2.872L3 3"/>
                            <path d="m15 9 6-6"/>
                        </svg>
                    </div>
                    <div class="fc-ia-stat-data">
                        <span class="fc-ia-stat-number">@_analysis.CrossSheetRuleCount</span>
                        <span class="fc-ia-stat-label">Cross-Sheet Rules</span>
                    </div>
                </div>
            </div>
            <div class="fc-ia-stat-card @RiskCardClass" style="animation-delay: 0.2s;">
                <div class="fc-ia-stat-accent" aria-hidden="true"></div>
                <div class="fc-ia-stat-body">
                    <div class="fc-ia-stat-icon @RiskIconClass" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                            <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                            <line x1="12" y1="9" x2="12" y2="13"/>
                            <line x1="12" y1="17" x2="12.01" y2="17"/>
                        </svg>
                    </div>
                    <div class="fc-ia-stat-data">
                        <span class="fc-ia-stat-number fc-ia-risk-value">@RiskLevel</span>
                        <span class="fc-ia-stat-label">Risk Level</span>
                    </div>
                    @if (RiskLevel == "High")
                    {
                        <div class="fc-ia-risk-pulse" aria-hidden="true"></div>
                    }
                </div>
            </div>
        </div>

        <!-- SECTION 2: Scenario Selector -->
        <div class="fc-ia-scenario-card" style="animation-delay: 0.25s;">
            <div class="fc-ia-scenario-header">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                </svg>
                <span>What-If Scenario</span>
            </div>
            <div class="fc-ia-scenario-options" role="radiogroup" aria-label="Impact analysis scenario">
                @foreach (var scenario in _scenarios)
                {
                    <button class="fc-ia-scenario-btn @(scenario == _activeScenario ? "fc-ia-scenario-btn-active" : "")"
                            role="radio"
                            aria-checked="@(scenario == _activeScenario)"
                            @onclick="() => _activeScenario = scenario">
                        <span class="fc-ia-scenario-dot" aria-hidden="true"></span>
                        @scenario
                    </button>
                }
            </div>
        </div>

        <!-- SECTION 3: Impact Metrics Visualization -->
        <div class="fc-ia-metrics-card" style="animation-delay: 0.3s;">
            <div class="fc-ia-metrics-header">
                <h2>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                        <line x1="18" y1="20" x2="18" y2="10"/>
                        <line x1="12" y1="20" x2="12" y2="4"/>
                        <line x1="6" y1="20" x2="6" y2="14"/>
                    </svg>
                    Impact Exposure Metrics
                </h2>
                <span class="fc-ia-metrics-scenario">Scenario: @_activeScenario</span>
            </div>
            <div class="fc-ia-rings-row">
                <RingChart Value="@TemplatesAffectedPct" Label="Templates" Variant="@(TemplatesAffectedPct > 50 ? "red" : TemplatesAffectedPct > 20 ? "gold" : "green")" />
                <RingChart Value="@FormulaCoveragePct" Label="Formula Coverage" Variant="@(FormulaCoveragePct < 30 ? "red" : FormulaCoveragePct < 70 ? "gold" : "green")" />
                <RingChart Value="@CrossSheetExposurePct" Label="Cross-Sheet Exposure" Variant="@(CrossSheetExposurePct > 40 ? "red" : CrossSheetExposurePct > 15 ? "gold" : "green")" />
                <RingChart Value="@FieldImpactPct" Label="Field Impact" Variant="@(FieldImpactPct > 60 ? "red" : FieldImpactPct > 30 ? "gold" : "green")" />
            </div>
        </div>

        <!-- SECTION 4: Dependency Graph -->
        <div class="fc-ia-graph-card" style="animation-delay: 0.35s;">
            <div class="fc-ia-graph-header">
                <h2>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                        <circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/>
                        <path d="M13 6h3a2 2 0 0 1 2 2v7"/><path d="M6 9v12"/>
                    </svg>
                    Dependency Graph
                </h2>
                <span class="fc-ia-graph-label">Template → Rules → Dependent Templates</span>
            </div>
            <div class="fc-ia-graph-body">
                <!-- Root node: selected template -->
                <div class="fc-ia-node fc-ia-node-template fc-ia-node-root">
                    <div class="fc-ia-node-badge fc-ia-node-badge-template">Template</div>
                    <div class="fc-ia-node-title">@_selectedTemplate</div>
                    <div class="fc-ia-node-meta">@_analysis.FieldCount fields &middot; @_analysis.FormulaCount formulas</div>
                </div>

                @if (_analysis.CrossSheetRules.Any())
                {
                    <div class="fc-ia-graph-connector" aria-hidden="true">
                        <div class="fc-ia-connector-line"></div>
                        <div class="fc-ia-connector-label">@_analysis.CrossSheetRuleCount cross-sheet @(_analysis.CrossSheetRuleCount == 1 ? "rule" : "rules")</div>
                    </div>

                    <div class="fc-ia-graph-branches">
                        @foreach (var rule in _analysis.CrossSheetRules)
                        {
                            <div class="fc-ia-branch">
                                <div class="fc-ia-branch-connector" aria-hidden="true"></div>
                                <div class="fc-ia-node fc-ia-node-rule">
                                    <div class="fc-ia-node-badge fc-ia-node-badge-rule">Rule</div>
                                    <div class="fc-ia-node-title">@rule.RuleCode</div>
                                    <div class="fc-ia-node-meta">@rule.RuleName</div>
                                    @if (rule.Expression != null)
                                    {
                                        <div class="fc-ia-node-expr">@rule.Expression.Expression</div>
                                    }
                                </div>
                                @{
                                    var dependents = rule.Operands
                                        .Where(o => o.TemplateReturnCode != _selectedTemplate)
                                        .Select(o => o.TemplateReturnCode)
                                        .Distinct()
                                        .ToList();
                                }
                                @if (dependents.Any())
                                {
                                    <div class="fc-ia-branch-children">
                                        @foreach (var dep in dependents)
                                        {
                                            <div class="fc-ia-node fc-ia-node-field">
                                                <div class="fc-ia-node-badge fc-ia-node-badge-dependent">Dependent</div>
                                                <a href="/templates/@dep" class="fc-ia-node-title fc-ia-node-link">@dep</a>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="fc-ia-graph-connector" aria-hidden="true">
                        <div class="fc-ia-connector-line fc-ia-connector-line-muted"></div>
                        <div class="fc-ia-connector-label fc-ia-connector-label-muted">No cross-sheet dependencies</div>
                    </div>
                    <div class="fc-ia-node fc-ia-node-empty">
                        <span>This template has no cross-sheet rule dependencies</span>
                    </div>
                }
            </div>
        </div>

        <!-- SECTION 5: Collapsible Impact Categories -->
        <div class="fc-ia-accordions" style="animation-delay: 0.4s;">

            <!-- Direct Template Impact -->
            <AccordionPanel Title="Direct Template Impact"
                            Subtitle="Fields, structure, and data type analysis"
                            Count="@_analysis.FieldCount"
                            Variant="green"
                            InitiallyOpen="true">
                <Icon>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/>
                    </svg>
                </Icon>
                <ChildContent>
                    @if (_templateDetail != null)
                    {
                        <div class="fc-ia-detail-grid">
                            <div class="fc-ia-detail-item">
                                <span class="fc-ia-detail-label">Return Code</span>
                                <span class="fc-ia-detail-value fc-ia-detail-code">@_selectedTemplate</span>
                            </div>
                            <div class="fc-ia-detail-item">
                                <span class="fc-ia-detail-label">Template Name</span>
                                <span class="fc-ia-detail-value">@_templateDetail.Name</span>
                            </div>
                            <div class="fc-ia-detail-item">
                                <span class="fc-ia-detail-label">Structural Category</span>
                                <span class="fc-ia-detail-value">
                                    <span class="fc-badge @CategoryBadge(_templateDetail.StructuralCategory)">@_templateDetail.StructuralCategory</span>
                                </span>
                            </div>
                            <div class="fc-ia-detail-item">
                                <span class="fc-ia-detail-label">Physical Table</span>
                                <span class="fc-ia-detail-value fc-ia-detail-code">@_templateDetail.PhysicalTableName</span>
                            </div>
                            <div class="fc-ia-detail-item">
                                <span class="fc-ia-detail-label">Total Fields</span>
                                <span class="fc-ia-detail-value">@_analysis.FieldCount</span>
                            </div>
                            <div class="fc-ia-detail-item">
                                <span class="fc-ia-detail-label">Computed Fields</span>
                                <span class="fc-ia-detail-value">@_analysis.ComputedFieldCount</span>
                            </div>
                            <div class="fc-ia-detail-item">
                                <span class="fc-ia-detail-label">Required Fields</span>
                                <span class="fc-ia-detail-value">@_analysis.RequiredFieldCount</span>
                            </div>
                            <div class="fc-ia-detail-item">
                                <span class="fc-ia-detail-label">Key Fields</span>
                                <span class="fc-ia-detail-value">@_analysis.KeyFieldCount</span>
                            </div>
                        </div>

                        @if (_analysis.FieldsBySection.Any())
                        {
                            <h4 class="fc-ia-sub-heading">Fields by Section</h4>
                            <div class="fc-ia-section-bars">
                                @foreach (var sec in _analysis.FieldsBySection)
                                {
                                    <div class="fc-ia-section-bar-item">
                                        <div class="fc-ia-section-bar-label">
                                            <span>@(string.IsNullOrEmpty(sec.Key) ? "Default" : sec.Key)</span>
                                            <span class="fc-ia-section-bar-count">@(sec.Value)</span>
                                        </div>
                                        <div class="fc-ia-section-bar-track">
                                            <div class="fc-ia-section-bar-fill" style="width: @(Math.Min(100, (int)(sec.Value * 100.0 / _analysis.FieldCount)))%"></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </ChildContent>
            </AccordionPanel>

            <!-- Formula Dependency Impact -->
            <AccordionPanel Title="Formula Dependency Impact"
                            Subtitle="Intra-sheet formula coverage and validation exposure"
                            Count="@_analysis.FormulaCount"
                            Variant="gold"
                            InitiallyOpen="@(_analysis.FormulaCount > 0)">
                <Icon>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/>
                    </svg>
                </Icon>
                <ChildContent>
                    @if (_analysis.FormulasByType.Any())
                    {
                        <div class="fc-ia-formula-grid">
                            @foreach (var ft in _analysis.FormulasByType)
                            {
                                <div class="fc-ia-formula-type-card">
                                    <span class="fc-ia-formula-type-count">@ft.Value</span>
                                    <span class="fc-ia-formula-type-name">@ft.Key</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="fc-ia-accordion-empty">
                            <p>No intra-sheet formulas defined for this template.</p>
                        </div>
                    }
                </ChildContent>
            </AccordionPanel>

            <!-- Cross-Sheet Rule Impact -->
            <AccordionPanel Title="Cross-Sheet Rule Impact"
                            Subtitle="Rules that validate relationships with other templates"
                            Count="@_analysis.CrossSheetRuleCount"
                            Variant="blue"
                            InitiallyOpen="@(_analysis.CrossSheetRuleCount > 0)">
                <Icon>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <path d="M16 3h5v5"/><path d="M8 3H3v5"/>
                        <path d="M12 22v-8.3a4 4 0 0 0-1.172-2.872L3 3"/>
                        <path d="m15 9 6-6"/>
                    </svg>
                </Icon>
                <ChildContent>
                    @if (_analysis.CrossSheetRules.Any())
                    {
                        <div class="fc-ia-rules-table-wrap">
                            <table class="fc-ia-rules-table" role="table">
                                <thead>
                                    <tr>
                                        <th scope="col">Rule Code</th>
                                        <th scope="col">Name</th>
                                        <th scope="col">Related Templates</th>
                                        <th scope="col">Expression</th>
                                        <th scope="col">Severity</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var rule in _analysis.CrossSheetRules)
                                    {
                                        <tr>
                                            <td class="fc-ia-cell-code">@rule.RuleCode</td>
                                            <td class="fc-ia-cell-strong">@rule.RuleName</td>
                                            <td>
                                                @foreach (var rc in rule.Operands.Select(o => o.TemplateReturnCode).Distinct())
                                                {
                                                    <span class="fc-ia-template-chip @(rc == _selectedTemplate ? "fc-ia-template-chip-self" : "")">@rc</span>
                                                }
                                            </td>
                                            <td class="fc-ia-cell-code">@(rule.Expression?.Expression ?? "—")</td>
                                            <td>
                                                <span class="fc-badge @StatusBadge(rule.Severity.ToString())">@rule.Severity</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="fc-ia-accordion-empty">
                            <p>No cross-sheet rules reference this template.</p>
                        </div>
                    }
                </ChildContent>
            </AccordionPanel>

            <!-- Dependent Templates -->
            <AccordionPanel Title="Dependent Templates"
                            Subtitle="Templates affected by changes to this template"
                            Count="@_analysis.DependentTemplates.Count"
                            Variant="@(_analysis.DependentTemplates.Count > 5 ? "red" : _analysis.DependentTemplates.Count > 0 ? "gold" : "green")">
                <Icon>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                        <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                    </svg>
                </Icon>
                <Badge>
                    @if (_analysis.DependentTemplates.Count > 5)
                    {
                        <span class="fc-ia-badge-warning">High Exposure</span>
                    }
                </Badge>
                <ChildContent>
                    @if (_analysis.DependentTemplates.Any())
                    {
                        <p class="fc-ia-dependent-note">
                            Changes to <strong>@_selectedTemplate</strong> may affect validation of the following templates
                            through cross-sheet rule dependencies:
                        </p>
                        <div class="fc-ia-rules-table-wrap">
                            <table class="fc-ia-rules-table" role="table">
                                <thead>
                                    <tr>
                                        <th scope="col">Return Code</th>
                                        <th scope="col">Via Rule</th>
                                        <th scope="col">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var (rc, rule) in _analysis.DependentTemplates)
                                    {
                                        <tr>
                                            <td class="fc-ia-cell-strong">@rc</td>
                                            <td class="fc-ia-cell-code">@rule</td>
                                            <td>
                                                <a href="/templates/@rc" class="fc-ia-view-link">View Template</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="fc-ia-accordion-empty">
                            <p>No dependent templates found. Changes to this template will not affect cross-sheet validation for other templates.</p>
                        </div>
                    }
                </ChildContent>
            </AccordionPanel>

            <!-- Business Rules Impact -->
            <AccordionPanel Title="Business Rule Exposure"
                            Subtitle="Generic business rules applicable to this template"
                            Count="@_analysis.BusinessRuleCount"
                            Variant="@(_analysis.BusinessRuleCount > 0 ? "gold" : "green")">
                <Icon>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                </Icon>
                <ChildContent>
                    @if (_analysis.BusinessRules.Any())
                    {
                        <div class="fc-ia-rules-table-wrap">
                            <table class="fc-ia-rules-table" role="table">
                                <thead>
                                    <tr>
                                        <th scope="col">Rule Code</th>
                                        <th scope="col">Name</th>
                                        <th scope="col">Type</th>
                                        <th scope="col">Severity</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var br in _analysis.BusinessRules)
                                    {
                                        <tr>
                                            <td class="fc-ia-cell-code">@br.RuleCode</td>
                                            <td class="fc-ia-cell-strong">@br.RuleName</td>
                                            <td>
                                                <span class="fc-badge fc-badge--review">@br.RuleType</span>
                                            </td>
                                            <td>
                                                <span class="fc-badge @StatusBadge(br.Severity.ToString())">@br.Severity</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="fc-ia-accordion-empty">
                            <p>No business rules are directly applicable to this template.</p>
                        </div>
                    }
                </ChildContent>
            </AccordionPanel>

            <!-- Breaking vs Non-Breaking Changes -->
            <AccordionPanel Title="Change Classification"
                            Subtitle="Breaking vs non-breaking change assessment"
                            Variant="@(RiskLevel == "High" ? "red" : RiskLevel == "Medium" ? "gold" : "green")">
                <Icon>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                        <line x1="12" y1="9" x2="12" y2="13"/>
                        <line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                </Icon>
                <ChildContent>
                    <div class="fc-ia-change-assessment">
                        <div class="fc-ia-change-category @(RiskLevel == "High" ? "fc-ia-change-breaking" : "fc-ia-change-safe")">
                            <div class="fc-ia-change-icon" aria-hidden="true">
                                @if (_analysis.CrossSheetRuleCount > 0 || _analysis.DependentTemplates.Count > 0)
                                {
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                                        <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                                        <line x1="12" y1="9" x2="12" y2="13"/>
                                        <line x1="12" y1="17" x2="12.01" y2="17"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                                        <polyline points="22 4 12 14.01 9 11.01"/>
                                    </svg>
                                }
                            </div>
                            <div class="fc-ia-change-text">
                                <strong>
                                    @if (_analysis.CrossSheetRuleCount > 0)
                                    {
                                        <span>Potentially Breaking Changes</span>
                                    }
                                    else
                                    {
                                        <span>Non-Breaking Change Scope</span>
                                    }
                                </strong>
                                <p>
                                    @if (_analysis.DependentTemplates.Count > 0)
                                    {
                                        <span>Structural changes to @_selectedTemplate may break @_analysis.DependentTemplates.Count dependent template(s) through @_analysis.CrossSheetRuleCount cross-sheet rule(s). Review each dependency before publishing.</span>
                                    }
                                    else if (_analysis.CrossSheetRuleCount > 0)
                                    {
                                        <span>This template participates in @_analysis.CrossSheetRuleCount cross-sheet rule(s) but no other templates depend on it. Changes should be validated carefully.</span>
                                    }
                                    else
                                    {
                                        <span>This template is self-contained with no cross-sheet dependencies. Field and formula changes can be published with lower risk.</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>
                </ChildContent>
            </AccordionPanel>
        </div>

        <!-- ============================================================
             SECTION 6: Printable Report View
             ============================================================ -->
        @if (_showPrintView)
        {
            <div class="fc-ia-print-overlay" @onclick="() => _showPrintView = false">
                <div class="fc-ia-print-report" @onclick:stopPropagation="true">
                    <div class="fc-ia-print-header">
                        <div class="fc-ia-print-brand">
                            <img src="images/cbn-logo.svg" alt="CBN" width="48" height="40" />
                            <div>
                                <strong>Central Bank of Nigeria</strong>
                                <span>FC Engine — Impact Analysis Report</span>
                            </div>
                        </div>
                        <div class="fc-ia-print-meta">
                            <span>Template: <strong>@_selectedTemplate</strong></span>
                            <span>Generated: @DateTime.Now.ToString("dd MMM yyyy, HH:mm")</span>
                            <span>Scenario: @_activeScenario</span>
                        </div>
                    </div>

                    <div class="fc-ia-print-body">
                        <h3>Summary</h3>
                        <div class="fc-ia-print-stats">
                            <div><span>Fields:</span> <strong>@_analysis.FieldCount</strong></div>
                            <div><span>Formulas:</span> <strong>@_analysis.FormulaCount</strong></div>
                            <div><span>Cross-Sheet Rules:</span> <strong>@_analysis.CrossSheetRuleCount</strong></div>
                            <div><span>Dependent Templates:</span> <strong>@_analysis.DependentTemplates.Count</strong></div>
                            <div><span>Business Rules:</span> <strong>@_analysis.BusinessRuleCount</strong></div>
                            <div><span>Risk Level:</span> <strong class="fc-ia-print-risk-@RiskLevel.ToLowerInvariant()">@RiskLevel</strong></div>
                        </div>

                        @if (_analysis.CrossSheetRules.Any())
                        {
                            <h3>Cross-Sheet Rules</h3>
                            <table class="fc-ia-print-table">
                                <thead><tr><th>Rule Code</th><th>Name</th><th>Expression</th><th>Severity</th></tr></thead>
                                <tbody>
                                    @foreach (var r in _analysis.CrossSheetRules)
                                    {
                                        <tr>
                                            <td>@r.RuleCode</td><td>@r.RuleName</td>
                                            <td>@(r.Expression?.Expression ?? "—")</td><td>@r.Severity</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }

                        @if (_analysis.DependentTemplates.Any())
                        {
                            <h3>Dependent Templates</h3>
                            <table class="fc-ia-print-table">
                                <thead><tr><th>Return Code</th><th>Via Rule</th></tr></thead>
                                <tbody>
                                    @foreach (var (rc, rule) in _analysis.DependentTemplates)
                                    {
                                        <tr><td>@rc</td><td>@rule</td></tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>

                    <div class="fc-ia-print-footer">
                        <span>Central Bank of Nigeria &middot; FC Engine Admin Portal</span>
                        <span>CONFIDENTIAL — For Internal Use Only</span>
                        <button class="fc-ia-print-action" @onclick="PrintReport">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true">
                                <polyline points="6 9 6 2 18 2 18 9"/>
                                <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
                                <rect x="6" y="14" width="12" height="8"/>
                            </svg>
                            Print
                        </button>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<string> _returnCodes = new();
    private Dictionary<string, string> _templateNames = new();
    private string _selectedTemplate = "";
    private bool _analyzing;
    private bool _showPrintView;
    private string _activeScenario = "Current Published Version";
    private ImpactAnalysisResult? _analysis;
    private CachedTemplate? _templateDetail;

    private readonly string[] _scenarios = new[]
    {
        "Current Published Version",
        "Draft Change Set",
        "Proposed Formula Update",
        "Template Structure Change",
        "Full Rollout Impact"
    };

    // Computed properties
    private string RiskLevel
    {
        get
        {
            if (_analysis == null) return "Low";
            var score = _analysis.DependentTemplates.Count * 3
                      + _analysis.CrossSheetRuleCount * 2
                      + (_analysis.BusinessRuleCount > 5 ? 3 : 0);
            return score >= 10 ? "High" : score >= 4 ? "Medium" : "Low";
        }
    }

    private string RiskCardClass => RiskLevel switch
    {
        "High" => "fc-ia-stat-red",
        "Medium" => "fc-ia-stat-gold",
        _ => "fc-ia-stat-green"
    };

    private string RiskIconClass => RiskLevel switch
    {
        "High" => "fc-ia-icon-red",
        "Medium" => "fc-ia-icon-gold",
        _ => "fc-ia-icon-green"
    };

    private int TemplatesAffectedPct => _returnCodes.Count > 0 && _analysis != null
        ? Math.Min(100, (int)((_analysis.DependentTemplates.Select(d => d.ReturnCode).Distinct().Count() + 1) * 100.0 / _returnCodes.Count))
        : 0;

    private int FormulaCoveragePct => _analysis != null && _analysis.FieldCount > 0
        ? Math.Min(100, (int)(_analysis.FormulaCount * 100.0 / _analysis.FieldCount))
        : 0;

    private int CrossSheetExposurePct => _analysis != null
        ? Math.Min(100, _analysis.CrossSheetRuleCount * 10)
        : 0;

    private int FieldImpactPct => _analysis != null && _analysis.FieldCount > 0
        ? Math.Min(100, (int)(_analysis.ComputedFieldCount * 100.0 / _analysis.FieldCount))
        : 0;

    protected override async Task OnInitializedAsync()
    {
        var templates = await Cache.GetAllPublishedTemplates();
        _returnCodes = templates.Select(t => t.ReturnCode).OrderBy(x => x).ToList();
        _templateNames = templates.ToDictionary(t => t.ReturnCode, t => t.Name);
    }

    private string GetTemplateName(string rc) =>
        _templateNames.TryGetValue(rc, out var name) ? name : rc;

    private async Task AnalyzeTemplate()
    {
        if (string.IsNullOrEmpty(_selectedTemplate))
        {
            _analysis = null;
            _templateDetail = null;
            return;
        }

        _analyzing = true;
        try
        {
            var template = await Cache.GetPublishedTemplate(_selectedTemplate);
            _templateDetail = template;

            var allRules = await FormulaRepo.GetAllActiveCrossSheetRules();
            var businessRules = await FormulaRepo.GetBusinessRulesForTemplate(_selectedTemplate);

            // Find all cross-sheet rules that reference this template
            var relevantRules = allRules
                .Where(r => r.Operands.Any(o => o.TemplateReturnCode == _selectedTemplate))
                .ToList();

            // Find dependent templates
            var dependents = new List<(string ReturnCode, string RuleCode)>();
            foreach (var rule in relevantRules)
            {
                foreach (var op in rule.Operands)
                {
                    if (op.TemplateReturnCode != _selectedTemplate)
                    {
                        dependents.Add((op.TemplateReturnCode, rule.RuleCode));
                    }
                }
            }

            // Group formulas by type
            var formulasByType = template.CurrentVersion.IntraSheetFormulas
                .GroupBy(f => f.FormulaType.ToString())
                .ToDictionary(g => g.Key, g => g.Count());

            // Group fields by section
            var fieldsBySection = template.CurrentVersion.Fields
                .GroupBy(f => f.SectionName ?? "")
                .OrderByDescending(g => g.Count())
                .ToDictionary(g => g.Key, g => g.Count());

            _analysis = new ImpactAnalysisResult
            {
                FieldCount = template.CurrentVersion.Fields.Count,
                FormulaCount = template.CurrentVersion.IntraSheetFormulas.Count,
                CrossSheetRuleCount = relevantRules.Count,
                CrossSheetRules = relevantRules,
                DependentTemplates = dependents.Distinct().ToList(),
                BusinessRules = businessRules.ToList(),
                BusinessRuleCount = businessRules.Count,
                ComputedFieldCount = template.CurrentVersion.Fields.Count(f => f.IsComputed),
                RequiredFieldCount = template.CurrentVersion.Fields.Count(f => f.IsRequired),
                KeyFieldCount = template.CurrentVersion.Fields.Count(f => f.IsKeyField),
                FormulasByType = formulasByType,
                FieldsBySection = fieldsBySection
            };
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message, "Analysis Failed");
            _analysis = null;
        }
        _analyzing = false;
    }

    private void PrintReport()
    {
        // Print report view - browser print dialog
    }

    private class ImpactAnalysisResult
    {
        public int FieldCount { get; set; }
        public int FormulaCount { get; set; }
        public int CrossSheetRuleCount { get; set; }
        public int ComputedFieldCount { get; set; }
        public int RequiredFieldCount { get; set; }
        public int KeyFieldCount { get; set; }
        public int BusinessRuleCount { get; set; }
        public List<CrossSheetRule> CrossSheetRules { get; set; } = new();
        public List<(string ReturnCode, string RuleCode)> DependentTemplates { get; set; } = new();
        public List<BusinessRule> BusinessRules { get; set; } = new();
        public Dictionary<string, int> FormulasByType { get; set; } = new();
        public Dictionary<string, int> FieldsBySection { get; set; } = new();
    }

    private static string StatusBadge(string status) => status.ToLowerInvariant() switch
    {
        "published" or "active" or "accepted" => "fc-badge--success",
        "draft" or "pending" => "fc-badge--warning",
        "review" or "inreview" => "fc-badge--review",
        "deprecated" or "retired" or "disabled" or "archived" => "fc-badge--muted",
        "rejected" or "failed" or "error" => "fc-badge--danger",
        "processing" or "validating" or "parsing" => "fc-badge--info",
        "acceptedwithwarnings" or "warnings" or "warning" => "fc-badge--warning",
        _ => "fc-badge--neutral"
    };

    private static string CategoryBadge(string cat) => cat.ToLowerInvariant() switch
    {
        "fixedrow" => "fc-badge--purple",
        "multirow" => "fc-badge--teal",
        "itemcoded" => "fc-badge--pink",
        _ => "fc-badge--neutral"
    };
}
