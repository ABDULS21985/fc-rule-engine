        public string PeriodCode { get; set; } = string.Empty;
        public string TimeHorizon { get; set; } = string.Empty;
        public int EntitiesShocked { get; set; }
        public int ContagionRounds { get; set; }
        public decimal? SystemicResilienceScore { get; set; }
        public string Status { get; set; } = string.Empty;
        public DateTime StartedAt { get; set; }
        public string ScenarioName { get; set; } = string.Empty;
        public string ScenarioCode { get; set; } = string.Empty;
        public string ResilienceRating { get; set; } = string.Empty;
    }

    private sealed class EntityResultRow
    {
        public int InstitutionId { get; set; }
        public string InstitutionName { get; set; } = string.Empty;
        public string InstitutionType { get; set; } = string.Empty;
        public decimal PreCAR { get; set; }
        public decimal PreNPL { get; set; }
        public decimal PreLCR { get; set; }
        public decimal PreNSFR { get; set; }
        public decimal PreROA { get; set; }
        public decimal PreTotalAssets { get; set; }
        public decimal PreTotalDeposits { get; set; }
        public decimal PostCAR { get; set; }
        public decimal PostNPL { get; set; }
        public decimal PostLCR { get; set; }
        public decimal PostNSFR { get; set; }
        public decimal PostROA { get; set; }
        public decimal PostCapitalShortfall { get; set; }
        public decimal AdditionalProvisions { get; set; }
        public bool BreachesCAR { get; set; }
        public bool BreachesLCR { get; set; }
        public bool BreachesNSFR { get; set; }
        public bool IsInsolvent { get; set; }
        public bool IsContagionVictim { get; set; }
