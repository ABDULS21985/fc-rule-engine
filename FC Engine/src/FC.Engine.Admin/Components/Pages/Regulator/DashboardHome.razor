@page "/regulator"
@attribute [Authorize(Policy = "RegulatorOnly")]

<PageTitle>Regulator Dashboard</PageTitle>

<PageHeader Title="Regulator Portal"
            Subtitle="Review submissions, run sector analytics, monitor early warnings, and manage examinations." />

<div class="rg-grid rg-grid-3" style="margin-top:1rem;">
    <a class="rg-card rg-card--hoverable" href="/regulator/inbox" style="text-decoration:none;">
        <div style="font-size:1.5rem;margin-bottom:0.25rem;">📥</div>
        <h3 style="margin:0 0 0.25rem;">Submissions Inbox</h3>
        <p class="rg-muted" style="margin:0;font-size:0.82rem;">Review and process incoming regulatory filings</p>
    </a>
    <a class="rg-card rg-card--hoverable" href="/regulator/warnings" style="text-decoration:none;">
        <div style="font-size:1.5rem;margin-bottom:0.25rem;">⚠️</div>
        <h3 style="margin:0 0 0.25rem;">Early Warnings</h3>
        <p class="rg-muted" style="margin:0;font-size:0.82rem;">Monitor early warning flags across institutions</p>
    </a>
    <a class="rg-card rg-card--hoverable" href="/regulator/analytics" style="text-decoration:none;">
        <div style="font-size:1.5rem;margin-bottom:0.25rem;">📊</div>
        <h3 style="margin:0 0 0.25rem;">Sector Analytics</h3>
        <p class="rg-muted" style="margin:0;font-size:0.82rem;">CAR distribution, NPL trends, and filing heatmaps</p>
    </a>
    <a class="rg-card rg-card--hoverable" href="/regulator/systemic-risk" style="text-decoration:none;">
        <div style="font-size:1.5rem;margin-bottom:0.25rem;">🔴</div>
        <h3 style="margin:0 0 0.25rem;">Systemic Risk</h3>
        <p class="rg-muted" style="margin:0;font-size:0.82rem;">Risk indices, CAMELS scores, and contagion analysis</p>
    </a>
    <a class="rg-card rg-card--hoverable" href="/regulator/stress-test" style="text-decoration:none;">
        <div style="font-size:1.5rem;margin-bottom:0.25rem;">🧪</div>
        <h3 style="margin:0 0 0.25rem;">Stress Testing</h3>
        <p class="rg-muted" style="margin:0;font-size:0.82rem;">Run NGFS climate and macro-economic scenarios</p>
    </a>
    <a class="rg-card rg-card--hoverable" href="/regulator/cross-border" style="text-decoration:none;">
        <div style="font-size:1.5rem;margin-bottom:0.25rem;">🌍</div>
        <h3 style="margin:0 0 0.25rem;">Cross-Border</h3>
        <p class="rg-muted" style="margin:0;font-size:0.82rem;">Pan-African dashboard and regulatory harmonisation</p>
    </a>
</div>
