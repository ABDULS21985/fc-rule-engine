@page "/regulator"
@attribute [Authorize(Policy = "RegulatorOnly")]

<PageTitle>Regulator Dashboard</PageTitle>

<PageHeader Title="Regulator Command Centre"
            Subtitle="Supervisory operations, stakeholder dashboards, and sector-wide intelligence in one premium workspace."
            StatusBadge="Supervisory live"
            StatusVariant="success" />

<div class="fc-page">
    <div class="rg-premium-flow">
        <section class="rg-premium-banner rg-premium-banner--success" aria-label="Supervisory posture">
            <div class="rg-premium-banner__grid">
                <div>
                    <div class="rg-premium-banner__eyebrow">Live posture</div>
                    <h2 class="rg-premium-banner__headline">Run the day from one regulator-grade overview.</h2>
                    <p class="rg-premium-banner__detail">
                        Move from inbox triage to early warnings, systemic risk, stress testing, and cross-border coordination
                        without dropping context. Each lane below is tuned for real supervisory workflows rather than generic reporting.
                    </p>
                </div>
                <div class="rg-premium-banner__meta">
                    <div class="rg-premium-banner__meta-label">Operating model</div>
                    <div class="rg-premium-banner__meta-value">4 stakeholder lanes</div>
                    <div class="rg-premium-banner__meta-copy">
                        Governor, executive, deputy, and examiner views align to the same intelligence backbone but prioritise different decisions.
                    </div>
                </div>
            </div>
        </section>

        <section class="rg-premium-hero" aria-labelledby="regulator-hub-title">
            <div class="rg-premium-hero__grid">
                <div>
                    <div class="rg-premium-hero__eyebrow">Oversight hub</div>
                    <h1 id="regulator-hub-title" class="rg-premium-hero__title">Choose the lens that matches the supervisory moment.</h1>
                    <p class="rg-premium-hero__subtitle">
                        Operational dashboards are separated from role-based cockpits so senior leadership can stay on posture,
                        while examiners and analysts work the queue with sharper focus.
                    </p>
                    <div class="rg-premium-badge-row">
                        <span class="rg-premium-chip rg-premium-chip--success">Inbox and filing triage</span>
                        <span class="rg-premium-chip rg-premium-chip--warning">Early warning surveillance</span>
                        <span class="rg-premium-chip rg-premium-chip--info">Stress and systemic analytics</span>
                        <span class="rg-premium-chip rg-premium-chip--danger">Cross-border escalation lanes</span>
                    </div>
                </div>
                <div class="rg-premium-hero__aside">
                    <div class="rg-premium-note">
                        <div class="rg-premium-note__label">Fastest route</div>
                        <div class="rg-premium-note__value">Governor cockpit</div>
                        <div class="rg-premium-note__copy">
                            Start with the sector pulse if you need the overall stability story, then drop into the executive and examiner lanes.
                        </div>
                    </div>
                    <div class="rg-premium-note">
                        <div class="rg-premium-note__label">Best for active supervision</div>
                        <div class="rg-premium-note__value">Inbox + Examiner</div>
                        <div class="rg-premium-note__copy">
                            Pair operational processing with the examiner queue when you need to convert signals into concrete supervisory action.
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section aria-labelledby="stakeholder-title">
            <h2 id="stakeholder-title" class="rg-premium-section-title">Stakeholder dashboards</h2>
            <p class="rg-premium-section-copy">
                Leadership and supervisory roles now get dedicated dashboards rather than sharing one crowded regulator home page.
            </p>
            <div class="rg-premium-action-grid" style="margin-top:16px;">
                @foreach (var card in StakeholderCards)
                {
                    <a class="rg-premium-link-card" href="@card.Href">
                        <div class="rg-premium-link-card__icon" style="@card.IconStyle">
                            @((MarkupString)card.IconSvg)
                        </div>
                        <h3 class="rg-premium-link-card__title">@card.Title</h3>
                        <p class="rg-premium-link-card__desc">@card.Description</p>
                        <div class="rg-premium-link-card__footer">
                            <span>@card.Footer</span>
                            <span class="rg-premium-link-card__arrow" aria-hidden="true">→</span>
                        </div>
                    </a>
                }
            </div>
        </section>

        <section aria-labelledby="operations-title">
            <h2 id="operations-title" class="rg-premium-section-title">Operational intelligence lanes</h2>
            <p class="rg-premium-section-copy">
                Use these workspaces for active monitoring, filing review, scenario analysis, and pan-African supervisory coordination.
            </p>
            <div class="rg-premium-action-grid" style="margin-top:16px;">
                @foreach (var card in OperationCards)
                {
                    <a class="rg-premium-link-card" href="@card.Href">
                        <div class="rg-premium-link-card__icon" style="@card.IconStyle">
                            @((MarkupString)card.IconSvg)
                        </div>
                        <h3 class="rg-premium-link-card__title">@card.Title</h3>
                        <p class="rg-premium-link-card__desc">@card.Description</p>
                        <div class="rg-premium-link-card__footer">
                            <span>@card.Footer</span>
                            <span class="rg-premium-link-card__arrow" aria-hidden="true">→</span>
                        </div>
                    </a>
                }
            </div>
        </section>
    </div>
</div>

