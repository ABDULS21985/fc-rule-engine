@page "/regulator/policies/compare"
@attribute [Authorize(Policy = "RegulatorOnly")]
@inject IImpactAssessmentEngine ImpactEngine
@inject IPolicyScenarioService ScenarioService
@inject RegulatorSessionService RegulatorSession
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ToastService Toast

<PageTitle>Compare Scenarios — Policy Simulation</PageTitle>

<PageHeader Title="Scenario Comparison"
            Subtitle="Compare impact assessment results across multiple simulation runs side by side."
            BackUrl="/regulator/policies">
</PageHeader>

<!-- Run Selector -->
<div class="rg-card">
    <h3 class="rg-section-title">Select Runs to Compare (2-4)</h3>
    <div class="rg-controls">
        <input class="rg-ps-input" placeholder="Run IDs, comma separated (e.g. 1,2,3)" @bind="_runIdsInput"
               style="max-width:400px;" />
        <button class="fc-btn fc-btn--primary" @onclick="LoadComparison" disabled="@_comparing">
            @(_comparing ? "Comparing..." : "Compare")
        </button>
    </div>
</div>

<SectionErrorBoundary Title="Couldn't load comparison data" ExternalError="@_loadException" OnRetry="LoadComparison">
    @if (_comparison is not null)
    {
        <!-- Summary Cards -->
        <div class="rg-ps-kpis" style="grid-template-columns:repeat(@_comparison.Scenarios.Count, 1fr);">
            @foreach (var col in _comparison.Scenarios)
            {
                <div class="rg-ps-kpi">
                    <span class="rg-ps-kpi-label">@col.ScenarioTitle</span>
                    <span class="rg-ps-kpi-value rg-ps-text-warning">@col.EntitiesWouldBreach breaches</span>
                    <span class="rg-ps-text-xs rg-ps-text-muted">Shortfall: @FormatCurrency(col.AggregateShortfall)</span>
                </div>
            }
        </div>

        <!-- Comparison Chart -->
        <div class="rg-card">
            <h3 class="rg-section-title">Breach Count Comparison</h3>
            <div class="rg-chart"><canvas id="compareBreachChart"></canvas></div>
        </div>

        <!-- Comparison Matrix -->
        <div class="rg-card">
            <h3 class="rg-section-title">Entity Comparison Matrix</h3>
            @if (_comparison.EntityRows.Count == 0)
            {
                <EmptyState Context="data"
                            Heading="No entity data"
                            Description="No entity data is available for the selected runs." />
            }
            else
            {
                <div class="rg-table-wrap">
                    <table class="rg-table rg-ps-compare-matrix">
                        <thead>
                            <tr>
                                <th>Institution</th>
                                <th>Type</th>
                                @foreach (var col in _comparison.Scenarios)
                                {
                                    <th>@col.ScenarioTitle</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _comparison.EntityRows.Take(100))
                            {
                                <tr>
                                    <td><strong>@row.InstitutionCode</strong></td>
                                    <td>@row.EntityType</td>
                                    @foreach (var col in _comparison.Scenarios)
                                    {
                                        <td>
                                            @if (row.CategoryByRunId.TryGetValue(col.RunId, out var cat))
                                            {
                                                <ImpactCategoryBadge Category="@cat" />
                                            }
                                            else
                                            {
                                                <span class="rg-muted">-</span>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (_comparison.EntityRows.Count > 100 || _comparison.IsTruncated)
                {
                    <p class="rg-ps-text-sm rg-ps-text-muted rg-ps-mt">
                        @if (_comparison.IsTruncated)
                        {
                            <span>Results are capped at 500 entities per comparison. Export individual run results for full data.</span>
                        }
                        else
                        {
                            <span>Showing 100 of @_comparison.EntityRows.Count entities.</span>
                        }
                    </p>
                }
            }
        </div>
    }
    else if (!_comparing && _loadException is null)
    {
        <EmptyState Context="data"
                    Heading="No comparison loaded"
                    Description="Enter two or more simulation run IDs above to compare their results side by side." />
    }
    else if (_comparing)
    {
        <div class="rg-ps-kpis">
                @for (var i = 0; i < 3; i++)
                {
                    <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Card" Index="i" />
                }
            </div>
            <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.TableRows" />
}
</SectionErrorBoundary>

@code {
    [SupplyParameterFromQuery(Name = "runs")] public string? InitialRunIds { get; set; }

    private int _regulatorId;
    private string _runIdsInput = string.Empty;
    private Exception? _loadException;
    private bool _comparing;
    private ScenarioComparisonResult? _comparison;
    private bool _chartRendered;

    protected override async Task OnInitializedAsync()
    {
        var session = await RegulatorSession.GetRequiredAsync();
        _regulatorId = session.RegulatorId;

        if (!string.IsNullOrWhiteSpace(InitialRunIds))
        {
            _runIdsInput = InitialRunIds;
            await LoadComparison();
        }
    }

    private async Task LoadComparison()
    {
        _loadException = null;
        var ids = _runIdsInput.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var runIds = new List<long>();
        foreach (var id in ids)
        {
            if (long.TryParse(id, out var val))
                runIds.Add(val);
        }

        if (runIds.Count < 2)
        {
            Toast.Error("Please enter at least 2 run IDs.");
            return;
        }

        _comparing = true;
        _chartRendered = false;
        StateHasChanged();
        try
        {
            _comparison = await ImpactEngine.CompareRunsAsync(runIds, _regulatorId);
            Toast.Success($"Compared {_comparison.Scenarios.Count} scenarios successfully.");
        }
        catch (Exception ex)
        {
            _loadException = ex;
            Toast.Error($"Comparison failed: {ex.Message}");
        }
        finally
        {
            _comparing = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_comparison is null || _chartRendered) return;
        _chartRendered = true;

        try
        {
            await JS.InvokeVoidAsync("renderChart", "compareBreachChart", "bar", new
            {
                labels = _comparison.Scenarios.Select(s => s.ScenarioTitle).ToArray(),
                datasets = new[]
                {
                    new
                    {
                        label = "Would Breach",
                        data = _comparison.Scenarios.Select(s => s.EntitiesWouldBreach).ToArray(),
                        backgroundColor = "#E69F00"
                    }
                }
            });
        }
        catch { }
    }

    private void GoBack() => Nav.NavigateTo("/regulator/policies");

    private static string FormatCurrency(decimal? value)
        => value.HasValue ? $"NGN {value.Value:N0}M" : "-";
}
