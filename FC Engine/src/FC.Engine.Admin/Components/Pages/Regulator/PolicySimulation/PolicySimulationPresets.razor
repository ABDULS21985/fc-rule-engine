@page "/regulator/policies/presets"
@attribute [Authorize(Policy = "RegulatorOnly")]
@inject IPolicyScenarioService ScenarioService
@inject RegulatorSessionService RegulatorSession
@inject NavigationManager Nav
@inject ToastService Toast
@using FC.Engine.Domain.Entities
@using FC.Engine.Infrastructure.Metadata
@using Microsoft.EntityFrameworkCore
@inject IServiceScopeFactory ScopeFactory

<PageTitle>Parameter Presets — Policy Simulation</PageTitle>

<PageHeader Title="Parameter Preset Library"
            Subtitle="Standard regulatory parameters from CBN, NDIC, and other regulators."
            BackUrl="/regulator/policies"
            CountBadge="@(!_loading ? _presets.Count : null)">
</PageHeader>

<!-- Filters -->
<div class="rg-card">
    <div class="rg-controls">
        <select @bind="_domainFilter" @bind:after="LoadAsync">
            <option value="">All Domains</option>
            @foreach (var d in Enum.GetValues<PolicyDomain>())
            {
                <option value="@d">@FormatDomain(d)</option>
            }
        </select>
        <select @bind="_regulatorFilter" @bind:after="LoadAsync">
            <option value="">All Regulators</option>
            <option value="CBN">CBN</option>
            <option value="NDIC">NDIC</option>
            <option value="SEC">SEC</option>
            <option value="NAICOM">NAICOM</option>
            <option value="PenCom">PenCom</option>
        </select>
        <input class="rg-ps-input" placeholder="Search parameters..." @bind="_search" @bind:after="LoadAsync"
               style="max-width:300px;" />
    </div>
</div>

<SectionErrorBoundary Title="Couldn't load parameter presets" ExternalError="@_loadException" OnRetry="LoadAsync">
    @if (_loading)
    {
        @for (var i = 0; i < 3; i++)
            {
                <div class="rg-card">
                    <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Heading" Index="i" />
                    <div class="rg-ps-preset-grid">
                        @for (var j = 0; j < 4; j++)
                        {
                            <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Card" Index="@(i * 4 + j)" />
                        }
                    </div>
                </div>
            }
}
    else if (_presets.Count == 0)
    {
        <EmptyState Context="data"
                    Heading="No parameter presets found"
                    Description="No presets match your current filters. Try adjusting your search criteria."
                    PrimaryActionLabel="Clear Filters"
                    OnPrimaryAction="ClearFilters" />
    }
    else
    {
        <!-- Group by domain -->
        @foreach (var group in _presets.GroupBy(p => p.PolicyDomain).OrderBy(g => g.Key))
        {
            <div class="rg-card">
                <h3 class="rg-section-title">
                    <DomainBadge Domain="@group.Key" />
                    <span style="margin-left:0.5rem;">@FormatDomain(group.Key)</span>
                    <span class="rg-ps-tab-badge">@group.Count()</span>
                </h3>
                <div class="rg-ps-preset-grid">
                    @foreach (var preset in group.OrderBy(p => p.ParameterCode))
                    {
                        <div class="rg-ps-preset-card">
                            <div class="rg-ps-preset-name">@preset.ParameterName</div>
                            <div class="rg-ps-preset-code">@preset.ParameterCode</div>
                            @if (!string.IsNullOrWhiteSpace(preset.Description))
                            {
                                <div class="rg-ps-preset-desc">@preset.Description</div>
                            }
                            <div class="rg-ps-preset-meta">
                                <span>Current: <strong>@preset.CurrentBaseline @FormatUnit(preset.Unit)</strong></span>
                                <span>@preset.RegulatorCode</span>
                                @if (!string.IsNullOrWhiteSpace(preset.ReturnLineReference))
                                {
                                    <span class="rg-ps-font-mono">@preset.ReturnLineReference</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</SectionErrorBoundary>

@code {
    private bool _loading = true;
    private Exception? _loadException;
    private string _domainFilter = string.Empty;
    private string _regulatorFilter = string.Empty;
    private string _search = string.Empty;
    private List<PolicyParameterPreset> _presets = new();

    protected override async Task OnInitializedAsync()
    {
        var session = await RegulatorSession.GetRequiredAsync();
        _regulatorFilter = session.RegulatorCode;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadException = null;
        StateHasChanged();
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<MetadataDbContext>();
            var query = db.Set<PolicyParameterPreset>().AsNoTracking().AsQueryable();

            if (!string.IsNullOrEmpty(_domainFilter))
            {
                var domain = Enum.Parse<PolicyDomain>(_domainFilter);
                query = query.Where(p => p.PolicyDomain == domain);
            }

            if (!string.IsNullOrEmpty(_regulatorFilter))
                query = query.Where(p => p.RegulatorCode == _regulatorFilter);

            if (!string.IsNullOrWhiteSpace(_search))
            {
                var term = _search.Trim().ToLower();
                query = query.Where(p =>
                    p.ParameterCode.ToLower().Contains(term) ||
                    p.ParameterName.ToLower().Contains(term));
            }

            _presets = await query.OrderBy(p => p.PolicyDomain).ThenBy(p => p.ParameterCode).ToListAsync();
        }
        catch (Exception ex) when (ex.IsMissingSchemaObject())
        {
            _presets = new();
        }
        catch (Exception ex)
        {
            _loadException = ex;
            _presets = new();
            Toast.Error($"Failed to load presets: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ClearFilters()
    {
        _domainFilter = string.Empty;
        _regulatorFilter = string.Empty;
        _search = string.Empty;
        await LoadAsync();
    }

    private static string FormatDomain(PolicyDomain d) => d switch
    {
        PolicyDomain.CapitalAdequacy => "Capital Adequacy",
        PolicyDomain.Liquidity => "Liquidity",
        PolicyDomain.Leverage => "Leverage",
        PolicyDomain.FX => "FX",
        PolicyDomain.RiskManagement => "Risk Management",
        _ => d.ToString()
    };

    private void GoBack() => Nav.NavigateTo("/regulator/policies");

    private static string FormatUnit(ParameterUnit unit) => unit switch
    {
        ParameterUnit.Percentage => "%",
        ParameterUnit.Bps => "bps",
        ParameterUnit.Ratio => "x",
        _ => ""
    };
}
