@page "/regulator/dashboards/deputy"
@attribute [Authorize(Policy = "RegulatorOnly")]
@inject FC.Engine.Admin.Services.Dashboards.StakeholderDashboardService DashboardService
@inject IJSRuntime JS
@inject ILogger<FC.Engine.Admin.Components.Pages.Regulator.Dashboards.DeputyGovernorDashboard> Logger

<PageTitle>Deputy Governor Dashboard</PageTitle>

<PageHeader Title="Deputy Governor Dashboard"
            Subtitle="Portfolio oversight, escalation control, remediation performance, and intervention sequencing."
            BackUrl="/regulator/dashboards/governor"
            StatusBadge="@ResolveStatusBadge()"
            StatusVariant="@ResolveStatusVariant()">
    <PrimaryAction>
        <button class="fc-btn fc-btn--primary" @onclick="ReloadAsync" disabled="@_loading">
            @if (_loading) { <span class="fc-btn__spinner"></span> }
            Refresh
        </button>
    </PrimaryAction>
    <SecondaryActions>
        <button class="fc-btn fc-btn--outline" @onclick='() => JS.InvokeVoidAsync("print")'>Print</button>
    </SecondaryActions>
</PageHeader>

<div class="fc-page">
    <SectionErrorBoundary Title="Failed to load deputy dashboard" ExternalError="@_loadException" OnRetry="ReloadAsync">
        @if (_loading)
        {
            <div class="rg-premium-flow">
                <div class="rg-premium-banner"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="138px" /></div>
                <div class="rg-premium-stat-grid rg-premium-stat-grid--5">
                    @for (var i = 0; i < 5; i++)
                    {
                        <div class="rg-premium-stat"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="140px" /></div>
                    }
                </div>
                <div class="rg-premium-content-grid">
                    <div class="rg-premium-main">
                        <div class="rg-premium-dual-grid">
                            <div class="rg-premium-panel"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="320px" /></div>
                            <div class="rg-premium-panel"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="320px" /></div>
                        </div>
                        <div class="rg-premium-panel"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="420px" /></div>
                        <div class="rg-premium-panel"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="420px" /></div>
                    </div>
                    <div class="rg-premium-side">
                        <div class="rg-premium-panel"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="260px" /></div>
                        <div class="rg-premium-panel"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="320px" /></div>
                        <div class="rg-premium-panel"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="280px" /></div>
                    </div>
                </div>
            </div>
        }
        else if (_data is null)
        {
            <EmptyState Context="data" Heading="No deputy dashboard data" Description="Refresh the Intelligence Hub to generate stakeholder data." />
        }
        else
        {
            <div class="rg-premium-flow">
                @* ── Banner ────────────────────────────────────────────── *@
                <section class="rg-premium-banner @ResolveBannerTone()" aria-label="Deputy governor posture">
                    <div class="rg-premium-banner__grid">
                        <div>
                            <div class="rg-premium-banner__eyebrow">Intervention pulse</div>
                            <h2 class="rg-premium-banner__headline">@BuildBannerHeadline()</h2>
                            <p class="rg-premium-banner__detail">@BuildBannerDetail()</p>
                        </div>
                        <div class="rg-premium-banner__meta">
                            <div class="rg-premium-banner__meta-label">Escalation posture</div>
                            <div class="rg-premium-banner__meta-value">@($"{_data.Escalations} escalations")</div>
                            <div class="rg-premium-banner__meta-copy">@BuildEscalationCopy()</div>
                        </div>
                    </div>
                </section>

                @* ── Hero ──────────────────────────────────────────────── *@
                <section class="rg-premium-hero" aria-labelledby="deputy-hero-title">
                    <div class="rg-premium-hero__grid">
                        <div>
                            <div class="rg-premium-hero__eyebrow">Deputy governor control room</div>
                            <h1 id="deputy-hero-title" class="rg-premium-hero__title">Sequence interventions before they become governance bottlenecks.</h1>
                            <p class="rg-premium-hero__subtitle">
                                This view is about queue control: what is unresolved, where escalations are forming, how much remediation is closing,
                                and which institutions deserve direct portfolio management attention.
                            </p>
                            <div class="rg-premium-badge-row">
                                <span class="rg-premium-chip rg-premium-chip--info">@($"{_data.PortfolioSize} institutions in portfolio")</span>
                                <span class="rg-premium-chip @BuildEscalationChipClass()">@($"{_data.Escalations} escalations live")</span>
                                <span class="rg-premium-chip @BuildRemediationChipClass()">@($"{_data.RemediationRatePercent:F1}% remediated")</span>
                                @if (_data.OverdueInterventions > 0)
                                {
                                    <span class="rg-premium-chip rg-premium-chip--danger">@($"{_data.OverdueInterventions} overdue")</span>
                                }
                                @if (_data.DueSoonInterventions > 0)
                                {
                                    <span class="rg-premium-chip rg-premium-chip--warning">@($"{_data.DueSoonInterventions} due within 7 days")</span>
                                }
                            </div>
                        </div>
                        <div class="rg-premium-hero__aside">
                            <div class="rg-premium-note">
                                <div class="rg-premium-note__label">Unresolved pressure</div>
                                <div class="rg-premium-note__value">@_data.UnresolvedIssues</div>
                                <div class="rg-premium-note__copy">
                                    Combined open obligations, resilience incidents, and alert load still outstanding across the portfolio.
                                </div>
                            </div>
                            <div class="rg-premium-note">
                                <div class="rg-premium-note__label">Dominant domain</div>
                                <div class="rg-premium-note__value">@BuildDominantDomainLabel()</div>
                                <div class="rg-premium-note__copy">@BuildDominantDomainCopy()</div>
                            </div>
                        </div>
                    </div>
                </section>

                @* ── Stat cards (5-up) ─────────────────────────────────── *@
                <section class="rg-premium-stat-grid rg-premium-stat-grid--5" aria-label="Deputy governor metrics">
                    <article class="rg-premium-stat">
                        <div class="rg-premium-stat__icon">
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2a6 6 0 0 0-6 6v1H3a1 1 0 0 0 0 2h1v1a6 6 0 0 0 12 0v-1h1a1 1 0 1 0 0-2h-1V8a6 6 0 0 0-6-6Zm-4 6a4 4 0 1 1 8 0v4a4 4 0 0 1-8 0V8Z" fill="currentColor"/></svg>
                        </div>
                        <div class="rg-premium-stat__label">Portfolio size</div>
                        <div class="rg-premium-stat__value">@_data.PortfolioSize</div>
                        <div class="rg-premium-stat__note">Institutions currently routed into this portfolio oversight lane.</div>
                    </article>
                    <article class="rg-premium-stat">
                        <div class="rg-premium-stat__icon rg-premium-stat__icon--warning">
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2a8 8 0 1 0 0 16 8 8 0 0 0 0-16Zm-.75 4.75a.75.75 0 0 1 1.5 0v4a.75.75 0 0 1-1.5 0v-4ZM10 14a1 1 0 1 1 0-2 1 1 0 0 1 0 2Z" fill="currentColor"/></svg>
                        </div>
                        <div class="rg-premium-stat__label">Unresolved issues</div>
                        <div class="rg-premium-stat__value @BuildIssueValueClass()">@_data.UnresolvedIssues</div>
                        <div class="rg-premium-stat__note">Current unresolved pressure needing remediation follow-through or re-sequencing.</div>
                    </article>
                    <article class="rg-premium-stat">
                        <div class="rg-premium-stat__icon rg-premium-stat__icon--danger">
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3.5 2A1.5 1.5 0 0 0 2 3.5v13A1.5 1.5 0 0 0 3.5 18h13a1.5 1.5 0 0 0 1.5-1.5v-13A1.5 1.5 0 0 0 16.5 2h-13ZM10 6a.75.75 0 0 1 .75.75v4.5a.75.75 0 0 1-1.5 0v-4.5A.75.75 0 0 1 10 6Zm0 8a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" fill="currentColor"/></svg>
                        </div>
                        <div class="rg-premium-stat__label">Escalations</div>
                        <div class="rg-premium-stat__value @BuildEscalationValueClass()">@_data.Escalations</div>
                        <div class="rg-premium-stat__note">Critical and high-priority interventions requiring deputy governor attention.</div>
                    </article>
                    <article class="rg-premium-stat">
                        <div class="rg-premium-stat__icon rg-premium-stat__icon--success">
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2a8 8 0 1 0 0 16 8 8 0 0 0 0-16Zm3.03 6.53-3.5 3.5a.75.75 0 0 1-1.06 0l-1.5-1.5a.75.75 0 1 1 1.06-1.06L9 10.44l2.97-2.97a.75.75 0 1 1 1.06 1.06Z" fill="currentColor"/></svg>
                        </div>
                        <div class="rg-premium-stat__label">Remediation rate</div>
                        <div class="rg-premium-stat__value @BuildRemediationValueClass()">@($"{_data.RemediationRatePercent:F1}%")</div>
                        <div class="rg-deputy-remediation-bar" title="@($"{_data.ResolvedCount} resolved of {_data.TotalInterventions} total")">
                            <div class="rg-deputy-remediation-bar__fill @BuildRemediationBarClass()" style="width: @($"{Math.Min(_data.RemediationRatePercent, 100):F0}%")"></div>
                        </div>
                        <div class="rg-premium-stat__note">@($"{_data.ResolvedCount} of {_data.TotalInterventions}") interventions resolved.</div>
                    </article>
                    <article class="rg-premium-stat">
                        <div class="rg-premium-stat__icon rg-premium-stat__icon--info">
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2a8 8 0 1 0 0 16 8 8 0 0 0 0-16Zm.75 4.75v2.5h2.5a.75.75 0 0 1 0 1.5h-2.5v2.5a.75.75 0 0 1-1.5 0v-2.5h-2.5a.75.75 0 0 1 0-1.5h2.5v-2.5a.75.75 0 0 1 1.5 0Z" fill="currentColor"/></svg>
                        </div>
                        <div class="rg-premium-stat__label">Queue depth</div>
                        <div class="rg-premium-stat__value">@_data.TotalInterventions</div>
                        <div class="rg-premium-stat__note">
                            @if (_data.OverdueInterventions > 0)
                            {
                                <span class="fc-text-danger">@_data.OverdueInterventions overdue</span><span> · </span>
                            }
                            @if (_data.DueSoonInterventions > 0)
                            {
                                <span class="fc-text-warning">@_data.DueSoonInterventions due soon</span>
                            }
                            else
                            {
                                <span>No items due within 7 days.</span>
                            }
                        </div>
                    </article>
                </section>

                @* ── Main + Sidebar ────────────────────────────────────── *@
                <section class="rg-premium-content-grid rg-cc-shell rg-cc-shell--deputy">
                    <div class="rg-premium-main">

                        @* ── Dual charts: Domain + Priority ───────────── *@
                        <div class="rg-premium-dual-grid">
                            <section class="rg-premium-panel">
                                <div class="rg-premium-panel__header">
                                    <div>
                                        <div class="rg-premium-panel__eyebrow">Issue concentration</div>
                                        <h2 class="rg-premium-panel__title">Issue distribution by domain</h2>
                                        <p class="rg-premium-panel__subtitle">Spot which operating lane is absorbing the largest share of queue pressure.</p>
                                    </div>
                                    <div class="rg-premium-panel__metric">
                                        <span class="rg-premium-panel__metric-label">Largest lane</span>
                                        @BuildDominantDomainLabel()
                                    </div>
                                </div>
                                <div class="rg-premium-panel__body rg-premium-panel__body--chart">
                                    <canvas id="deputyDomainChart" style="max-height:260px;"></canvas>
                                </div>
                            </section>

                            <section class="rg-premium-panel">
                                <div class="rg-premium-panel__header">
                                    <div>
                                        <div class="rg-premium-panel__eyebrow">Escalation mix</div>
                                        <h2 class="rg-premium-panel__title">Priority distribution</h2>
                                        <p class="rg-premium-panel__subtitle">Whether escalation pressure is clustering in critical lanes or spread across lower severity.</p>
                                    </div>
                                    <div class="rg-premium-panel__metric">
                                        <span class="rg-premium-panel__metric-label">Dominant band</span>
                                        @BuildTopPriorityLabel()
                                    </div>
                                </div>
                                <div class="rg-premium-panel__body rg-premium-panel__body--chart">
                                    <canvas id="deputyPriorityChart" style="max-height:260px;"></canvas>
                                </div>
                            </section>
                        </div>

                        @* ── Intervention queue ───────────────────────── *@
                        <section class="rg-premium-panel">
                            <div class="rg-premium-panel__header">
                                <div>
                                    <div class="rg-premium-panel__eyebrow">Intervention sequencing</div>
                                    <h2 class="rg-premium-panel__title">Intervention queue</h2>
                                    <p class="rg-premium-panel__subtitle">The queue is sorted toward due-date urgency so escalation decisions stay operationally grounded.</p>
                                </div>
                                <div class="rg-premium-panel__metric">
                                    <span class="rg-premium-panel__metric-label">Next due</span>
                                    @(BuildNextDueDate())
                                </div>
                            </div>
                            <div class="rg-premium-panel__body">
                                @if (_data.InterventionQueue.Count == 0)
                                {
                                    <div class="rg-premium-empty">No active interventions are currently queued.</div>
                                }
                                else
                                {
                                    <div class="rg-cc-queue-grid">
                                        @foreach (var item in _data.InterventionQueue.Take(8))
                                        {
                                            var days = (item.DueDate.Date - DateTime.UtcNow.Date).Days;
                                            <article class="rg-cc-queue-card">
                                                <div class="rg-cc-queue-card__top">
                                                    <span class="fc-badge fc-badge--neutral">@item.Domain</span>
                                                    <span class="fc-badge @PriorityBadge(item.Priority)">@item.Priority</span>
                                                </div>
                                                <h3 class="rg-cc-queue-card__title">@item.Subject</h3>
                                                <p class="rg-cc-queue-card__copy">@item.NextAction</p>
                                                <div class="rg-cc-statline">
                                                    <span class="rg-cc-statline__item">@item.OwnerLane</span>
                                                    <span class="rg-cc-statline__item">@DueStateLabel(item.Signal, days)</span>
                                                </div>
                                                <div class="rg-premium-list__tags">
                                                    <span class="fc-badge @SignalBadge(item.Signal)">@item.Signal</span>
                                                    <span class="fc-badge fc-badge--neutral">@item.DueDate.ToString("dd MMM yyyy")</span>
                                                </div>
                                            </article>
                                        }
                                    </div>
                                }
                            </div>
                        </section>

                        @* ── Institution scorecards ───────────────────── *@
                        <section class="rg-premium-panel">
                            <div class="rg-premium-panel__header">
                                <div>
                                    <div class="rg-premium-panel__eyebrow">Portfolio ranking</div>
                                    <h2 class="rg-premium-panel__title">Institution scorecards</h2>
                                    <p class="rg-premium-panel__subtitle">Compare institutions by overdue pressure, due-soon obligations, capital strength, and supervisory priority.</p>
                                </div>
                                <div class="rg-premium-panel__metric">
                                    <span class="rg-premium-panel__metric-label">Top pressure</span>
                                    @(_data.InstitutionScorecards.FirstOrDefault()?.InstitutionName ?? "No queue")
                                </div>
                            </div>
                            <div class="rg-premium-panel__body">
                                @if (_data.InstitutionScorecards.Count == 0)
                                {
                                    <div class="rg-premium-empty">No institution scorecards are currently available.</div>
                                }
                                else
                                {
                                    <div class="rg-cc-institution-stack">
                                        @foreach (var ranked in _data.InstitutionScorecards.Take(10).Select((institution, index) => new { institution, index }))
                                        {
                                            var pressure = CombinedPressure(ranked.institution);
                                            <article class="rg-cc-institution-card">
                                                <div class="rg-cc-institution-card__top">
                                                    <div>
                                                        <div class="rg-cc-institution-card__rank">#@(ranked.index + 1)</div>
                                                        <h3 class="rg-cc-institution-card__title">@ranked.institution.InstitutionName</h3>
                                                        <p class="rg-cc-institution-card__copy">@BuildInstitutionPressureCopy(ranked.institution)</p>
                                                    </div>
                                                    <div class="rg-cc-kpi-pack">
                                                        <div class="rg-cc-kpi-pack__value">@pressure</div>
                                                        <div class="rg-cc-kpi-pack__label">Pressure</div>
                                                    </div>
                                                </div>
                                                <div class="rg-cc-pressure-bar" aria-label="Portfolio pressure breakdown">
                                                    @if (ranked.institution.OverdueObligations > 0)
                                                    {
                                                        <span class="rg-cc-pressure-bar__segment rg-cc-pressure-bar__segment--danger" style="flex:@ranked.institution.OverdueObligations"></span>
                                                    }
                                                    @if (ranked.institution.DueSoonObligations > 0)
                                                    {
                                                        <span class="rg-cc-pressure-bar__segment rg-cc-pressure-bar__segment--warning" style="flex:@ranked.institution.DueSoonObligations"></span>
                                                    }
                                                    @if (ranked.institution.OpenResilienceIncidents > 0)
                                                    {
                                                        <span class="rg-cc-pressure-bar__segment rg-cc-pressure-bar__segment--info" style="flex:@ranked.institution.OpenResilienceIncidents"></span>
                                                    }
                                                    @if (ranked.institution.OpenSecurityAlerts > 0)
                                                    {
                                                        <span class="rg-cc-pressure-bar__segment rg-cc-pressure-bar__segment--purple" style="flex:@ranked.institution.OpenSecurityAlerts"></span>
                                                    }
                                                </div>
                                                <div class="rg-cc-statline">
                                                    <span class="rg-cc-statline__item">@ranked.institution.LicenceType</span>
                                                    <span class="rg-cc-statline__item">@(ranked.institution.CapitalScore?.ToString("F1") ?? "No capital score")</span>
                                                    <span class="rg-cc-statline__item">@BuildInstitutionActionLabel(ranked.institution)</span>
                                                </div>
                                                <div class="rg-premium-list__tags">
                                                    <span class="fc-badge @PriorityBadge(ranked.institution.Priority)">@ranked.institution.Priority</span>
                                                    @if (ranked.institution.OverdueObligations > 0)
                                                    {
                                                        <span class="fc-badge fc-badge--danger">@($"{ranked.institution.OverdueObligations} overdue")</span>
                                                    }
                                                    @if (ranked.institution.DueSoonObligations > 0)
                                                    {
                                                        <span class="fc-badge fc-badge--warning">@($"{ranked.institution.DueSoonObligations} due soon")</span>
                                                    }
                                                    @if (ranked.institution.OpenResilienceIncidents > 0)
                                                    {
                                                        <span class="fc-badge fc-badge--info">@($"{ranked.institution.OpenResilienceIncidents} incidents")</span>
                                                    }
                                                    @if (ranked.institution.OpenSecurityAlerts > 0)
                                                    {
                                                        <span class="fc-badge fc-badge--purple">@($"{ranked.institution.OpenSecurityAlerts} alerts")</span>
                                                    }
                                                </div>
                                            </article>
                                        }
                                    </div>
                                }
                            </div>
                        </section>
                    </div>

                    @* ── Sidebar ───────────────────────────────────────── *@
                    <aside class="rg-premium-side">
                        @* ── Remediation gauge card ────────────────────── *@
                        <section class="rg-premium-panel">
                            <div class="rg-premium-panel__header">
                                <div>
                                    <div class="rg-premium-panel__eyebrow">Remediation throughput</div>
                                    <h2 class="rg-premium-panel__title">Queue resolution</h2>
                                </div>
                            </div>
                            <div class="rg-premium-panel__body" style="text-align:center;padding-block:var(--space-6);">
                                <div class="rg-deputy-gauge" style="--pct:@($"{Math.Min(_data.RemediationRatePercent, 100):F0}")">
                                    <svg viewBox="0 0 120 120" class="rg-deputy-gauge__ring">
                                        <circle cx="60" cy="60" r="52" fill="none" stroke="var(--cbn-border, #e2e8f0)" stroke-width="10"/>
                                        <circle cx="60" cy="60" r="52" fill="none"
                                                stroke="@RemediationGaugeColor()"
                                                stroke-width="10"
                                                stroke-linecap="round"
                                                stroke-dasharray="@($"{_data.RemediationRatePercent / 100m * 326.7m:F1}") 326.7"
                                                transform="rotate(-90 60 60)"/>
                                    </svg>
                                    <div class="rg-deputy-gauge__label">
                                        <span class="rg-deputy-gauge__value">@($"{_data.RemediationRatePercent:F0}")%</span>
                                        <span class="rg-deputy-gauge__caption">resolved</span>
                                    </div>
                                </div>
                                <div class="rg-deputy-gauge-legend">
                                    <div class="rg-deputy-gauge-legend__item">
                                        <span class="rg-deputy-gauge-legend__dot rg-deputy-gauge-legend__dot--resolved"></span>
                                        @_data.ResolvedCount resolved
                                    </div>
                                    <div class="rg-deputy-gauge-legend__item">
                                        <span class="rg-deputy-gauge-legend__dot rg-deputy-gauge-legend__dot--open"></span>
                                        @(_data.TotalInterventions - _data.ResolvedCount) open
                                    </div>
                                </div>
                            </div>
                        </section>

                        @* ── Due-soon preview cards ────────────────────── *@
                        <section class="rg-premium-panel">
                            <div class="rg-premium-panel__header">
                                <div>
                                    <div class="rg-premium-panel__eyebrow">Due-soon rail</div>
                                    <h2 class="rg-premium-panel__title">Immediate intervention preview</h2>
                                    <p class="rg-premium-panel__subtitle">Fast-read cards for the next interventions likely to need explicit sequencing or escalation decisions.</p>
                                </div>
                            </div>
                            <div class="rg-premium-panel__body">
                                @if (_data.InterventionQueue.Count == 0)
                                {
                                    <div class="rg-premium-empty">The intervention queue is currently clear.</div>
                                }
                                else
                                {
                                    <div class="rg-premium-list">
                                        @foreach (var item in _data.InterventionQueue.Take(5))
                                        {
                                            var itemDays = (item.DueDate.Date - DateTime.UtcNow.Date).Days;
                                            <article class="rg-premium-list__item @(itemDays < 0 ? "rg-premium-list__item--overdue" : string.Empty)">
                                                <div class="rg-premium-list__top">
                                                    <div class="rg-premium-list__heading">@item.Subject</div>
                                                    <span class="fc-badge @PriorityBadge(item.Priority)">@item.Priority</span>
                                                </div>
                                                <div class="rg-premium-list__meta">@item.NextAction</div>
                                                <div class="rg-premium-list__tags">
                                                    <span class="fc-badge fc-badge--neutral">@item.Domain</span>
                                                    <span class="fc-badge @SignalBadge(item.Signal)">@item.Signal</span>
                                                    @if (item.Signal != "Resolved")
                                                    {
                                                        @if (itemDays < 0)
                                                        {
                                                            <span class="fc-badge fc-badge--danger">@Math.Abs(itemDays)d overdue</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="fc-badge fc-badge--neutral">@item.DueDate.ToString("dd MMM")</span>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="fc-badge fc-badge--neutral">@item.DueDate.ToString("dd MMM")</span>
                                                    }
                                                </div>
                                            </article>
                                        }
                                    </div>
                                }
                            </div>
                        </section>

                        @* ── Portfolio pressure cards ──────────────────── *@
                        <section class="rg-premium-panel">
                            <div class="rg-premium-panel__header">
                                <div>
                                    <div class="rg-premium-panel__eyebrow">Priority spread</div>
                                    <h2 class="rg-premium-panel__title">Portfolio pressure cards</h2>
                                    <p class="rg-premium-panel__subtitle">Institutions carrying the heaviest open obligation load.</p>
                                </div>
                            </div>
                            <div class="rg-premium-panel__body">
                                @if (_data.InstitutionScorecards.Count == 0)
                                {
                                    <div class="rg-premium-empty">Institution scorecards will appear here after the next intelligence refresh.</div>
                                }
                                else
                                {
                                    <div class="rg-premium-list">
                                        @foreach (var institution in _data.InstitutionScorecards.Take(5))
                                        {
                                            var totalPressure = institution.OverdueObligations + institution.DueSoonObligations + institution.OpenResilienceIncidents + institution.OpenSecurityAlerts;
                                            <article class="rg-premium-list__item">
                                                <div class="rg-premium-list__top">
                                                    <div class="rg-premium-list__heading">@institution.InstitutionName</div>
                                                    <span class="fc-badge @PriorityBadge(institution.Priority)">@institution.Priority</span>
                                                </div>
                                                <div class="rg-premium-list__meta">@institution.Summary</div>
                                                @if (totalPressure > 0)
                                                {
                                                    <div class="rg-deputy-pressure-bar" title="@($"Combined pressure: {totalPressure} items")">
                                                        @if (institution.OverdueObligations > 0)
                                                        {
                                                            <div class="rg-deputy-pressure-bar__seg rg-deputy-pressure-bar__seg--danger"
                                                                 style="flex:@institution.OverdueObligations"
                                                                 title="@($"{institution.OverdueObligations} overdue")"></div>
                                                        }
                                                        @if (institution.DueSoonObligations > 0)
                                                        {
                                                            <div class="rg-deputy-pressure-bar__seg rg-deputy-pressure-bar__seg--warning"
                                                                 style="flex:@institution.DueSoonObligations"
                                                                 title="@($"{institution.DueSoonObligations} due soon")"></div>
                                                        }
                                                        @if (institution.OpenResilienceIncidents > 0)
                                                        {
                                                            <div class="rg-deputy-pressure-bar__seg rg-deputy-pressure-bar__seg--info"
                                                                 style="flex:@institution.OpenResilienceIncidents"
                                                                 title="@($"{institution.OpenResilienceIncidents} incidents")"></div>
                                                        }
                                                        @if (institution.OpenSecurityAlerts > 0)
                                                        {
                                                            <div class="rg-deputy-pressure-bar__seg rg-deputy-pressure-bar__seg--purple"
                                                                 style="flex:@institution.OpenSecurityAlerts"
                                                                 title="@($"{institution.OpenSecurityAlerts} alerts")"></div>
                                                        }
                                                    </div>
                                                }
                                                <div class="rg-premium-list__tags">
                                                    <span class="fc-badge fc-badge--neutral">@institution.LicenceType</span>
                                                    @if (institution.OverdueObligations > 0)
                                                    {
                                                        <span class="fc-badge fc-badge--danger">@($"{institution.OverdueObligations} overdue")</span>
                                                    }
                                                    @if (institution.DueSoonObligations > 0)
                                                    {
                                                        <span class="fc-badge fc-badge--warning">@($"{institution.DueSoonObligations} due soon")</span>
                                                    }
                                                </div>
                                            </article>
                                        }
                                    </div>
                                }
                            </div>
                        </section>

                        @* ── Activity timeline ─────────────────────────── *@
                        <section class="rg-premium-panel">
                            <div class="rg-premium-panel__header">
                                <div>
                                    <div class="rg-premium-panel__eyebrow">Activity rail</div>
                                    <h2 class="rg-premium-panel__title">Recent supervisory movement</h2>
                                    <p class="rg-premium-panel__subtitle">The latest significant activity captured across the portfolio.</p>
                                </div>
                            </div>
                            <div class="rg-premium-panel__body">
                                @if (_data.RecentActivity.Count == 0)
                                {
                                    <div class="rg-premium-empty">No recent supervisory events are available yet.</div>
                                }
                                else
                                {
                                    <div class="rg-premium-list">
                                        @foreach (var activity in _data.RecentActivity.Take(8))
                                        {
                                            <article class="rg-premium-list__item">
                                                <div class="rg-premium-list__top">
                                                    <div class="rg-premium-list__heading">@activity.Title</div>
                                                    <span class="fc-badge @SeverityBadge(activity.Severity)">@activity.Severity</span>
                                                </div>
                                                <div class="rg-premium-list__meta">@activity.Detail</div>
                                                <div class="rg-premium-list__tags">
                                                    <span class="fc-badge fc-badge--neutral">@activity.Domain</span>
                                                    <span class="fc-badge fc-badge--neutral">@activity.HappenedAt.ToString("dd MMM HH:mm")</span>
                                                </div>
                                            </article>
                                        }
                                    </div>
                                }
                            </div>
                        </section>
                    </aside>
                </section>
            </div>
        }
    </SectionErrorBoundary>
</div>

@code {
    private bool _loading = true;
    private bool _chartsRendered;
    private Exception? _loadException;
    private FC.Engine.Admin.Services.Dashboards.DeputyGovernorDashboardData? _data;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_chartsRendered && _data is not null)
        {
            _chartsRendered = true;
            await RenderChartsAsync();
        }
    }

    private async Task RenderChartsAsync()
    {
        if (_data is null) return;

        try
        {
            if (_data.DomainDistribution.Count > 0)
            {
                await JS.InvokeVoidAsync("fcCharts.init", "deputyDomainChart", new
                {
                    type = "bar",
                    labels = _data.DomainDistribution.Select(d => d.Label).ToArray(),
                    datasets = new object[]
                    {
                        new { label = "Issues", data = _data.DomainDistribution.Select(d => d.Count).ToArray(), color = "primary" }
                    }
                });
            }

            if (_data.PriorityDistribution.Count > 0)
            {
                await JS.InvokeVoidAsync("fcCharts.init", "deputyPriorityChart", new
                {
                    type = "doughnut",
                    labels = _data.PriorityDistribution.Select(p => p.Label).ToArray(),
                    data = _data.PriorityDistribution.Select(p => p.Count).ToArray(),
                    colors = _data.PriorityDistribution.Select(p => PriorityColor(p.Label)).ToArray()
                });
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Deputy Governor dashboard chart rendering failed");
        }
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _loadException = null;
        _chartsRendered = false;

        try
        {
            _data = await DashboardService.GetDeputyGovernorDashboardAsync();
        }
        catch (Exception ex)
        {
            _loadException = ex;
        }
        finally
        {
            _loading = false;
        }
    }

    private string ResolveStatusBadge()
    {
        if (_loading) return "Refreshing";
        if (_data is null) return "Awaiting data";
        if (_data.Escalations > 0) return $"{_data.Escalations} escalations";
        return _data.RemediationRatePercent >= 80m ? "Queue controlled" : "Monitoring";
    }

    private string ResolveStatusVariant()
    {
        if (_data is null) return "neutral";
        if (_data.Escalations >= 5 || _data.RemediationRatePercent < 50m) return "danger";
        if (_data.Escalations > 0 || _data.UnresolvedIssues > 0 || _data.RemediationRatePercent < 80m) return "warning";
        return "success";
    }

    private string ResolveBannerTone()
    {
        if (_data is null) return "rg-premium-banner--info";
        if (_data.Escalations >= 5 || _data.RemediationRatePercent < 50m) return "rg-premium-banner--danger";
        if (_data.Escalations > 0 || _data.UnresolvedIssues > 0 || _data.RemediationRatePercent < 80m) return "rg-premium-banner--warning";
        return "rg-premium-banner--success";
    }

    private string BuildBannerHeadline()
    {
        if (_data is null) return "Refreshing intervention posture.";
        if (_data.Escalations >= 5) return "Escalation pressure is high enough to dominate portfolio management today.";
        if (_data.RemediationRatePercent < 50m) return "Remediation throughput is lagging the pace of new supervisory pressure.";
        if (_data.OverdueInterventions > 0) return $"{_data.OverdueInterventions} interventions are past their due date and need immediate sequencing.";
        return _data.UnresolvedIssues > 0
            ? "The queue is manageable, but unresolved issues still require deliberate sequencing."
            : "Intervention pressure is currently under control.";
    }

    private string BuildBannerDetail()
    {
        if (_data is null) return string.Empty;
        return $"The portfolio spans {_data.PortfolioSize} institutions, {_data.UnresolvedIssues} unresolved issues, and {_data.InterventionQueue.Count} queued interventions.";
    }

    private string BuildEscalationCopy()
    {
        if (_data is null) return string.Empty;
        return _data.Escalations == 0
            ? "No critical or high-priority interventions are currently waiting for escalation."
            : $"{_data.Escalations} intervention items are sitting in critical or high-priority lanes and may need direct deputy governor steering.";
    }

    private string BuildDominantDomainLabel()
    {
        var dominant = _data?.DomainDistribution.OrderByDescending(x => x.Count).FirstOrDefault();
        return dominant is null ? "Balanced" : dominant.Label;
    }

    private string BuildDominantDomainCopy()
    {
        var dominant = _data?.DomainDistribution.OrderByDescending(x => x.Count).FirstOrDefault();
        return dominant is null
            ? "Issue pressure is currently spread evenly across domains."
            : $"{dominant.Count} queued items are concentrated in the {dominant.Label.ToLowerInvariant()} lane.";
    }

    private string BuildTopPriorityLabel()
    {
        var top = _data?.PriorityDistribution.OrderByDescending(x => x.Count).FirstOrDefault();
        return top is null ? "Balanced" : $"{top.Label} ({top.Count})";
    }

    private string BuildNextDueDate()
    {
        var nextDue = _data?.InterventionQueue.Where(i => i.Signal != "Resolved").OrderBy(x => x.DueDate).FirstOrDefault();
        return nextDue is null ? "No due date" : nextDue.DueDate.ToString("dd MMM");
    }

    private string BuildIssueValueClass() =>
        _data is null ? string.Empty :
        _data.UnresolvedIssues == 0 ? "rg-premium-stat__value--success" :
        _data.UnresolvedIssues < 10 ? "rg-premium-stat__value--warning" :
        "rg-premium-stat__value--danger";

    private string BuildEscalationValueClass() =>
        _data is null ? string.Empty :
        _data.Escalations == 0 ? "rg-premium-stat__value--success" :
        _data.Escalations < 5 ? "rg-premium-stat__value--warning" :
        "rg-premium-stat__value--danger";

    private string BuildRemediationValueClass() =>
        _data is null ? string.Empty :
        _data.RemediationRatePercent >= 80m ? "rg-premium-stat__value--success" :
        _data.RemediationRatePercent >= 50m ? "rg-premium-stat__value--warning" :
        "rg-premium-stat__value--danger";

    private string BuildRemediationBarClass() =>
        _data is null ? string.Empty :
        _data.RemediationRatePercent >= 80m ? "rg-deputy-remediation-bar__fill--success" :
        _data.RemediationRatePercent >= 50m ? "rg-deputy-remediation-bar__fill--warning" :
        "rg-deputy-remediation-bar__fill--danger";

    private string RemediationGaugeColor() =>
        _data is null ? "#9CA3AF" :
        _data.RemediationRatePercent >= 80m ? "#16a34a" :
        _data.RemediationRatePercent >= 50m ? "#d97706" :
        "#dc2626";

    private string BuildEscalationChipClass() =>
        _data is null ? "rg-premium-chip--info" :
        _data.Escalations == 0 ? "rg-premium-chip--success" :
        _data.Escalations < 5 ? "rg-premium-chip--warning" :
        "rg-premium-chip--danger";

    private string BuildRemediationChipClass() =>
        _data is null ? "rg-premium-chip--info" :
        _data.RemediationRatePercent >= 80m ? "rg-premium-chip--success" :
        _data.RemediationRatePercent >= 50m ? "rg-premium-chip--warning" :
        "rg-premium-chip--danger";

    private static string CapitalScoreClass(decimal score) =>
        score >= 80m ? "fc-text-success" :
        score >= 65m ? "fc-text-warning" :
        "fc-text-danger";

    private static int CombinedPressure(InstitutionScorecardRow institution) =>
        institution.OverdueObligations
        + institution.DueSoonObligations
        + institution.OpenResilienceIncidents
        + institution.OpenSecurityAlerts;

    private static string BuildInstitutionPressureCopy(InstitutionScorecardRow institution)
    {
        if (!string.IsNullOrWhiteSpace(institution.Summary))
        {
            return institution.Summary;
        }

        if (institution.OverdueObligations > 0)
        {
            return "Overdue obligations are driving this institution into the front of the deputy queue.";
        }

        if (institution.DueSoonObligations > 0)
        {
            return "Due-soon obligations are pushing this institution toward active sequencing.";
        }

        return "This institution remains visible because its supervisory signals still need portfolio management attention.";
    }

    private static string BuildInstitutionActionLabel(InstitutionScorecardRow institution)
    {
        if (institution.OverdueObligations > 0)
        {
            return "Escalate filing";
        }

        if (institution.DueSoonObligations > 0)
        {
            return "Protect deadline";
        }

        if (institution.OpenSecurityAlerts > 0)
        {
            return "Tighten alerts";
        }

        if (institution.OpenResilienceIncidents > 0)
        {
            return "Contain incident";
        }

        return "Monitor";
    }

    private static string DueStateLabel(string signal, int days)
    {
        if (signal == "Resolved")
        {
            return "Resolved lane";
        }

        if (days < 0)
        {
            return $"{Math.Abs(days)}d overdue";
        }

        if (days == 0)
        {
            return "Due today";
        }

        if (days <= 7)
        {
            return $"{days}d left";
        }

        return $"Due {days}d out";
    }

    private static string PriorityBadge(string priority) => priority switch
    {
        "Critical" => "fc-badge--danger",
        "High" => "fc-badge--warning",
        "Medium" => "fc-badge--info",
        _ => "fc-badge--neutral"
    };

    private static string PriorityColor(string priority) => priority switch
    {
        "Critical" => "#D32F2F",
        "High" => "#E07C24",
        "Medium" => "#C8A415",
        _ => "#9CA3AF"
    };

    private static string SignalBadge(string signal) => signal switch
    {
        "Critical" or "Alert" => "fc-badge--danger",
        "Warning" or "Watch" => "fc-badge--warning",
        "Resolved" => "fc-badge--success",
        _ => "fc-badge--neutral"
    };

    private static string SeverityBadge(string severity) => severity switch
    {
        "Critical" => "fc-badge--danger",
        "High" or "Warning" => "fc-badge--warning",
        "Info" => "fc-badge--info",
        _ => "fc-badge--neutral"
    };
}
