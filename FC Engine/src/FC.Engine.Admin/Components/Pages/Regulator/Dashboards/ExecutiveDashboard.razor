@page "/regulator/dashboards/executive"
@attribute [Authorize(Policy = "RegulatorOnly")]
@inject FC.Engine.Admin.Services.Dashboards.StakeholderDashboardService DashboardService
@inject IJSRuntime JS

<PageTitle>Executive Dashboard</PageTitle>

<PageHeader Title="Executive Dashboard"
            Subtitle="Filing compliance, upcoming deadlines, cross-domain risk summary, and peer benchmarks."
            BackUrl="/regulator/dashboards/governor">
    <PrimaryAction><button class="fc-btn fc-btn--primary" @onclick="ReloadAsync" disabled="@_loading">Refresh</button></PrimaryAction>
</PageHeader>

<div class="fc-page">
    <SectionErrorBoundary Title="Failed to load executive dashboard" ExternalError="@_loadException" OnRetry="ReloadAsync">
        @if (_loading)
        {
            <div class="rg-dash-kpi-strip">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="rg-dash-kpi"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="88px" /></div>
                }
            </div>
        }
        else if (_data is null)
        {
            <EmptyState Context="data" Heading="No executive data" Description="Refresh the Intelligence Hub to generate stakeholder data." />
        }
        else
        {
            <div class="rg-dash-kpi-strip">
                <div class="rg-dash-kpi">
                    <div class="rg-dash-kpi-value @(_data.FilingCompliancePercent >= 95 ? "rg-dash-kpi-value--green" : _data.FilingCompliancePercent >= 80 ? "rg-dash-kpi-value--amber" : "rg-dash-kpi-value--red")">@_data.FilingCompliancePercent%</div>
                    <div class="rg-dash-kpi-label">Filing Compliance</div>
                </div>
                <div class="rg-dash-kpi">
                    <div class="rg-dash-kpi-value">@(_data.DaysToNextDeadline)d</div>
                    <div class="rg-dash-kpi-label">Days to Deadline</div>
                </div>
                <div class="rg-dash-kpi">
                    <div class="rg-dash-kpi-value @(_data.OpenFindings > 0 ? "rg-dash-kpi-value--amber" : "rg-dash-kpi-value--green")">@_data.OpenFindings</div>
                    <div class="rg-dash-kpi-label">Open Findings</div>
                </div>
                <div class="rg-dash-kpi">
                    <div class="rg-dash-kpi-value">@_data.ActiveInterventions</div>
                    <div class="rg-dash-kpi-label">Active Interventions</div>
                </div>
            </div>

            @* Domain Risk Summary *@
            <div class="fc-card fc-card--mb" style="margin-top:var(--space-4);">
                <div class="fc-card__header"><h2 class="fc-card__title">Cross-Domain Risk Summary</h2></div>
                <div class="fc-card__body">
                    <canvas id="execDomainChart" style="max-height:280px;"></canvas>
                </div>
            </div>

            @* Top Institutions *@
            <div class="fc-card fc-card--mb">
                <div class="fc-card__header"><h2 class="fc-card__title">Institutions Requiring Attention</h2></div>
                <div class="fc-card__body">
                    @if (_data.TopInstitutions.Count == 0)
                    {
                        <p class="fc-text-muted">No institutions require immediate attention.</p>
                    }
                    else
                    {
                        <DataTable TItem="InstitutionScorecardRow" Items="@_data.TopInstitutions" PageSize="10" Sortable="true" ShowExport="true" ExportFileName="executive-institutions">
                            <ChildContent>
                                <DataColumn TItem="InstitutionScorecardRow" Title="Institution" SortKey="@(x => x.InstitutionName)">
                                    <CellTemplate><strong>@context.InstitutionName</strong></CellTemplate>
                                </DataColumn>
                                <DataColumn TItem="InstitutionScorecardRow" Title="Licence" Width="120px" SortKey="@(x => x.LicenceType)">
                                    <CellTemplate><span class="fc-badge fc-badge--neutral">@context.LicenceType</span></CellTemplate>
                                </DataColumn>
                                <DataColumn TItem="InstitutionScorecardRow" Title="Priority" Width="100px" SortKey="@(x => x.Priority)">
                                    <CellTemplate><span class="fc-badge @PriorityBadge(context.Priority)">@context.Priority</span></CellTemplate>
                                </DataColumn>
                                <DataColumn TItem="InstitutionScorecardRow" Title="Capital" Width="90px" SortKey="@(x => x.CapitalScore)">
                                    <CellTemplate>@(context.CapitalScore?.ToString("F1") ?? "—")</CellTemplate>
                                </DataColumn>
                                <DataColumn TItem="InstitutionScorecardRow" Title="Overdue" Width="90px" SortKey="@(x => x.OverdueObligations)">
                                    <CellTemplate><span class="@(context.OverdueObligations > 0 ? "fc-text-danger" : "")">@context.OverdueObligations</span></CellTemplate>
                                </DataColumn>
                                <DataColumn TItem="InstitutionScorecardRow" Title="Incidents" Width="90px" SortKey="@(x => x.OpenResilienceIncidents)">
                                    <CellTemplate>@context.OpenResilienceIncidents</CellTemplate>
                                </DataColumn>
                                <DataColumn TItem="InstitutionScorecardRow" Title="Model Items" Width="100px" SortKey="@(x => x.ModelReviewItems)">
                                    <CellTemplate>@context.ModelReviewItems</CellTemplate>
                                </DataColumn>
                                <DataColumn TItem="InstitutionScorecardRow" Title="Summary" SortKey="@(x => x.Summary)">
                                    <CellTemplate><span class="fc-text-muted">@context.Summary</span></CellTemplate>
                                </DataColumn>
                            </ChildContent>
                        </DataTable>
                    }
                </div>
            </div>

            @* Recent Activity *@
            <div class="fc-card">
                <div class="fc-card__header"><h2 class="fc-card__title">Recent Activity</h2></div>
                <div class="fc-card__body">
                    <DataTable TItem="ActivityTimelineRow" Items="@_data.RecentActivity" PageSize="10" Sortable="true">
                        <ChildContent>
                            <DataColumn TItem="ActivityTimelineRow" Title="Domain" Width="120px" SortKey="@(x => x.Domain)">
                                <CellTemplate><span class="fc-badge fc-badge--neutral">@context.Domain</span></CellTemplate>
                            </DataColumn>
                            <DataColumn TItem="ActivityTimelineRow" Title="Event" SortKey="@(x => x.Title)">
                                <CellTemplate>
                                    <strong>@context.Title</strong>
                                    <div class="fc-text-muted-sm">@context.Detail</div>
                                </CellTemplate>
                            </DataColumn>
                            <DataColumn TItem="ActivityTimelineRow" Title="Severity" Width="100px" SortKey="@(x => x.Severity)">
                                <CellTemplate><span class="fc-badge @SeverityBadge(context.Severity)">@context.Severity</span></CellTemplate>
                            </DataColumn>
                            <DataColumn TItem="ActivityTimelineRow" Title="When" Width="150px" SortKey="@(x => x.HappenedAt)">
                                <CellTemplate>@context.HappenedAt.ToString("dd MMM yyyy HH:mm")</CellTemplate>
                            </DataColumn>
                        </ChildContent>
                    </DataTable>
                </div>
            </div>
        }
    </SectionErrorBoundary>
</div>

@code {
    private bool _loading = true, _chartsRendered;
    private Exception? _loadException;
    private FC.Engine.Admin.Services.Dashboards.ExecutiveDashboardData? _data;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_chartsRendered && _data is not null && _data.DomainSummary.Count > 0)
        {
            _chartsRendered = true;
            try
            {
                await JS.InvokeVoidAsync("fcCharts.renderBar", "execDomainChart", new
                {
                    labels = _data.DomainSummary.Select(d => d.Label).ToArray(),
                    datasets = new object[]
                    {
                        new { label = "Open Items", data = _data.DomainSummary.Select(d => d.Count).ToArray(), backgroundColor = new[] { "#2563EB", "#C8A415", "#E07C24", "#7C3AED", "#D32F2F" } }
                    }
                });
            }
            catch { }
        }
    }

    private async Task ReloadAsync()
    {
        _loading = true; _loadException = null; _chartsRendered = false;
        try { _data = await DashboardService.GetExecutiveDashboardAsync(); }
        catch (Exception ex) { _loadException = ex; }
        finally { _loading = false; }
    }

    private static string PriorityBadge(string p) => p switch { "Critical" => "fc-badge--danger", "High" => "fc-badge--warning", "Medium" => "fc-badge--info", _ => "fc-badge--neutral" };
    private static string SeverityBadge(string s) => s switch { "Critical" => "fc-badge--danger", "High" or "Warning" => "fc-badge--warning", "Info" => "fc-badge--info", _ => "fc-badge--neutral" };
}
