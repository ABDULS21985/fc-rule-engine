    private void StartExaminationTimer()
    {
        _examinationStartedAt = DateTime.Now;
        _examTimer = new System.Timers.Timer(1000); // Update every second
        _examTimer.Elapsed += (sender, e) =>
        {
            if (_examinationStartedAt.HasValue)
            {
                var elapsed = DateTime.Now - _examinationStartedAt.Value;
                _examElapsed = $"{elapsed.Hours:D2}:{elapsed.Minutes:D2}:{elapsed.Seconds:D2}";
                InvokeAsync(StateHasChanged);
            }
        };
        _examTimer.Start();
    }

    private void StopExaminationTimer()
    {
        _examTimer?.Stop();
        _examTimer?.Dispose();
        _examTimer = null;
        _examElapsed = "00:00:00";
    }

    private void StartThinkingTimer()
    {
        _thinkingIndex = 0;
        _thinkingLabel = _thinkingLabels[0];
        _thinkingTimer = new System.Timers.Timer(1800); // 1.8 seconds
        _thinkingTimer.Elapsed += (sender, e) =>
        {
            _thinkingIndex = (_thinkingIndex + 1) % _thinkingLabels.Length;
            _thinkingLabel = _thinkingLabels[_thinkingIndex];
            InvokeAsync(StateHasChanged);
        };
        _thinkingTimer.Start();
    }

    private void StopThinkingTimer()
    {
        _thinkingTimer?.Stop();
        _thinkingTimer?.Dispose();
        _thinkingTimer = null;
        _thinkingLabel = "Analysing data sources…";
    }

    private void TogglePanelDrawer()
    {
        _panelDrawerOpen = !_panelDrawerOpen;
        StateHasChanged();
    }

    private async Task HandleLookupInputAsync(ChangeEventArgs args)
    {
        _entityLookupTerm = args.Value?.ToString() ?? string.Empty;
        await SearchLookupAsync();
