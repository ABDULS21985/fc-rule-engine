    private Task RunTrySectorHealthAsync() => SubmitQueryAsync("Show sector health summary");
    private Task RunTryEntityProfileAsync() => SubmitQueryAsync("Give me a full profile of Access Bank");
    private Task RunShowSystemicRiskAsync() => SubmitQueryAsync("Show me the systemic risk dashboard");

    private async Task SubmitQueryAsync(string? query)
    {
        if (_session is null || string.IsNullOrWhiteSpace(query) || _isSubmitting)
        {
            return;
        }

        var trimmedQuery = query.Trim();
        _query = string.Empty;
        CloseLookup();

        // Add to history
        if (!_queryHistory.Contains(trimmedQuery, StringComparer.OrdinalIgnoreCase))
        {
            _queryHistory.Insert(0, trimmedQuery);
            if (_queryHistory.Count > 20)
            {
                _queryHistory.RemoveRange(20, _queryHistory.Count - 20);
            }
        }
        _historyIndex = -1;

        var userMessage = new ConversationMessage
        {
            IsUser = true,
            Text = trimmedQuery,
            Timestamp = DateTime.Now
        };
        _messages.Add(userMessage);

        _isSubmitting = true;
        StartThinkingTimer();
        _shouldScrollToBottom = true;
        StateHasChanged();

        try
        {
            var turn = await RegulatorIqService.QueryAsync(new RegulatorIqQueryRequest
            {
                Query = trimmedQuery,
                ConversationId = _conversationId,
                ExaminationTargetTenantId = _currentExaminationEntityId,
                Scope = _currentScope,
                RegulatorTenantId = _session.TenantId,
                RegulatorCode = _session.RegulatorCode,
                RegulatorId = _session.UserId.ToString(CultureInfo.InvariantCulture),
                UserRole = HasActiveExamination ? "Examiner" : "Regulator"
            });

            _conversationId = turn.ConversationId;
            var response = turn.Response;
            _messages.Add(new ConversationMessage
            {
                Text = response.AnswerText,
                Timestamp = DateTime.Now,
                Response = response,
                DisambiguationOptions = turn.NeedsDisambiguation ? turn.DisambiguationOptions.ToList() : new List<string>()
            });

            var intent = new RegulatorIntentResult
            {
                IntentCode = turn.IntentCode,
                ResolvedEntityIds = response.EntitiesAccessed.ToList()
            };

            UpdateConversationContext(trimmedQuery, intent, response);
            await RefreshPanelAsync(intent, response);
        }
        catch (Exception ex)
        {
            _messages.Add(new ConversationMessage
            {
                Text = $"RegulatorIQ could not complete that request: {ex.Message}",
                Timestamp = DateTime.Now
            });
        }
        finally
        {
            _isSubmitting = false;
            StopThinkingTimer();
            _shouldScrollToBottom = true;
            StateHasChanged();
        }
    }

    private async Task RefreshPanelAsync(RegulatorIntentResult intent, RegulatorIqResponse response)
    {
        if (_session is null)
        {
            return;
        }

        var scope = DetermineScope(intent.IntentCode);
        _currentScope = scope;

        if (response.StructuredData is RegulatorProfileData profileData)
        {
            _currentEntityProfile = profileData.Profile;
            return;
        }

        if (response.StructuredData is ExaminationBriefing briefing)
        {
            _currentEntityProfile = briefing.Profile;
            _sectorSummary = briefing.PeerContext;
            return;
        }

        if (response.StructuredData is SystemicRiskDashboard dashboard)
        {
            _systemicDashboard = dashboard;
            return;
        }

        if (scope == "SYSTEMIC")
        {
            _systemicDashboard ??= await SystemicRiskService.GetDashboard(_session.RegulatorCode);
            return;
        }

        if (scope == "ENTITY")
        {
            var tenantId = response.EntitiesAccessed.FirstOrDefault();
            if (tenantId == Guid.Empty)
            {
                tenantId = intent.ResolvedEntityIds.FirstOrDefault();
            }

            if (tenantId == Guid.Empty && _currentExaminationEntityId.HasValue)
            {
                tenantId = _currentExaminationEntityId.Value;
            }

            if (tenantId != Guid.Empty)
            {
                _currentEntityProfile = await RegulatorIntelligence.GetEntityProfileAsync(tenantId, _session.RegulatorCode);
            }

            return;
        }

        _sectorSummary = await RegulatorIntelligence.GetSectorSummaryAsync(_session.RegulatorCode, intent.LicenceCategory, intent.PeriodCode);
    }

    private void UpdateConversationContext(string query, RegulatorIntentResult intent, RegulatorIqResponse response)
    {
        _recentTurns.Insert(0, (query, intent.IntentCode));
        if (_recentTurns.Count > 10)
        {
            _recentTurns.RemoveRange(10, _recentTurns.Count - 10);
        }

        for (var i = 0; i < intent.ResolvedEntityIds.Count; i++)
        {
            var tenantId = intent.ResolvedEntityIds[i];
            string name;
            if (i < intent.ResolvedEntityNames.Count && !string.IsNullOrWhiteSpace(intent.ResolvedEntityNames[i]))
            {
                name = intent.ResolvedEntityNames[i];
            }
            else if (_currentExaminationEntityId == tenantId && !string.IsNullOrWhiteSpace(_currentExaminationEntityName))
            {
                name = _currentExaminationEntityName!;
            }
            else if (_currentEntityProfile?.TenantId == tenantId && !string.IsNullOrWhiteSpace(_currentEntityProfile.InstitutionName))
            {
                name = _currentEntityProfile.InstitutionName;
            }
            else
            {
                name = tenantId.ToString();
            }
            UpsertRecentEntity(tenantId, name);
        }

        if (_currentExaminationEntityId.HasValue && !string.IsNullOrWhiteSpace(_currentExaminationEntityName))
        {
            UpsertRecentEntity(_currentExaminationEntityId.Value, _currentExaminationEntityName!);
        }

    }

    private void UpsertRecentEntity(Guid tenantId, string name)
    {
        _recentEntities.RemoveAll(x => x.TenantId == tenantId);
        _recentEntities.Insert(0, new RecentEntityContext(tenantId, name));
        if (_recentEntities.Count > 5)
        {
            _recentEntities.RemoveRange(5, _recentEntities.Count - 5);
        }
    }

    private async Task HandleInputKeyDown(KeyboardEventArgs args)
    {
        // Handle Esc to end examination
        if (args.Key == "Escape" && HasActiveExamination)
        {
            await EndExaminationSession();
            return;
        }

        if (args.Key == "Enter" && !args.ShiftKey)
        {
            await SubmitQueryAsync(_query);
            return;
        }

        // Handle @ mention
        if (args.Key == "@" && string.IsNullOrEmpty(_query))
        {
            await OpenLookupAsync();
            return;
        }

        // Handle history navigation
        if (_queryHistory.Count > 0)
        {
            if (args.Key == "ArrowUp" && _historyIndex < _queryHistory.Count - 1)
            {
                _historyIndex++;
                _query = _queryHistory[_historyIndex];
                await InvokeAsync(StateHasChanged);
                return;
            }
            else if (args.Key == "ArrowDown")
            {
                if (_historyIndex > 0)
                {
                    _historyIndex--;
                    _query = _queryHistory[_historyIndex];
                }
                else
                {
                    _historyIndex = -1;
                    _query = string.Empty;
                }
                await InvokeAsync(StateHasChanged);
                return;
            }
        }
    }

