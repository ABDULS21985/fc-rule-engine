@page "/regulator/regulatoriq"
@using System.Globalization
@using System.Text.Json
@attribute [Authorize(Policy = "RegulatorOnly")]

@inject RegulatorSessionService RegulatorSession
@inject IRegulatorIqService RegulatorIqService
@inject IRegulatorIntelligenceService RegulatorIntelligence
@inject IRegulatorDataService RegulatorData
@inject ISystemicRiskService SystemicRiskService
@inject IJSRuntime JS

<PageHeader Title="RegulatorIQ"
            Subtitle="Cross-tenant regulator intelligence chat for entity drill-downs, sector surveillance, and systemic supervision."
            StatusBadge="@(_session?.RegulatorCode ?? "Regulator")"
            StatusVariant="info"
            CountBadge="@_messages.Count"
            PrimaryAction="@HeaderActions" />

<SectionErrorBoundary>
    @if (_initializing)
    {
        <div class="row g-4 align-items-start">
            <div class="col-12 col-xl-8">
                <section class="regiq-chat">
                    <!-- Hero skeleton -->
                    <header class="regiq-hero-skel fc-skel">
                        <div class="regiq-hero-skel__top">
                            <div class="regiq-hero-skel__badges">
                                <span class="fc-skel__rect" style="width: 180px; height: 24px;"></span>
                                <span class="fc-skel__rect" style="width: 140px; height: 24px;"></span>
                                <span class="fc-skel__rect" style="width: 160px; height: 24px;"></span>
                            </div>
                        </div>
                        <div class="regiq-hero-skel__copy">
                            <div class="fc-skel__rect" style="width: 280px; height: 32px; margin-bottom: 8px;"></div>
                            <div class="fc-skel__rect" style="width: 100%; height: 20px;"></div>
                            <div class="fc-skel__rect" style="width: 85%; height: 20px; margin-top: 4px;"></div>
                        </div>
                    </header>

                    <!-- Chat thread skeleton -->
                    <div class="regiq-thread">
                        <!-- User message skeleton -->
                        <article class="regiq-msg regiq-msg--user fc-skel">
                            <div class="regiq-msg__bubble--user fc-skel__rect" style="width: 320px; height: 48px;"></div>
                        </article>
                        <!-- AI message skeleton -->
                        <article class="regiq-msg regiq-msg--ai fc-skel">
                            <div class="regiq-msg__avatar fc-skel__circle" style="width: 42px; height: 42px;"></div>
                            <div class="regiq-msg__body">
                                <div class="regiq-msg__card fc-skel__rect" style="width: 480px; height: 120px;"></div>
                            </div>
                        </article>
                        <!-- User message skeleton -->
                        <article class="regiq-msg regiq-msg--user fc-skel">
                            <div class="regiq-msg__bubble--user fc-skel__rect" style="width: 280px; height: 36px;"></div>
                        </article>
                        <!-- AI message skeleton -->
                        <article class="regiq-msg regiq-msg--ai fc-skel">
                            <div class="regiq-msg__avatar fc-skel__circle" style="width: 42px; height: 42px;"></div>
                            <div class="regiq-msg__body">
                                <div class="regiq-msg__card fc-skel__rect" style="width: 520px; height: 180px;"></div>
                            </div>
                        </article>
                    </div>
                </section>
            </div>
            <div class="col-12 col-xl-4">
                <!-- Intelligence panel skeleton -->
                <div class="regiq-panel-skel fc-skel">
                    <div class="fc-skel__rect" style="width: 100%; height: 200px; margin-bottom: 16px;"></div>
                    <div class="fc-skel__rect" style="width: 100%; height: 150px; margin-bottom: 16px;"></div>
                    <div class="fc-skel__rect" style="width: 100%; height: 120px;"></div>
                </div>
            </div>
        </div>
    }
    else if (_loadException is not null)
    {
        <EmptyState Context="data"
                    Heading="RegulatorIQ could not initialise"
                    Description="@_loadException.Message"
                    PrimaryActionLabel="Retry"
                    OnPrimaryAction="ReloadAsync" />
    }
    else
    {
        <div id="regiq-print-root" class="regiq-shell @(HasActiveExamination ? "regiq-shell--examination" : "")">
            <!-- Print header -->
            <header class="regiq-print-header">
                <div class="regiq-print-header__left">
                    <h1 class="regiq-print-header__title">RegulatorIQ Intelligence Report</h1>
                    <p class="regiq-print-header__subtitle">@_session?.TenantName — Session @_conversationId?.ToString("D")</p>
                </div>
                <div class="regiq-print-header__right">
                    <p class="regiq-print-header__date">@DateTime.Now.ToString("MMMM dd, yyyy")</p>
                    <p class="regiq-print-header__classification">@ResolveClassificationBadge(_messages.LastOrDefault()?.Response?.ClassificationLevel ?? "UNCLASSIFIED")</p>
                </div>
            </header>

            <style>
                :root {
                    --regiq-thread-offset: 460px;
                }
            </style>
            <div class="row g-4 align-items-start">
                <div class="col-12 col-xl-8">
                    <section class="regiq-chat">

                        <header class="regiq-hero">
                            <div class="regiq-hero__top">
                                <div class="regiq-hero__badges">
                                    <span class="regiq-hero__badge-session">
                                        <i class="bi bi-shield-check" aria-hidden="true"></i>
                                        @(_session?.TenantName ?? "Regulator Session")
                                    </span>
                                    <span class="regiq-hero__badge-tag">Cross-tenant intelligence</span>
                                    <span class="regiq-hero__badge-tag regiq-hero__badge-tag--live @(HasActiveExamination ? "regiq-hero__badge-tag--exam" : "")">
                                        <span class="regiq-hero__live-dot" aria-hidden="true"></span>
                                        Live grounded responses
                                    </span>
                                </div>
                                <div class="regiq-hero__actions">
                                    <button type="button"
                                            class="regiq-hero__btn @(HasActiveExamination ? "regiq-hero__btn--active" : "")"
                                            @onclick="ToggleExaminationPickerAsync">
                                        <i class="bi @(HasActiveExamination ? "bi-binoculars-fill" : "bi-binoculars")" aria-hidden="true"></i>
                                        @(HasActiveExamination ? "Switch Examination" : "Start Examination")
                                    </button>
                                    @if (HasActiveExamination)
                                    {
                                        <button type="button" class="regiq-hero__btn" @onclick="EndExaminationSession">
                                            <i class="bi bi-x-circle" aria-hidden="true"></i>
                                            End Session
                                        </button>
                                    }
                                </div>
                            </div>
                            <div class="regiq-hero__copy">
                                <h2 class="regiq-hero__title">Regulator intelligence workspace</h2>
                                <p class="regiq-hero__subtitle">
                                    Ask about a single institution, compare peers, scan sector trends, or move into a focused examination session without leaving the regulator console.
                                </p>
                            </div>
                        </header>

                        @if (HasActiveExamination)
                        {
                            <div class="regiq-exam-banner" role="status">
                                <div class="regiq-exam-banner__left">
                                    <span class="regiq-exam-banner__icon">
                                        <i class="bi bi-binoculars-fill" aria-hidden="true"></i>
                                    </span>
                                    <div>
                                        <strong>Examination mode active —</strong>
                                        <span class="regiq-exam-banner__entity">@_currentExaminationEntityName</span>
                                        <span class="regiq-exam-banner__timer">@_examElapsed</span>
                                        <span class="regiq-exam-banner__hint">Queries default to this entity until you end the session.</span>
                                    </div>
                                </div>
                                <button type="button" class="regiq-exam-banner__close" @onclick="EndExaminationSession">
                                    <i class="bi bi-x" aria-hidden="true"></i>
                                    Clear
                                </button>
                            </div>
                        }

                        <section class="regiq-cmd-bar" aria-label="Quick access commands">
                            <div class="regiq-cmd-grid">
                                <button type="button" class="regiq-cmd-card" @onclick="OpenLookupAsync">
                                    <span class="regiq-cmd-card__icon regiq-cmd-card__icon--blue">
                                        <i class="bi bi-buildings-fill" aria-hidden="true"></i>
                                    </span>
                                    <span class="regiq-cmd-card__label">Entity Lookup</span>
                                    <span class="regiq-cmd-card__hint">Search by name</span>
                                </button>
                                <button type="button" class="regiq-cmd-card" @onclick="RunTrySectorHealthAsync">
                                    <span class="regiq-cmd-card__icon regiq-cmd-card__icon--green">
                                        <i class="bi bi-bar-chart-line-fill" aria-hidden="true"></i>
                                    </span>
                                    <span class="regiq-cmd-card__label">Sector Health</span>
                                    <span class="regiq-cmd-card__hint">Sector-wide view</span>
                                </button>
                                <button type="button" class="regiq-cmd-card" @onclick="RunShowSystemicRiskAsync">
                                    <span class="regiq-cmd-card__icon regiq-cmd-card__icon--red">
                                        <i class="bi bi-activity" aria-hidden="true"></i>
                                    </span>
                                    <span class="regiq-cmd-card__label">Systemic Risk</span>
                                    <span class="regiq-cmd-card__hint">Contagion indicators</span>
                                </button>
                                <button type="button" class="regiq-cmd-card" @onclick="HandleMyExaminationsAsync">
                                    <span class="regiq-cmd-card__icon regiq-cmd-card__icon--amber">
                                        <i class="bi bi-briefcase-fill" aria-hidden="true"></i>
                                    </span>
                                    <span class="regiq-cmd-card__label">Examinations</span>
                                    <span class="regiq-cmd-card__hint">My active cases</span>
                                </button>
                            </div>

                            @if (_entityLookupOpen)
                            {
                                <div class="regiq-lookup">
                                    <div class="regiq-lookup__search">
                                        <i class="bi bi-search regiq-lookup__icon" aria-hidden="true"></i>
                                        <input class="regiq-lookup__input"
                                               placeholder="@(_lookupMode == LookupMode.Examination ? "Select institution for examination mode…" : "Search institution name or alias…")"
                                               value="@_entityLookupTerm"
                                               @oninput="HandleLookupInputAsync"
                                               aria-label="Entity lookup" />
                                        <button type="button" class="regiq-lookup__close" @onclick="CloseLookup" aria-label="Close lookup">
                                            <i class="bi bi-x" aria-hidden="true"></i>
                                        </button>
                                    </div>

                                    @if (_entityLookupLoading)
                                    {
                                        <div class="regiq-lookup__loading">
                                            <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.TableRows" RowCount="3" />
                                        </div>
                                    }
                                    else if (_entityLookupResults.Count > 0)
                                    {
                                        <div class="regiq-lookup__results" role="listbox" aria-label="Entity lookup results">
                                            @foreach (var result in _entityLookupResults)
                                            {
                                                <button type="button"
                                                        class="regiq-lookup__result"
                                                        @onclick="() => SelectLookupResultAsync(result)">
                                                    <div class="regiq-lookup__result-icon">
                                                        <i class="bi bi-bank" aria-hidden="true"></i>
                                                    </div>
                                                    <div class="regiq-lookup__result-text">
                                                        <strong>@result.Name</strong>
                                                        <span>@result.LicenceCategory</span>
                                                    </div>
                                                    <i class="bi bi-arrow-right regiq-lookup__result-arrow" aria-hidden="true"></i>
                                                </button>
                                            }
                                        </div>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(_entityLookupTerm))
                                    {
                                        <div class="regiq-lookup__empty">
                                            <i class="bi bi-search" aria-hidden="true"></i>
                                            No matching institutions found for "<strong>@_entityLookupTerm</strong>"
                                        </div>
                                    }
                                </div>
                            }
                        </section>

                        <div class="regiq-thread" id="regiq-thread" aria-live="polite">
                            @if (_messages.Count == 0 && !_isSubmitting)
                            {
                                <div class="regiq-zero-state">
                                    <div class="regiq-zero-state__graphic">
                                        <svg class="regiq-zero-state__shield" viewBox="0 0 120 140" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M60 10 L110 30 L110 80 Q110 110 85 125 Q60 140 35 125 Q10 110 10 80 L10 30 Z" fill="url(#shield-gradient)" stroke="#006B3F" stroke-width="2"/>
                                            <circle cx="60" cy="60" r="25" fill="none" stroke="#C8A415" stroke-width="2" stroke-dasharray="5,5" class="regiq-spotlight"/>
                                            <defs>
                                                <linearGradient id="shield-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                                                    <stop offset="0%" style="stop-color:#E8F5EE;stop-opacity:1" />
                                                    <stop offset="100%" style="stop-color:#F5FBE8;stop-opacity:1" />
                                                </linearGradient>
                                            </defs>
                                        </svg>
                                    </div>
                                    <h3 class="regiq-zero-state__heading">What would you like to investigate?</h3>
                                    <div class="regiq-zero-state__categories">
                                        <div class="regiq-zero-state__category">
                                            <h4 class="regiq-zero-state__category-title">Sector</h4>
                                            <div class="regiq-zero-state__chips">
                                                <button class="regiq-chip" @onclick='() => SubmitQueryAsync("Show sector health")'>
                                                    <i class="bi bi-bar-chart-line" aria-hidden="true"></i>
                                                    Show sector health
                                                </button>
                                                <button class="regiq-chip" @onclick='() => SubmitQueryAsync("Top overdue filers")'>
                                                    <i class="bi bi-clock-history" aria-hidden="true"></i>
                                                    Top overdue filers
                                                </button>
                                                <button class="regiq-chip" @onclick='() => SubmitQueryAsync("License category breakdown")'>
                                                    <i class="bi bi-pie-chart" aria-hidden="true"></i>
                                                    License category breakdown
                                                </button>
                                            </div>
                                        </div>
                                        <div class="regiq-zero-state__category">
                                            <h4 class="regiq-zero-state__category-title">Entity</h4>
                                            <div class="regiq-zero-state__chips">
                                                <button class="regiq-chip" @onclick='() => SubmitQueryAsync("Give me a full profile of Access Bank")'>
                                                    <i class="bi bi-building" aria-hidden="true"></i>
                                                    Profile: Access Bank
                                                </button>
                                                <button class="regiq-chip" @onclick='() => SubmitQueryAsync("Compare GTBank vs Zenith")'>
                                                    <i class="bi bi-arrow-left-right" aria-hidden="true"></i>
                                                    Compare GTBank vs Zenith
                                                </button>
                                                <button class="regiq-chip" @onclick='() => SubmitQueryAsync("Generate an examination brief for Zenith Bank")'>
                                                    <i class="bi bi-binoculars" aria-hidden="true"></i>
                                                    Examination brief
                                                </button>
                                            </div>
                                        </div>
                                        <div class="regiq-zero-state__category">
                                            <h4 class="regiq-zero-state__category-title">Systemic</h4>
                                            <div class="regiq-zero-state__chips">
                                                <button class="regiq-chip" @onclick='() => SubmitQueryAsync("Show me the systemic risk dashboard")'>
                                                    <i class="bi bi-graph-up" aria-hidden="true"></i>
                                                    Systemic risk dashboard
                                                </button>
                                                <button class="regiq-chip" @onclick='() => SubmitQueryAsync("Show contagion indicators")'>
                                                    <i class="bi bi-diagram-3" aria-hidden="true"></i>
                                                    Contagion indicators
                                                </button>
                                                <button class="regiq-chip" @onclick='() => SubmitQueryAsync("Run stress test summary")'>
                                                    <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
                                                    Stress test summary
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                @foreach (var message in _messages)
                                {
                                    @if (message.IsUser)
                                    {
                                        <article class="regiq-msg regiq-msg--user @(HasActiveExamination ? "regiq-msg--exam-mode" : "")" @key="message.Id">
                                            <div class="regiq-msg__bubble--user">
                                                <p class="regiq-msg__text">@message.Text</p>
                                                <time class="regiq-msg__time">@message.Timestamp.ToString("HH:mm", CultureInfo.InvariantCulture)</time>
                                            </div>
                                            <div class="regiq-msg__avatar regiq-msg__avatar--user" aria-hidden="true">
                                                <i class="bi bi-person-fill"></i>
                                            </div>
                                        </article>
                                    }
                                    else
                                    {
                                        <article class="regiq-msg regiq-msg--ai @ResolveClassificationClass(message.Response?.ClassificationLevel) @(HasActiveExamination ? "regiq-msg--exam-mode" : "")" @key="message.Id">
                                            <div class="regiq-msg__avatar regiq-msg__avatar--ai" aria-hidden="true">
                                                <svg width="10" height="12" viewBox="0 0 24 24" fill="currentColor">
                                                    <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
                                                </svg>
                                            </div>
                                            <div class="regiq-msg__body">
                                                <div class="regiq-msg__card">
                                                    <div class="regiq-msg__header">
                                                        <div class="regiq-msg__header-left">
                                                            <span class="regiq-msg__author">RegulatorIQ</span>
                                                            @if (message.Response is not null)
                                                            {
                                                                <span class="badge @ResolveClassificationBadge(message.Response.ClassificationLevel)">@message.Response.ClassificationLevel</span>
                                                                <span class="badge text-bg-light border">@message.Response.AnswerFormat</span>
                                                            }
                                                        </div>
                                                        <time class="regiq-msg__time">@message.Timestamp.ToString("HH:mm", CultureInfo.InvariantCulture)</time>
                                                    </div>
                                                    <div class="regiq-msg__actions">
                                                        <button type="button" class="regiq-msg__action-btn" @onclick="() => CopyMessageAsync(message)" title="Copy message">
                                                            <i class="bi bi-clipboard"></i>
                                                        </button>
                                                        <button type="button" class="regiq-msg__action-btn" @onclick="() => ExportMessageAsync(message)" title="Export message">
                                                            <i class="bi bi-file-earmark-arrow-down"></i>
                                                        </button>
                                                        <button type="button" class="regiq-msg__action-btn" @onclick="() => ThumbsUpAsync(message)" title="Thumbs up">
                                                            <i class="bi bi-hand-thumbs-up"></i>
                                                        </button>
                                                        <button type="button" class="regiq-msg__action-btn" @onclick="() => ThumbsDownAsync(message)" title="Thumbs down">
                                                            <i class="bi bi-hand-thumbs-down"></i>
                                                        </button>
                                                    </div>

                                                    <div class="regiq-msg__content">
                                                        <p class="mb-0">@message.Text</p>

                                                        @if (message.Response is not null)
                                                        {
                                                            var response = message.Response;

                                                            @switch (response.AnswerFormat.ToLowerInvariant())
                                                            {
                                                                case "profile":
                                                                    if (response.StructuredData is RegulatorProfileData profileData)
                                                                    {
                                                                        <EntityProfileCard Profile="profileData.Profile" OnDeepDive="HandleDeepDiveAsync" />
                                                                    }
                                                                    else if (response.StructuredData is ExaminationBriefing briefing)
                                                                    {
                                                                        <div class="regiq-briefing">
                                                                            <EntityProfileCard Profile="briefing.Profile" OnDeepDive="HandleDeepDiveAsync" />
                                                                            <div class="regiq-briefing__grid">
                                                                                <section class="regiq-briefing__card">
                                                                                    <h5>Suggested Focus Areas</h5>
                                                                                    <ul class="regiq-briefing__list">
                                                                                        @foreach (var focusArea in briefing.FocusAreas.Take(5))
                                                                                        {
                                                                                            <li>
                                                                                                <span class="badge @ResolvePriorityBadge(focusArea.Priority)">@focusArea.Priority</span>
                                                                                                <div>
                                                                                                    <strong>@focusArea.Area</strong>
                                                                                                    <div class="text-secondary">@focusArea.Reason</div>
                                                                                                </div>
                                                                                            </li>
                                                                                        }
                                                                                    </ul>
                                                                                </section>
                                                                                <section class="regiq-briefing__card">
                                                                                    <h5>Peer Context</h5>
                                                                                    <div class="regiq-briefing__stats">
                                                                                        <div><span>Avg CAR</span><strong>@FormatPercent(briefing.PeerContext.AverageCarRatio)</strong></div>
                                                                                        <div><span>Avg NPL</span><strong>@FormatPercent(briefing.PeerContext.AverageNplRatio)</strong></div>
                                                                                        <div><span>High-risk entities</span><strong>@briefing.PeerContext.HighRiskEntityCount</strong></div>
                                                                                        <div><span>Overdue filings</span><strong>@briefing.PeerContext.OverdueFilingCount</strong></div>
                                                                                    </div>
                                                                                </section>
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                    else
                                                                    {
                                                                        <div class="regiq-msg__fallback">The profile payload was returned in an unsupported shape.</div>
                                                                    }
                                                                    break;

                                                                case "comparison":
                                                                    if (response.StructuredData is RegulatorComparisonData comparisonData)
                                                                    {
                                                                        <ComparisonMatrix Comparison="comparisonData" />
                                                                    }
                                                                    else
                                                                    {
                                                                        <div class="regiq-msg__fallback">The comparison payload was returned in an unsupported shape.</div>
                                                                    }
                                                                    break;

                                                                case "ranking":
                                                                    if (response.StructuredData is RegulatorRankingData rankingData)
                                                                    {
                                                                        <RankingTable Ranking="rankingData" OnEntitySelected="HandleDeepDiveAsync" />
                                                                    }
                                                                    else
                                                                    {
                                                                        <div class="regiq-msg__fallback">The ranking payload was returned in an unsupported shape.</div>
                                                                    }
                                                                    break;

                                                                case "chart_data":
                                                                    <RegulatorChartPayload Payload="response.StructuredData" />
                                                                    break;

                                                                case "table":
                                                                    if (response.StructuredData is RegulatorTableData tableData)
                                                                    {
                                                                        <div class="table-responsive">
                                                                            <table class="table table-hover align-middle regiq-table">
                                                                                <thead>
                                                                                    <tr>
                                                                                        @foreach (var column in tableData.Columns)
                                                                                        {
                                                                                            <th scope="col">
                                                                                                <button type="button"
                                                                                                        class="btn btn-link p-0 regiq-table__sort"
                                                                                                        @onclick="() => SortTable(message, column)">
                                                                                                    @HumanizeColumn(column)
                                                                                                    @if (string.Equals(message.SortColumn, column, StringComparison.OrdinalIgnoreCase))
                                                                                                    {
                                                                                                        <i class="bi @(message.SortAscending ? "bi-sort-down" : "bi-sort-up") ms-1" aria-hidden="true"></i>
                                                                                                    }
                                                                                                </button>
                                                                                            </th>
                                                                                        }
                                                                                    </tr>
                                                                                </thead>
                                                                                <tbody>
                                                                                    @foreach (var row in GetSortedRows(message, tableData))
                                                                                    {
                                                                                        <tr>
                                                                                            @foreach (var column in tableData.Columns)
                                                                                            {
                                                                                                row.TryGetValue(column, out var cellValue);
                                                                                                <td>
                                                                                                    <span class="@ResolveTableCellTone(column, cellValue)">
                                                                                                        @FormatTableValue(cellValue)
                                                                                                    </span>
                                                                                                </td>
                                                                                            }
                                                                                        </tr>
                                                                                    }
                                                                                </tbody>
                                                                            </table>
                                                                        </div>
                                                                    }
                                                                    else
                                                                    {
                                                                        <RegulatorStructuredPayload Payload="response.StructuredData" />
                                                                    }
                                                                    break;

                                                                default:
                                                                    <RegulatorStructuredPayload Payload="response.StructuredData" />
                                                                    break;
                                                            }

                                                            @if (response.Flags.Count > 0)
                                                            {
                                                                <div class="regiq-flags">
                                                                    @foreach (var flag in response.Flags.Take(6))
                                                                    {
                                                                        <div class="regiq-flag @ResolveFlagCard(flag.FlagType)">
                                                                            <span class="badge @ResolveFlagBadge(flag.FlagType)">@flag.FlagType.Replace('_', ' ')</span>
                                                                            <div>
                                                                                <strong>@flag.Source</strong>
                                                                                <div>@flag.Message</div>
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            }

                                                            @if (response.Citations.Count > 0)
                                                            {
                                                                <div class="regiq-citations">
                                                                    <span class="regiq-citations__label">Citations</span>
                                                                    <div class="regiq-citations__list">
                                                                        @foreach (var citation in response.Citations.Take(5))
                                                                        {
                                                                            <span class="badge text-bg-light border">@BuildCitationLabel(citation)</span>
                                                                        }
                                                                    </div>
                                                                </div>
                                                            }

                                                            @if (response.DataSourcesUsed.Count > 0)
                                                            {
                                                                <div class="regiq-sources">
                                                                    <span class="regiq-sources__label">Data sources</span>
                                                                    <div class="regiq-sources__list">
                                                                        @foreach (var source in response.DataSourcesUsed.Distinct(StringComparer.OrdinalIgnoreCase))
                                                                        {
