@page "/regulator/workspace"
@attribute [Authorize(Policy = "RegulatorOnly")]
@inject IExaminationWorkspaceService WorkspaceService
@inject ToastService Toast
@inject IJSRuntime JS
@using FC.Engine.Domain.Entities
@using FC.Engine.Domain.Enums
@using FC.Engine.Domain.Models

<PageTitle>Examination Workspace</PageTitle>

<PageHeader Title="Examination Workspace"
            Subtitle="Digital examination & on-site inspection toolkit"
            Tabs="@_tabs"
            ActiveTabId="@_activeTab"
            OnTabChange="@HandleTabChange"
            StatusBadge="@(_workspace?.Project.Status.ToString())"
            StatusVariant="@ProjectStatusVariant(_workspace?.Project.Status)">
    <PrimaryAction>
        @if (_workspace is not null)
        {
            <button class="fc-btn fc-btn--gold" @onclick="() => _showFindingModal = true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                New Finding
            </button>
        }
    </PrimaryAction>
    <SecondaryActions>
        @if (_workspace is not null)
        {
            <a href="/regulator/workspace/@_workspace.Project.Id/intelligence-pack" target="_blank"
               class="fc-ph__overflow-item" role="menuitem">Download Intelligence Pack</a>
            <a href="/regulator/workspace/@_workspace.Project.Id/report" target="_blank"
               class="fc-ph__overflow-item" role="menuitem">Download Examination Report</a>
        }
    </SecondaryActions>
</PageHeader>

<SectionErrorBoundary Title="Couldn't load examination workspace" ExternalError="@_loadException" OnRetry="ReloadAsync">
    @if (_loading)
    {
        <div class="fc-exam-kpi-grid">
                <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Width="100%" Height="80px" />
                <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Width="100%" Height="80px" />
                <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Width="100%" Height="80px" />
                <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Width="100%" Height="80px" />
            </div>
            <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.TableRows" RowCount="5" />
}
    else
    {
        @* ── Project List (always visible above tabs) ── *@
        <ExamProjectList Projects="@_projects"
                         OnSelectProject="SelectProject"
                         SelectedProjectId="@_workspace?.Project.Id"
                         OnProjectCreated="ReloadProjects"
                         TenantId="@_tenantId"
                         UserId="@_userId" />

        @if (_workspace is not null)
        {
            @* ── KPI Strip ── *@
            <div class="fc-exam-kpi-grid">
                <div class="fc-exam-kpi-card">
                    <span class="fc-exam-kpi-label">Institutions</span>
                    <span class="fc-exam-kpi-value">@(_workspace.IntelligencePack?.TotalInstitutions ?? 0)</span>
                    <span class="fc-exam-kpi-hint">In current scope</span>
                </div>
                <div class="fc-exam-kpi-card">
                    <span class="fc-exam-kpi-label">Active EWIs</span>
                    <span class="fc-exam-kpi-value">@(_workspace.IntelligencePack?.TotalActiveEwis ?? 0)</span>
                    <span class="fc-exam-kpi-hint">Risk triggers</span>
                </div>
                <div class="fc-exam-kpi-card">
                    <span class="fc-exam-kpi-label">Findings</span>
                    <span class="fc-exam-kpi-value">@_workspace.Findings.Count</span>
                    <span class="fc-exam-kpi-hint">@_workspace.Findings.Count(f => f.RiskRating == ExaminationRiskRating.High) high risk</span>
                </div>
                <div class="fc-exam-kpi-card">
                    <span class="fc-exam-kpi-label">Escalated</span>
                    <span class="fc-exam-kpi-value">@_workspace.Findings.Count(f => f.RemediationStatus == ExaminationRemediationStatus.Escalated)</span>
                    <span class="fc-exam-kpi-hint">Remediation items</span>
                </div>
            </div>

            @* ── Tab Content ── *@
            <div class="fc-exam-tab-content">
                @switch (_activeTab)
                {
                    case "overview":
                        @* Project detail: team + milestones *@
                        <section class="rg-card">
                            <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;margin-bottom:0.9rem">
                                <div>
                                    <h3 class="rg-section-title">@_workspace.Project.Name</h3>
                                    <p class="rg-muted">@_workspace.Project.Scope</p>
                                </div>
                                <span class="rg-badge @ProjectStatusClass(_workspace.Project.Status)">@_workspace.Project.Status</span>
                            </div>
                            <div class="fc-exam-project-detail">
                                <div>
                                    <h4 class="rg-subsection-title">Team</h4>
                                    @if (_workspace.TeamAssignments.Count == 0)
                                    {
                                        <EmptyState Context="users" Size="sm"
                                                    Heading="No team assignments"
                                                    Description="Add team members when creating the examination project." />
                                    }
                                    else
                                    {
                                        <ul class="rg-plain-list">
                                            @foreach (var a in _workspace.TeamAssignments)
                                            {
                                                <li><strong>@a.DisplayName</strong> — @a.Role</li>
                                            }
                                        </ul>
                                    }
                                </div>
                                <div>
                                    <h4 class="rg-subsection-title">Milestones</h4>
                                    @if (_workspace.Milestones.Count == 0)
                                    {
                                        <EmptyState Context="data" Size="sm"
                                                    Heading="No milestones"
                                                    Description="Add milestones when creating the examination project." />
                                    }
                                    else
                                    {
                                        <ul class="rg-plain-list">
                                            @foreach (var m in _workspace.Milestones)
                                            {
                                                <li>
                                                    @m.Title
                                                    @if (m.DueAt.HasValue)
                                                    {
                                                        <span class="rg-muted"> — @m.DueAt.Value.ToString("dd MMM yyyy")</span>
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    }
                                </div>
                            </div>
                        </section>

                        @* Scoped Submissions *@
                        <section class="rg-card">
                            <h3 class="rg-section-title">Scoped Submissions</h3>
                            @if (_workspace.Submissions.Count == 0)
                            {
                                <EmptyState Context="submissions" Size="sm"
                                            Heading="No submissions in scope"
                                            Description="No submissions match the current examination scope." />
                            }
                            else
                            {
                                <DataTable TItem="RegulatorSubmissionInboxItem"
                                           Items="@_workspace.Submissions"
                                           ShowExport="true"
                                           ExportFileName="scoped-submissions"
                                           PageSize="25"
                                           EmptyTitle="No submissions">
                                    <ChildContent>
                                        <DataColumn TItem="RegulatorSubmissionInboxItem" Title="Submission" Width="100px">
                                            <CellTemplate>#@context.SubmissionId</CellTemplate>
                                        </DataColumn>
                                        <DataColumn TItem="RegulatorSubmissionInboxItem" Title="Institution" SortKey="x => x.InstitutionName">
                                            <CellTemplate>@context.InstitutionName</CellTemplate>
                                        </DataColumn>
                                        <DataColumn TItem="RegulatorSubmissionInboxItem" Title="Module" SortKey="x => x.ModuleCode" Width="120px">
                                            <CellTemplate>@context.ModuleCode</CellTemplate>
                                        </DataColumn>
                                        <DataColumn TItem="RegulatorSubmissionInboxItem" Title="Period" SortKey="x => x.PeriodLabel" Width="120px">
                                            <CellTemplate>@context.PeriodLabel</CellTemplate>
                                        </DataColumn>
                                        <DataColumn TItem="RegulatorSubmissionInboxItem" Title="Status" Width="120px">
                                            <CellTemplate>@context.SubmissionStatus</CellTemplate>
                                        </DataColumn>
                                    </ChildContent>
                                </DataTable>
                            }
                        </section>
                        break;

                    case "intelligence":
                        <ExamIntelligencePack IntelligencePack="@_workspace.IntelligencePack" />
                        break;

                    case "kanban":
                        <ExamKanban Findings="@_workspace.Findings"
                                    OnStatusChange="HandleKanbanStatusChange"
                                    OnEditFinding="HandleEditFinding" />
                        break;

                    case "evidence":
                        <ExamEvidencePanel EvidenceRequests="@_workspace.EvidenceRequests"
                                           EvidenceFiles="@_workspace.EvidenceFiles"
                                           Findings="@_workspace.Findings"
                                           OnRefresh="RefreshWorkspace"
                                           TenantId="@_tenantId"
                                           ProjectId="@_workspace.Project.Id"
                                           UserId="@_userId" />
                        break;

                    case "remediation":
                        <ExamRemediationTable Findings="@_workspace.Findings"
                                              OnManageFinding="HandleEditFinding" />
                        break;

                    case "annotations":
                        <ExamAnnotationsTable Annotations="@_workspace.Annotations"
                                              OnRefresh="RefreshWorkspace"
                                              TenantId="@_tenantId"
                                              ProjectId="@_workspace.Project.Id"
                                              UserId="@_userId" />
                        break;
                }
            </div>

            @* ── Finding Modal (available from any tab) ── *@
            <ExamFindingModal @bind-Visible="_showFindingModal"
                              Finding="@_editingFinding"
                              OnSaved="HandleFindingSaved"
                              TenantId="@_tenantId"
                              RegulatorCode="@_regulatorCode"
                              ProjectId="@_workspace.Project.Id"
                              UserId="@_userId" />
        }
        else if (!_loading && _projects.Count > 0)
        {
            <EmptyState Context="data"
                        Heading="Select a project"
                        Description="Choose an examination project from the list above to view its workspace." />
        }
    }
</SectionErrorBoundary>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private static readonly List<TabItem> _tabs = new()
    {
        new("overview", "Overview", Count: null),
        new("intelligence", "Intelligence Pack"),
        new("kanban", "Findings Kanban"),
        new("evidence", "Evidence"),
        new("remediation", "Remediation"),
        new("annotations", "Annotations")
    };

    private string _activeTab = "overview";
    private bool _loading = true;
    private Exception? _loadException;

    private Guid _tenantId;
    private int _userId;
    private string _regulatorCode = string.Empty;

    private List<ExaminationProject> _projects = new();
    private ExaminationWorkspaceData? _workspace;

    private bool _showFindingModal;
    private ExaminationFinding? _editingFinding;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _loadException = null;

        try
        {
            await ResolveContext();
            await ReloadProjects();
        }
        catch (Exception ex)
        {
            _loadException = ex;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ResolveContext()
    {
        var state = await AuthState!;

        var tenantClaim = state.User.FindFirst("TenantId")?.Value;
        var regulatorClaim = state.User.FindFirst("RegulatorCode")?.Value;
        var userClaim = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!Guid.TryParse(tenantClaim, out _tenantId)
            || !int.TryParse(userClaim, out _userId)
            || string.IsNullOrWhiteSpace(regulatorClaim))
        {
            throw new InvalidOperationException("Regulator identity claims are incomplete for this session.");
        }

        _regulatorCode = regulatorClaim.Trim();
    }

    private async Task ReloadProjects()
    {
        _projects = (await WorkspaceService.ListProjects(_tenantId)).ToList();
    }

    private async Task SelectProject(int projectId)
    {
        try
        {
            _workspace = await WorkspaceService.GetWorkspace(_tenantId, _regulatorCode, projectId);
            if (_workspace is null)
            {
                Toast.Warning("Project not found.");
                return;
            }

            _editingFinding = null;
            Toast.Success($"Loaded \"{_workspace.Project.Name}\".");
        }
        catch (Exception ex)
        {
            Toast.Error($"Failed to load project: {ex.Message}");
        }
    }

    private async Task RefreshWorkspace()
    {
        if (_workspace is null) return;
        try
        {
            _workspace = await WorkspaceService.GetWorkspace(_tenantId, _regulatorCode, _workspace.Project.Id);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Toast.Error($"Failed to refresh workspace: {ex.Message}");
        }
    }

    private async Task HandleKanbanStatusChange((int FindingId, ExaminationWorkflowStatus NewStatus) args)
    {
        if (_workspace is null) return;

        var finding = _workspace.Findings.FirstOrDefault(f => f.Id == args.FindingId);
        if (finding is null) return;

        var remediation = args.NewStatus == ExaminationWorkflowStatus.Closed
            ? ExaminationRemediationStatus.Closed
            : finding.RemediationStatus;

        try
        {
            await WorkspaceService.UpdateFinding(
                _tenantId,
                _workspace.Project.Id,
                finding.Id,
                new ExaminationFindingUpdateRequest
                {
                    Status = args.NewStatus,
                    RemediationStatus = remediation,
                    RiskRating = finding.RiskRating,
                    Observation = finding.Observation,
                    Recommendation = finding.Recommendation,
                    ManagementResponseDeadline = finding.ManagementResponseDeadline,
                    ManagementResponse = finding.ManagementResponse,
                    ManagementActionPlan = finding.ManagementActionPlan,
                    EvidenceReference = finding.EvidenceReference
                },
                _userId);

            Toast.Success($"Moved \"{finding.Title}\" to {FormatWorkflowStatus(args.NewStatus)}.");
            await RefreshWorkspace();
        }
        catch (Exception ex)
        {
            Toast.Error($"Failed to move finding: {ex.Message}");
        }
    }

    private void HandleEditFinding(int findingId)
    {
        _editingFinding = _workspace?.Findings.FirstOrDefault(f => f.Id == findingId);
        _showFindingModal = true;
        StateHasChanged();
    }

    private async Task HandleFindingSaved()
    {
        _editingFinding = null;
        await RefreshWorkspace();
    }

    private void HandleTabChange(string tabId)
    {
        _activeTab = tabId;
        StateHasChanged();
    }

    private static string FormatWorkflowStatus(ExaminationWorkflowStatus status) => status switch
    {
        ExaminationWorkflowStatus.ToReview => "To Review",
        ExaminationWorkflowStatus.InProgress => "In Progress",
        ExaminationWorkflowStatus.FindingDocumented => "Finding Documented",
        ExaminationWorkflowStatus.ManagementResponseRequired => "Management Response Required",
        ExaminationWorkflowStatus.Closed => "Closed",
        _ => status.ToString()
    };

    private static string ProjectStatusVariant(ExaminationProjectStatus? status) => status switch
    {
        ExaminationProjectStatus.Completed => "success",
        ExaminationProjectStatus.Archived => "neutral",
        ExaminationProjectStatus.InProgress => "info",
        _ => "warning"
    };

    private static string ProjectStatusClass(ExaminationProjectStatus status) => status switch
    {
        ExaminationProjectStatus.Completed => "accept",
        ExaminationProjectStatus.Archived => "recd",
        _ => "review"
    };
}
