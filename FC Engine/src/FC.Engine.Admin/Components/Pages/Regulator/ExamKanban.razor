@using FC.Engine.Domain.Entities
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="fc-exam-kanban" @ref="_boardRef" aria-label="Examination findings kanban board">
    @foreach (var col in _columns)
    {
        <div class="fc-exam-kanban-col" data-kanban-col="@col.Status" aria-label="@col.Label column, @(ColFindings(col.Status).Count) items">
            <div class="fc-exam-kanban-col-head">
                <span class="fc-exam-kanban-col-title">@col.Label</span>
                <span class="fc-exam-kanban-col-count">@ColFindings(col.Status).Count</span>
            </div>

            @foreach (var finding in ColFindings(col.Status))
            {
                <div class="fc-exam-kanban-card" data-kanban-card="@finding.Id" tabindex="0" role="button"
                     aria-label="@finding.Title — @finding.RiskRating risk. Press Enter to edit."
                     @onclick="() => OnEditFinding.InvokeAsync(finding.Id)"
                     @onkeydown="e => HandleCardKey(e, finding.Id)">
                    <div class="fc-exam-kanban-card-head">
                        <strong>@finding.Title</strong>
                        <span class="@RiskClass(finding.RiskRating)">@finding.RiskRating</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(finding.RiskArea))
                    {
                        <div class="fc-exam-kanban-card-obs">@finding.RiskArea</div>
                    }
                    <div class="fc-exam-kanban-meta">
                        <span>@finding.RemediationStatus</span>
                        <span>@(finding.ManagementResponseDeadline?.ToString("dd MMM") ?? "No deadline")</span>
                    </div>
                </div>
            }

            @if (!ColFindings(col.Status).Any())
            {
                <div class="fc-exam-kanban-empty" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                    <span>No items</span>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<ExaminationFinding> Findings { get; set; } = Array.Empty<ExaminationFinding>();
    [Parameter] public EventCallback<(int FindingId, ExaminationWorkflowStatus NewStatus)> OnStatusChange { get; set; }
    [Parameter] public EventCallback<int> OnEditFinding { get; set; }

    private ElementReference _boardRef;
    private DotNetObjectReference<ExamKanban>? _dotNetRef;

    private static readonly (ExaminationWorkflowStatus Status, string Label)[] _columns =
    {
        (ExaminationWorkflowStatus.ToReview, "To Review"),
        (ExaminationWorkflowStatus.InProgress, "In Progress"),
        (ExaminationWorkflowStatus.FindingDocumented, "Finding Documented"),
        (ExaminationWorkflowStatus.ManagementResponseRequired, "Mgmt Response"),
        (ExaminationWorkflowStatus.Closed, "Closed")
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("fcDragDrop.initKanban", _boardRef, _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task OnKanbanDrop(string cardId, string targetColumn)
    {
        if (int.TryParse(cardId, out var findingId) && Enum.TryParse<ExaminationWorkflowStatus>(targetColumn, out var status))
        {
            await OnStatusChange.InvokeAsync((findingId, status));
        }
    }

    private List<ExaminationFinding> ColFindings(ExaminationWorkflowStatus status)
        => Findings.Where(f => f.Status == status).OrderByDescending(f => f.RiskRating).ThenBy(f => f.Title).ToList();

    private static string RiskClass(ExaminationRiskRating rating) => rating switch
    {
        ExaminationRiskRating.High => "fc-exam-risk-high",
        ExaminationRiskRating.Medium => "fc-exam-risk-medium",
        _ => "fc-exam-risk-low"
    };

    private async Task HandleCardKey(KeyboardEventArgs e, int findingId)
    {
        if (e.Key == "Enter" || e.Key == " ")
            await OnEditFinding.InvokeAsync(findingId);
    }

    public async ValueTask DisposeAsync()
    {
        if (_dotNetRef is not null)
        {
            try { await JS.InvokeVoidAsync("fcDragDrop.destroyKanban", _boardRef); } catch { }
            _dotNetRef.Dispose();
        }
    }
}
