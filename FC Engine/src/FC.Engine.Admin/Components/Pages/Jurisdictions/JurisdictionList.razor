@page "/jurisdictions"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "PlatformAdmin")]
@using FC.Engine.Domain.Entities
@using FC.Engine.Admin.Services
@inject JurisdictionManagementService JurisdictionSvc
@inject ToastService Toast
@inject DialogService Dialog

<PageTitle>Jurisdiction Registry</PageTitle>

<div class="fc-page">

    <!-- Breadcrumb -->
    <nav class="fc-detail-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Dashboard</a>
        <span class="fc-detail-breadcrumb-sep" aria-hidden="true">/</span>
        <a href="/jurisdictions">Platform</a>
        <span class="fc-detail-breadcrumb-sep" aria-hidden="true">/</span>
        <span class="fc-detail-breadcrumb-current">Jurisdictions</span>
    </nav>

    <!-- Page Header -->
    <div class="fc-page-header">
        <div class="fc-page-header-top">
            <div>
                <h1>Jurisdiction Registry</h1>
                <p class="fc-page-header-subtitle">Multi-Jurisdiction Template Extension Framework — RG-27</p>
            </div>
        </div>

        <!-- Summary Chips -->
        @if (_stats is not null)
        {
            <div class="fc-chip-group">
                <span class="fc-chip">
                    <span class="fc-chip__count">@_stats.Total</span> Total
                </span>
                <span class="fc-chip">
                    <span class="fc-chip__dot fc-chip__dot--active" aria-hidden="true"></span>
                    <span class="fc-chip__count">@_stats.Active</span> Active
                </span>
                @if (_stats.Planned > 0)
                {
                    <span class="fc-chip">
                        <span class="fc-chip__dot fc-chip__dot--inactive" aria-hidden="true"></span>
                        <span class="fc-chip__count">@_stats.Planned</span> Planned
                    </span>
                }
            </div>
        }
    </div>

    <!-- Toolbar -->
    <div class="fc-toolbar">
        <div class="fc-toolbar-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" placeholder="Search by country name, code, or currency..." @bind="_searchQuery" @bind:event="oninput" aria-label="Search jurisdictions" />
        </div>
        <div class="fc-toolbar-filter">
            <select @bind="_statusFilter" aria-label="Filter by status">
                <option value="">All Status</option>
                <option value="active">Active</option>
                <option value="planned">Planned</option>
            </select>
        </div>
    </div>

    <!-- Content -->
    @if (_loading)
    {
        <div class="fc-card">
            <div class="fc-card__body" style="padding:0;overflow:auto;">
                <table class="fc-table">
                    <thead>
                        <tr>
                            <th>Country</th>
                            <th>Code</th>
                            <th>Currency</th>
                            <th>Timezone</th>
                            <th>Data Residency</th>
                            <th>Regulators</th>
                            <th style="text-align:center;">Modules</th>
                            <th style="text-align:center;">Institutions</th>
                            <th>Status</th>
                            <th style="text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < 5; i++)
                        {
                            <tr>
                                <td><div class="fc-skel fc-skel-text" style="width:120px;"></div></td>
                                <td><div class="fc-skel fc-skel-text" style="width:40px;"></div></td>
                                <td><div class="fc-skel fc-skel-text" style="width:40px;"></div></td>
                                <td><div class="fc-skel fc-skel-text" style="width:100px;"></div></td>
                                <td><div class="fc-skel fc-skel-text" style="width:80px;"></div></td>
                                <td><div class="fc-skel fc-skel-text" style="width:100px;"></div></td>
                                <td style="text-align:center;"><div class="fc-skel fc-skel-text" style="width:24px;margin:0 auto;"></div></td>
                                <td style="text-align:center;"><div class="fc-skel fc-skel-text" style="width:24px;margin:0 auto;"></div></td>
                                <td><div class="fc-skel" style="width:52px;height:20px;border-radius:var(--radius-pill);"></div></td>
                                <td style="text-align:right;"><div class="fc-skel" style="width:120px;height:28px;border-radius:6px;margin-left:auto;"></div></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (_jurisdictions is not null && !FilteredJurisdictions.Any())
    {
        <div class="fc-empty">
            <div class="fc-empty-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
            </div>
            @if (string.IsNullOrEmpty(_searchQuery) && string.IsNullOrEmpty(_statusFilter))
            {
                <h3 class="fc-empty-title">No jurisdictions found</h3>
                <p class="fc-empty-text">No jurisdictions have been configured yet.</p>
            }
            else
            {
                <h3 class="fc-empty-title">No matching jurisdictions</h3>
                <p class="fc-empty-text">Try adjusting your search or filters.</p>
            }
        </div>
    }
    else if (_jurisdictions is not null)
    {
        <div class="fc-card">
            <div class="fc-card__body" style="padding:0;overflow:auto;">
                <table class="fc-table">
                    <thead>
                        <tr>
                            <th>Country</th>
                            <th>Code</th>
                            <th>Currency</th>
                            <th>Timezone</th>
                            <th>Data Residency</th>
                            <th>Regulators</th>
                            <th style="text-align:center;">Modules</th>
                            <th style="text-align:center;">Institutions</th>
                            <th>Status</th>
                            <th style="text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var j in FilteredJurisdictions)
                        {
                            <tr>
                                <td style="font-weight:500;">@j.CountryName</td>
                                <td><code>@j.CountryCode</code></td>
                                <td><code>@j.Currency</code></td>
                                <td>@j.Timezone</td>
                                <td>@j.DataResidencyRegion</td>
                                <td>@FormatRegulators(j.RegulatoryBodies)</td>
                                <td style="text-align:center;">@j.ModuleCount</td>
                                <td style="text-align:center;">@j.InstitutionCount</td>
                                <td>
                                    @if (j.IsActive)
                                    {
                                        <span class="fc-portal-badge fc-portal-badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="fc-portal-badge fc-portal-badge-warning">Planned</span>
                                    }
                                </td>
                                <td style="text-align:right;">
                                    <div style="display:flex;gap:0.35rem;justify-content:flex-end;">
                                        <button class="fc-btn fc-btn--ghost" @onclick="() => OpenEditDialog(j)" type="button" title="Edit jurisdiction">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                            Edit
                                        </button>
                                        @if (j.IsActive)
                                        {
                                            <button class="fc-btn fc-btn--ghost fc-btn--danger" @onclick="() => ToggleActive(j.Id)" type="button" title="Deactivate jurisdiction">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                                                Deactivate
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="fc-btn fc-btn--ghost" @onclick="() => ToggleActive(j.Id)" type="button" title="Activate jurisdiction">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                                Activate
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- FX Rates Section -->
    <div style="margin-top:2rem;">
        <div class="fc-card">
            <div class="fc-card__header" style="display:flex;align-items:center;justify-content:space-between;">
                <div>
                    <h2 class="fc-card__title">FX Rates</h2>
                    <p style="color:#64748b;font-size:0.85rem;margin:0;">Cross-jurisdiction currency conversion reference rates</p>
                </div>
                <button class="fc-btn fc-btn--primary" @onclick="OpenFxRateDialog" type="button">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Add FX Rate
                </button>
            </div>
            <div class="fc-card__body" style="padding:0;overflow:auto;">
                @if (_fxRates is not null && _fxRates.Count > 0)
                {
                    <table class="fc-table">
                        <thead>
                            <tr>
                                <th>Base</th>
                                <th>Quote</th>
                                <th style="text-align:right;">Rate</th>
                                <th>Date</th>
                                <th>Source</th>
                                <th style="text-align:right;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rate in _fxRates)
                            {
                                <tr>
                                    <td><code>@rate.BaseCurrency</code></td>
                                    <td><code>@rate.QuoteCurrency</code></td>
                                    <td style="text-align:right;"><code>@rate.Rate.ToString("N6")</code></td>
                                    <td>@rate.RateDate.ToString("yyyy-MM-dd")</td>
                                    <td>@rate.Source</td>
                                    <td style="text-align:right;">
                                        <button class="fc-btn fc-btn--ghost fc-btn--danger" @onclick="() => DeleteFxRate(rate.Id)" type="button" title="Delete FX rate">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else if (_fxRates is not null)
                {
                    <div class="fc-empty">
                        <div class="fc-empty-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                        </div>
                        <h3 class="fc-empty-title">No FX rates configured</h3>
                        <p class="fc-empty-text">Add rates for cross-jurisdiction currency conversion.</p>
                    </div>
                }
            </div>
        </div>
    </div>

</div>

<!-- Edit Jurisdiction Modal -->
<AppModal @bind-Visible="_showEditDialog"
          Title="@($"Edit Jurisdiction — {_editItem?.CountryCode}")"
          Subtitle="Update jurisdiction configuration and compliance settings"
          Size="lg">
    <ChildContent>
        <div class="fc-form-grid">
            <div class="fc-form-group">
                <label class="fc-form-label fc-form-label-required">Country Name</label>
                <input class="fc-form-input" type="text" @bind="_editCountryName" />
            </div>
            <div class="fc-form-group">
                <label class="fc-form-label fc-form-label-required">Currency (ISO 4217)</label>
                <input class="fc-form-input" type="text" @bind="_editCurrency" maxlength="3" style="font-family:monospace;" />
            </div>
            <div class="fc-form-group">
                <label class="fc-form-label">Timezone</label>
                <input class="fc-form-input" type="text" @bind="_editTimezone" />
            </div>
            <div class="fc-form-group">
                <label class="fc-form-label">Date Format</label>
                <input class="fc-form-input" type="text" @bind="_editDateFormat" style="font-family:monospace;" />
            </div>
        </div>
        <div class="fc-form-group" style="margin-top:1rem;">
            <label class="fc-form-label">Data Residency Region (Azure)</label>
            <input class="fc-form-input" type="text" @bind="_editDataResidencyRegion" />
        </div>
        <div class="fc-form-group" style="margin-top:1rem;">
            <label class="fc-form-label">Regulatory Bodies (JSON array)</label>
            <input class="fc-form-input" type="text" @bind="_editRegulatoryBodies" style="font-family:monospace;" />
        </div>
        <div class="fc-form-group" style="margin-top:1rem;">
            <label class="fc-form-label">Data Protection Law</label>
            <input class="fc-form-input" type="text" @bind="_editDataProtectionLaw" />
        </div>
    </ChildContent>
    <FooterContent>
        <button class="fc-btn fc-btn--outline" @onclick="CloseDialogs" type="button">Cancel</button>
        <button class="fc-btn fc-btn--primary" @onclick="SaveJurisdiction" disabled="@_isSaving" type="button">
            @if (_isSaving)
            {
                <span class="spinner" style="width:16px;height:16px;"></span>
            }
            Save Changes
        </button>
    </FooterContent>
</AppModal>

<!-- Add FX Rate Modal -->
<AppModal @bind-Visible="_showFxRateDialog"
          Title="Add FX Rate"
          Subtitle="Define a cross-jurisdiction currency conversion rate"
          Size="default">
    <ChildContent>
        <div class="fc-form-grid">
            <div class="fc-form-group">
                <label class="fc-form-label fc-form-label-required">Base Currency</label>
                <input class="fc-form-input" type="text" @bind="_fxBaseCurrency" maxlength="3" placeholder="NGN" style="font-family:monospace;" />
            </div>
            <div class="fc-form-group">
                <label class="fc-form-label fc-form-label-required">Quote Currency</label>
                <input class="fc-form-input" type="text" @bind="_fxQuoteCurrency" maxlength="3" placeholder="GHS" style="font-family:monospace;" />
            </div>
            <div class="fc-form-group">
                <label class="fc-form-label fc-form-label-required">Rate</label>
                <input class="fc-form-input" type="number" step="0.000001" @bind="_fxRate" style="font-family:monospace;" />
            </div>
            <div class="fc-form-group">
                <label class="fc-form-label fc-form-label-required">Rate Date</label>
                <input class="fc-form-input" type="date" @bind="_fxRateDate" />
            </div>
        </div>
        <div class="fc-form-group" style="margin-top:1rem;">
            <label class="fc-form-label">Source</label>
            <input class="fc-form-input" type="text" @bind="_fxSource" placeholder="Manual" />
        </div>
    </ChildContent>
    <FooterContent>
        <button class="fc-btn fc-btn--outline" @onclick="CloseDialogs" type="button">Cancel</button>
        <button class="fc-btn fc-btn--primary" @onclick="SaveFxRate" disabled="@_isSaving" type="button">
            @if (_isSaving)
            {
                <span class="spinner" style="width:16px;height:16px;"></span>
            }
            Add Rate
        </button>
    </FooterContent>
</AppModal>

@code {
    private List<JurisdictionListItem>? _jurisdictions;
    private List<JurisdictionFxRate>? _fxRates;
    private JurisdictionDashboardStats? _stats;
    private bool _isSaving;
    private bool _loading = true;

    // Search & filter
    private string _searchQuery = "";
    private string _statusFilter = "";

    // Edit dialog state
    private bool _showEditDialog;
    private JurisdictionListItem? _editItem;
    private string _editCountryName = "";
    private string _editCurrency = "";
    private string _editTimezone = "";
    private string _editDateFormat = "";
    private string _editRegulatoryBodies = "";
    private string? _editDataProtectionLaw;
    private string _editDataResidencyRegion = "";

    // FX rate dialog state
    private bool _showFxRateDialog;
    private string _fxBaseCurrency = "";
    private string _fxQuoteCurrency = "";
    private decimal _fxRate;
    private DateTime _fxRateDate = DateTime.UtcNow.Date;
    private string _fxSource = "Manual";

    private IEnumerable<JurisdictionListItem> FilteredJurisdictions => (_jurisdictions ?? new())
        .Where(j => string.IsNullOrEmpty(_searchQuery) ||
                    j.CountryName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    j.CountryCode.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    j.Currency.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
        .Where(j => string.IsNullOrEmpty(_statusFilter) ||
                    (_statusFilter == "active" && j.IsActive) ||
                    (_statusFilter == "planned" && !j.IsActive));

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _loading = false;
    }

    private async Task LoadData()
    {
        _jurisdictions = await JurisdictionSvc.GetAllAsync();
        _stats = await JurisdictionSvc.GetStatsAsync();
        _fxRates = await JurisdictionSvc.GetFxRatesAsync();
    }

    private async Task ToggleActive(int id)
    {
        try
        {
            await JurisdictionSvc.ToggleActiveAsync(id);
            await LoadData();
            Toast.Success("Jurisdiction status updated.");
        }
        catch (Exception ex)
        {
            Toast.Error($"Failed to update jurisdiction: {ex.Message}");
        }
    }

    private void OpenEditDialog(JurisdictionListItem item)
    {
        _editItem = item;
        _editCountryName = item.CountryName;
        _editCurrency = item.Currency;
        _editTimezone = item.Timezone;
        _editDateFormat = item.DateFormat;
        _editRegulatoryBodies = item.RegulatoryBodies;
        _editDataProtectionLaw = item.DataProtectionLaw;
        _editDataResidencyRegion = item.DataResidencyRegion;
        _showEditDialog = true;
    }

    private async Task SaveJurisdiction()
    {
        if (_editItem is null) return;
        _isSaving = true;

        try
        {
            await JurisdictionSvc.UpdateAsync(_editItem.Id, new JurisdictionUpdateRequest
            {
                CountryName = _editCountryName,
                Currency = _editCurrency.ToUpperInvariant(),
                Timezone = _editTimezone,
                DateFormat = _editDateFormat,
                RegulatoryBodies = _editRegulatoryBodies,
                DataProtectionLaw = _editDataProtectionLaw,
                DataResidencyRegion = _editDataResidencyRegion
            });

            Toast.Success("Jurisdiction updated successfully.");
            CloseDialogs();
            await LoadData();
        }
        catch (Exception ex)
        {
            Toast.Error($"Failed to update: {ex.Message}");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void OpenFxRateDialog()
    {
        _fxBaseCurrency = "";
        _fxQuoteCurrency = "";
        _fxRate = 0;
        _fxRateDate = DateTime.UtcNow.Date;
        _fxSource = "Manual";
        _showFxRateDialog = true;
    }

    private async Task SaveFxRate()
    {
        if (string.IsNullOrWhiteSpace(_fxBaseCurrency) || string.IsNullOrWhiteSpace(_fxQuoteCurrency) || _fxRate <= 0)
        {
            Toast.Error("Please fill in all required fields.");
            return;
        }

        _isSaving = true;
        try
        {
            await JurisdictionSvc.UpsertFxRateAsync(new JurisdictionFxRate
            {
                BaseCurrency = _fxBaseCurrency.ToUpperInvariant(),
                QuoteCurrency = _fxQuoteCurrency.ToUpperInvariant(),
                Rate = _fxRate,
                RateDate = DateOnly.FromDateTime(_fxRateDate),
                Source = string.IsNullOrWhiteSpace(_fxSource) ? "Manual" : _fxSource
            });

            Toast.Success("FX rate saved successfully.");
            CloseDialogs();
            await LoadData();
        }
        catch (Exception ex)
        {
            Toast.Error($"Failed to save FX rate: {ex.Message}");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteFxRate(int id)
    {
        var confirmed = await Dialog.Confirm(new ConfirmRequest
        {
            Title = "Delete FX Rate",
            Message = "Are you sure you want to delete this FX rate? This action cannot be undone.",
            ConfirmText = "Delete",
            IsDestructive = true,
            Icon = "delete"
        });

        if (!confirmed) return;

        try
        {
            await JurisdictionSvc.DeleteFxRateAsync(id);
            await LoadData();
            Toast.Success("FX rate deleted.");
        }
        catch (Exception ex)
        {
            Toast.Error($"Failed to delete FX rate: {ex.Message}");
        }
    }

    private void CloseDialogs()
    {
        _showEditDialog = false;
        _showFxRateDialog = false;
        _editItem = null;
    }

    private static string FormatRegulators(string json)
    {
        try
        {
            var trimmed = json.Trim();
            if (trimmed.StartsWith('['))
            {
                return trimmed
                    .Replace("[", "").Replace("]", "")
                    .Replace("\"", "").Replace(",", ", ")
                    .Trim();
            }
            return trimmed;
        }
        catch
        {
            return json;
        }
    }
}
