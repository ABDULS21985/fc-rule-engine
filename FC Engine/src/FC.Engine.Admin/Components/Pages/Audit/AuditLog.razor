    // ── Data models ───────────────────────────────────────────────────────────
    private sealed class AuditDisplayEntry
    {
        public long Id { get; init; }
        public DateTime Timestamp { get; init; }
        public string Action { get; init; } = string.Empty;
        public string EntityType { get; init; } = string.Empty;
        public string EntityId { get; init; } = string.Empty;
        public string PerformedBy { get; init; } = string.Empty;
        public string? OldValues { get; init; }
        public string? NewValues { get; init; }
        public string? IpAddress { get; init; }
        public bool IsNew { get; set; }
        public bool IsFlagged { get; set; }
        public bool ShowDiff { get; set; }
        public List<DiffField>? DiffFields { get; init; }
    }

    private sealed class AuditEventGroup(string performedBy, DateTime windowStart)
    {
        public string PerformedBy { get; } = performedBy;
        public DateTime WindowStart { get; } = windowStart;
        public List<AuditDisplayEntry> Entries { get; } = new();
    }

    private sealed record DiffField(string Field, string? OldValue, string? NewValue, DiffKind Type);

    private enum DiffKind { Added, Removed, Changed }
}
