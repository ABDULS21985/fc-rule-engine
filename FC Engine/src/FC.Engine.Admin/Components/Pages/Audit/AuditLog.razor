@page "/audit"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "ApproverOrAdmin")]
@using FC.Engine.Infrastructure.Metadata
@using Microsoft.EntityFrameworkCore
@inject IServiceProvider ServiceProvider

<PageHeader Title="Audit Log"
            Subtitle="Trace all operational activity, metadata changes, and administrative actions across the platform." />

<div class="fc-page">

    <!-- Filter Toolbar -->
    <div class="fc-toolbar">
        <div class="fc-toolbar-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" placeholder="Search by entity, user, or action..." @bind="_searchQuery" @bind:event="oninput" aria-label="Search audit entries" />
        </div>
        <div class="fc-toolbar-filter">
            <select @bind="_actionFilter" aria-label="Filter by action type">
                <option value="">All Actions</option>
                @foreach (var action in _entries.Select(e => e.Action).Distinct().OrderBy(a => a))
                {
                    <option value="@action">@action</option>
                }
            </select>
            <select @bind="_entityFilter" aria-label="Filter by entity type">
                <option value="">All Entities</option>
                @foreach (var entity in _entries.Select(e => e.EntityType).Distinct().OrderBy(e => e))
                {
                    <option value="@entity">@entity</option>
                }
            </select>
        </div>
        <div class="fc-toolbar-date">
            <input type="date" @bind="_dateFrom" aria-label="From date" />
            <span class="fc-toolbar-date-sep">to</span>
            <input type="date" @bind="_dateTo" aria-label="To date" />
        </div>
        <div class="fc-toolbar-actions">
            <button class="fc-btn fc-btn--outline" @onclick="ClearFilters" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                Clear
            </button>
            <button class="fc-btn fc-btn--gold" @onclick="LoadAuditLog" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
                Refresh
            </button>
        </div>
    </div>

    <!-- Content -->
    @if (_loading)
    {
        <div class="fc-skel-timeline" role="status" aria-label="Loading audit trail">
            @for (var i = 0; i < 5; i++)
            {
                <div class="fc-skel-timeline-item">
                    <div style="display:flex;align-items:center;gap:var(--space-3);margin-bottom:var(--space-2);">
                        <div class="fc-skel fc-skel-circle" style="width:32px;height:32px;flex-shrink:0;"></div>
                        <div style="flex:1;">
                            <div class="fc-skel fc-skel-text" style="width:120px;"></div>
                            <div class="fc-skel fc-skel-text" style="width:180px;"></div>
                        </div>
                    </div>
                    <div style="display:flex;gap:var(--space-4);margin-top:var(--space-2);">
                        <div class="fc-skel" style="width:100px;height:10px;"></div>
                        <div class="fc-skel" style="width:130px;height:10px;"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (!FilteredEntries.Any())
    {
        <div class="fc-empty">
            <div class="fc-empty-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            </div>
            @if (string.IsNullOrEmpty(_searchQuery) && string.IsNullOrEmpty(_actionFilter) && string.IsNullOrEmpty(_entityFilter) && _dateFrom is null && _dateTo is null)
            {
                <h3 class="fc-empty-title">No audit events recorded</h3>
                <p class="fc-empty-text">System activity will appear here as operations are performed.</p>
            }
            else
            {
                <h3 class="fc-empty-title">No matching events</h3>
                <p class="fc-empty-text">Try adjusting the date range or filters.</p>
            }
        </div>
    }
    else
    {
        <!-- Vertical Alternating Timeline -->
        <div class="fc-audit-timeline" role="feed" aria-label="Audit trail timeline">
            @foreach (var entry in FilteredEntries.Take(200))
            {
                <div class="fc-audit-timeline-item" role="article">
                    <span class="fc-audit-timeline-dot @GetDotClass(entry.Action)" aria-hidden="true"></span>
                    <div class="fc-audit-timeline-card">
                        <div class="fc-audit-card-header">
                            <div class="fc-audit-card-icon @GetIconClass(entry.Action)" aria-hidden="true">
                                @GetActionIcon(entry.Action)
                            </div>
                            <div class="fc-audit-card-content">
                                <div class="fc-audit-card-action">@entry.Action</div>
                                <div class="fc-audit-card-entity">
                                    @entry.EntityType
                                    @if (!string.IsNullOrEmpty(entry.EntityId))
                                    {
                                        <code>#@entry.EntityId</code>
                                    }
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(entry.Changes))
                        {
                            <div class="fc-audit-card-entity" style="margin-top: var(--space-2); font-size: var(--text-caption); color: var(--cbn-text-muted);">
                                @entry.Changes
                            </div>
                        }

                        <div class="fc-audit-card-footer">
                            <span class="fc-audit-card-meta">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4-4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                @entry.PerformedBy
                            </span>
                            <span class="fc-audit-card-meta">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                @entry.Timestamp.ToString("dd MMM yyyy, HH:mm:ss")
                            </span>
                            @if (!string.IsNullOrEmpty(entry.IpAddress))
                            {
                                <span class="fc-audit-card-meta">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                                    @entry.IpAddress
                                </span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (FilteredEntries.Count() > 200)
        {
            <div style="text-align:center; padding: var(--space-4); color: var(--cbn-text-muted); font-size: var(--text-body-sm);">
                Showing 200 of @FilteredEntries.Count() matching events. Narrow your filters to see more.
            </div>
        }
    }
</div>

@code {
    private bool _loading = true;
    private List<AuditEntry> _entries = new();

    // Filters
    private string _searchQuery = "";
    private string _actionFilter = "";
    private string _entityFilter = "";
    private DateTime? _dateFrom;
    private DateTime? _dateTo;

    private IEnumerable<AuditEntry> FilteredEntries => _entries
        .Where(e => string.IsNullOrEmpty(_searchQuery) ||
                    e.EntityType.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    e.PerformedBy.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    e.Action.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
        .Where(e => string.IsNullOrEmpty(_actionFilter) || e.Action == _actionFilter)
        .Where(e => string.IsNullOrEmpty(_entityFilter) || e.EntityType == _entityFilter)
        .Where(e => _dateFrom is null || e.Timestamp.Date >= _dateFrom.Value.Date)
        .Where(e => _dateTo is null || e.Timestamp.Date <= _dateTo.Value.Date);

    protected override async Task OnInitializedAsync()
    {
        await LoadAuditLog();
    }

    private async Task LoadAuditLog()
    {
        _loading = true;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<MetadataDbContext>();
            _entries = await db.Set<AuditLogEntry>()
                .OrderByDescending(a => a.PerformedAt)
                .Take(500)
                .Select(a => new AuditEntry
                {
                    Timestamp = a.PerformedAt,
                    Action = a.Action,
                    EntityType = a.EntityType,
                    EntityId = a.EntityId.ToString(),
                    PerformedBy = a.PerformedBy,
                    Changes = a.NewValues != null && a.NewValues.Length > 120 ? a.NewValues.Substring(0, 120) + "..." : a.NewValues,
                    IpAddress = a.IpAddress
                })
                .ToListAsync();
        }
        catch
        {
            _entries = new();
        }
        _loading = false;
    }

    private void ClearFilters()
    {
        _searchQuery = "";
        _actionFilter = "";
        _entityFilter = "";
        _dateFrom = null;
        _dateTo = null;
    }

    // --- Visual helpers ---
    private static string GetDotClass(string action) => NormalizeAction(action) switch
    {
        "created" => "fc-audit-dot-created",
        "updated" => "fc-audit-dot-updated",
        "deleted" => "fc-audit-dot-deleted",
        "archived" => "fc-audit-dot-archived",
        "published" => "fc-audit-dot-published",
        "approved" => "fc-audit-dot-approved",
        "rejected" => "fc-audit-dot-rejected",
        "loggedin" or "login" => "fc-audit-dot-login",
        _ => "fc-audit-dot-default"
    };

    private static string GetIconClass(string action) => NormalizeAction(action) switch
    {
        "created" => "fc-audit-icon-created",
        "updated" => "fc-audit-icon-updated",
        "deleted" => "fc-audit-icon-deleted",
        "archived" => "fc-audit-icon-archived",
        "published" => "fc-audit-icon-published",
        "approved" => "fc-audit-icon-approved",
        "rejected" => "fc-audit-icon-rejected",
        "loggedin" or "login" => "fc-audit-icon-login",
        _ => "fc-audit-icon-default"
    };

    private static string GetChipDotClass(string action) => NormalizeAction(action) switch
    {
        "created" => "fc-chip__dot--active",
        "updated" => "fc-chip__dot--approver",
        "deleted" or "archived" => "fc-chip__dot--inactive",
        "published" or "approved" => "fc-chip__dot--approver",
        _ => "fc-chip__dot--viewer"
    };

    private static string NormalizeAction(string action) =>
        action.Trim().ToLowerInvariant().Replace(" ", "");

    private static RenderFragment GetActionIcon(string action) => NormalizeAction(action) switch
    {
        "created" => @<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>,
        "updated" => @<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>,
        "deleted" => @<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>,
        "archived" => @<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/></svg>,
        "published" => @<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3"/></svg>,
        "approved" => @<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>,
        "rejected" => @<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>,
        "loggedin" or "login" => @<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>,
        _ => @<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
    };

    private record AuditEntry
    {
        public DateTime Timestamp { get; init; }
        public string Action { get; init; } = "";
        public string EntityType { get; init; } = "";
        public string EntityId { get; init; } = "";
        public string PerformedBy { get; init; } = "";
        public string? Changes { get; init; }
        public string? IpAddress { get; init; }
    }
}
