@page "/templates"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using FC.Engine.Admin.Utilities
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Enums
@using FC.Engine.Application.DTOs
@using FC.Engine.Application.Services
@inject IModuleService ModuleService
@inject TemplateService TemplateService
@inject NavigationManager Nav
@inject ToastService Toast
@inject DataCacheService DataCache
@implements IDisposable

<PageHeader Title="Return Templates"
            Subtitle="Manage draft and published return templates, their fields, formulas, and physical table mappings"
            CountBadge="@(!_loading ? _templates.Count : null)">
    <PrimaryAction>
        <AuthorizeView Policy="CanEditTemplates">
            <Authorized>
                <button class="fc-btn fc-btn--gold" @onclick="ShowCreateForm">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                    New Template
                </button>
            </Authorized>
        </AuthorizeView>
    </PrimaryAction>
</PageHeader>

<div class="fc-list-page">

    @{
        var chips = GetActiveFilterChips().ToList();
    }
    @if (chips.Count > 0)
    {
        <div class="fc-active-filters">
            <span class="fc-active-filters-label">Filters active:</span>
            @foreach (var chip in chips)
            {
                var c = chip;
                <span class="fc-filter-chip">
                    @c.Label
                    <button class="fc-filter-chip__remove" type="button" @onclick="@c.Clear" title="Remove filter">x</button>
                </span>
            }
            <button class="fc-filter-clear-all" type="button" @onclick="ResetFilters">Clear all x</button>
        </div>
    }

    @if (_showCreateForm)
    {
        <div class="fc-list-inline-form">
            <h3>Create New Template</h3>
            <div class="grid-2">
                <div class="form-group">
                    <label>Return Code</label>
                    <input class="form-control" @bind="_createRequest.ReturnCode" placeholder="e.g. MFCR 999" />
                </div>
                <div class="form-group">
                    <label>Name</label>
                    <input class="form-control" @bind="_createRequest.Name" placeholder="e.g. New Return Template" />
                </div>
                <div class="form-group">
                    <label>Frequency</label>
                    <select class="form-control" @bind="_createFrequency">
                        @foreach (var f in Enum.GetValues<ReturnFrequency>())
                        {
                            <option value="@f">@f</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Structural Category</label>
                    <select class="form-control" @bind="_createCategory">
                        @foreach (var c in Enum.GetValues<StructuralCategory>())
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <input class="form-control" @bind="_createRequest.Description" placeholder="Optional description" />
                </div>
                <div class="form-group">
                    <label>Module</label>
                    <select class="form-control" @bind="_createModuleId">
                        <option value="">Global / Unassigned</option>
                        @foreach (var module in _moduleOptions.Where(m => m.IsActive))
                        {
                            <option value="@module.Id">@module.ModuleCode - @module.ModuleName</option>
                        }
                    </select>
                </div>
            </div>
            <div class="fc-list-form-actions">
                <button class="fc-btn fc-btn--primary fc-btn--sm" @onclick="CreateTemplate">Create</button>
                <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="CancelCreate">Cancel</button>
            </div>
        </div>
    }

    <DataTable TItem="TemplateDto"
               Items="@FilteredTemplates.ToList()"
               Loading="_loading"
               PageSize="25"
               ShowPagination="true"
               ShowPageSizeSelector="true"
               Sortable="true"
               Clickable="true"
               OnRowClick="(t) => ViewTemplate(t.ReturnCode)"
               EmptyTitle="No templates found"
               EmptyText="Try adjusting your search criteria or filters to find what you're looking for."
               SkeletonRows="6"
               ShowExport="false">
        <ToolbarContent>
            <div class="fc-list-toolbar-filters">
                <div class="fc-list-search-wrap">
                    <svg class="fc-list-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    <input class="fc-list-search-input" placeholder="Search by code or name..."
                           value="@_searchTerm" @oninput="OnSearchInput" />
                    @if (_searchTyping) { <span class="fc-search-typing" aria-hidden="true" title="Filtering…"></span> }
                </div>
                <select class="fc-list-filter-select" value="@_frequencyFilter" @onchange="OnFrequencyChange">
                    <option value="">All Frequencies</option>
                    <option value="Monthly">Monthly</option>
                    <option value="Quarterly">Quarterly</option>
                    <option value="Semi-Annual">Semi-Annual</option>
                    <option value="Computed">Computed</option>
                </select>
                <select class="fc-list-filter-select" value="@_categoryFilter" @onchange="OnCategoryChange">
                    <option value="">All Categories</option>
                    <option value="FixedRow">FixedRow</option>
                    <option value="MultiRow">MultiRow</option>
                    <option value="ItemCoded">ItemCoded</option>
                </select>
            </div>
        </ToolbarContent>
        <ChildContent>
            <DataColumn TItem="TemplateDto" Title="Return Code" SortKey="x => x.ReturnCode" Width="120px">
                <CellTemplate>
                    <span class="fc-list-cell-code">@context.ReturnCode</span>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="TemplateDto" Title="Name" SortKey="x => x.Name">
                <CellTemplate>
                    <span class="fc-list-cell-strong">@context.Name</span>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="TemplateDto" Title="Status" Width="100px">
                <CellTemplate>
                    <span class="fc-badge @StatusBadge(context.CurrentVersionStatus)">
                        @(context.CurrentVersionStatus ?? "Unknown")
                    </span>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="TemplateDto" Title="Category" Width="110px">
                <CellTemplate>
                    <span class="fc-badge @CategoryBadge(context.StructuralCategory)">
                        @context.StructuralCategory
                    </span>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="TemplateDto" Title="Frequency" Width="110px">
                <CellTemplate>
                    <span class="fc-list-cell-muted">@GetFrequency(context)</span>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="TemplateDto" Title="Fields" Width="60px">
                <CellTemplate>
                    @context.FieldCount
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="TemplateDto" Title="Version" Width="80px">
                <CellTemplate>
                    @if (context.CurrentVersionNumber.HasValue)
                    {
                        <span class="fc-list-cell-muted">v@context.CurrentVersionNumber</span>
                    }
                    else
                    {
                        <span class="fc-list-cell-muted">—</span>
                    }
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="TemplateDto" Title="Physical Table" Width="150px">
                <CellTemplate>
                    <span class="fc-list-cell-code">@context.PhysicalTableName</span>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="TemplateDto" Title="" Width="60px">
                <CellTemplate>
                    <div class="fc-list-row-actions">
                        <button class="fc-btn fc-btn--ghost fc-btn--xs" @onclick="() => ViewTemplate(context.ReturnCode)" @onclick:stopPropagation="true">
                            View
                        </button>
                    </div>
                </CellTemplate>
            </DataColumn>
        </ChildContent>
    </DataTable>

</div>

@code {
    // URL query parameters
    [Parameter, SupplyParameterFromQuery(Name = "search")]    public string? QSearch    { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "frequency")] public string? QFrequency { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "category")]  public string? QCategory  { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private string _currentUser = string.Empty;
    private IReadOnlyList<TemplateDto> _templates = Array.Empty<TemplateDto>();
    private string _searchTerm = "";
    private string _filterTerm = "";   // debounced; FilteredTemplates uses this
    private bool _searchTyping;
    private CancellationTokenSource? _searchCts;
    private string _frequencyFilter = "";
    private string _categoryFilter = "";

    // Create form
    private bool _showCreateForm;
    private CreateTemplateRequest _createRequest = new();
    private IReadOnlyList<ModuleSummaryDto> _moduleOptions = Array.Empty<ModuleSummaryDto>();
    private string _createModuleId = "";
    private ReturnFrequency _createFrequency = ReturnFrequency.Monthly;
    private StructuralCategory _createCategory = StructuralCategory.FixedRow;

    private IEnumerable<TemplateDto> FilteredTemplates => _templates
        .Where(t => string.IsNullOrEmpty(_filterTerm) ||
                    t.ReturnCode.Contains(_filterTerm, StringComparison.OrdinalIgnoreCase) ||
                    t.Name.Contains(_filterTerm, StringComparison.OrdinalIgnoreCase))
        .Where(t => string.IsNullOrEmpty(_categoryFilter) || t.StructuralCategory == _categoryFilter)
        .Where(t => string.IsNullOrEmpty(_frequencyFilter) || GetFrequency(t) == _frequencyFilter)
        .OrderBy(t => t.ReturnCode);

    // Restore filter state from URL on browser back/forward
    protected override Task OnParametersSetAsync()
    {
        var s = QSearch    ?? "";
        var f = QFrequency ?? "";
        var c = QCategory  ?? "";
        if (s != _searchTerm) { _searchTerm = s; _filterTerm = s; }
        if (f != _frequencyFilter) _frequencyFilter = f;
        if (c != _categoryFilter)  _categoryFilter  = c;
        return Task.CompletedTask;
    }

    protected override async Task OnInitializedAsync()
    {
        var state = AuthState is null ? null : await AuthState;
        _currentUser = UserIdentityResolver.ResolveActor(state?.User);
        _moduleOptions = await ModuleService.GetModuleSummaries();

        // Register loader so NavMenu hover-prefetch can warm this data
        DataCache.RegisterLoader("/templates", async () =>
        {
            var data = await TemplateService.GetAllTemplates();
            DataCache.Set("templates:all", data);
        });

        _templates = await DataCache.GetOrFetchAsync(
            "templates:all",
            () => TemplateService.GetAllTemplates(),
            TimeSpan.FromMinutes(5),
            updated => { _templates = updated; InvokeAsync(StateHasChanged); }
        );
        _loading = false;
    }

    private async void OnSearchInput(ChangeEventArgs e)
    {
        _searchTerm = e.Value?.ToString() ?? "";
        _searchTyping = true;
        StateHasChanged();

        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(200, _searchCts.Token);
            _filterTerm = _searchTerm;
            _searchTyping = false;
            PushUrl();   // encode into URL after debounce
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    private void OnFrequencyChange(ChangeEventArgs e)
    {
        _frequencyFilter = e.Value?.ToString() ?? "";
        PushUrl();
    }

    private void OnCategoryChange(ChangeEventArgs e)
    {
        _categoryFilter = e.Value?.ToString() ?? "";
        PushUrl();
    }

    private void PushUrl() => Nav.NavigateTo(BuildUrl(), replace: true);

    private string BuildUrl()
    {
        var q = new List<string>();
        if (!string.IsNullOrEmpty(_filterTerm))      q.Add($"search={Uri.EscapeDataString(_filterTerm)}");
        if (!string.IsNullOrEmpty(_frequencyFilter)) q.Add($"frequency={Uri.EscapeDataString(_frequencyFilter)}");
        if (!string.IsNullOrEmpty(_categoryFilter))  q.Add($"category={Uri.EscapeDataString(_categoryFilter)}");
        return "/templates" + (q.Count > 0 ? "?" + string.Join("&", q) : "");
    }

    private void ResetFilters()
    {
        _searchTerm = ""; _filterTerm = "";
        _frequencyFilter = ""; _categoryFilter = "";
        Nav.NavigateTo("/templates");
    }

    private sealed record FilterChip(string Label, Action Clear);

    private IEnumerable<FilterChip> GetActiveFilterChips()
    {
        if (!string.IsNullOrEmpty(_filterTerm))
            yield return new FilterChip($"search: {_filterTerm}",         () => { _searchTerm = ""; _filterTerm = ""; PushUrl(); });
        if (!string.IsNullOrEmpty(_frequencyFilter))
            yield return new FilterChip($"frequency: {_frequencyFilter}", () => { _frequencyFilter = ""; PushUrl(); });
        if (!string.IsNullOrEmpty(_categoryFilter))
            yield return new FilterChip($"category: {_categoryFilter}",   () => { _categoryFilter  = ""; PushUrl(); });
    }

    public void Dispose() => _searchCts?.Dispose();

    private void ViewTemplate(string returnCode) => Nav.NavigateTo($"/templates/{returnCode}");

    private void ShowCreateForm()
    {
        _showCreateForm = true;
        _createModuleId = "";
        _createRequest = new CreateTemplateRequest { CreatedBy = _currentUser };
    }

    private void CancelCreate() => _showCreateForm = false;

    private async Task CreateTemplate()
    {
        try
        {
            _createRequest.Frequency = _createFrequency;
            _createRequest.StructuralCategory = _createCategory;
            _createRequest.CreatedBy = _currentUser;
            _createRequest.ModuleId = int.TryParse(_createModuleId, out var moduleId) ? moduleId : null;
            var result = await TemplateService.CreateTemplate(_createRequest);
            DataCache.Invalidate("templates:all");
            Toast.Success($"Template '{result.ReturnCode}' created successfully.", "Template Created");
            _showCreateForm = false;
            Nav.NavigateTo($"/templates/{result.ReturnCode}");
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message, "Create Failed");
        }
    }

    private static string CategoryBadge(string cat) => cat.ToLowerInvariant() switch
    {
        "fixedrow" => "fc-badge--purple",
        "multirow" => "fc-badge--teal",
        "itemcoded" => "fc-badge--pink",
        _ => "fc-badge--neutral"
    };

    private static string StatusBadge(string? status) => status switch
    {
        nameof(TemplateStatus.Published) => "fc-badge--success",
        nameof(TemplateStatus.Review) => "fc-badge--warning",
        nameof(TemplateStatus.Draft) => "fc-badge--neutral",
        nameof(TemplateStatus.Deprecated) => "fc-badge--danger",
        nameof(TemplateStatus.Retired) => "fc-badge--neutral",
        _ => "fc-badge--neutral"
    };

    private static string GetFrequency(TemplateDto template) => template.Frequency switch
    {
        nameof(ReturnFrequency.SemiAnnual) => "Semi-Annual",
        _ => template.Frequency
    };
}
