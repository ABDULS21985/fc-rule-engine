@page "/templates/{ReturnCode}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Enums
@using FC.Engine.Domain.Metadata
@using FC.Engine.Domain.Validation
@using FC.Engine.Application.DTOs
@using FC.Engine.Application.Services
@inject ITemplateMetadataCache Cache
@inject IXsdGenerator XsdGenerator
@inject TemplateService TemplateService
@inject TemplateVersioningService VersioningService
@inject IFormulaRepository FormulaRepo
@inject NavigationManager Nav
@inject ToastService Toast
@inject DialogService Dialog

<div class="detail-page">

    <!-- Breadcrumb -->
    <nav class="detail-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Dashboard</a>
        <span class="detail-breadcrumb-sep" aria-hidden="true">/</span>
        <a href="/templates">Templates</a>
        <span class="detail-breadcrumb-sep" aria-hidden="true">/</span>
        <span class="detail-breadcrumb-current">@ReturnCode</span>
    </nav>

    @if (_loading)
    {
        <div class="skel-detail" role="status" aria-label="Loading template">
            <div class="skel-detail-hero">
                <div class="skel skel-text-xl" style="width:200px;"></div>
                <div class="skel skel-text" style="width:300px;"></div>
                <div style="display:flex;gap:var(--space-3);margin-top:var(--space-2);">
                    <div class="skel" style="width:80px;height:24px;border-radius:var(--radius-pill);"></div>
                    <div class="skel" style="width:70px;height:24px;border-radius:var(--radius-pill);"></div>
                    <div class="skel" style="width:90px;height:24px;border-radius:var(--radius-pill);"></div>
                </div>
            </div>
            <div class="skel-detail-tabs">
                @for (var i = 0; i < 5; i++)
                {
                    <div class="skel skel-detail-tab" style="width:@(60 + i * 10)px;"></div>
                }
            </div>
            <div class="skel-detail-section">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="skel skel-text" style="width:@(40 + i * 20)%;"></div>
                }
            </div>
        </div>
    }
    else if (_detail == null)
    {
        <div class="fc-alert fc-alert--inline fc-alert--error">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            Template not found: @ReturnCode
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <AppAlert Variant="AppAlert.AlertVariant.Error" Message="@_errorMessage" Dismissible="true" OnDismiss="() => _errorMessage = null" />
        }

        <!-- Hero Header -->
        <section class="detail-hero" role="banner">
            <div class="detail-hero-left">
                <div class="detail-hero-title-row">
                    <h1 class="detail-hero-title">@_detail.Name</h1>
                    @if (_activeVersion != null)
                    {
                        <span class="detail-status detail-status-@_activeVersion.Status.ToLowerInvariant()">
                            <span class="detail-status-dot" aria-hidden="true"></span>
                            @_activeVersion.Status
                        </span>
                    }
                </div>
                <p class="detail-hero-subtitle">@_detail.ReturnCode &mdash; @_detail.Frequency template &middot; @_detail.StructuralCategory structure</p>

                <div class="detail-hero-meta">
                    <div class="detail-meta-item">
                        <span class="detail-meta-label">Return Code</span>
                        <span class="detail-meta-value"><code>@_detail.ReturnCode</code></span>
                    </div>
                    <div class="detail-meta-item">
                        <span class="detail-meta-label">Category</span>
                        <span class="detail-meta-value">@_detail.StructuralCategory</span>
                    </div>
                    <div class="detail-meta-item">
                        <span class="detail-meta-label">Version</span>
                        <span class="detail-meta-value">v@(_activeVersion?.VersionNumber)</span>
                    </div>
                    <div class="detail-meta-item">
                        <span class="detail-meta-label">Fields</span>
                        <span class="detail-meta-value">@(_activeVersion?.FieldCount ?? 0)</span>
                    </div>
                    <div class="detail-meta-item">
                        <span class="detail-meta-label">Formulas</span>
                        <span class="detail-meta-value">@(_activeVersion?.FormulaCount ?? 0)</span>
                    </div>
                </div>
            </div>

            <div class="detail-hero-actions">
                @if (_activeVersion?.Status == "Draft")
                {
                    <AuthorizeView Roles="Admin,Approver" Context="submitAuth">
                        <Authorized Context="sAuth">
                            <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="SubmitForReview">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
                                Submit for Review
                            </button>
                        </Authorized>
                    </AuthorizeView>
                }
                @if (_activeVersion?.Status == "Review")
                {
                    <AuthorizeView Roles="Admin" Context="publishAuth">
                        <Authorized Context="pAuth">
                            <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="PreviewDdl">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                                Preview DDL
                            </button>
                            <button class="fc-btn fc-btn--primary fc-btn--sm" @onclick="PublishVersion">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                Publish
                            </button>
                        </Authorized>
                    </AuthorizeView>
                }
                @if (_activeVersion?.Status == "Published")
                {
                    <AuthorizeView Roles="Admin,Approver" Context="versionAuth">
                        <Authorized Context="vAuth">
                            <button class="fc-btn fc-btn--primary fc-btn--sm" @onclick="CreateDraftVersion">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                New Draft
                            </button>
                        </Authorized>
                    </AuthorizeView>
                }
            </div>
        </section>

        <!-- Tabbed Navigation -->
        <div class="detail-tabs" role="tablist" aria-label="Template sections">
            <button class="detail-tab @(_activeTab == "overview" ? "detail-tab-active" : "")"
                    role="tab" aria-selected="@(_activeTab == "overview")" @onclick='() => _activeTab = "overview"'>
                Overview
            </button>
            <button class="detail-tab @(_activeTab == "fields" ? "detail-tab-active" : "")"
                    role="tab" aria-selected="@(_activeTab == "fields")" @onclick='() => _activeTab = "fields"'>
                Fields
                <span class="detail-tab-badge">@(_activeVersion?.FieldCount ?? 0)</span>
            </button>
            <button class="detail-tab @(_activeTab == "formulas" ? "detail-tab-active" : "")"
                    role="tab" aria-selected="@(_activeTab == "formulas")" @onclick='() => _activeTab = "formulas"'>
                Formulas
                <span class="detail-tab-badge">@(_activeVersion?.FormulaCount ?? 0)</span>
            </button>
            @if (_activeVersion?.ItemCodes.Any() == true)
            {
                <button class="detail-tab @(_activeTab == "itemcodes" ? "detail-tab-active" : "")"
                        role="tab" aria-selected="@(_activeTab == "itemcodes")" @onclick='() => _activeTab = "itemcodes"'>
                    Item Codes
                    <span class="detail-tab-badge">@_activeVersion.ItemCodes.Count</span>
                </button>
            }
            <button class="detail-tab @(_activeTab == "versions" ? "detail-tab-active" : "")"
                    role="tab" aria-selected="@(_activeTab == "versions")" @onclick='() => _activeTab = "versions"'>
                Versions
                <span class="detail-tab-badge">@_detail.Versions.Count</span>
            </button>
            <button class="detail-tab @(_activeTab == "settings" ? "detail-tab-active" : "")"
                    role="tab" aria-selected="@(_activeTab == "settings")" @onclick='() => _activeTab = "settings"'>
                Settings
            </button>
        </div>

        <!-- Tab: Overview -->
        <div class="detail-tab-content @(_activeTab == "overview" ? "detail-tab-content-active" : "")" role="tabpanel">
            <div class="detail-section">
                <div class="detail-section-header">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                        Template Overview
                    </h3>
                </div>
                <div class="detail-section-body">
                    <div class="detail-info-grid">
                        <div class="detail-info-item">
                            <span class="detail-info-label">Return Code</span>
                            <span class="detail-info-value"><code>@_detail.ReturnCode</code></span>
                        </div>
                        <div class="detail-info-item">
                            <span class="detail-info-label">Template Name</span>
                            <span class="detail-info-value">@_detail.Name</span>
                        </div>
                        <div class="detail-info-item">
                            <span class="detail-info-label">Frequency</span>
                            <span class="detail-info-value">@_detail.Frequency</span>
                        </div>
                        <div class="detail-info-item">
                            <span class="detail-info-label">Structural Category</span>
                            <span class="detail-info-value">
                                <span class="fc-badge @CategoryBadge(_detail.StructuralCategory)">@_detail.StructuralCategory</span>
                            </span>
                        </div>
                        <div class="detail-info-item">
                            <span class="detail-info-label">Physical Table</span>
                            <span class="detail-info-value"><code>@_detail.PhysicalTableName</code></span>
                        </div>
                        <div class="detail-info-item">
                            <span class="detail-info-label">Created</span>
                            <span class="detail-info-value">@_detail.CreatedAt.ToString("d MMM yyyy")</span>
                        </div>
                        @if (_detail.Description != null)
                        {
                            <div class="detail-info-item" style="grid-column: span 2;">
                                <span class="detail-info-label">Description</span>
                                <span class="detail-info-value">@_detail.Description</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @if (_activeVersion != null)
            {
                <div class="detail-section">
                    <div class="detail-section-header">
                        <h3>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                            Active Version Summary
                        </h3>
                        <span class="detail-status detail-status-@_activeVersion.Status.ToLowerInvariant()">
                            <span class="detail-status-dot" aria-hidden="true"></span>
                            v@(_activeVersion.VersionNumber) — @_activeVersion.Status
                        </span>
                    </div>
                    <div class="detail-section-body">
                        <div class="detail-info-grid">
                            <div class="detail-info-item">
                                <span class="detail-info-label">Version</span>
                                <span class="detail-info-value">v@(_activeVersion.VersionNumber)</span>
                            </div>
                            <div class="detail-info-item">
                                <span class="detail-info-label">Status</span>
                                <span class="detail-info-value">@_activeVersion.Status</span>
                            </div>
                            <div class="detail-info-item">
                                <span class="detail-info-label">Fields</span>
                                <span class="detail-info-value">@_activeVersion.FieldCount</span>
                            </div>
                            <div class="detail-info-item">
                                <span class="detail-info-label">Formulas</span>
                                <span class="detail-info-value">@_activeVersion.FormulaCount</span>
                            </div>
                            @if (_activeVersion.ApprovedBy != null)
                            {
                                <div class="detail-info-item">
                                    <span class="detail-info-label">Approved By</span>
                                    <span class="detail-info-value">@_activeVersion.ApprovedBy</span>
                                </div>
                            }
                            @if (_activeVersion.PublishedAt.HasValue)
                            {
                                <div class="detail-info-item">
                                    <span class="detail-info-label">Published</span>
                                    <span class="detail-info-value">@_activeVersion.PublishedAt.Value.ToString("d MMM yyyy, HH:mm")</span>
                                </div>
                            }
                            @if (_activeVersion.ChangeSummary != null)
                            {
                                <div class="detail-info-item" style="grid-column: span 2;">
                                    <span class="detail-info-label">Change Summary</span>
                                    <span class="detail-info-value">@_activeVersion.ChangeSummary</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Tab: Fields -->
        <div class="detail-tab-content @(_activeTab == "fields" ? "detail-tab-content-active" : "")" role="tabpanel">
            <div class="detail-section">
                <div class="detail-section-header">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                        Template Fields (@(_activeVersion?.Fields.Count ?? 0))
                    </h3>
                    @if (_activeVersion?.Status == "Draft")
                    {
                        <button class="fc-btn fc-btn--primary fc-btn--sm" @onclick="ShowAddField">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            Add Field
                        </button>
                    }
                </div>

                @if (_showAddField && _activeVersion?.Status == "Draft")
                {
                    <div class="detail-add-panel">
                        <h3>Add New Field</h3>
                        <div class="detail-add-grid">
                            <div class="detail-float-field">
                                <input class="detail-float-input" placeholder=" " @bind="_newField.FieldName" />
                                <label class="detail-float-label">Field Name</label>
                            </div>
                            <div class="detail-float-field">
                                <input class="detail-float-input" placeholder=" " @bind="_newField.DisplayName" />
                                <label class="detail-float-label">Display Name</label>
                            </div>
                            <div class="detail-float-field">
                                <input class="detail-float-input" placeholder=" " @bind="_newField.XmlElementName" />
                                <label class="detail-float-label">XML Element</label>
                            </div>
                            <div class="detail-float-field">
                                <input class="detail-float-input" placeholder=" " @bind="_newField.LineCode" />
                                <label class="detail-float-label">Line Code</label>
                            </div>
                            <div class="detail-float-field">
                                <select class="detail-float-input" @bind="_newFieldDataType">
                                    @foreach (var dt in Enum.GetValues<FieldDataType>())
                                    {
                                        <option value="@dt">@dt</option>
                                    }
                                </select>
                                <label class="detail-float-label">Data Type</label>
                            </div>
                            <div class="detail-float-field">
                                <input type="number" class="detail-float-input" placeholder=" " @bind="_newField.FieldOrder" />
                                <label class="detail-float-label">Field Order</label>
                            </div>
                            <div class="detail-float-field">
                                <input class="detail-float-input" placeholder=" " @bind="_newField.SectionName" />
                                <label class="detail-float-label">Section (optional)</label>
                            </div>
                            <div class="detail-float-field">
                                <select class="detail-float-input" @bind="_newFieldRequired">
                                    <option value="false">No</option>
                                    <option value="true">Yes</option>
                                </select>
                                <label class="detail-float-label">Required</label>
                            </div>
                        </div>
                        <div class="detail-add-actions">
                            <button class="fc-btn fc-btn--primary fc-btn--sm" @onclick="AddField">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                                Add Field
                            </button>
                            <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="() => _showAddField = false">Cancel</button>
                        </div>
                    </div>
                }

                @if (_activeVersion?.Fields.Any() == true)
                {
                    <div style="overflow-x:auto;">
                        <table class="detail-field-table">
                            <thead>
                                <tr>
                                    <th style="width:36px;" aria-label="Reorder"></th>
                                    <th>#</th>
                                    <th>Field Name</th>
                                    <th>Display Name</th>
                                    <th>Line Code</th>
                                    <th>Data Type</th>
                                    <th>SQL Type</th>
                                    <th>Required</th>
                                    <th>Flags</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var f in _activeVersion.Fields)
                                {
                                    <tr>
                                        <td class="detail-field-drag" aria-label="Drag to reorder">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="8" y2="6.01"/><line x1="8" y1="12" x2="8" y2="12.01"/><line x1="8" y1="18" x2="8" y2="18.01"/><line x1="16" y1="6" x2="16" y2="6.01"/><line x1="16" y1="12" x2="16" y2="12.01"/><line x1="16" y1="18" x2="16" y2="18.01"/></svg>
                                        </td>
                                        <td>@f.FieldOrder</td>
                                        <td><code>@f.FieldName</code></td>
                                        <td>@f.DisplayName</td>
                                        <td>@f.LineCode</td>
                                        <td><span class="fc-badge fc-badge--info">@f.DataType</span></td>
                                        <td><code>@f.SqlType</code></td>
                                        <td>
                                            @if (f.IsRequired)
                                            {
                                                <svg viewBox="0 0 24 24" fill="none" stroke="var(--cbn-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-label="Required"><polyline points="20 6 9 17 4 12"/></svg>
                                            }
                                        </td>
                                        <td>
                                            <div style="display:flex;gap:4px;">
                                                @if (f.IsKeyField) { <span class="fc-badge fc-badge--success">Key</span> }
                                                @if (f.IsComputed) { <span class="fc-badge fc-badge--review">Computed</span> }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="detail-empty">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                        <p class="detail-empty-title">No fields defined</p>
                        <p class="detail-empty-text">Add fields to this template version to define the data structure.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Tab: Formulas -->
        <div class="detail-tab-content @(_activeTab == "formulas" ? "detail-tab-content-active" : "")" role="tabpanel">
            <div class="detail-section">
                <div class="detail-section-header">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/></svg>
                        Intra-Sheet Formulas
                    </h3>
                    <a href="/formulas" class="fc-btn fc-btn--outline fc-btn--sm">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                        Manage Formulas
                    </a>
                </div>
                <div class="detail-section-body">
                    @if (_formulas.Any())
                    {
                        <div style="overflow-x:auto;">
                            <table class="detail-field-table">
                                <thead>
                                    <tr>
                                        <th>Rule Code</th>
                                        <th>Name</th>
                                        <th>Type</th>
                                        <th>Target</th>
                                        <th>Severity</th>
                                        <th>Active</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var f in _formulas)
                                    {
                                        <tr>
                                            <td><code>@f.RuleCode</code></td>
                                            <td>@f.RuleName</td>
                                            <td><span class="fc-badge @FormulaBadge(f.FormulaType.ToString())">@f.FormulaType</span></td>
                                            <td><code>@f.TargetFieldName</code></td>
                                            <td>
                                                <span class="fc-badge @(f.Severity == ValidationSeverity.Error ? "fc-badge--danger" : f.Severity == ValidationSeverity.Warning ? "fc-badge--warning" : "fc-badge--info")">
                                                    @f.Severity
                                                </span>
                                            </td>
                                            <td>
                                                @if (f.IsActive)
                                                {
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--cbn-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-label="Active"><polyline points="20 6 9 17 4 12"/></svg>
                                                }
                                                else
                                                {
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--cbn-gray-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-label="Inactive"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="detail-empty">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/></svg>
                            <p class="detail-empty-title">No formulas</p>
                            <p class="detail-empty-text">Intra-sheet formulas can be configured from the Formulas management page.</p>
                        </div>
                    }
                </div>
            </div>

            @if (_crossSheetRules.Any())
            {
                <div class="detail-section">
                    <div class="detail-section-header">
                        <h3>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                            Cross-Sheet Rules
                        </h3>
                    </div>
                    <div class="detail-section-body">
                        <div style="overflow-x:auto;">
                            <table class="detail-field-table">
                                <thead>
                                    <tr>
                                        <th>Rule Code</th>
                                        <th>Name</th>
                                        <th>Severity</th>
                                        <th>Active</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in _crossSheetRules)
                                    {
                                        <tr>
                                            <td><code>@r.RuleCode</code></td>
                                            <td>@r.RuleName</td>
                                            <td>
                                                <span class="fc-badge @(r.Severity == ValidationSeverity.Error ? "fc-badge--danger" : r.Severity == ValidationSeverity.Warning ? "fc-badge--warning" : "fc-badge--info")">
                                                    @r.Severity
                                                </span>
                                            </td>
                                            <td>
                                                @if (r.IsActive)
                                                {
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--cbn-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-label="Active"><polyline points="20 6 9 17 4 12"/></svg>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Tab: Item Codes -->
        @if (_activeVersion?.ItemCodes.Any() == true)
        {
            <div class="detail-tab-content @(_activeTab == "itemcodes" ? "detail-tab-content-active" : "")" role="tabpanel">
                <div class="detail-section">
                    <div class="detail-section-header">
                        <h3>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                            Item Codes (@_activeVersion.ItemCodes.Count)
                        </h3>
                    </div>
                    <div style="overflow-x:auto;">
                        <table class="detail-field-table">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Description</th>
                                    <th>Order</th>
                                    <th>Total Row</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ic in _activeVersion.ItemCodes)
                                {
                                    <tr>
                                        <td><code>@ic.ItemCode</code></td>
                                        <td>@ic.ItemName</td>
                                        <td>@ic.SortOrder</td>
                                        <td>
                                            @* ItemCodes don't have IsTotalRow in DTO, skip *@
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Tab: Versions -->
        <div class="detail-tab-content @(_activeTab == "versions" ? "detail-tab-content-active" : "")" role="tabpanel">
            <!-- Version Selector -->
            <div class="detail-section">
                <div class="detail-section-header">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        Version Selector
                    </h3>
                </div>
                <div class="detail-section-body">
                    <div style="display:flex;gap:var(--space-2);flex-wrap:wrap;">
                        @foreach (var v in _detail.Versions.OrderByDescending(v => v.VersionNumber))
                        {
                            <button class="fc-btn @(v.Id == _activeVersion?.Id ? "fc-btn--primary" : "fc-btn--outline") fc-btn--sm"
                                    @onclick="() => SelectVersion(v)">
                                v@(v.VersionNumber)
                                <span class="detail-status detail-status-@v.Status.ToLowerInvariant()" style="font-size:0.65rem;padding:1px 8px;">
                                    @v.Status
                                </span>
                            </button>
                        }
                    </div>
                </div>
            </div>

            <!-- DDL Preview -->
            @if (_showDdlPreview && !string.IsNullOrEmpty(_ddlPreview))
            {
                <div class="detail-section">
                    <div class="detail-section-header">
                        <h3>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                            DDL Preview
                        </h3>
                        <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="() => _showDdlPreview = false">Hide</button>
                    </div>
                    <div class="detail-section-body">
                        <pre class="detail-code-block">@_ddlPreview</pre>
                    </div>
                </div>
            }

            <!-- Version Timeline -->
            <div class="detail-section">
                <div class="detail-section-header">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="10"/></svg>
                        Version History
                    </h3>
                </div>
                <div class="detail-section-body">
                    <div class="detail-timeline" role="list" aria-label="Version history">
                        @foreach (var v in _detail.Versions.OrderByDescending(v => v.VersionNumber))
                        {
                            <div class="detail-timeline-item" role="listitem">
                                <div class="detail-timeline-dot detail-timeline-dot-@v.Status.ToLowerInvariant()" aria-hidden="true"></div>
                                <div class="detail-timeline-content">
                                    <div class="detail-timeline-header">
                                        <span class="detail-timeline-version">Version @v.VersionNumber</span>
                                        <span class="detail-status detail-status-@v.Status.ToLowerInvariant()" style="font-size:0.65rem;padding:1px 8px;">
                                            <span class="detail-status-dot" aria-hidden="true"></span>
                                            @v.Status
                                        </span>
                                    </div>
                                    <div class="detail-timeline-meta">
                                        <span>@v.FieldCount fields</span>
                                        <span>@v.FormulaCount formulas</span>
                                        @if (v.PublishedAt.HasValue)
                                        {
                                            <span>Published @v.PublishedAt.Value.ToString("d MMM yyyy")</span>
                                        }
                                        @if (v.ApprovedBy != null)
                                        {
                                            <span>by @v.ApprovedBy</span>
                                        }
                                    </div>
                                    @if (v.ChangeSummary != null)
                                    {
                                        <p class="detail-timeline-summary">@v.ChangeSummary</p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab: Settings -->
        <div class="detail-tab-content @(_activeTab == "settings" ? "detail-tab-content-active" : "")" role="tabpanel">
            <div class="detail-section">
                <div class="detail-section-header">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
                        Technical Configuration
                    </h3>
                </div>
                <div class="detail-section-body">
                    <div class="detail-info-grid">
                        <div class="detail-info-item">
                            <span class="detail-info-label">Physical Table</span>
                            <span class="detail-info-value"><code>@_detail.PhysicalTableName</code></span>
                        </div>
                        <div class="detail-info-item">
                            <span class="detail-info-label">XML Root Element</span>
                            <span class="detail-info-value"><code>@_detail.XmlRootElement</code></span>
                        </div>
                        <div class="detail-info-item">
                            <span class="detail-info-label">XML Namespace</span>
                            <span class="detail-info-value"><code>@_detail.XmlNamespace</code></span>
                        </div>
                        <div class="detail-info-item">
                            <span class="detail-info-label">XSD Schema</span>
                            <span class="detail-info-value">
                                <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="ToggleXsd">
                                    @(_showXsd ? "Hide" : "Show") XSD
                                </button>
                            </span>
                        </div>
                    </div>

                    @if (_showXsd && !string.IsNullOrEmpty(_xsdContent))
                    {
                        <div style="margin-top:var(--space-4);">
                            <pre class="detail-code-block">@_xsdContent</pre>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string ReturnCode { get; set; } = "";

    private bool _loading = true;
    private TemplateDetailDto? _detail;
    private TemplateVersionDto? _activeVersion;
    private string? _errorMessage;
    private string _activeTab = "overview";

    // Formulas
    private IReadOnlyList<IntraSheetFormula> _formulas = Array.Empty<IntraSheetFormula>();
    private IReadOnlyList<CrossSheetRule> _crossSheetRules = Array.Empty<CrossSheetRule>();

    // XSD
    private bool _showXsd;
    private string? _xsdContent;

    // DDL
    private bool _showDdlPreview;
    private string? _ddlPreview;

    // Add field
    private bool _showAddField;
    private AddFieldRequest _newField = new();
    private FieldDataType _newFieldDataType = FieldDataType.Money;
    private string _newFieldRequired = "false";

    private string CurrentUser => "system"; // TODO: get from auth state

    protected override async Task OnInitializedAsync()
    {
        await LoadTemplate();
    }

    private async Task LoadTemplate()
    {
        _loading = true;
        _detail = await TemplateService.GetTemplateDetail(ReturnCode);
        if (_detail != null)
        {
            _activeVersion = _detail.Versions
                .OrderByDescending(v => v.Status == "Draft" ? 3 : v.Status == "Review" ? 2 : v.Status == "Published" ? 1 : 0)
                .ThenByDescending(v => v.VersionNumber)
                .FirstOrDefault();

            // Load formulas for the active version
            if (_activeVersion != null)
            {
                try
                {
                    _formulas = await FormulaRepo.GetIntraSheetFormulas(_activeVersion.Id);
                }
                catch { _formulas = Array.Empty<IntraSheetFormula>(); }
            }

            // Load cross-sheet rules for this template
            try
            {
                _crossSheetRules = await FormulaRepo.GetCrossSheetRulesForTemplate(ReturnCode);
            }
            catch { _crossSheetRules = Array.Empty<CrossSheetRule>(); }
        }
        _loading = false;
    }

    private async Task SelectVersion(TemplateVersionDto v)
    {
        _activeVersion = v;
        try { _formulas = await FormulaRepo.GetIntraSheetFormulas(v.Id); }
        catch { _formulas = Array.Empty<IntraSheetFormula>(); }
    }

    private async Task CreateDraftVersion()
    {
        try
        {
            await VersioningService.CreateNewDraftVersion(_detail!.Id, CurrentUser);
            Toast.Success("Draft version created. You can now add/modify fields.", "Version Created");
            await LoadTemplate();
        }
        catch (Exception ex) { SetError(ex.Message); }
    }

    private async Task SubmitForReview()
    {
        try
        {
            await VersioningService.SubmitForReview(_detail!.Id, _activeVersion!.Id, CurrentUser);
            Toast.Info("Version submitted for review.", "Submitted");
            await LoadTemplate();
        }
        catch (Exception ex) { SetError(ex.Message); }
    }

    private async Task PreviewDdl()
    {
        try
        {
            var ddl = await VersioningService.PreviewDdl(_detail!.Id, _activeVersion!.Id);
            _ddlPreview = ddl.ForwardSql;
            _showDdlPreview = true;
            _activeTab = "versions";
        }
        catch (Exception ex) { SetError(ex.Message); }
    }

    private async Task PublishVersion()
    {
        try
        {
            await VersioningService.Publish(_detail!.Id, _activeVersion!.Id, CurrentUser);
            Toast.Success("Version published successfully! Physical table created/updated.", "Published");
            _showDdlPreview = false;
            await LoadTemplate();
        }
        catch (Exception ex) { SetError(ex.Message); }
    }

    private void ShowAddField()
    {
        _showAddField = true;
        _activeTab = "fields";
        _newField = new AddFieldRequest
        {
            FieldOrder = (_activeVersion?.Fields.Count ?? 0) + 1
        };
        _newFieldDataType = FieldDataType.Money;
        _newFieldRequired = "false";
    }

    private async Task AddField()
    {
        try
        {
            _newField.DataType = _newFieldDataType;
            _newField.IsRequired = _newFieldRequired == "true";
            if (string.IsNullOrWhiteSpace(_newField.XmlElementName))
                _newField.XmlElementName = _newField.FieldName;

            await TemplateService.AddFieldToVersion(_detail!.Id, _activeVersion!.Id, _newField, CurrentUser);
            Toast.Success($"Field '{_newField.FieldName}' added successfully.", "Field Added");
            _showAddField = false;
            await LoadTemplate();
        }
        catch (Exception ex) { SetError(ex.Message); }
    }

    private async Task ToggleXsd()
    {
        _showXsd = !_showXsd;
        if (_showXsd && _xsdContent == null)
        {
            try { _xsdContent = await XsdGenerator.GenerateSchemaXml(ReturnCode); }
            catch { _xsdContent = "XSD generation not available for this template."; }
        }
    }

    private void SetError(string msg)
    {
        _errorMessage = msg;
    }

    private static string CategoryBadge(string cat) => cat.ToLowerInvariant() switch
    {
        "fixedrow" => "fc-badge--purple",
        "multirow" => "fc-badge--teal",
        "itemcoded" => "fc-badge--pink",
        _ => "fc-badge--neutral"
    };

    private static string FormulaBadge(string type) => type.ToLowerInvariant() switch
    {
        "sum" => "fc-badge--success",
        "difference" => "fc-badge--info",
        "equals" => "fc-badge--purple",
        "custom" => "fc-badge--warning",
        "ratio" => "fc-badge--pink",
        "required" => "fc-badge--danger",
        _ => "fc-badge--info"
    };
}
