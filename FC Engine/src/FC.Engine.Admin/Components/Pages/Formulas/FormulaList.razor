@page "/formulas"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]
@using FC.Engine.Admin.Utilities
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Enums
@using FC.Engine.Domain.Metadata
@using FC.Engine.Application.Services
@inject ITemplateMetadataCache Cache
@inject FormulaService FormulaService
@inject TemplateService TemplateService
@inject ITemplateRepository TemplateRepo
@inject ToastService Toast
@inject DialogService Dialog

<PageHeader Title="Intra-Sheet Formulas"
            Subtitle="View and manage validation formulas across all templates. Formulas define how computed fields are validated."
            CountBadge="@(!_loading ? _allFormulas.Count : null)" />

<div class="fc-list-page">

    @if (_showAddForm)
    {
        <div class="fc-list-inline-form">
            <h3>@(_editFormulaId.HasValue ? "Edit Formula" : "Add Intra-Sheet Formula")</h3>
            <div class="grid-2">
                <div class="form-group">
                    <label>Template</label>
                    <select class="form-control" @bind="_addTemplateCode" @bind:after="OnTemplateSelected" disabled="@(_editFormulaId.HasValue)">
                        <option value="">Select template...</option>
                        @foreach (var rc in _returnCodes)
                        {
                            <option value="@rc">@rc</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Rule Code</label>
                    <input class="form-control" @bind="_addRuleCode" placeholder="e.g. MFCR300-SUM-001" disabled="@(_editFormulaId.HasValue)" />
                </div>
                <div class="form-group">
                    <label>Rule Name / Description</label>
                    <input class="form-control" @bind="_addRuleName" placeholder="e.g. TOTAL CASH = Notes + Coins" />
                </div>
                <div class="form-group">
                    <label>Formula Type</label>
                    <select class="form-control" @bind="_addFormulaType">
                        @foreach (var ft in Enum.GetValues<FormulaType>())
                        {
                            <option value="@ft">@ft</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Target Field</label>
                    @if (_selectedTemplateFields.Any())
                    {
                        <select class="form-control" @bind="_addTargetField">
                            <option value="">Select field...</option>
                            @foreach (var f in _selectedTemplateFields)
                            {
                                <option value="@f">@f</option>
                            }
                        </select>
                    }
                    else
                    {
                        <input class="form-control" @bind="_addTargetField" placeholder="e.g. total_cash" />
                    }
                </div>
                <div class="form-group">
                    <label>Target Line Code (Item Code)</label>
                    <input class="form-control" @bind="_addTargetLineCode" placeholder="e.g. 10140" />
                </div>
                <div class="form-group">
                    <label>Operand Fields (comma-separated)</label>
                    <input class="form-control" @bind="_addOperandFields" placeholder="e.g. cash_notes,cash_coins" />
                </div>
                @if (_addFormulaType == FormulaType.Custom)
                {
                    <div class="form-group">
                        <label>Custom Expression (item-code formula)</label>
                        <input class="form-control" @bind="_addExpression" placeholder="e.g. 10420+10430+10440-10510" />
                    </div>
                }
                <div class="form-group">
                    <label>Tolerance</label>
                    <input type="number" step="0.01" class="form-control" @bind="_addTolerance" />
                </div>
                <div class="form-group">
                    <label>Severity</label>
                    <select class="form-control" @bind="_addSeverity">
                        @foreach (var s in Enum.GetValues<ValidationSeverity>())
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>
            </div>
            @if (_selectedTemplateFields.Any())
            {
                <div class="fc-formula-fields-hint">
                    Available fields: @string.Join(", ", _selectedTemplateFields.Take(20))@(_selectedTemplateFields.Count > 20 ? $"... (+{_selectedTemplateFields.Count - 20} more)" : "")
                </div>
            }
            <div class="fc-list-form-actions">
                @if (_editFormulaId.HasValue)
                {
                    <button class="fc-btn fc-btn--primary fc-btn--sm @(_isSaving ? "fc-btn--loading" : "")" @onclick="UpdateFormula" disabled="@_isSaving" aria-busy="@(_isSaving ? "true" : null)">
                        @if (_isSaving) { <span class="fc-spinner fc-spinner--sm fc-spinner--white" aria-hidden="true"></span> }
                        Update
                    </button>
                }
                else
                {
                    <button class="fc-btn fc-btn--primary fc-btn--sm @(_isSaving ? "fc-btn--loading" : "")" @onclick="AddFormula" disabled="@_isSaving" aria-busy="@(_isSaving ? "true" : null)">
                        @if (_isSaving) { <span class="fc-spinner fc-spinner--sm fc-spinner--white" aria-hidden="true"></span> }
                        Add
                    </button>
                }
                <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="CancelForm" disabled="@_isSaving">Cancel</button>
            </div>
        </div>
    }

    <DataTable TItem="(string ReturnCode, IntraSheetFormula Formula)"
               Items="@FilteredFormulas.ToList()"
               Loading="_loading"
               PageSize="30"
               ShowPagination="true"
               ShowPageSizeSelector="true"
               Sortable="true"
               EmptyTitle="No formulas found"
               EmptyText="Try adjusting your search criteria or filters. You can also add a new formula to get started."
               SkeletonRows="8"
               ShowExport="false">
        <ToolbarContent>
            <div class="fc-list-toolbar-filters">
                <div class="fc-list-search-wrap">
                    <svg class="fc-list-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    <input class="fc-list-search-input" placeholder="Search by rule code, field, or description..." @bind="_search" @bind:event="oninput" />
                </div>
                <select class="fc-list-filter-select" @bind="_typeFilter">
                    <option value="">All Types</option>
                    @foreach (var ft in Enum.GetValues<FormulaType>())
                    {
                        <option value="@ft">@ft</option>
                    }
                </select>
                <select class="fc-list-filter-select" @bind="_templateFilter">
                    <option value="">All Templates</option>
                    @foreach (var rc in _returnCodes)
                    {
                        <option value="@rc">@rc</option>
                    }
                </select>
            </div>
            <div class="fc-list-toolbar-actions">
                <AuthorizeView Roles="Admin,Approver">
                    <Authorized Context="addAuth">
                        <button class="fc-btn fc-btn--gold" @onclick="ShowAddFormula">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                            New Formula
                        </button>
                    </Authorized>
                </AuthorizeView>
            </div>
        </ToolbarContent>
        <ChildContent>
            <DataColumn TItem="(string ReturnCode, IntraSheetFormula Formula)" Title="Template" SortKey="x => x.ReturnCode" Width="100px">
                <CellTemplate>
                    <a class="fc-list-cell-link" href="/templates/@context.ReturnCode">@context.ReturnCode</a>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="(string ReturnCode, IntraSheetFormula Formula)" Title="Rule Code" SortKey="x => x.Formula.RuleCode" Width="160px">
                <CellTemplate>
                    <span class="fc-list-cell-code">@context.Formula.RuleCode</span>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="(string ReturnCode, IntraSheetFormula Formula)" Title="Name" SortKey="x => x.Formula.RuleName">
                <CellTemplate>
                    <span class="fc-list-cell-truncate" title="@context.Formula.RuleName">@context.Formula.RuleName</span>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="(string ReturnCode, IntraSheetFormula Formula)" Title="Type" Width="90px">
                <CellTemplate>
                    <span class="fc-badge @FormulaBadge(context.Formula.FormulaType.ToString())">@context.Formula.FormulaType</span>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="(string ReturnCode, IntraSheetFormula Formula)" Title="Target" Width="130px">
                <CellTemplate>
                    <span class="fc-list-cell-code">@context.Formula.TargetFieldName</span>
                    @if (!string.IsNullOrEmpty(context.Formula.TargetLineCode))
                    {
                        <br /><span class="fc-list-cell-muted">@context.Formula.TargetLineCode</span>
                    }
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="(string ReturnCode, IntraSheetFormula Formula)" Title="Formula / Operands">
                <CellTemplate>
                    @if (context.Formula.FormulaType == FormulaType.Custom && !string.IsNullOrEmpty(context.Formula.CustomExpression))
                    {
                        <span class="fc-list-cell-code fc-list-cell-truncate" title="@context.Formula.CustomExpression">@TruncateExpression(context.Formula.CustomExpression, 50)</span>
                    }
                    else
                    {
                        <span class="fc-list-cell-code fc-list-cell-truncate" title="@context.Formula.OperandFields">@FormatOperands(context.Formula.OperandFields, context.Formula.FormulaType)</span>
                    }
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="(string ReturnCode, IntraSheetFormula Formula)" Title="Tolerance" Width="90px">
                <CellTemplate>
                    <span class="fc-list-cell-muted">@context.Formula.ToleranceAmount</span>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="(string ReturnCode, IntraSheetFormula Formula)" Title="Severity" Width="90px">
                <CellTemplate>
                    <span class="fc-badge @StatusBadge(context.Formula.Severity.ToString())">@context.Formula.Severity</span>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="(string ReturnCode, IntraSheetFormula Formula)" Title="Actions" Width="110px">
                <CellTemplate>
                    <AuthorizeView Roles="Admin,Approver">
                        <Authorized Context="editAuth">
                            <div class="fc-list-row-actions">
                                <button class="fc-btn fc-btn--ghost fc-btn--xs" @onclick="() => EditFormula(context.ReturnCode, context.Formula)" @onclick:stopPropagation="true">Edit</button>
                                <button class="fc-btn fc-btn--ghost fc-btn--xs fc-btn--danger" @onclick="() => DeleteFormula(context.Formula)" @onclick:stopPropagation="true">Delete</button>
                            </div>
                        </Authorized>
                    </AuthorizeView>
                </CellTemplate>
            </DataColumn>
        </ChildContent>
    </DataTable>

</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _isSaving;
    private string _search = "", _typeFilter = "", _templateFilter = "";
    private List<string> _returnCodes = new();
    private List<(string ReturnCode, IntraSheetFormula Formula)> _allFormulas = new();
    private string _currentUser = string.Empty;

    // Add/Edit form state
    private bool _showAddForm;
    private int? _editFormulaId;
    private string _addTemplateCode = "", _addRuleCode = "", _addRuleName = "";
    private string _addTargetField = "", _addTargetLineCode = "";
    private string _addOperandFields = "", _addExpression = "";
    private FormulaType _addFormulaType = FormulaType.Sum;
    private decimal _addTolerance = 0.01m;
    private ValidationSeverity _addSeverity = ValidationSeverity.Error;
    private List<string> _selectedTemplateFields = new();
    private int _selectedTemplateId, _selectedVersionId;

    private IEnumerable<(string ReturnCode, IntraSheetFormula Formula)> FilteredFormulas =>
        _allFormulas
            .Where(x => string.IsNullOrEmpty(_search) ||
                        x.Formula.RuleCode.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                        x.Formula.TargetFieldName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                        x.Formula.RuleName.Contains(_search, StringComparison.OrdinalIgnoreCase))
            .Where(x => string.IsNullOrEmpty(_typeFilter) || x.Formula.FormulaType.ToString() == _typeFilter)
            .Where(x => string.IsNullOrEmpty(_templateFilter) || x.ReturnCode == _templateFilter);

    protected override async Task OnInitializedAsync()
    {
        var state = AuthState is null ? null : await AuthState;
        _currentUser = UserIdentityResolver.ResolveActor(state?.User);
        await LoadFormulas();
        _loading = false;
    }

    private async Task LoadFormulas()
    {
        var templates = await Cache.GetAllPublishedTemplates();
        _returnCodes = templates.Select(t => t.ReturnCode).OrderBy(x => x).ToList();
        _allFormulas.Clear();
        foreach (var t in templates)
        {
            if (t.CurrentVersion?.IntraSheetFormulas == null) continue;
            foreach (var f in t.CurrentVersion.IntraSheetFormulas)
                _allFormulas.Add((t.ReturnCode, f));
        }
    }

    private void ShowAddFormula()
    {
        ResetForm();
        _showAddForm = true;
    }

    private void CancelForm()
    {
        _showAddForm = false;
        _editFormulaId = null;
    }

    private void ResetForm()
    {
        _editFormulaId = null;
        _addTemplateCode = "";
        _addRuleCode = "";
        _addRuleName = "";
        _addTargetField = "";
        _addTargetLineCode = "";
        _addOperandFields = "";
        _addExpression = "";
        _addFormulaType = FormulaType.Sum;
        _addTolerance = 0.01m;
        _addSeverity = ValidationSeverity.Error;
        _selectedTemplateFields.Clear();
    }

    private async Task OnTemplateSelected()
    {
        _selectedTemplateFields.Clear();
        if (string.IsNullOrEmpty(_addTemplateCode)) return;

        try
        {
            // Use TemplateService to get all versions (including Draft) — formulas can only be
            // added to Draft versions, so prefer the Draft version if one exists.
            var detail = await TemplateService.GetTemplateDetail(_addTemplateCode);
            if (detail is not null)
            {
                _selectedTemplateId = detail.Id;
                var draftVersion = detail.Versions.FirstOrDefault(v => v.Status == "Draft");
                var targetVersion = draftVersion ?? detail.Versions.FirstOrDefault();
                if (targetVersion is not null)
                {
                    _selectedVersionId = targetVersion.Id;
                    _selectedTemplateFields = targetVersion.Fields
                        .Select(f => f.FieldName).OrderBy(x => x).ToList();
                }
            }
            else
            {
                // Fallback to cache for published-only templates (read-only field list)
                var template = await Cache.GetPublishedTemplate(_addTemplateCode);
                _selectedTemplateId = template.TemplateId;
                _selectedVersionId = template.CurrentVersion.Id;
                _selectedTemplateFields = template.CurrentVersion.Fields
                    .Select(f => f.FieldName).OrderBy(x => x).ToList();
            }
        }
        catch { }
    }

    private void EditFormula(string returnCode, IntraSheetFormula formula)
    {
        _showAddForm = true;
        _editFormulaId = formula.Id;
        _addTemplateCode = returnCode;
        _addRuleCode = formula.RuleCode;
        _addRuleName = formula.RuleName;
        _addFormulaType = formula.FormulaType;
        _addTargetField = formula.TargetFieldName;
        _addTargetLineCode = formula.TargetLineCode ?? "";
        _addExpression = formula.CustomExpression ?? "";
        _addTolerance = formula.ToleranceAmount;
        _addSeverity = formula.Severity;

        try
        {
            var operands = System.Text.Json.JsonSerializer.Deserialize<List<string>>(formula.OperandFields);
            _addOperandFields = operands != null ? string.Join(", ", operands) : formula.OperandFields;
        }
        catch
        {
            _addOperandFields = formula.OperandFields;
        }

        _ = OnTemplateSelected();
    }

    private async Task AddFormula()
    {
        _isSaving = true;
        try
        {
            var operandJson = BuildOperandJson(_addOperandFields);

            await FormulaService.AddIntraSheetFormula(
                _selectedTemplateId, _selectedVersionId,
                _addRuleCode, _addRuleName, _addFormulaType,
                _addTargetField, operandJson,
                _addFormulaType == FormulaType.Custom ? _addExpression : null,
                _addTolerance, _addSeverity, _currentUser,
                string.IsNullOrWhiteSpace(_addTargetLineCode) ? null : _addTargetLineCode.Trim());

            Toast.Success($"Formula '{_addRuleCode}' added successfully.", "Formula Added");
            _showAddForm = false;
            _editFormulaId = null;

            Cache.InvalidateAll();
            await LoadFormulas();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message, "Add Failed");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task UpdateFormula()
    {
        if (!_editFormulaId.HasValue) return;

        _isSaving = true;
        try
        {
            var operandJson = BuildOperandJson(_addOperandFields);

            await FormulaService.UpdateIntraSheetFormula(
                _editFormulaId.Value, _addRuleName, _addFormulaType,
                _addTargetField, string.IsNullOrWhiteSpace(_addTargetLineCode) ? null : _addTargetLineCode,
                operandJson,
                _addFormulaType == FormulaType.Custom ? _addExpression : null,
                _addTolerance, _addSeverity, _currentUser);

            Toast.Success($"Formula '{_addRuleCode}' updated successfully.", "Formula Updated");
            _showAddForm = false;
            _editFormulaId = null;

            Cache.InvalidateAll();
            await LoadFormulas();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message, "Update Failed");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteFormula(IntraSheetFormula formula)
    {
        var confirmed = await Dialog.ConfirmDelete("Formula");
        if (!confirmed) return;

        try
        {
            await FormulaService.DeleteIntraSheetFormula(formula.Id, _currentUser);
            Toast.Success($"Formula '{formula.RuleCode}' deleted.", "Formula Deleted");

            Cache.InvalidateAll();
            await LoadFormulas();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message, "Delete Failed");
        }
    }

    private static string BuildOperandJson(string commaSeparated)
    {
        var fields = commaSeparated
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return "[" + string.Join(",", fields.Select(f => $"\"{f}\"")) + "]";
    }

    private static string FormatOperands(string operandFieldsJson, FormulaType type)
    {
        try
        {
            var operands = System.Text.Json.JsonSerializer.Deserialize<List<string>>(operandFieldsJson);
            if (operands == null || !operands.Any()) return operandFieldsJson;
            var op = type == FormulaType.Difference ? " - " : " + ";
            return string.Join(op, operands);
        }
        catch
        {
            return operandFieldsJson;
        }
    }

    private static string TruncateExpression(string expr, int maxLen)
    {
        return expr.Length <= maxLen ? expr : expr[..maxLen] + "...";
    }

    private static string FormulaBadge(string type) => type.ToLowerInvariant() switch
    {
        "sum" => "fc-badge--success",
        "difference" => "fc-badge--info",
        "equals" => "fc-badge--purple",
        "custom" => "fc-badge--warning",
        "ratio" => "fc-badge--pink",
        "required" => "fc-badge--danger",
        _ => "fc-badge--info"
    };

    private static string StatusBadge(string status) => status.ToLowerInvariant() switch
    {
        "published" or "active" or "accepted" => "fc-badge--success",
        "draft" or "pending" => "fc-badge--warning",
        "review" or "inreview" => "fc-badge--review",
        "deprecated" or "retired" or "disabled" or "archived" => "fc-badge--muted",
        "rejected" or "failed" or "error" => "fc-badge--danger",
        "processing" or "validating" or "parsing" => "fc-badge--info",
        "acceptedwithwarnings" or "warnings" or "warning" => "fc-badge--warning",
        _ => "fc-badge--neutral"
    };
}
