@code {
    private static readonly string[] RegulatorOptions = ["CBN", "NDIC", "NAICOM", "SEC"];

    private static readonly Dictionary<string, IReadOnlyList<string>> LicenceOptions = new(StringComparer.OrdinalIgnoreCase)
    {
        ["CBN"] = ["DMB", "MFB", "PMB"],
        ["NDIC"] = ["DMB", "MFB"],
        ["NAICOM"] = ["GENERAL_INSURER", "LIFE_INSURER"],
        ["SEC"] = ["BROKER_DEALER"]
    };

    private List<RegulatoryActionForecast> _regulatoryRanking = new();
    private List<ChurnRiskAssessment> _churnRisks = new();
    private string _selectedRegulator = "CBN";
    private string _selectedLicence = string.Empty;
    private string? _error;
    private Exception? _loadException;
    private bool _loading = true;

    private IReadOnlyList<string> CurrentLicenceOptions =>
        LicenceOptions.TryGetValue(_selectedRegulator, out var options)
            ? options
            : Array.Empty<string>();

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task OnRegulatorChangedAsync()
    {
        if (!CurrentLicenceOptions.Contains(_selectedLicence, StringComparer.OrdinalIgnoreCase))
        {
            _selectedLicence = string.Empty;
        }

        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        _loadException = null;

        try
        {
            _regulatoryRanking = (await ForeSightService.GetRegulatoryRiskRankingAsync(
                _selectedRegulator,
                string.IsNullOrWhiteSpace(_selectedLicence) ? null : _selectedLicence)).ToList();
            _churnRisks = (await ForeSightService.GetChurnRiskDashboardAsync()).ToList();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _loadException = ex;
            Toast.Error($"Unable to load ForeSight platform data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private string ResolveStatusBadge()
    {
        if (_loading)
        {
            return "Refreshing signals";
        }

        if (!string.IsNullOrWhiteSpace(_error))
        {
            return "Data unavailable";
        }

        var highPriorityCount = _regulatoryRanking.Count(x => x.RiskBand is "HIGH" or "CRITICAL");
        var elevatedChurnCount = _churnRisks.Count(x => x.RiskBand is "HIGH" or "CRITICAL");

        return highPriorityCount + elevatedChurnCount > 0
            ? "Priority signals live"
            : "Portfolio stable";
    }

    private string ResolveStatusVariant()
    {
        if (_loading)
        {
            return "info";
        }

        if (!string.IsNullOrWhiteSpace(_error))
        {
            return "danger";
        }

        var highPriorityCount = _regulatoryRanking.Count(x => x.RiskBand is "HIGH" or "CRITICAL");
        var elevatedChurnCount = _churnRisks.Count(x => x.RiskBand is "HIGH" or "CRITICAL");

        return highPriorityCount + elevatedChurnCount > 0
            ? "warning"
            : "success";
    }

    private string BuildScopeLabel()
    {
        return string.IsNullOrWhiteSpace(_selectedLicence)
            ? $"{_selectedRegulator} · All licences"
            : $"{_selectedRegulator} · {_selectedLicence}";
    }

    private static string ResolveBannerTone(int highPriorityCount, int elevatedChurnCount)
    {
        if (highPriorityCount >= 5 || elevatedChurnCount >= 5)
        {
            return "critical";
        }

        if (highPriorityCount > 0 || elevatedChurnCount > 0)
        {
            return "warning";
        }

        return "success";
    }

    private static string BuildBannerHeadline(int highPriorityCount, int elevatedChurnCount)
    {
        var combined = highPriorityCount + elevatedChurnCount;
        return combined > 0
            ? $"{combined} elevated forecasts are competing for operator attention."
            : "No elevated forecasts are currently pressing this supervisory scope.";
    }

    private static string BuildBannerDetail(int highPriorityCount, int elevatedChurnCount, decimal averageConfidence)
    {
        return highPriorityCount + elevatedChurnCount > 0
            ? $"{highPriorityCount} regulatory priority signal(s) and {elevatedChurnCount} churn case(s) remain visible, with average confidence at {averageConfidence:P0}."
            : $"All visible forecasts are sitting in lower bands, with average confidence at {averageConfidence:P0}.";
    }

    private static string BuildPriorityLabel(int highPriorityCount, int elevatedChurnCount)
    {
        var combined = highPriorityCount + elevatedChurnCount;
        return combined switch
        {
            0 => "No elevated watchlist pressure",
            1 => "1 elevated case in play",
            _ => $"{combined} elevated cases in play"
        };
    }

    private decimal BuildAverageConfidence()
    {
        var allScores = _regulatoryRanking.Select(x => x.ConfidenceScore)
            .Concat(_churnRisks.Select(x => x.ConfidenceScore))
            .ToList();

        return allScores.Count == 0 ? 0m : allScores.Average();
    }

    private static string GetRiskClass(string riskBand)
    {
        return riskBand.ToUpperInvariant() switch
        {
            "CRITICAL" => "fc-fsa-risk--critical",
            "HIGH" => "fc-fsa-risk--high",
            "MEDIUM" => "fc-fsa-risk--medium",
            "LOW" => "fc-fsa-risk--low",
            _ => "fc-fsa-risk--none"
        };
    }
}
