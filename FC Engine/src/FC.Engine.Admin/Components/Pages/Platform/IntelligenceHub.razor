@page "/platform/intelligence"
@attribute [Authorize(Policy = "PlatformAdmin")]
@using System.Globalization
@using System.Text
@using FC.Engine.Admin.Services
@using FC.Engine.Infrastructure.Services
@inject PlatformIntelligenceService IntelligenceService
@inject ToastService Toast
@inject DataTableExportService ExportService
@inject IJSRuntime JS

<PageTitle>Platform Intelligence Workspace</PageTitle>

<PageHeader Title="Platform Intelligence Workspace"
            Subtitle="An integrated operating surface for knowledge graph navigation, capital analytics, sanctions screening, resilience oversight, and model governance.">
    <SecondaryActions>
        <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="ExportCurrentViewCsvAsync" disabled="@(_loading || _workspace is null)">
            Export CSV
        </button>
        <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="ExportBriefingPdfAsync" disabled="@(_loading || _workspace is null)">
            Board Brief
        </button>
        <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="ReloadAsync">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="23 4 23 10 17 10"></polyline>
                <path d="M20.49 15A9 9 0 1 1 18.36 5.64L23 10"></path>
            </svg>
            Refresh
        </button>
    </SecondaryActions>
</PageHeader>

<div class="fc-intel-page">
    @if (_loading)
    {
        <div class="fc-intel-skeleton-grid">
            @for (var i = 0; i < 5; i++)
            {
                <div class="fc-intel-skeleton-card"></div>
            }
        </div>
    }
    else if (_error is not null)
    {
        <SectionErrorBoundary Title="Failed to load platform intelligence" ExternalError="@_error" OnRetry="ReloadAsync" />
    }
    else if (_workspace is not null)
    {
        <section class="fc-intel-hero">
            <div class="fc-intel-hero__copy">
                <span class="fc-intel-kicker">Platform intelligence fabric</span>
                <h1>RegOS signal fusion for supervision and compliance operations.</h1>
                <p>
                    Grounded in live metadata, filings, control evidence, and resilience telemetry.
                    Updated @FormatTimestamp(_workspace.GeneratedAt).
                </p>
            </div>
            <div class="fc-intel-hero__grid">
                <article class="fc-intel-stat fc-intel-stat--gold">
                    <span class="fc-intel-stat__label">Graph Nodes</span>
                    <strong>@_workspace.Hero.KnowledgeGraphNodes</strong>
                    <span class="fc-intel-stat__meta">lineage-bearing fields</span>
                </article>
                <article class="fc-intel-stat fc-intel-stat--emerald">
                    <span class="fc-intel-stat__label">Capital Alerts</span>
                    <strong>@_workspace.Hero.ActiveCapitalAlerts</strong>
                    <span class="fc-intel-stat__meta">institutions needing action</span>
                </article>
                <article class="fc-intel-stat fc-intel-stat--crimson">
                    <span class="fc-intel-stat__label">Watchlist Sources</span>
                    <strong>@_workspace.Hero.WatchlistSources</strong>
                    <span class="fc-intel-stat__meta">screening feeds catalogued</span>
                </article>
                <article class="fc-intel-stat fc-intel-stat--teal">
                    <span class="fc-intel-stat__label">Open Incidents</span>
                    <strong>@_workspace.Hero.OpenResilienceIncidents</strong>
                    <span class="fc-intel-stat__meta">resilience issues in flight</span>
                </article>
                <article class="fc-intel-stat fc-intel-stat--ink">
                    <span class="fc-intel-stat__label">Governed Models</span>
                    <strong>@_workspace.Hero.ModelsUnderGovernance</strong>
                    <span class="fc-intel-stat__meta">model inventory baseline</span>
                </article>
                <article class="fc-intel-stat fc-intel-stat--crimson">
                    <span class="fc-intel-stat__label">Priority Queue</span>
                    <strong>@_workspace.Hero.PriorityInterventions</strong>
                    <span class="fc-intel-stat__meta">critical and high-priority actions</span>
                </article>
            </div>
        </section>

        <div class="fc-intel-tabs" role="tablist" aria-label="Platform intelligence sections">
            @foreach (var tab in Tabs)
            {
                <button class="fc-intel-tab @(_activeTab == tab.Id ? "is-active" : null)"
                        @onclick="() => _activeTab = tab.Id"
                        role="tab"
                        aria-selected="@(_activeTab == tab.Id)">
                    <span>@tab.Label</span>
                    <small>@tab.Meta</small>
                </button>
            }
        </div>

        @switch (_activeTab)
        {
            case "knowledge":
                <section class="fc-intel-section">
                    <div class="fc-intel-grid fc-intel-grid--metrics">
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Regulators</span>
                            <strong>@_workspace.KnowledgeGraph.RegulatorCount</strong>
                            <p>Distinct regulators represented in the active module graph.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Templates</span>
                            <strong>@_workspace.KnowledgeGraph.TemplateCount</strong>
                            <p>Return templates currently forming the filing lineage network.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Referenced Fields</span>
                            <strong>@_workspace.KnowledgeGraph.ReferencedFieldCount</strong>
                            <p>Fields with a direct regulatory reference attached.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Requirements</span>
                            <strong>@_workspace.KnowledgeGraph.RequirementCount</strong>
                            <p>Distinct regulatory references currently materialized into the graph.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Persisted Nodes</span>
                            <strong>@_workspace.KnowledgeGraph.PersistedNodeCount</strong>
                            <p>Schema-backed graph nodes stored in the SQL knowledge catalog.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Persisted Edges</span>
                            <strong>@_workspace.KnowledgeGraph.PersistedEdgeCount</strong>
                            <p>Stored graph relationships across regulators, returns, fields, and institutions.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Obligations</span>
                            <strong>@_workspace.KnowledgeGraph.ObligationCount</strong>
                            <p>Derived obligations from licence-to-module applicability.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Dossier Sections</span>
                            <strong>@_workspace.KnowledgeGraph.DossierPack.Count</strong>
                            <p>Structured compliance-dossier sections currently assembled from graph evidence.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Dossier Attention</span>
                            <strong>@_workspace.KnowledgeGraph.DossierAttentionCount</strong>
                            <p>Knowledge-dossier sections currently in watch or critical posture.</p>
                        </article>
                    </div>

                    <div class="fc-intel-controlbar">
                        <div class="fc-intel-searchbar">
                            <label for="kg-search">Trace a regulatory reference or return code</label>
                            <input id="kg-search"
                                   class="fc-input"
                                   @bind="_knowledgeQuery"
                                   @bind:event="oninput"
                                   placeholder="e.g. CRD-001, NFIU_TFS, BDC_FXV" />
                        </div>
                        <label class="fc-intel-stack">
                            <span>Institution focus</span>
                            <select class="fc-input fc-intel-select" @bind="_selectedInstitutionId">
                                <option value="">All institutions</option>
                                @foreach (var option in _workspace.KnowledgeGraph.InstitutionOptions.Take(160))
                                {
                                    <option value="@option.InstitutionId.ToString(CultureInfo.InvariantCulture)">
                                        @option.InstitutionName (@option.LicenceType)
                                    </option>
                                }
                            </select>
                        </label>
                    </div>

                    <div class="fc-intel-pill-grid">
                        <article class="fc-intel-metric-tile">
                            <span class="fc-intel-card__label">Institution Obligations</span>
                            <strong>@FocusedInstitutionObligations.Count</strong>
                            <p>@(SelectedInstitutionOption?.InstitutionName ?? "Filtered supervisory obligation rows")</p>
                        </article>
                        <article class="fc-intel-metric-tile">
                            <span class="fc-intel-card__label">Overdue / Attention</span>
                            <strong>@FocusedInstitutionObligations.Count(x => x.Status is "Overdue" or "Attention Required")</strong>
                            <p>Rows requiring immediate intervention or refiling.</p>
                        </article>
                        <article class="fc-intel-metric-tile">
                            <span class="fc-intel-card__label">Filed / In Flight</span>
                            <strong>@FocusedInstitutionObligations.Count(x => x.Status is "Filed" or "Pending Approval" or "In Progress")</strong>
                            <p>Current obligations with recent filing activity.</p>
                        </article>
                        <article class="fc-intel-metric-tile">
                            <span class="fc-intel-card__label">Regulators</span>
                            <strong>@FocusedInstitutionObligations.Select(x => x.RegulatorCode).Distinct(StringComparer.OrdinalIgnoreCase).Count()</strong>
                            <p>Distinct regulators represented in the filtered obligation set.</p>
                        </article>
                        <article class="fc-intel-metric-tile">
                            <span class="fc-intel-card__label">Change Paths</span>
                            <strong>@FilteredImpactPropagationRows.Count</strong>
                            <p>Ranked regulatory references with downstream template and filing impact.</p>
                        </article>
                        <article class="fc-intel-metric-tile">
                            <span class="fc-intel-card__label">Critical Change Paths</span>
                            <strong>@FilteredImpactPropagationRows.Count(x => x.Signal == "Critical")</strong>
                            <p>References with material filing pressure or broad downstream rule surface.</p>
                        </article>
                        <article class="fc-intel-metric-tile">
                            <span class="fc-intel-card__label">Deadlines Inside 14 Days</span>
                            <strong>@FilteredImpactPropagationRows.Count(x => x.NextDeadline <= DateTime.UtcNow.AddDays(14))</strong>
                            <p>Change paths that need action before the next supervisory filing window closes.</p>
                        </article>
                    </div>

                    <article class="fc-intel-card fc-intel-card--table">
                        <header class="fc-intel-card__header">
                            <div>
                                <span class="fc-intel-card__label">Materialized Graph Catalog</span>
                                <h2>SQL-backed `kg_nodes` and `kg_edges` persisted from the live compliance graph</h2>
                            </div>
                            <span class="fc-intel-chip">@(_workspace.KnowledgeGraph.CatalogMaterializedAt?.ToString("dd MMM HH:mm", CultureInfo.InvariantCulture) ?? "Pending")</span>
                        </header>
                        <div class="fc-intel-pill-grid">
                            <article class="fc-intel-metric-tile">
                                <span class="fc-intel-card__label">Catalog Nodes</span>
                                <strong>@_workspace.KnowledgeGraph.PersistedNodeCount</strong>
                                <p>Stored graph nodes ready for downstream navigation and impact analysis.</p>
                            </article>
                            <article class="fc-intel-metric-tile">
                                <span class="fc-intel-card__label">Catalog Edges</span>
                                <strong>@_workspace.KnowledgeGraph.PersistedEdgeCount</strong>
                                <p>Persisted relationships covering filing, lineage, and institution obligations.</p>
                            </article>
                            <article class="fc-intel-metric-tile">
                                <span class="fc-intel-card__label">Last Materialized</span>
                                <strong>@(_workspace.KnowledgeGraph.CatalogMaterializedAt?.ToString("dd MMM yyyy", CultureInfo.InvariantCulture) ?? "Pending")</strong>
                                <p>@(_workspace.KnowledgeGraph.CatalogMaterializedAt?.ToString("HH:mm 'UTC'", CultureInfo.InvariantCulture) ?? "The graph catalog has not been written yet.")</p>
                            </article>
                        </div>

                        <div class="fc-intel-grid fc-intel-grid--two">
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Node type</th>
                                            <th>Count</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _workspace.KnowledgeGraph.CatalogNodeTypes)
                                        {
                                            <tr>
                                                <td>@row.Type</td>
                                                <td>@row.Count</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Edge type</th>
                                            <th>Count</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _workspace.KnowledgeGraph.CatalogEdgeTypes)
                                        {
                                            <tr>
                                                <td>@row.Type</td>
                                                <td>@row.Count</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </article>

                    <article class="fc-intel-card fc-intel-card--table">
                        <header class="fc-intel-card__header">
                            <div>
                                <span class="fc-intel-card__label">Compliance Dossier</span>
                                <h2>Structured regulator-facing pack assembled from graph, obligation, and impact evidence</h2>
                            </div>
                            <span class="fc-intel-chip">@_workspace.KnowledgeGraph.DossierPack.Count section(s)</span>
                        </header>
                        @if (_workspace.KnowledgeGraph.DossierPack.Count == 0)
                        {
                            <div class="fc-intel-empty">
                                <h3>No compliance dossier is currently assembled</h3>
                                <p>As the knowledge graph matures, the regulator-facing dossier pack will appear here for readiness review.</p>
                            </div>
                        }
                        else
                        {
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Section</th>
                                            <th>Rows</th>
                                            <th>Coverage</th>
                                            <th>Signal</th>
                                            <th>Current posture</th>
                                            <th>Next action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _workspace.KnowledgeGraph.DossierPack)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@row.SectionCode</strong>
                                                    <div class="fc-intel-table__sub">@row.SectionName</div>
                                                </td>
                                                <td>@row.RowCount</td>
                                                <td class="fc-intel-table__sub">@row.Coverage</td>
                                                <td><span class="fc-intel-status fc-intel-status--@StatusClass(row.Signal)">@row.Signal</span></td>
                                                <td class="fc-intel-table__sub">@row.Commentary</td>
                                                <td class="fc-intel-table__sub">@row.RecommendedAction</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </article>

                    <div class="fc-intel-grid fc-intel-grid--two">
                        <article class="fc-intel-card fc-intel-card--table">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Regulatory Ontology</span>
                                    <h2>Coverage by regulator and filing path</h2>
                                </div>
                                <span class="fc-intel-chip">@_workspace.KnowledgeGraph.OntologyCoverage.Count row(s)</span>
                            </header>
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Regulator</th>
                                            <th>Families</th>
                                            <th>Requirements</th>
                                            <th>Modules / Returns</th>
                                            <th>Institutions</th>
                                            <th>Primary path</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _workspace.KnowledgeGraph.OntologyCoverage)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@row.RegulatorCode</strong>
                                                    <div class="fc-intel-table__sub">@row.ObligationCount obligation path(s)</div>
                                                </td>
                                                <td>@row.RegulationFamilyCount</td>
                                                <td>@row.RequirementCount</td>
                                                <td>
                                                    <strong>@row.ModuleCount module(s)</strong>
                                                    <div class="fc-intel-table__sub">@row.ReturnCount return(s)</div>
                                                </td>
                                                <td>@row.InstitutionCount</td>
                                                <td><span class="fc-intel-ref">@row.PrimaryFilingPath</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </article>

                        <article class="fc-intel-card fc-intel-card--table">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Requirement Register</span>
                                    <h2>Reference -> licence -> filing implementation</h2>
                                </div>
                                <span class="fc-intel-chip">@_workspace.KnowledgeGraph.RequirementRegister.Count row(s)</span>
                            </header>
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Reference</th>
                                            <th>Family</th>
                                            <th>Filed via</th>
                                            <th>Applies to</th>
                                            <th>Institutions</th>
                                            <th>Next deadline</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _workspace.KnowledgeGraph.RequirementRegister)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@row.RegulatoryReference</strong>
                                                    <div class="fc-intel-table__sub">@row.RegulatorCode · @row.ModuleCode</div>
                                                </td>
                                                <td>@row.RegulationFamily</td>
                                                <td>
                                                    <strong>@row.FiledViaReturns</strong>
                                                    <div class="fc-intel-table__sub">@row.FieldCount field(s) · @row.FrequencyProfile</div>
                                                </td>
                                                <td class="fc-intel-table__sub">@row.AppliesToLicenceTypes</td>
                                                <td>@row.InstitutionCount</td>
                                                <td>@row.NextDeadline.ToString("dd MMM yyyy", CultureInfo.InvariantCulture)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </article>
                    </div>

                    <div class="fc-intel-grid fc-intel-grid--two">
                        <article class="fc-intel-card fc-intel-card--table">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Lineage Trace</span>
                                    <h2>Regulation -> template -> field</h2>
                                </div>
                                <span class="fc-intel-chip">@FilteredLineage.Count row(s)</span>
                            </header>
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Regulator</th>
                                            <th>Template</th>
                                            <th>Field</th>
                                            <th>Reference</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in FilteredLineage)
                                        {
                                            <tr class="@(SelectedNavigatorDetail?.NavigatorKey == row.NavigatorKey ? "is-selected" : null)">
                                                <td>@row.RegulatorCode</td>
                                                <td>
                                                    <strong>@row.ReturnCode</strong>
                                                    <div class="fc-intel-table__sub">@row.TemplateName</div>
                                                </td>
                                                <td>
                                                    <strong>@row.FieldName</strong>
                                                    <div class="fc-intel-table__sub">@row.FieldCode</div>
                                                </td>
                                                <td><span class="fc-intel-ref">@row.RegulatoryReference</span></td>
                                                <td>
                                                    <button class="fc-btn fc-btn--outline fc-btn--sm"
                                                            @onclick="() => SelectKnowledgeNavigator(row.NavigatorKey)">
                                                        Inspect
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </article>

                        <article class="fc-intel-card fc-intel-card--table">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Impact Propagation</span>
                                    <h2>Ranked regulatory changes requiring downstream action</h2>
                                </div>
                                <span class="fc-intel-chip">@FilteredImpactPropagationRows.Count row(s)</span>
                            </header>
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Reference</th>
                                            <th>Primary return</th>
                                            <th>Impact</th>
                                            <th>Filing pressure</th>
                                            <th>Next deadline</th>
                                            <th>Signal</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in FilteredImpactPropagationRows)
                                        {
                                            <tr>
                                                <td>
                                                    <span class="fc-intel-ref">@row.RegulatoryReference</span>
                                                    <div class="fc-intel-table__sub">@row.RegulationFamily · @row.RegulatorCode</div>
                                                </td>
                                                <td>
                                                    <strong>@row.PrimaryReturnCode</strong>
                                                    <div class="fc-intel-table__sub">@row.ImpactedTemplates template(s) · @row.ImpactedFields field(s)</div>
                                                </td>
                                                <td>
                                                    <strong>@row.RuleSurfaceCount rule item(s)</strong>
                                                    <div class="fc-intel-table__sub">@row.AffectedInstitutions institution(s)</div>
                                                </td>
                                                <td>
                                                    <strong>@row.FilingAttentionCount needing action</strong>
                                                    <div class="fc-intel-table__sub">@row.FiledInstitutionCount in-flight or filed</div>
                                                </td>
                                                <td>@row.NextDeadline.ToString("dd MMM yyyy", CultureInfo.InvariantCulture)</td>
                                                <td>
                                                    <span class="fc-intel-status fc-intel-status--@StatusClass(row.Signal)">@row.Signal</span>
                                                    <div class="fc-intel-table__sub">@row.RecommendedAction</div>
                                                </td>
                                                <td>
                                                    <button class="fc-btn fc-btn--outline fc-btn--sm"
                                                            @onclick="() => SelectKnowledgeNavigator(row.NavigatorKey)">
                                                        Inspect
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </article>
                    </div>

                    <article class="fc-intel-card fc-intel-card--nested">
                        <header class="fc-intel-card__header">
                            <div>
                                <span class="fc-intel-card__label">Compliance Navigator</span>
                                <h2>@(SelectedNavigatorDetail?.ReturnCode ?? "Select a lineage row to inspect")</h2>
                            </div>
                            @if (SelectedNavigatorDetail is not null)
                            {
                                <span class="fc-intel-chip">@SelectedNavigatorDetail.RegulatoryReference</span>
                            }
                        </header>

                        @if (SelectedNavigatorDetail is null)
                        {
                            <div class="fc-intel-empty">
                                <h3>No lineage trace selected</h3>
                                <p>Select a lineage row above to inspect the regulatory reference, affected institutions, and recent filing activity.</p>
                            </div>
                        }
                        else
                        {
                            <div class="fc-intel-profile-shell">
                                <section class="fc-intel-profile-hero">
                                    <div>
                                        <div class="fc-intel-inline-chips">
                                            <span class="fc-intel-chip">@SelectedNavigatorDetail.RegulatorCode</span>
                                            <span class="fc-intel-chip">@SelectedNavigatorDetail.ModuleCode</span>
                                            <span class="fc-intel-chip">@SelectedNavigatorDetail.TemplateName</span>
                                            <span class="fc-intel-chip">@SelectedNavigatorDetail.FieldName</span>
                                        </div>
                                        <p class="fc-intel-card__lede">
                                            This trace links regulatory reference <strong>@SelectedNavigatorDetail.RegulatoryReference</strong>
                                            to template <strong>@SelectedNavigatorDetail.ReturnCode</strong>, field <strong>@SelectedNavigatorDetail.FieldCode</strong>,
                                            and the current institution obligation surface.
                                        </p>
                                    </div>

                                    <div class="fc-intel-pill-grid">
                                        <article class="fc-intel-metric-tile">
                                            <span class="fc-intel-card__label">Institutions</span>
                                            <strong>@SelectedNavigatorDetail.AffectedInstitutionCount</strong>
                                            <p>Affected institutions currently connected to this filing path.</p>
                                        </article>
                                        <article class="fc-intel-metric-tile">
                                            <span class="fc-intel-card__label">Tenants</span>
                                            <strong>@SelectedNavigatorDetail.AffectedTenantCount</strong>
                                            <p>Distinct supervised tenants touched by the trace.</p>
                                        </article>
                                        <article class="fc-intel-metric-tile">
                                            <span class="fc-intel-card__label">Rules</span>
                                            <strong>@SelectedNavigatorDetail.RuleSurfaceCount</strong>
                                            <p>Formula, cross-sheet, and business-rule surface linked to this reference.</p>
                                        </article>
                                        <article class="fc-intel-metric-tile">
                                            <span class="fc-intel-card__label">Filed</span>
                                            <strong>@SelectedNavigatorDetail.FiledInstitutionCount</strong>
                                            <p>Institutions with current filing activity on this return.</p>
                                        </article>
                                    </div>
                                </section>

                                <div class="fc-intel-grid fc-intel-grid--two">
                                    <article class="fc-intel-card fc-intel-card--table">
                                        <header class="fc-intel-card__header">
                                            <div>
                                                <span class="fc-intel-card__label">Affected Institutions</span>
                                                <h2>Current obligation and filing posture</h2>
                                            </div>
                                            <span class="fc-intel-chip">@SelectedNavigatorDetail.AffectedInstitutions.Count row(s)</span>
                                        </header>
                                        <div class="fc-intel-table-wrap">
                                            <table class="fc-intel-table">
                                                <thead>
                                                    <tr>
                                                        <th>Institution</th>
                                                        <th>Status</th>
                                                        <th>Last submitted</th>
                                                        <th>Next deadline</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var row in SelectedNavigatorDetail.AffectedInstitutions)
                                                    {
                                                        <tr>
                                                            <td>
                                                                <strong>@row.InstitutionName</strong>
                                                                <div class="fc-intel-table__sub">@row.LicenceType</div>
                                                            </td>
                                                            <td><span class="fc-intel-status fc-intel-status--@StatusClass(row.Status)">@row.Status</span></td>
                                                            <td>
                                                                @if (row.LastSubmittedAt.HasValue)
                                                                {
                                                                    <strong>@FormatTimestamp(row.LastSubmittedAt.Value)</strong>
                                                                    <div class="fc-intel-table__sub">@row.LatestSubmissionStatus</div>
                                                                }
                                                                else
                                                                {
                                                                    <span class="fc-intel-table__sub">No filing yet</span>
                                                                }
                                                            </td>
                                                            <td>@row.NextDeadline.ToString("dd MMM yyyy", CultureInfo.InvariantCulture)</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </article>

                                    <article class="fc-intel-card fc-intel-card--table">
                                        <header class="fc-intel-card__header">
                                            <div>
                                                <span class="fc-intel-card__label">Recent Filings</span>
                                                <h2>Latest submissions on this return</h2>
                                            </div>
                                            <span class="fc-intel-chip">@SelectedNavigatorDetail.RecentSubmissions.Count row(s)</span>
                                        </header>
                                        <div class="fc-intel-table-wrap">
                                            <table class="fc-intel-table">
                                                <thead>
                                                    <tr>
                                                        <th>Submission</th>
                                                        <th>Institution</th>
                                                        <th>Status</th>
                                                        <th>Submitted</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var row in SelectedNavigatorDetail.RecentSubmissions)
                                                    {
                                                        <tr>
                                                            <td><strong>#@row.SubmissionId</strong></td>
                                                            <td>@row.InstitutionName</td>
                                                            <td><span class="fc-intel-status fc-intel-status--@StatusClass(row.Status)">@row.Status</span></td>
                                                            <td>@FormatTimestamp(row.SubmittedAt)</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </article>
                                </div>
                            </div>
                        }
                    </article>

                    <article class="fc-intel-card fc-intel-card--table">
                        <header class="fc-intel-card__header">
                            <div>
                                <span class="fc-intel-card__label">Obligation Register</span>
                                <h2>Licence-driven filing obligations</h2>
                            </div>
                            <span class="fc-intel-chip">@_workspace.KnowledgeGraph.Obligations.Count row(s)</span>
                        </header>
                        <div class="fc-intel-table-wrap">
                            <table class="fc-intel-table">
                                <thead>
                                    <tr>
                                        <th>Licence</th>
                                        <th>Regulator</th>
                                        <th>Module</th>
                                        <th>Return</th>
                                        <th>Frequency</th>
                                        <th>Tenants</th>
                                        <th>Next deadline</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in _workspace.KnowledgeGraph.Obligations)
                                    {
                                        <tr>
                                            <td>@row.LicenceType</td>
                                            <td>@row.RegulatorCode</td>
                                            <td>@row.ModuleCode</td>
                                            <td>@row.ReturnCode</td>
                                            <td>@row.Frequency</td>
                                            <td>@row.AffectedTenants</td>
                                            <td>@row.NextDeadline.ToString("dd MMM yyyy", CultureInfo.InvariantCulture)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </article>

                    <article class="fc-intel-card fc-intel-card--table">
                        <header class="fc-intel-card__header">
                            <div>
                                <span class="fc-intel-card__label">Institution Obligation Register</span>
                                <h2>@InstitutionRegisterHeading</h2>
                            </div>
                            <span class="fc-intel-chip">@FocusedInstitutionObligations.Count row(s)</span>
                        </header>
                        <div class="fc-intel-table-wrap">
                            <table class="fc-intel-table">
                                <thead>
                                    <tr>
                                        <th>Institution</th>
                                        <th>Return</th>
                                        <th>Status</th>
                                        <th>Latest submission</th>
                                        <th>Next deadline</th>
                                        <th>Period</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in FocusedInstitutionObligations)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@row.InstitutionName</strong>
                                                <div class="fc-intel-table__sub">@row.LicenceType</div>
                                            </td>
                                            <td>
                                                <strong>@row.ReturnCode</strong>
                                                <div class="fc-intel-table__sub">@row.ModuleCode · @row.RegulatorCode</div>
                                            </td>
                                            <td><span class="fc-intel-status fc-intel-status--@StatusClass(row.Status)">@row.Status</span></td>
                                            <td>
                                                @if (row.LastSubmittedAt.HasValue)
                                                {
                                                    <strong>@FormatTimestamp(row.LastSubmittedAt.Value)</strong>
                                                    <div class="fc-intel-table__sub">@row.LatestSubmissionStatus</div>
                                                }
                                                else
                                                {
                                                    <span class="fc-intel-table__sub">No filing yet</span>
                                                }
                                            </td>
                                            <td>@row.NextDeadline.ToString("dd MMM yyyy", CultureInfo.InvariantCulture)</td>
                                            <td>@row.PeriodLabel</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </article>
                </section>
                break;

            case "capital":
                <section class="fc-intel-section">
                    <div class="fc-intel-grid fc-intel-grid--metrics">
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Average Capital Score</span>
                            <strong>@_workspace.Capital.AverageCapitalScore.ToString("0.0")</strong>
                            <p>Latest sector capital pillar score from compliance health snapshots.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Median Capital Score</span>
                            <strong>@_workspace.Capital.MedianCapitalScore.ToString("0.0")</strong>
                            <p>Median snapshot across the live supervised base.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Capital Watchlist</span>
                            <strong>@_workspace.Capital.CapitalWatchlistCount</strong>
                            <p>Institutions whose capital signal has slipped into intervention range.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Active Simulations</span>
                            <strong>@_workspace.Capital.ActiveScenarioCount</strong>
                            <p>Policy and what-if scenarios already alive in the platform.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Pack Sections</span>
                            <strong>@_capitalPackRows.Count</strong>
                            <p>Structured capital-management sections assembled from the current live scenario.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Pack Materialized</span>
                            <strong>@(_workspace.Capital.ReturnPackMaterializedAt?.ToString("dd MMM") ?? "Pending")</strong>
                            <p>@(_workspace.Capital.ReturnPackMaterializedAt?.ToString("HH:mm 'UTC'", CultureInfo.InvariantCulture) ?? "The capital supervisory pack has not been written yet.")</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Pack Attention</span>
                            <strong>@CapitalPackAttentionCount</strong>
                            <p>Capital pack sections currently sitting in watch or critical posture.</p>
                        </article>
                    </div>

                    <article class="fc-intel-card fc-intel-card--table">
                        <header class="fc-intel-card__header">
                            <div>
                                <span class="fc-intel-card__label">Capital Supervisory Pack</span>
                                <h2>Structured prudential capital pack assembled from the current live scenario</h2>
                            </div>
                            <div class="fc-intel-inline-chips">
                                <span class="fc-intel-chip">@_capitalPackRows.Count section(s)</span>
                                <span class="fc-intel-chip">@(_workspace.Capital.ReturnPackMaterializedAt?.ToString("dd MMM HH:mm", CultureInfo.InvariantCulture) ?? "Pending")</span>
                            </div>
                        </header>
                        @if (_capitalPackRows.Count == 0)
                        {
                            <div class="fc-intel-empty">
                                <h3>No capital supervisory pack is currently assembled</h3>
                                <p>Recalculate the capital scenario to build the prudential pack for review and export.</p>
                            </div>
                        }
                        else
                        {
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Section</th>
                                            <th>Rows</th>
                                            <th>Coverage</th>
                                            <th>Signal</th>
                                            <th>Current posture</th>
                                            <th>Next action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _capitalPackRows)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@row.SectionCode</strong>
                                                    <div class="fc-intel-table__sub">@row.SectionName</div>
                                                </td>
                                                <td>@row.RowCount</td>
                                                <td>@row.Coverage</td>
                                                <td><span class="fc-intel-status fc-intel-status--@StatusClass(row.Signal)">@row.Signal</span></td>
                                                <td class="fc-intel-table__sub">@row.Commentary</td>
                                                <td class="fc-intel-table__sub">@row.RecommendedAction</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </article>

                    <div class="fc-intel-grid fc-intel-grid--two">
                        <article class="fc-intel-card">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Capital Planning</span>
                                    <h2>4-8 quarter CAR projection</h2>
                                </div>
                                <span class="fc-intel-chip">@_projectionRows.Count quarter(s)</span>
                            </header>
                            <div class="fc-intel-form-grid">
                                <label>
                                    Current CAR %
                                    <input class="fc-input" type="number" step="0.1" @bind="_projectionInput.CurrentCarPercent" />
                                </label>
                                <label>
                                    Current RWA (bn)
                                    <input class="fc-input" type="number" step="0.1" @bind="_projectionInput.CurrentRwaBn" />
                                </label>
                                <label>
                                    RWA growth / quarter %
                                    <input class="fc-input" type="number" step="0.1" @bind="_projectionInput.QuarterlyRwaGrowthPercent" />
                                </label>
                                <label>
                                    Retained earnings / quarter (bn)
                                    <input class="fc-input" type="number" step="0.1" @bind="_projectionInput.QuarterlyRetainedEarningsBn" />
                                </label>
                                <label>
                                    Planned capital action (bn)
                                    <input class="fc-input" type="number" step="0.1" @bind="_projectionInput.CapitalActionBn" />
                                </label>
                                <label>
                                    RWA optimisation %
                                    <input class="fc-input" type="number" step="0.1" @bind="_projectionInput.RwaOptimisationPercent" />
                                </label>
                                <label>
                                    Minimum requirement %
                                    <input class="fc-input" type="number" step="0.1" @bind="_projectionInput.MinimumRequirementPercent" />
                                </label>
                                <label>
                                    Conservation buffer %
                                    <input class="fc-input" type="number" step="0.1" @bind="_projectionInput.ConservationBufferPercent" />
                                </label>
                                <label>
                                    Countercyclical buffer %
                                    <input class="fc-input" type="number" step="0.1" @bind="_projectionInput.CountercyclicalBufferPercent" />
                                </label>
                                <label>
                                    D-SIB buffer %
                                    <input class="fc-input" type="number" step="0.1" @bind="_projectionInput.DsibBufferPercent" />
                                </label>
                            </div>
                            <div class="fc-intel-inline-actions">
                                <button class="fc-btn fc-btn--primary fc-btn--sm" @onclick="RebuildProjectionAsync">Recalculate</button>
                                <span class="fc-intel-inline-note">@ProjectionHeadline</span>
                            </div>
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Quarter</th>
                                            <th>Projected CAR</th>
                                            <th>Min headroom</th>
                                            <th>Total buffer headroom</th>
                                            <th>Signal</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _projectionRows)
                                        {
                                            <tr>
                                                <td>@row.Label</td>
                                                <td>@row.ProjectedCarPercent.ToString("0.0")%</td>
                                                <td>@row.MinimumHeadroomPercent.ToString("0.0")%</td>
                                                <td>@row.BufferHeadroomPercent.ToString("0.0")%</td>
                                                <td><span class="fc-intel-status fc-intel-status--@StatusClass(row.Signal)">@row.Signal</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </article>

                        <article class="fc-intel-card fc-intel-card--table">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Buffer Management</span>
                                    <h2>Institutions trending toward intervention</h2>
                                </div>
                                <span class="fc-intel-chip">@_workspace.Capital.Watchlist.Count row(s)</span>
                            </header>
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Institution</th>
                                            <th>Capital score</th>
                                            <th>Overall</th>
                                            <th>Recommended action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _workspace.Capital.Watchlist)
                                        {
                                            <tr>
                                                <td>@row.InstitutionName</td>
                                                <td>@row.CapitalScore.ToString("0.0")</td>
                                                <td>@row.OverallScore.ToString("0.0")</td>
                                                <td class="fc-intel-table__sub">@row.Alert</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </article>
                    </div>

                    <div class="fc-intel-grid fc-intel-grid--two">
                        <article class="fc-intel-card fc-intel-card--table">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Buffer Stack</span>
                                    <h2>Layered capital thresholds and available headroom</h2>
                                </div>
                                <span class="fc-intel-chip">@_bufferRows.Count layer(s)</span>
                            </header>
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Layer</th>
                                            <th>Requirement</th>
                                            <th>Threshold</th>
                                            <th>Current headroom</th>
                                            <th>Q8 headroom</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _bufferRows)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@row.Layer</strong>
                                                    <div class="fc-intel-table__sub">@row.Commentary</div>
                                                </td>
                                                <td>@row.RequirementPercent.ToString("0.0")%</td>
                                                <td>@row.ThresholdPercent.ToString("0.0")%</td>
                                                <td>@row.CurrentHeadroomPercent.ToString("0.0")%</td>
                                                <td>@row.ProjectedHeadroomPercent.ToString("0.0")%</td>
                                                <td><span class="fc-intel-status fc-intel-status--@StatusClass(row.Signal)">@row.Signal</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </article>

                        <article class="fc-intel-card fc-intel-card--table">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">RWA Optimisation</span>
                                    <h2>Concrete RWA levers ranked by projected uplift</h2>
                                </div>
                                <span class="fc-intel-chip">@_rwaOpportunityRows.Count action(s)</span>
                            </header>
                            <div class="fc-intel-inline-actions">
                                <span class="fc-intel-inline-note">@BestRwaOpportunityHeadline</span>
                            </div>
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Action</th>
                                            <th>Mechanism</th>
                                            <th>Q8 CAR</th>
                                            <th>Worst buffer headroom</th>
                                            <th>Improvement</th>
                                            <th>Signal</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _rwaOpportunityRows)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@row.Title</strong>
                                                    <div class="fc-intel-table__sub">@row.Summary</div>
                                                </td>
                                                <td>@row.PrimaryLever</td>
                                                <td>@row.EndingCarPercent.ToString("0.0")%</td>
                                                <td>@row.WorstHeadroomPercent.ToString("0.0")%</td>
                                                <td>@row.ImprovementBps.ToString("+0;-0;0") bps</td>
                                                <td><span class="fc-intel-status fc-intel-status--@StatusClass(row.Recommendation)">@row.Recommendation</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </article>
                    </div>

                    <div class="fc-intel-grid fc-intel-grid--two">
                        <article class="fc-intel-card">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Capital Stack Optimiser</span>
                                    <h2>Lowest-cost CET1, AT1, and Tier 2 mix</h2>
                                </div>
                                <span class="fc-intel-chip">@_capitalStackRows.Count mix(es)</span>
                            </header>
                            <div class="fc-intel-form-grid">
                                <label>
                                    Target CAR %
                                    <input class="fc-input" type="number" step="0.1" @bind="_capitalStackInput.TargetCarPercent" />
                                </label>
                                <label>
                                    CET1 annual cost %
                                    <input class="fc-input" type="number" step="0.1" @bind="_capitalStackInput.Cet1CostPercent" />
                                </label>
                                <label>
                                    AT1 annual cost %
                                    <input class="fc-input" type="number" step="0.1" @bind="_capitalStackInput.At1CostPercent" />
                                </label>
                                <label>
                                    Tier 2 annual cost %
                                    <input class="fc-input" type="number" step="0.1" @bind="_capitalStackInput.Tier2CostPercent" />
                                </label>
                                <label>
                                    Max AT1 share %
                                    <input class="fc-input" type="number" step="1" @bind="_capitalStackInput.MaxAt1SharePercent" />
                                </label>
                                <label>
                                    Max Tier 2 share %
                                    <input class="fc-input" type="number" step="1" @bind="_capitalStackInput.MaxTier2SharePercent" />
                                </label>
                            </div>
                            <div class="fc-intel-inline-actions">
                                <button class="fc-btn fc-btn--primary fc-btn--sm" @onclick="RebuildProjectionAsync">Optimise Stack</button>
                                <span class="fc-intel-inline-note">@CapitalStackHeadline</span>
                            </div>
                            @if (_capitalStackRows.FirstOrDefault() is { } bestCapitalStack)
                            {
                                <div class="fc-intel-pill-grid">
                                    <article class="fc-intel-metric-tile">
                                        <span class="fc-intel-card__label">Required Capital</span>
                                        <strong>@bestCapitalStack.RequiredCapitalBn.ToString("0.0") bn</strong>
                                        <p>Incremental capital needed from the current CAR and RWA base.</p>
                                    </article>
                                    <article class="fc-intel-metric-tile">
                                        <span class="fc-intel-card__label">Weighted Cost</span>
                                        <strong>@bestCapitalStack.WeightedAverageCostPercent.ToString("0.0")%</strong>
                                        <p>Blended annual carrying cost for the recommended stack.</p>
                                    </article>
                                    <article class="fc-intel-metric-tile">
                                        <span class="fc-intel-card__label">Annual Carry</span>
                                        <strong>@bestCapitalStack.AnnualCarryingCostBn.ToString("0.0") bn</strong>
                                        <p>Estimated annual capital servicing cost for the selected mix.</p>
                                    </article>
                                    <article class="fc-intel-metric-tile">
                                        <span class="fc-intel-card__label">Target Horizon</span>
                                        <strong>@bestCapitalStack.TargetCarPercent.ToString("0.0")%</strong>
                                        <p>Optimiser target benchmark against the live capital base.</p>
                                    </article>
                                </div>
                            }
                        </article>

                        <article class="fc-intel-card fc-intel-card--table">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Ranked Capital Mixes</span>
                                    <h2>Feasible stack options inside configured instrument caps</h2>
                                </div>
                                <span class="fc-intel-chip">@_capitalStackRows.Count row(s)</span>
                            </header>
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Mix</th>
                                            <th>CET1</th>
                                            <th>AT1</th>
                                            <th>Tier 2</th>
                                            <th>Weighted cost</th>
                                            <th>Annual carry</th>
                                            <th>Signal</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _capitalStackRows)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@row.RequiredCapitalBn.ToString("0.0") bn</strong>
                                                    <div class="fc-intel-table__sub">@row.Commentary</div>
                                                </td>
                                                <td>
                                                    <strong>@row.Cet1SharePercent.ToString("0")%</strong>
                                                    <div class="fc-intel-table__sub">@row.Cet1AmountBn.ToString("0.0") bn</div>
                                                </td>
                                                <td>
                                                    <strong>@row.At1SharePercent.ToString("0")%</strong>
                                                    <div class="fc-intel-table__sub">@row.At1AmountBn.ToString("0.0") bn</div>
                                                </td>
                                                <td>
                                                    <strong>@row.Tier2SharePercent.ToString("0")%</strong>
                                                    <div class="fc-intel-table__sub">@row.Tier2AmountBn.ToString("0.0") bn</div>
                                                </td>
                                                <td>@row.WeightedAverageCostPercent.ToString("0.0")%</td>
                                                <td>@row.AnnualCarryingCostBn.ToString("0.0") bn</td>
                                                <td><span class="fc-intel-status fc-intel-status--@StatusClass(row.Recommendation)">@row.Recommendation</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </article>
                    </div>

                    <article class="fc-intel-card fc-intel-card--table">
                        <header class="fc-intel-card__header">
                            <div>
                                <span class="fc-intel-card__label">What-If Capital Actions</span>
                                <h2>Side-by-side CAR and buffer uplift comparison</h2>
                            </div>
                            <span class="fc-intel-chip">@_capitalActionRows.Count scenario(s)</span>
                        </header>
                        <div class="fc-intel-inline-actions">
                            <span class="fc-intel-inline-note">@BestCapitalActionHeadline</span>
                        </div>
                        <div class="fc-intel-table-wrap">
                            <table class="fc-intel-table">
                                <thead>
                                    <tr>
                                        <th>Action</th>
                                        <th>Primary lever</th>
                                        <th>Annual cost</th>
                                        <th>Q8 CAR</th>
                                        <th>Worst headroom</th>
                                        <th>Improvement</th>
                                        <th>Recommendation</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in _capitalActionRows)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@row.Title</strong>
                                                <div class="fc-intel-table__sub">@row.Summary</div>
                                            </td>
                                            <td>@row.PrimaryLever</td>
                                            <td>@row.EstimatedAnnualCostPercent.ToString("0.0")%</td>
                                            <td>@row.EndingCarPercent.ToString("0.0")%</td>
                                            <td>@row.WorstHeadroomPercent.ToString("0.0")%</td>
                                            <td>@row.ImprovementBps.ToString("+0;-0;0") bps</td>
                                            <td><span class="fc-intel-status fc-intel-status--@StatusClass(row.Recommendation)">@row.Recommendation</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </article>
                </section>
                break;

            case "sanctions":
                <section class="fc-intel-section">
                    <div class="fc-intel-grid fc-intel-grid--metrics">
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Source Catalog</span>
                            <strong>@_workspace.Sanctions.SourceCount</strong>
                            <p>Global and domestic watchlist streams configured in the screening surface.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Curated Entries</span>
                            <strong>@_workspace.Sanctions.EntryCount</strong>
                            <p>Baseline screening entities currently normalized for the fuzzy matcher.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">TFS-Linked Fields</span>
                            <strong>@_workspace.Sanctions.TfsLinkedFieldCount</strong>
                            <p>Fields connected to sanctions and TFS reporting semantics.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Last Sync</span>
                            <strong>@_workspace.Sanctions.LastUpdatedAt.ToString("dd MMM")</strong>
                            <p>@_workspace.Sanctions.LastUpdatedAt.ToString("HH:mm") UTC</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">False-Positive Library</span>
                            <strong>@SanctionsFalsePositiveLibraryCount</strong>
                            <p>Dismissed matches remembered in the platform workflow store and auto-suppressed here.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Decision Audit</span>
                            <strong>@SanctionsDecisionAuditCount</strong>
                            <p>Persisted review decisions across screening runs in the sanctions workflow store.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">STR Drafts</span>
                            <strong>@ReviewedStrDrafts.Count</strong>
                            <p>Auto-drafted sanctions narratives ready for compliance packaging.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Escalations Ready</span>
                            <strong>@EscalatedStrDraftCount</strong>
                            <p>Draft(s) already flagged for higher-urgency compliance review.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Pack Sections</span>
                            <strong>@_sanctionsPackRows.Count</strong>
                            <p>Structured AML / TFS sections assembled from the current screening state.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Pack Attention</span>
                            <strong>@SanctionsPackAttentionCount</strong>
                            <p>Sections currently sitting in watch or critical posture before regulatory reporting.</p>
                        </article>
                    </div>

                    <article class="fc-intel-card fc-intel-card--table">
                        <header class="fc-intel-card__header">
                            <div>
                                <span class="fc-intel-card__label">AML / TFS Supervisory Pack</span>
                                <h2>Structured sanctions, TFS, STR, and transaction-control pack from the live workflow</h2>
                            </div>
                            <span class="fc-intel-chip">@_sanctionsPackRows.Count section(s)</span>
                        </header>
                        @if (_sanctionsPackRows.Count == 0)
                        {
                            <div class="fc-intel-empty">
                                <h3>No sanctions supervisory pack is currently assembled</h3>
                                <p>Load screening evidence or run a transaction control check to assemble the AML / TFS pack.</p>
                            </div>
                        }
                        else
                        {
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Section</th>
                                            <th>Rows</th>
                                            <th>Coverage</th>
                                            <th>Signal</th>
                                            <th>Current posture</th>
                                            <th>Next action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _sanctionsPackRows)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@row.SectionCode</strong>
                                                    <div class="fc-intel-table__sub">@row.SectionName</div>
                                                </td>
                                                <td>@row.RowCount</td>
                                                <td>@row.Coverage</td>
                                                <td><span class="fc-intel-status fc-intel-status--@StatusClass(row.Signal)">@row.Signal</span></td>
                                                <td class="fc-intel-table__sub">@row.Commentary</td>
                                                <td class="fc-intel-table__sub">@row.RecommendedAction</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </article>

                    <div class="fc-intel-grid fc-intel-grid--two">
                        <article class="fc-intel-card">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Screening Engine</span>
                                    <h2>Batch-screen names and counterparties</h2>
                                </div>
                                <span class="fc-intel-chip">@Math.Round(_screeningThreshold * 100d)% threshold</span>
                            </header>
                            <label class="fc-intel-stack">
                                <span>Subjects to screen</span>
                                <textarea class="fc-input fc-intel-textarea"
                                          @bind="_screeningInput"
                                          placeholder="Enter one name or counterparty per line."></textarea>
                            </label>
                            <label class="fc-intel-stack">
                                <span>Matching threshold: @Math.Round(_screeningThreshold * 100d)%</span>
                                <input type="range" min="70" max="95" step="1" value="@(_screeningThreshold * 100d)" @oninput="OnThresholdChanged" />
                            </label>
                            <div class="fc-intel-inline-actions">
                                <button class="fc-btn fc-btn--primary fc-btn--sm" @onclick="RunScreeningAsync">Run Screening</button>
                                <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="UseSampleScreeningData">Load Sample Subjects</button>
                            </div>
                            @if (_screeningRun is not null)
                            {
                                <div class="fc-intel-banner">
                                    <strong>@_screeningRun.MatchCount / @_screeningRun.TotalSubjects</strong>
                                    <span>
                                        subjects triggered a true or potential match at @_screeningRun.ThresholdPercent.ToString("0")% confidence.
                                        @if (SuppressedFalsePositiveCount > 0)
                                        {
                                            <span>@SuppressedFalsePositiveCount known false-positive match(es) were auto-suppressed.</span>
                                        }
                                    </span>
                                </div>
                            }
                        </article>

                        <article class="fc-intel-card fc-intel-card--table">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Source Coverage</span>
                                    <h2>Watchlist feed catalog</h2>
                                </div>
                                <span class="fc-intel-chip">@_workspace.Sanctions.Sources.Count source(s)</span>
                            </header>
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Code</th>
                                            <th>Source</th>
                                            <th>Entries</th>
                                            <th>Refresh</th>
                                            <th>Synced</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var source in _workspace.Sanctions.Sources)
                                        {
                                            <tr>
                                                <td>@source.Code</td>
                                                <td>@source.Name</td>
                                                <td>@source.EntryCount</td>
                                                <td>@source.RefreshCadence</td>
                                                <td>@(source.LastSyncedAt?.ToString("dd MMM HH:mm", CultureInfo.InvariantCulture) ?? "Pending")</td>
                                                <td><span class="fc-intel-status fc-intel-status--success">@source.Status</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </article>
                    </div>

                    <div class="fc-intel-grid fc-intel-grid--two">
                        <article class="fc-intel-card">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Transaction Screening</span>
                                    <h2>Real-time counterparty and payment-path check</h2>
                                </div>
                                <span class="fc-intel-chip">@(_transactionScreeningInput.HighRisk ? "high-risk mode" : "standard mode")</span>
                            </header>
                            <div class="fc-intel-form-grid">
                                <label>
                                    Transaction reference
                                    <input class="fc-input" @bind="_transactionScreeningInput.TransactionReference" />
                                </label>
                                <label>
                                    Amount
                                    <input class="fc-input" type="number" step="0.01" @bind="_transactionScreeningInput.Amount" />
                                </label>
                                <label>
                                    Currency
                                    <input class="fc-input" @bind="_transactionScreeningInput.Currency" />
                                </label>
                                <label>
                                    Channel
                                    <input class="fc-input" @bind="_transactionScreeningInput.Channel" />
                                </label>
                                <label>
                                    Originator
                                    <input class="fc-input" @bind="_transactionScreeningInput.OriginatorName" />
                                </label>
                                <label>
                                    Beneficiary
                                    <input class="fc-input" @bind="_transactionScreeningInput.BeneficiaryName" />
                                </label>
                                <label style="grid-column: 1 / -1;">
                                    Counterparty
                                    <input class="fc-input" @bind="_transactionScreeningInput.CounterpartyName" />
                                </label>
                            </div>
                            <div class="fc-intel-stack">
                                <span>Risk posture</span>
                                <label class="fc-intel-inline-note">
                                    <input type="checkbox" @bind="_transactionScreeningInput.HighRisk" />
                                    Treat this transaction as high risk and lower the real-time screening threshold.
                                </label>
                            </div>
                            <div class="fc-intel-inline-actions">
                                <button class="fc-btn fc-btn--primary fc-btn--sm" @onclick="RunTransactionScreeningAsync">Run Transaction Check</button>
                                <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="UseSampleTransactionData">Load Sample Transaction</button>
                            </div>
                        </article>

                        <article class="fc-intel-card fc-intel-card--table">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Transaction Decision</span>
                                    <h2>@(_transactionScreeningResult?.TransactionReference ?? "Awaiting transaction screening")</h2>
                                </div>
                                @if (_transactionScreeningResult is not null)
                                {
                                    <span class="fc-intel-chip">@_transactionScreeningResult.ThresholdPercent.ToString("0")% threshold</span>
                                }
                            </header>
                            @if (_transactionScreeningResult is null)
                            {
                                <div class="fc-intel-empty">
                                    <h3>No transaction decision yet</h3>
                                    <p>Run the real-time transaction check to see a payment control decision and screened party results.</p>
                                </div>
                            }
                            else
                            {
                                <div class="fc-intel-banner">
                                    <strong>@_transactionScreeningResult.ControlDecision</strong>
                                    <span>@_transactionScreeningResult.Narrative</span>
                                </div>
                                <div class="fc-intel-inline-chips">
                                    <span class="fc-intel-chip">@_transactionScreeningResult.Amount.ToString("N2", CultureInfo.InvariantCulture) @_transactionScreeningResult.Currency</span>
                                    <span class="fc-intel-chip">@_transactionScreeningResult.Channel</span>
                                    <span class="fc-intel-chip">@(_transactionScreeningResult.HighRisk ? "high-risk routing" : "standard routing")</span>
                                    @if (_transactionScreeningResult.RequiresStrDraft)
                                    {
                                        <span class="fc-intel-chip">STR escalation indicated</span>
                                    }
                                </div>
                                <div class="fc-intel-table-wrap">
                                    <table class="fc-intel-table">
                                        <thead>
                                            <tr>
                                                <th>Role</th>
                                                <th>Party</th>
                                                <th>Disposition</th>
                                                <th>Score</th>
                                                <th>Matched name</th>
                                                <th>Source</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in _transactionScreeningResult.PartyResults)
                                            {
                                                <tr>
                                                    <td>@row.PartyRole</td>
                                                    <td>@row.PartyName</td>
                                                    <td>
                                                        <span class="fc-intel-status fc-intel-status--@DispositionClass(row.Disposition)">@row.Disposition</span>
                                                        <div class="fc-intel-table__sub">@row.RiskLevel risk</div>
                                                    </td>
                                                    <td>@row.MatchScore.ToString("0.0")%</td>
                                                    <td>@row.MatchedName</td>
                                                    <td>@row.SourceCode</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </article>
                    </div>

                    <article class="fc-intel-card fc-intel-card--table">
                        <header class="fc-intel-card__header">
                            <div>
                                <span class="fc-intel-card__label">Alert Management</span>
                                <h2>Screening outcome ledger</h2>
                            </div>
                            <span class="fc-intel-chip">@(_screeningRun?.Results.Count ?? 0) result(s)</span>
                        </header>
                        @if (_screeningRun is null)
                        {
                            <div class="fc-intel-empty">
                                <h3>No screening run yet</h3>
                                <p>Run the engine to review true matches, potential matches, and cleared subjects.</p>
                            </div>
                        }
                        else
                        {
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Subject</th>
                                            <th>Disposition</th>
                                            <th>Review</th>
                                            <th>Score</th>
                                            <th>Matched name</th>
                                            <th>Source</th>
                                            <th>Risk</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _screeningRun.Results)
                                        {
                                            <tr>
                                                <td>@row.Subject</td>
                                                <td><span class="fc-intel-status fc-intel-status--@DispositionClass(row.Disposition)">@row.Disposition</span></td>
                                                <td>
                                                    <select class="fc-input fc-intel-select"
                                                            value="@GetScreeningDecision(row.Subject)"
                                                            @onchange="args => UpdateScreeningDecisionAsync(row, args)">
                                                        <option value="Clear">Clear</option>
                                                        <option value="Review">Review</option>
                                                        <option value="Confirm Match">Confirm Match</option>
                                                        <option value="False Positive">False Positive</option>
                                                        <option value="Escalate">Escalate</option>
                                                    </select>
                                                </td>
                                                <td>@row.MatchScore.ToString("0.0")%</td>
                                                <td>@row.MatchedName</td>
                                                <td>@row.SourceCode</td>
                                                <td><span class="fc-intel-risk fc-intel-risk--@row.RiskLevel">@row.RiskLevel</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </article>

                    @if (_screeningRun is not null)
                    {
                        <div class="fc-intel-grid fc-intel-grid--two">
                            <article class="fc-intel-card">
                                <header class="fc-intel-card__header">
                                    <div>
                                        <span class="fc-intel-card__label">TFS Return Preview</span>
                                        <h2>NFIU_TFS screening metrics</h2>
                                    </div>
                                    <span class="fc-intel-chip">@ReviewedTfsPreview.MatchesFound flagged</span>
                                </header>
                                <div class="fc-intel-pill-grid">
                                    <article class="fc-intel-metric-tile">
                                        <span class="fc-intel-card__label">Screened</span>
                                        <strong>@ReviewedTfsPreview.ScreeningCount</strong>
                                        <p>Total customers and counterparties screened.</p>
                                    </article>
                                    <article class="fc-intel-metric-tile">
                                        <span class="fc-intel-card__label">Confirmed</span>
                                        <strong>@ReviewedTfsPreview.ConfirmedMatches</strong>
                                        <p>Analyst-confirmed sanctions hits.</p>
                                    </article>
                                    <article class="fc-intel-metric-tile">
                                        <span class="fc-intel-card__label">False Positives</span>
                                        <strong>@ReviewedTfsPreview.FalsePositiveCount</strong>
                                        <p>@ReviewedTfsPreview.FalsePositiveRatePercent.ToString("0.0")% of reviewed matches.</p>
                                    </article>
                                    <article class="fc-intel-metric-tile">
                                        <span class="fc-intel-card__label">Assets Frozen</span>
                                        <strong>@ReviewedTfsPreview.AssetsFrozenCount</strong>
                                        <p>Critical/high-risk confirmed matches requiring immediate control action.</p>
                                    </article>
                                </div>
                                <p class="fc-intel-card__lede">@ReviewedTfsPreview.Narrative</p>
                                <div class="fc-intel-inline-chips">
                                    @foreach (var source in ReviewedTfsPreview.WatchlistSources)
                                    {
                                        <span class="fc-intel-chip">@source</span>
                                    }
                                </div>
                            </article>

                            <article class="fc-intel-card">
                                <header class="fc-intel-card__header">
                                    <div>
                                        <span class="fc-intel-card__label">STR Draft Readiness</span>
                                        <h2>goAML escalation signal</h2>
                                    </div>
                                    <span class="fc-intel-chip">RG-34</span>
                                </header>
                                @if (ReviewedTfsPreview.StrDraftRequired)
                                {
                                    <div class="fc-intel-banner">
                                        <strong>STR draft recommended</strong>
                                        <span>Confirmed sanctions hits should be packaged for compliance review and goAML escalation.</span>
                                    </div>
                                    <p class="fc-intel-card__lede">
                                        Draft narrative: Screening detected @ReviewedTfsPreview.ConfirmedMatches confirmed match(es)
                                        across @ReviewedTfsPreview.WatchlistSources.Count watchlist source(s). Recommended actions:
                                        freeze impacted assets, document the investigation trail, and prepare STR submission.
                                    </p>
                                }
                                else
                                {
                                    <div class="fc-intel-empty">
                                        <h3>No STR draft required</h3>
                                        <p>Confirmed sanctions hits have not crossed the escalation threshold in this screening run.</p>
                                    </div>
                                }
                            </article>
                        </div>

                        <div class="fc-intel-grid fc-intel-grid--two">
                            <article class="fc-intel-card fc-intel-card--feature fc-intel-card--brief">
                                <header class="fc-intel-card__header">
                                    <div>
                                        <span class="fc-intel-card__label">STR Draft Centre</span>
                                        <h2>@(SelectedStrDraft?.Subject ?? "No active STR draft")</h2>
                                    </div>
                                    <span class="fc-intel-chip">RG-34 / goAML</span>
                                </header>
                                @if (SelectedStrDraft is null)
                                {
                                    <div class="fc-intel-empty">
                                        <h3>No draft packets are currently open</h3>
                                        <p>Confirm or escalate a screening hit to auto-draft an STR review packet.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="fc-intel-inline-chips">
                                        <span class="fc-intel-chip">@SelectedStrDraft.DraftId</span>
                                        <span class="fc-intel-chip">@SelectedStrDraft.SourceCode</span>
                                        <span class="fc-intel-chip">@SelectedStrDraft.ReviewDueAtUtc.ToString("dd MMM HH:mm", CultureInfo.InvariantCulture) UTC due</span>
                                        <span class="fc-intel-status fc-intel-status--@StatusClass(SelectedStrDraft.Priority)">@SelectedStrDraft.Priority</span>
                                        <span class="fc-intel-status fc-intel-status--@StatusClass(SelectedStrDraft.Status)">@SelectedStrDraft.Status</span>
                                    </div>
                                    <p class="fc-intel-card__lede">@SelectedStrDraft.Narrative</p>
                                    <div class="fc-intel-pill-grid">
                                        <article class="fc-intel-metric-tile">
                                            <span class="fc-intel-card__label">Confidence</span>
                                            <strong>@SelectedStrDraft.ScorePercent.ToString("0.0")%</strong>
                                            <p>@SelectedStrDraft.MatchedName</p>
                                        </article>
                                        <article class="fc-intel-metric-tile">
                                            <span class="fc-intel-card__label">Freeze Control</span>
                                            <strong>@(SelectedStrDraft.FreezeRecommended ? "Required" : "Review")</strong>
                                            <p>@(SelectedStrDraft.FreezeRecommended ? "Immediate control action should be documented." : "Document rationale before final escalation.")</p>
                                        </article>
                                        <article class="fc-intel-metric-tile">
                                            <span class="fc-intel-card__label">Screened</span>
                                            <strong>@SelectedStrDraft.ScreenedAtUtc.ToString("dd MMM", CultureInfo.InvariantCulture)</strong>
                                            <p>@SelectedStrDraft.ScreenedAtUtc.ToString("HH:mm") UTC</p>
                                        </article>
                                    </div>
                                    <div class="fc-intel-stack">
                                        <span>Suspicion basis</span>
                                        <p class="fc-intel-card__lede">@SelectedStrDraft.SuspicionBasis</p>
                                    </div>
                                    <div class="fc-intel-stack">
                                        <span>goAML package</span>
                                        <p class="fc-intel-card__lede">@SelectedStrDraft.GoAmlPayloadSummary</p>
                                    </div>
                                    <div class="fc-intel-inline-chips">
                                        @foreach (var action in SelectedStrDraft.RecommendedActions)
                                        {
                                            <span class="fc-intel-chip">@action</span>
                                        }
                                    </div>
                                }
                            </article>

                            <article class="fc-intel-card fc-intel-card--table">
                                <header class="fc-intel-card__header">
                                    <div>
                                        <span class="fc-intel-card__label">STR Draft Queue</span>
                                        <h2>Confirmed and escalated sanctions cases</h2>
                                    </div>
                                    <span class="fc-intel-chip">@ReviewedStrDrafts.Count row(s)</span>
                                </header>
                                @if (ReviewedStrDrafts.Count == 0)
                                {
                                    <div class="fc-intel-empty">
                                        <h3>No sanctions drafts yet</h3>
                                        <p>Once a match is confirmed or escalated, the review packet will appear here automatically.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="fc-intel-table-wrap">
                                        <table class="fc-intel-table">
                                            <thead>
                                                <tr>
                                                    <th>Draft</th>
                                                    <th>Source</th>
                                                    <th>Risk</th>
                                                    <th>Status</th>
                                                    <th>Due</th>
                                                    <th>Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var row in ReviewedStrDrafts)
                                                {
                                                    <tr>
                                                        <td>
                                                            <strong>@row.Subject</strong>
                                                            <div class="fc-intel-table__sub">@row.DraftId</div>
                                                        </td>
                                                        <td>
                                                            <strong>@row.SourceCode</strong>
                                                            <div class="fc-intel-table__sub">@row.MatchedName</div>
                                                        </td>
                                                        <td><span class="fc-intel-risk fc-intel-risk--@row.RiskLevel">@row.RiskLevel</span></td>
                                                        <td>
                                                            <span class="fc-intel-status fc-intel-status--@StatusClass(row.Status)">@row.Status</span>
                                                            <div class="fc-intel-table__sub">@row.Priority priority</div>
                                                        </td>
                                                        <td>@row.ReviewDueAtUtc.ToString("dd MMM yyyy HH:mm", CultureInfo.InvariantCulture)</td>
                                                        <td>
                                                            <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="@(() => SelectStrDraft(row.DraftId))">Inspect</button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </article>
                        </div>
                    }

                    <div class="fc-intel-grid fc-intel-grid--two">
                        <article class="fc-intel-card fc-intel-card--table">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">False-Positive Library</span>
                                    <h2>Dismissed matches remembered for future screening runs</h2>
                                </div>
                                <span class="fc-intel-chip">@SanctionsFalsePositiveLibraryCount row(s)</span>
                            </header>
                            @if (SanctionsFalsePositiveLibraryCount == 0)
                            {
                                <div class="fc-intel-empty">
                                    <h3>No false positives saved yet</h3>
                                    <p>Mark a reviewed screening result as `False Positive` to add it to the platform library.</p>
                                </div>
                            }
                            else
                            {
                                <div class="fc-intel-table-wrap">
                                    <table class="fc-intel-table">
                                        <thead>
                                            <tr>
                                                <th>Subject</th>
                                                <th>Matched name</th>
                                                <th>Source</th>
                                                <th>Risk</th>
                                                <th>Reviewed</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in _falsePositiveLibrary.OrderByDescending(x => x.ReviewedAtUtc).Take(12))
                                            {
                                                <tr>
                                                    <td>@row.Subject</td>
                                                    <td>@row.MatchedName</td>
                                                    <td>@row.SourceCode</td>
                                                    <td><span class="fc-intel-risk fc-intel-risk--@row.RiskLevel">@row.RiskLevel</span></td>
                                                    <td>@FormatTimestamp(row.ReviewedAtUtc)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </article>

                        <article class="fc-intel-card fc-intel-card--table">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Decision Audit Trail</span>
                                    <h2>Review history across sanctions screening runs</h2>
                                </div>
                                <span class="fc-intel-chip">@SanctionsDecisionAuditCount row(s)</span>
                            </header>
                            @if (SanctionsDecisionAuditCount == 0)
                            {
                                <div class="fc-intel-empty">
                                    <h3>No audit entries yet</h3>
                                    <p>Every review decision will be stamped with subject, source, previous state, and timestamp.</p>
                                </div>
                            }
                            else
                            {
                                <div class="fc-intel-table-wrap">
                                    <table class="fc-intel-table">
                                        <thead>
                                            <tr>
                                                <th>Time</th>
                                                <th>Subject</th>
                                                <th>Source</th>
                                                <th>Previous</th>
                                                <th>Decision</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in _screeningAuditTrail.OrderByDescending(x => x.ReviewedAtUtc).Take(12))
                                            {
                                                <tr>
                                                    <td>@FormatTimestamp(row.ReviewedAtUtc)</td>
                                                    <td>
                                                        <strong>@row.Subject</strong>
                                                        <div class="fc-intel-table__sub">@row.MatchedName</div>
                                                    </td>
                                                    <td>@row.SourceCode</td>
                                                    <td><span class="fc-intel-status fc-intel-status--@StatusClass(row.PreviousDecision)">@row.PreviousDecision</span></td>
                                                    <td><span class="fc-intel-status fc-intel-status--@StatusClass(row.Decision)">@row.Decision</span></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </article>
                    </div>
                </section>
                break;

            case "resilience":
                <section class="fc-intel-section">
                    <div class="fc-intel-grid fc-intel-grid--metrics">
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Critical Assets</span>
                            <strong>@_workspace.Resilience.CriticalAssetCount</strong>
                            <p>Assets marked high or critical in the cyber asset registry.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Dependency Edges</span>
                            <strong>@_workspace.Resilience.DependencyEdgeCount</strong>
                            <p>Documented inter-asset relationships available for concentration analysis.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Open Incidents</span>
                            <strong>@_workspace.Resilience.OpenIncidentCount</strong>
                            <p>Resilience incidents currently not remediated.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">RCA Coverage</span>
                            <strong>@_workspace.Resilience.RcaCoveragePercent.ToString("0.0")%</strong>
                            <p>Incident coverage with cached root-cause analysis artifacts.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Gap Score</span>
                            <strong>@_workspace.Resilience.GapScore.ToString("0.0")</strong>
                            <p>Derived resilience posture score across mapping, testing, response, and oversight.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">OPS_RESILIENCE Sheets</span>
                            <strong>@_workspace.Resilience.ReturnPack.Count</strong>
                            <p>Structured operational-resilience return sheets currently materialized in the pack.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Pack Materialized</span>
                            <strong>@(_workspace.Resilience.ReturnPackMaterializedAt?.ToString("dd MMM") ?? "Pending")</strong>
                            <p>@(_workspace.Resilience.ReturnPackMaterializedAt?.ToString("HH:mm 'UTC'", CultureInfo.InvariantCulture) ?? "The OPS_RESILIENCE pack has not been written yet.")</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Pack Attention</span>
                            <strong>@_workspace.Resilience.ReturnPackAttentionCount</strong>
                            <p>Sheet rows currently in watch or critical posture before formal filing.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Cyber Score</span>
                            <strong>@_workspace.Resilience.CyberAssessmentScore.ToString("0.0")</strong>
                            <p>Derived cyber resilience posture across asset coverage, detection, recovery, and incident discipline.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Cyber Critical Domains</span>
                            <strong>@_workspace.Resilience.CyberAssessmentCriticalCount</strong>
                            <p>Cyber control domains currently sitting in critical supervisory posture.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Board Actions</span>
                            <strong>@_workspace.Resilience.ActionTracker.Count(x => x.Status != "Complete")</strong>
                            <p>Outstanding resilience actions surfaced for board and risk oversight.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Testing Schedule</span>
                            <strong>@_workspace.Resilience.TestingSchedule.Count</strong>
                            <p>Scenario-based resilience tests with status and outcome tracking.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Important Services</span>
                            <strong>@_workspace.Resilience.ImportantServiceCount</strong>
                            <p>Derived important business services currently mapped from critical assets and dependencies.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Tolerance Watch</span>
                            <strong>@_workspace.Resilience.ImpactToleranceWatchCount</strong>
                            <p>Service tolerances currently in watch or critical posture.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Third-Party Providers</span>
                            <strong>@_workspace.Resilience.ThirdPartyProviderCount</strong>
                            <p>Derived ICT providers currently represented in the resilience dependency map.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Concentration Watch</span>
                            <strong>@_workspace.Resilience.ThirdPartyConcentrationCount</strong>
                            <p>Providers currently in watch or critical concentration posture.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">BCP Watch</span>
                            <strong>@_workspace.Resilience.BusinessContinuityRiskCount</strong>
                            <p>Important services with continuity plans currently in watch or critical status.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Recovery Watch</span>
                            <strong>@_workspace.Resilience.RecoveryTimeWatchCount</strong>
                            <p>Services whose recovery evidence is near or above declared recovery targets.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Recovery Breaches</span>
                            <strong>@_workspace.Resilience.RecoveryTimeBreachCount</strong>
                            <p>Services with material recovery-time breaches requiring immediate challenge.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Change Controls</span>
                            <strong>@_workspace.Resilience.ChangeControlReviewCount</strong>
                            <p>Operational change-control areas currently requiring review attention.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Self-Assessment</span>
                            <strong>@(ResilienceAssessmentScorePercent?.ToString("0.0", CultureInfo.InvariantCulture) ?? "Pending")</strong>
                            <p>Questionnaire-derived resilience score based on curated control prompts.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Assessment Coverage</span>
                            <strong>@ResilienceAssessmentCoveragePercent.ToString("0.0", CultureInfo.InvariantCulture)%</strong>
                            <p>Completed answers across the resilience self-assessment set.</p>
                        </article>
                        <article class="fc-intel-card">
                            <span class="fc-intel-card__label">Blended Posture</span>
                            <strong>@ResilienceBlendedScore.ToString("0.0", CultureInfo.InvariantCulture)</strong>
                            <p>Combined view of derived telemetry and self-assessed control maturity.</p>
                        </article>
                    </div>

                    <div class="fc-intel-grid fc-intel-grid--two">
                        <article class="fc-intel-card fc-intel-card--table">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Self-Assessment Questionnaire</span>
                                    <h2>Control maturity by resilience domain</h2>
                                </div>
                                <div class="fc-intel-inline-chips">
                                    <span class="fc-intel-chip">@AnsweredResilienceQuestionCount / @ResilienceAssessmentQuestions.Count answered</span>
                                    @if (_workspace.Resilience.LastAssessmentUpdatedAt.HasValue)
                                    {
                                        <span class="fc-intel-chip">Saved @FormatTimestamp(_workspace.Resilience.LastAssessmentUpdatedAt.Value)</span>
                                    }
                                    <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="ResetResilienceAssessmentAsync">Clear</button>
                                </div>
                            </header>
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Domain</th>
                                            <th>Prompt</th>
                                            <th>Maturity</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var question in ResilienceAssessmentQuestions)
                                        {
                                            <tr>
                                                <td>@question.Domain</td>
                                                <td class="fc-intel-table__sub">@question.Prompt</td>
                                                <td>
                                                    <select class="fc-input fc-intel-select"
                                                            value="@GetResilienceAssessmentValue(question.Id).ToString(CultureInfo.InvariantCulture)"
                                                            @onchange="args => UpdateResilienceAssessmentAsync(question.Id, args)">
                                                        <option value="0">Not assessed</option>
                                                        <option value="1">1 · Absent</option>
                                                        <option value="2">2 · Ad hoc</option>
                                                        <option value="3">3 · Developing</option>
                                                        <option value="4">4 · Established</option>
                                                        <option value="5">5 · Embedded</option>
                                                    </select>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </article>

                        <article class="fc-intel-card fc-intel-card--table">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Assessment Summary</span>
                                    <h2>Self-assessment versus derived resilience posture</h2>
                                </div>
                                <span class="fc-intel-chip">@ResilienceAssessmentDomainRows.Count row(s)</span>
                            </header>
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Domain</th>
                                            <th>Self score</th>
                                            <th>Derived score</th>
                                            <th>Delta</th>
                                            <th>Signal</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in ResilienceAssessmentDomainRows)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@row.Domain</strong>
                                                    <div class="fc-intel-table__sub">@row.Commentary</div>
                                                </td>
                                                <td>@(row.AssessmentScore?.ToString("0.0", CultureInfo.InvariantCulture) ?? "Pending")</td>
                                                <td>@row.DerivedScore.ToString("0.0", CultureInfo.InvariantCulture)</td>
                                                <td>@row.DeltaText</td>
                                                <td>
                                                    <span class="fc-intel-status fc-intel-status--@StatusClass(row.Signal)">@row.Signal</span>
                                                    <div class="fc-intel-table__sub">@row.NextAction</div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </article>
                    </div>

                    <div class="fc-intel-grid fc-intel-grid--two">
                        <article class="fc-intel-card fc-intel-card--feature fc-intel-card--brief">
                            <span class="fc-intel-card__label">Board Oversight</span>
                            <h2>@_workspace.Resilience.BoardSummary.GapScore.ToString("0.0") resilience gap score</h2>
                            <p>@_workspace.Resilience.BoardSummary.Narrative</p>
                            <div class="fc-intel-inline-chips">
                                <span class="fc-intel-chip">@_workspace.Resilience.BoardSummary.CriticalIssues critical issue(s)</span>
                                <span class="fc-intel-chip">@_workspace.Resilience.BoardSummary.OverdueActions overdue action(s)</span>
                                <span class="fc-intel-chip">@_workspace.Resilience.BoardSummary.DueTests due test(s)</span>
                            </div>
                        </article>

                        <article class="fc-intel-card fc-intel-card--table">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Gap Analysis</span>
                                    <h2>Operational resilience control posture</h2>
                                </div>
                                <span class="fc-intel-chip">@_workspace.Resilience.GapAnalysis.Count row(s)</span>
                            </header>
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Domain</th>
                                            <th>Score</th>
                                            <th>Signal</th>
                                            <th>Current posture</th>
                                            <th>Next action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _workspace.Resilience.GapAnalysis)
                                        {
                                            <tr>
                                                <td>@row.Domain</td>
                                                <td>@row.Score.ToString("0.0")</td>
                                                <td><span class="fc-intel-status fc-intel-status--@StatusClass(row.Signal)">@row.Signal</span></td>
                                                <td class="fc-intel-table__sub">@row.Commentary</td>
                                                <td class="fc-intel-table__sub">@row.NextAction</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </article>
                    </div>

                    <article class="fc-intel-card fc-intel-card--table">
                        <header class="fc-intel-card__header">
                            <div>
                                <span class="fc-intel-card__label">OPS_RESILIENCE Return Pack</span>
                                <h2>Ten-sheet operational resilience module assembled from live platform evidence</h2>
                            </div>
                            <div class="fc-intel-inline-chips">
                                <span class="fc-intel-chip">@_workspace.Resilience.ReturnPack.Count sheet(s)</span>
                                <span class="fc-intel-chip">@(_workspace.Resilience.ReturnPackMaterializedAt?.ToString("dd MMM HH:mm", CultureInfo.InvariantCulture) ?? "Pending")</span>
                            </div>
                        </header>
                        @if (_workspace.Resilience.ReturnPack.Count == 0)
                        {
                            <div class="fc-intel-empty">
                                <h3>No operational resilience return pack is currently assembled</h3>
                                <p>As resilience evidence matures, the structured `OPS_RESILIENCE` sheet pack will appear here for filing readiness review.</p>
                            </div>
                        }
                        else
                        {
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Sheet</th>
                                            <th>Rows</th>
                                            <th>Coverage</th>
                                            <th>Signal</th>
                                            <th>Current posture</th>
                                            <th>Next action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _workspace.Resilience.ReturnPack)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@row.SheetCode</strong>
                                                    <div class="fc-intel-table__sub">@row.SheetName</div>
                                                </td>
                                                <td>@row.RowCount</td>
                                                <td class="fc-intel-table__sub">@row.Coverage</td>
                                                <td>
                                                    <span class="fc-intel-status fc-intel-status--@StatusClass(row.Signal)">@row.Signal</span>
                                                </td>
                                                <td class="fc-intel-table__sub">@row.Commentary</td>
                                                <td class="fc-intel-table__sub">@row.RecommendedAction</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </article>

                    <article class="fc-intel-card fc-intel-card--table">
                        <header class="fc-intel-card__header">
                            <div>
                                <span class="fc-intel-card__label">Cyber Resilience Assessment</span>
                                <h2>Cyber control posture across assets, monitoring, recovery, and response</h2>
                            </div>
                            <span class="fc-intel-chip">@_workspace.Resilience.CyberAssessment.Count row(s)</span>
                        </header>
                        @if (_workspace.Resilience.CyberAssessment.Count == 0)
                        {
                            <div class="fc-intel-empty">
                                <h3>No cyber resilience assessment rows are currently derived</h3>
                                <p>Populate cyber assets, alert telemetry, and resilience testing evidence to produce domain-level cyber posture.</p>
                            </div>
                        }
                        else
                        {
                            <div class="fc-intel-table-wrap">
                                <table class="fc-intel-table">
                                    <thead>
                                        <tr>
                                            <th>Domain</th>
                                            <th>Score</th>
                                            <th>Signal</th>
                                            <th>Lead indicator</th>
                                            <th>Current posture</th>
                                            <th>Next action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _workspace.Resilience.CyberAssessment)
                                        {
                                            <tr>
                                                <td>@row.Domain</td>
                                                <td>@row.Score.ToString("0.0", CultureInfo.InvariantCulture)</td>
                                                <td>
                                                    <span class="fc-intel-status fc-intel-status--@StatusClass(row.Signal)">@row.Signal</span>
                                                </td>
                                                <td>
                                                    <strong>@row.EvidenceCount</strong>
                                                    <div class="fc-intel-table__sub">@row.LeadIndicator</div>
                                                </td>
                                                <td class="fc-intel-table__sub">@row.Commentary</td>
                                                <td class="fc-intel-table__sub">@row.RecommendedAction</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </article>

                    <div class="fc-intel-grid fc-intel-grid--two">
                        <article class="fc-intel-card fc-intel-card--table">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Important Business Services</span>
                                    <h2>Critical-service inventory derived from live operational assets</h2>
                                </div>
                                <span class="fc-intel-chip">@_workspace.Resilience.BusinessServices.Count row(s)</span>
                            </header>
                            @if (_workspace.Resilience.BusinessServices.Count == 0)
                            {
                                <div class="fc-intel-empty">
                                    <h3>No important services are currently derived</h3>
                                    <p>Tag critical assets and dependencies to surface important business services in the resilience inventory.</p>
                                </div>
                            }
                            else
                            {
                                <div class="fc-intel-table-wrap">
                                    <table class="fc-intel-table">
                                        <thead>
                                            <tr>
                                                <th>Service</th>
                                                <th>Owner</th>
                                                <th>Criticality</th>
                                                <th>Dependencies</th>
                                                <th>Tolerance</th>
                                                <th>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in _workspace.Resilience.BusinessServices)
                                            {
                                                <tr>
                                                    <td>
                                                        <strong>@row.ServiceName</strong>
                                                        <div class="fc-intel-table__sub">@row.SupportingAsset · @row.AssetType</div>
                                                    </td>
                                                    <td>@row.ServiceOwner</td>
                                                    <td><span class="fc-intel-risk fc-intel-risk--@row.Criticality.ToLowerInvariant()">@row.Criticality</span></td>
                                                    <td>
                                                        <strong>@row.DependencyCount</strong>
                                                        <div class="fc-intel-table__sub">@row.EventSignalCount signal(s)</div>
                                                    </td>
                                                    <td>
                                                        <strong>@row.MaximumDisruptionMinutes mins</strong>
                                                        <div class="fc-intel-table__sub">RTO @row.RecoveryTargetMinutes mins</div>
                                                    </td>
                                                    <td>
                                                        <span class="fc-intel-status fc-intel-status--@StatusClass(row.Status)">@row.Status</span>
                                                        <div class="fc-intel-table__sub">@row.LatestTestOutcome</div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </article>

                        <article class="fc-intel-card fc-intel-card--table">
                            <header class="fc-intel-card__header">
                                <div>
                                    <span class="fc-intel-card__label">Impact Tolerance Register</span>
                                    <h2>Maximum acceptable disruption and recovery targets</h2>
                                </div>
                                <span class="fc-intel-chip">@_workspace.Resilience.ImpactTolerances.Count row(s)</span>
                            </header>
                            @if (_workspace.Resilience.ImpactTolerances.Count == 0)
                            {
                                <div class="fc-intel-empty">
                                    <h3>No tolerance thresholds are currently derived</h3>
                                    <p>Resilience tolerances will appear here as critical services and test evidence are catalogued.</p>
                                </div>
                            }
                            else
                            {
                                <div class="fc-intel-table-wrap">
                                    <table class="fc-intel-table">
                                        <thead>
                                            <tr>
                                                <th>Service</th>
                                                <th>Max disruption</th>
                                                <th>Recovery target</th>
                                                <th>Dependencies</th>
                                                <th>Latest test</th>
                                                <th>Signal</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in _workspace.Resilience.ImpactTolerances)
