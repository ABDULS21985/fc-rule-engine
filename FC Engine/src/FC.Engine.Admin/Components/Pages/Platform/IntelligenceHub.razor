        {
            if (_workspace is null || _stakeholderLens == "executive")
            {
                return [];
            }

            return _workspace.InstitutionScorecards
                .GroupBy(x => x.LicenceType, StringComparer.OrdinalIgnoreCase)
                .Select(group =>
                {
                    var priorityInstitutions = group.Count(x => x.Priority is "Critical" or "High");
                    var overdue = group.Sum(x => x.OverdueObligations);
                    var dueSoon = group.Sum(x => x.DueSoonObligations);
                    var capitalWatchlist = group.Count(x => x.CapitalScore is not null && x.CapitalScore < 60m);
                    var incidents = group.Sum(x => x.OpenResilienceIncidents);
                    var modelReviews = group.Sum(x => x.ModelReviewItems);

                    var signal = priorityInstitutions > 0 || overdue > 0
                        ? "Critical"
                        : dueSoon > 0 || capitalWatchlist > 0 || incidents > 0 || modelReviews > 0
                            ? "Watch"
                            : "Current";

                    return new DashboardPortfolioConcentrationRow(
                        group.Key,
                        group.Count(),
                        priorityInstitutions,
                        overdue,
                        dueSoon,
                        capitalWatchlist,
                        incidents,
                        modelReviews,
                        signal,
                        $"{group.Key} carries {priorityInstitutions} high-pressure institution(s), {capitalWatchlist} capital watchlist case(s), and {modelReviews} model review item(s).");
                })
                .OrderByDescending(x => DashboardPriorityRank(x.Signal))
                .ThenByDescending(x => x.PriorityInstitutionCount)
                .ThenByDescending(x => x.OverdueObligations + x.DueSoonObligations + x.OpenResilienceIncidents + x.ModelReviewItems)
                .ThenBy(x => x.LicenceType, StringComparer.OrdinalIgnoreCase)
                .Take(8)
                .ToList();
        }
    }

    private IReadOnlyList<ExecutiveSupervisoryFollowUpRow> ExecutiveSupervisoryFollowUpRows
    {
        get
        {
            if (DashboardInstitutionProfile is not { } institution)
            {
                return [];
            }

            var rows = new List<ExecutiveSupervisoryFollowUpRow>();

            rows.AddRange(institution.TopObligations
                .Where(x => x.Status == "Overdue" || x.Status == "Attention Required" || x.Status == "Due Soon")
                .Select(x => new ExecutiveSupervisoryFollowUpRow(
                    "Filing",
                    x.ReturnCode,
                    x.Status == "Overdue" || x.Status == "Attention Required" ? "Critical" : "Watch",
                    x.NextDeadline.ToString("dd MMM yyyy", CultureInfo.InvariantCulture),
                    $"{x.ModuleCode} · {x.RegulatorCode} · {x.PeriodLabel}",
                    x.Status == "Overdue" || x.Status == "Attention Required"
                        ? "Resolve the filing blocker and respond before the supervisory deadline."
                        : "Confirm readiness for the upcoming filing window.")));

            rows.AddRange(institution.RecentSubmissions
                .Where(x => x.Status.Contains("Reject", StringComparison.OrdinalIgnoreCase))
                .Take(3)
                .Select(x => new ExecutiveSupervisoryFollowUpRow(
                    "Submission",
                    x.ReturnCode,
                    "Critical",
                    FormatTimestamp(x.SubmittedAt),
                    $"Submission #{x.SubmissionId} remains in a rejected outcome.",
                    "Close the rejection findings and prepare a corrected submission pack.")));

            if (institution.OpenResilienceIncidents > 0 || institution.OpenSecurityAlerts > 0)
            {
                rows.Add(new ExecutiveSupervisoryFollowUpRow(
                    "Resilience",
                    $"{institution.OpenResilienceIncidents} incident(s) / {institution.OpenSecurityAlerts} alert(s)",
                    institution.OpenResilienceIncidents > 0 ? "Critical" : "Watch",
                    "Current supervisory cycle",
                    "Operational resilience issues remain open for the selected institution.",
                    "Provide remediation evidence and update the incident-response trail."));
            }

            if (institution.ModelReviewItems > 0)
            {
                rows.Add(new ExecutiveSupervisoryFollowUpRow(
                    "Model Risk",
                    $"{institution.ModelReviewItems} review item(s)",
                    "Watch",
                    "Current supervisory cycle",
                    "Outstanding model-governance review items remain open.",
                    "Complete validation, governance sign-off, and supporting evidence updates."));
            }

            rows.AddRange(institution.RecentActivity
                .Where(x => x.Severity is "Critical" or "High")
                .Take(3)
                .Select(x => new ExecutiveSupervisoryFollowUpRow(
                    x.Domain,
                    x.Title,
                    x.Severity == "Critical" ? "Critical" : "Watch",
                    FormatTimestamp(x.HappenedAt),
                    x.Detail,
                    "Update management response and retain the supervisory evidence trail.")));

            return rows
                .OrderByDescending(x => DashboardPriorityRank(x.Signal))
                .ThenBy(x => x.Area, StringComparer.OrdinalIgnoreCase)
                .ThenBy(x => x.Subject, StringComparer.OrdinalIgnoreCase)
                .Take(10)
                .ToList();
        }
    }

