    private IReadOnlyList<DashboardDomainSummaryRow> CurrentDashboardDomainRows
    {
        get
        {
            if (_workspace is null || _stakeholderLens == "executive")
            {
                return [];
            }

            var topFiling = _workspace.KnowledgeGraph.InstitutionObligations.FirstOrDefault(x => x.Status is "Overdue" or "Attention Required" or "Due Soon")
                ?? _workspace.KnowledgeGraph.InstitutionObligations.FirstOrDefault();
            var topCapital = _workspace.Capital.Watchlist.OrderBy(x => x.CapitalScore).FirstOrDefault();
            var topResilience = _workspace.Resilience.GapAnalysis.OrderBy(x => x.Score).FirstOrDefault();
            var topModel = _workspace.ModelRisk.AppetiteRegister.OrderBy(x => x.NextValidationDue).FirstOrDefault();
            var criticalDrafts = ReviewedStrDrafts.Count(x => x.Priority == "Critical");

            return
            [
                new DashboardDomainSummaryRow(
                    "Filing",
                    _workspace.KnowledgeGraph.InstitutionObligations.Count(x => x.Status is "Overdue" or "Attention Required" or "Due Soon"),
                    _workspace.ActivityTimeline.Count(x => x.Domain == "Submission" && x.Severity is "Critical" or "High"),
                    topFiling is null ? "No filing signal is currently active." : $"{topFiling.InstitutionName}: {topFiling.ReturnCode} is {topFiling.Status.ToLowerInvariant()} for {topFiling.PeriodLabel}.",
                    "Escalate blocked returns, validate remediation evidence, and confirm submission plans.",
                    topFiling?.Status ?? "Current"),
                new DashboardDomainSummaryRow(
                    "Capital",
                    _workspace.Capital.CapitalWatchlistCount,
                    _workspace.Capital.Watchlist.Count(x => x.CapitalScore < 45m),
                    topCapital is null ? "No institution is currently on the capital watchlist." : $"{topCapital.InstitutionName}: {topCapital.Alert}",
                    "Run RWA and capital-action scenarios, then assign prudential follow-up.",
                    topCapital is null ? "Current" : topCapital.CapitalScore < 45m ? "Critical" : "Watch"),
                new DashboardDomainSummaryRow(
                    "Sanctions",
                    ReviewedTfsPreview.ConfirmedMatches + ReviewedTfsPreview.PotentialMatches,
                    criticalDrafts,
                    ReviewedTfsPreview.Narrative,
                    "Resolve pending analyst reviews, finalize TFS metrics, and push STR drafts where needed.",
                    ReviewedTfsPreview.ConfirmedMatches > 0 ? "Critical" : ReviewedTfsPreview.PotentialMatches > 0 ? "Watch" : "Current"),
                new DashboardDomainSummaryRow(
                    "Resilience",
                    _workspace.Resilience.OpenIncidentCount + _workspace.Resilience.BoardSummary.OverdueActions,
                    _workspace.Resilience.RecentIncidents.Count(x => x.Severity is "Critical" or "High") + _workspace.Resilience.RecentSecurityAlerts.Count(x => x.Severity is "Critical" or "High"),
                    topResilience is null ? _workspace.Resilience.BoardSummary.Narrative : $"{topResilience.Domain}: {topResilience.Commentary}",
                    "Close overdue actions, retest weak services, and maintain board escalation on critical issues.",
                    _workspace.Resilience.BoardSummary.CriticalIssues > 0 ? "Critical" : _workspace.Resilience.OpenIncidentCount > 0 ? "Watch" : "Current"),
                new DashboardDomainSummaryRow(
                    "Model Risk",
                    _workspace.ModelRisk.DueValidationCount + _workspace.ModelRisk.ChangeReviewCount,
                    _workspace.ModelRisk.BreachCount + _workspace.ModelRisk.PerformanceAlertCount,
                    topModel is null ? "No model-risk item currently leads the queue." : $"{topModel.ModelCode}: {topModel.NextAction}",
                    "Prioritize overdue validations, backtesting, and governance sign-off on material changes.",
                    _workspace.ModelRisk.BreachCount > 0 ? "Critical" : _workspace.ModelRisk.DueValidationCount > 0 ? "Watch" : "Current")
            ];
        }
    }

