    private List<ExecutiveBriefRow> BuildExecutiveBriefRows()
    {
        if (_workspace is null)
        {
            return [];
        }

        var topObligation = _workspace.KnowledgeGraph.InstitutionObligations
            .FirstOrDefault(x => x.Status is "Overdue" or "Attention Required")
            ?? _workspace.KnowledgeGraph.InstitutionObligations.FirstOrDefault();

        var topCapitalAction = _capitalActionRows.FirstOrDefault();
        var topCapitalPackAttention = _capitalPackRows.FirstOrDefault(x => x.Signal == "Critical")
                                      ?? _capitalPackRows.FirstOrDefault(x => x.Signal == "Watch");
        var topSanctionsPackAttention = _sanctionsPackRows.FirstOrDefault(x => x.Signal == "Critical")
                                        ?? _sanctionsPackRows.FirstOrDefault(x => x.Signal == "Watch");
        var topKnowledgeDossier = _workspace.KnowledgeGraph.DossierPack.FirstOrDefault(x => x.Signal == "Critical")
                                 ?? _workspace.KnowledgeGraph.DossierPack.FirstOrDefault(x => x.Signal == "Watch");
        var topHotspot = _workspace.Resilience.Hotspots.FirstOrDefault();
        var topCyberAssessment = _workspace.Resilience.CyberAssessment.FirstOrDefault(x => x.Signal == "Critical")
                                 ?? _workspace.Resilience.CyberAssessment.FirstOrDefault(x => x.Signal == "Watch");
        var topRecoveryBreach = _workspace.Resilience.RecoveryTimeTests.FirstOrDefault(x => x.Signal == "Breach");
        var topModelPackAttention = _workspace.ModelRisk.ReturnPack.FirstOrDefault(x => x.Signal == "Critical")
                                   ?? _workspace.ModelRisk.ReturnPack.FirstOrDefault(x => x.Signal == "Watch");
        var topModel = _workspace.ModelRisk.Inventory.OrderBy(x => x.NextValidationDue).FirstOrDefault();

        return
        [
            new ExecutiveBriefRow("Snapshot Generated", FormatTimestamp(_workspace.GeneratedAt), "Current UTC timestamp for the intelligence pack."),
            new ExecutiveBriefRow("Knowledge Graph", _workspace.KnowledgeGraph.PersistedNodeCount > 0 ? _workspace.KnowledgeGraph.PersistedNodeCount.ToString(CultureInfo.InvariantCulture) : _workspace.KnowledgeGraph.ReferencedFieldCount.ToString(CultureInfo.InvariantCulture), topKnowledgeDossier is not null ? $"{topKnowledgeDossier.SectionName} is currently {topKnowledgeDossier.Signal.ToLowerInvariant()}; {_workspace.KnowledgeGraph.PersistedEdgeCount} persisted graph edge(s) are available for trace and impact work. {topKnowledgeDossier.RecommendedAction}" : $"{FilteredImpactPropagationRows.Count} prioritized change path(s), {_workspace.KnowledgeGraph.ObligationCount} licence-driven obligations, and {_workspace.KnowledgeGraph.PersistedEdgeCount} persisted graph edge(s) are currently mapped."),
            new ExecutiveBriefRow("Top Filing Signal", topObligation is null ? "No active obligation" : $"{topObligation.InstitutionName} · {topObligation.ReturnCode}", topObligation is null ? "No institution-specific obligation data is currently available." : $"{topObligation.Status} for {topObligation.PeriodLabel}; next deadline {topObligation.NextDeadline:dd MMM yyyy}."),
            new ExecutiveBriefRow("Capital Watchlist", _workspace.Capital.CapitalWatchlistCount.ToString(CultureInfo.InvariantCulture), topCapitalPackAttention is not null ? $"{topCapitalPackAttention.SectionName} is currently {topCapitalPackAttention.Signal.ToLowerInvariant()}; {topCapitalPackAttention.RecommendedAction}" : topCapitalAction is null ? "No action scenarios available." : $"{topCapitalAction.Title} yields the strongest projected headroom improvement at {topCapitalAction.ImprovementBps:+0;-0;0} bps."),
            new ExecutiveBriefRow("Sanctions / TFS", ReviewedTfsPreview.MatchesFound.ToString(CultureInfo.InvariantCulture), topSanctionsPackAttention is not null ? $"{topSanctionsPackAttention.SectionName} is currently {topSanctionsPackAttention.Signal.ToLowerInvariant()}; {topSanctionsPackAttention.RecommendedAction}" : ReviewedTfsPreview.Narrative),
            new ExecutiveBriefRow("Operational Resilience", _workspace.Resilience.OpenIncidentCount.ToString(CultureInfo.InvariantCulture), topCyberAssessment is not null ? $"{topCyberAssessment.Domain} is currently {topCyberAssessment.Signal.ToLowerInvariant()} at {topCyberAssessment.Score.ToString("0.0", CultureInfo.InvariantCulture)}; {topCyberAssessment.RecommendedAction}" : topRecoveryBreach is not null ? $"{topRecoveryBreach.ServiceName} is currently above its RTO threshold; next test due {topRecoveryBreach.NextTestDue:dd MMM yyyy}." : topHotspot is null ? "No dependency hotspot currently registered." : $"{topHotspot.AssetName} has {topHotspot.DependentCount} dependent asset(s), making it the leading concentration proxy."),
            new ExecutiveBriefRow("Model Risk", _workspace.ModelRisk.DueValidationCount.ToString(CultureInfo.InvariantCulture), topModelPackAttention is not null ? $"{topModelPackAttention.SheetName} is currently {topModelPackAttention.Signal.ToLowerInvariant()}; {topModelPackAttention.RecommendedAction}" : topModel is null ? "No model inventory baseline loaded." : $"{topModel.ModelCode} is the nearest validation due item ({topModel.NextValidationDue:dd MMM yyyy}).")
        ];
