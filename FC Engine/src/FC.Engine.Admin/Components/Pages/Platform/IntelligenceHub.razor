                    new DashboardMetricRow("Critical interventions", _workspace.Interventions.Count(x => x.Priority == "Critical").ToString(CultureInfo.InvariantCulture), "Priority actions that need leadership attention now.", _workspace.Interventions.Any(x => x.Priority == "Critical") ? "Critical" : "Current"),
                    new DashboardMetricRow("Pressure institutions", _workspace.InstitutionScorecards.Count(x => x.Priority is "Critical" or "High").ToString(CultureInfo.InvariantCulture), "Institutions carrying the heaviest combined filing, capital, resilience, or model-risk load.", _workspace.InstitutionScorecards.Any(x => x.Priority is "Critical" or "High") ? "Watch" : "Current"),
