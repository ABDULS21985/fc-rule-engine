    private async Task RebuildProjectionAsync()
    {
        RecalculateProjection();
        await SyncCapitalPackAsync();
    }

    private void RecalculateProjection()
    {
        _projectionRows = BuildProjectionRows(_projectionInput);
        _capitalActionRows = BuildCapitalActionRows(_projectionInput, _workspace?.Capital.ActionTemplates ?? []);
        _bufferRows = BuildBufferManagementRows(_projectionInput, _projectionRows);
        _rwaOpportunityRows = _capitalActionRows
            .Where(x => x.PrimaryLever == "RWA")
            .OrderByDescending(x => x.ImprovementBps)
            .ThenBy(x => x.EstimatedAnnualCostPercent)
            .ToList();
        _capitalStackRows = BuildCapitalStackRows(_projectionInput, _capitalStackInput);
        _capitalPackRows = BuildCapitalPackRows(
            _projectionRows,
            _bufferRows,
            _workspace?.Capital.Watchlist ?? [],
            _rwaOpportunityRows,
            _capitalActionRows,
            _capitalStackRows);
    }

    private void RebuildSanctionsPack()
    {
        _sanctionsPackRows = BuildSanctionsPackRows(
            _workspace?.Sanctions.Sources ?? [],
            _workspace?.Sanctions.LastUpdatedAt ?? DateTime.UtcNow,
            _screeningRun,
            ReviewedTfsPreview,
            ReviewedStrDrafts,
            _falsePositiveLibrary,
            _screeningAuditTrail,
            _transactionScreeningResult,
            SuppressedFalsePositiveCount);
    }

    private async Task SyncCapitalPackAsync()
    {
        if (_workspace is null)
        {
            return;
        }

        try
        {
            var catalog = await IntelligenceService.MaterializeCapitalPackAsync(
                _capitalPackRows
                    .Select(x => new CapitalPackSectionInput
                    {
                        SectionCode = x.SectionCode,
                        SectionName = x.SectionName,
                        RowCount = x.RowCount,
                        Signal = x.Signal,
                        Coverage = x.Coverage,
                        Commentary = x.Commentary,
                        RecommendedAction = x.RecommendedAction
                    })
                    .ToList());

            _workspace.Capital.ReturnPack = catalog.Sections.ToList();
            _workspace.Capital.ReturnPackAttentionCount = catalog.Sections.Count(x => x.Signal is "Critical" or "Watch");
            _workspace.Capital.ReturnPackMaterializedAt = catalog.MaterializedAt;
        }
        catch
        {
            // Keep the live in-memory pack visible even if the persistence refresh fails.
        }
    }

    private static List<CapitalProjectionRow> BuildProjectionRows(CapitalProjectionInput input)
    {
        var rows = new List<CapitalProjectionRow>();
        var rwa = input.CurrentRwaBn;
        var capital = input.CurrentCarPercent / 100m * rwa;
        var totalBuffer = input.ConservationBufferPercent + input.CountercyclicalBufferPercent + input.DsibBufferPercent;
        var requiredThreshold = input.MinimumRequirementPercent + totalBuffer;

        for (var quarter = 1; quarter <= 8; quarter++)
        {
            rwa *= 1m + input.QuarterlyRwaGrowthPercent / 100m;
            rwa *= 1m - input.RwaOptimisationPercent / 100m;

            capital += input.QuarterlyRetainedEarningsBn;
            if (quarter == 1)
            {
                capital += input.CapitalActionBn;
            }

            var car = rwa == 0m ? 0m : capital / rwa * 100m;
            var headroom = car - requiredThreshold;

            rows.Add(new CapitalProjectionRow
            {
                Label = $"Q{quarter}",
                ProjectedCarPercent = Math.Round(car, 2),
                MinimumHeadroomPercent = Math.Round(car - input.MinimumRequirementPercent, 2),
                BufferHeadroomPercent = Math.Round(headroom, 2),
                Signal = headroom < 0m ? "Breach" : headroom < 1.5m ? "Watch" : "Healthy"
            });
        }

        return rows;
    }

    private static List<CapitalScenarioComparisonRow> BuildCapitalActionRows(
        CapitalProjectionInput input,
        IReadOnlyList<CapitalActionTemplate> templates)
    {
        var baseline = BuildProjectionRows(input);
        var baselineWorstHeadroom = baseline.Count == 0 ? 0m : baseline.Min(x => x.BufferHeadroomPercent);

        return templates
            .Select(template =>
            {
                var scenarioInput = new CapitalProjectionInput
                {
                    CurrentCarPercent = input.CurrentCarPercent,
                    CurrentRwaBn = input.CurrentRwaBn,
                    QuarterlyRwaGrowthPercent = input.QuarterlyRwaGrowthPercent,
                    QuarterlyRetainedEarningsBn = input.QuarterlyRetainedEarningsBn + template.QuarterlyRetainedEarningsDeltaBn,
                    CapitalActionBn = input.CapitalActionBn + template.CapitalActionBn,
                    MinimumRequirementPercent = input.MinimumRequirementPercent,
                    ConservationBufferPercent = input.ConservationBufferPercent,
                    CountercyclicalBufferPercent = input.CountercyclicalBufferPercent,
                    DsibBufferPercent = input.DsibBufferPercent,
                    RwaOptimisationPercent = input.RwaOptimisationPercent + template.RwaOptimisationPercent
                };

                var projection = BuildProjectionRows(scenarioInput);
                var worstHeadroom = projection.Count == 0 ? 0m : projection.Min(x => x.BufferHeadroomPercent);
                var endingCar = projection.LastOrDefault()?.ProjectedCarPercent ?? 0m;
                var improvementBps = (worstHeadroom - baselineWorstHeadroom) * 100m;

                return new CapitalScenarioComparisonRow
                {
                    Code = template.Code,
                    Title = template.Title,
                    Summary = template.Summary,
                    PrimaryLever = template.PrimaryLever,
                    EstimatedAnnualCostPercent = template.EstimatedAnnualCostPercent,
                    EndingCarPercent = endingCar,
                    WorstHeadroomPercent = worstHeadroom,
                    ImprovementBps = Math.Round(improvementBps, 0),
                    Recommendation = improvementBps switch
                    {
                        >= 150m => "Priority",
                        >= 50m => "Evaluate",
                        >= 0m => "Optional",
                        _ => "Avoid"
                    }
                };
            })
            .OrderByDescending(x => x.ImprovementBps)
            .ThenBy(x => x.EstimatedAnnualCostPercent)
            .ToList();
    }

    private static List<BufferManagementRow> BuildBufferManagementRows(
        CapitalProjectionInput input,
        IReadOnlyList<CapitalProjectionRow> projectionRows)
    {
        var q8 = projectionRows.LastOrDefault();
        var currentCar = input.CurrentCarPercent;

        var layers = new[]
        {
            new { Layer = "Minimum requirement", Requirement = input.MinimumRequirementPercent, Threshold = input.MinimumRequirementPercent, Commentary = "Statutory floor before any distributable buffers." },
            new { Layer = "Conservation buffer", Requirement = input.ConservationBufferPercent, Threshold = input.MinimumRequirementPercent + input.ConservationBufferPercent, Commentary = "Core capital conservation margin above the minimum requirement." },
            new { Layer = "Countercyclical buffer", Requirement = input.CountercyclicalBufferPercent, Threshold = input.MinimumRequirementPercent + input.ConservationBufferPercent + input.CountercyclicalBufferPercent, Commentary = "Macroprudential layer activated to absorb cyclical risk build-up." },
            new { Layer = "D-SIB buffer", Requirement = input.DsibBufferPercent, Threshold = input.MinimumRequirementPercent + input.ConservationBufferPercent + input.CountercyclicalBufferPercent + input.DsibBufferPercent, Commentary = "Additional loss-absorbing margin for systemic institutions." }
        };

        return layers
            .Select(layer =>
            {
                var currentHeadroom = currentCar - layer.Threshold;
                var projectedHeadroom = (q8?.ProjectedCarPercent ?? currentCar) - layer.Threshold;
                var signal = projectedHeadroom < 0m
                    ? "Breach"
                    : projectedHeadroom < 1m
                        ? "Watch"
                        : "Healthy";

                return new BufferManagementRow
                {
                    Layer = layer.Layer,
                    RequirementPercent = layer.Requirement,
                    ThresholdPercent = layer.Threshold,
                    CurrentHeadroomPercent = Math.Round(currentHeadroom, 2),
                    ProjectedHeadroomPercent = Math.Round(projectedHeadroom, 2),
                    Signal = signal,
                    Commentary = layer.Commentary
                };
            })
            .ToList();
    }

    private static List<CapitalStackMixRow> BuildCapitalStackRows(
        CapitalProjectionInput projectionInput,
        CapitalStackOptimiserInput optimiserInput)
    {
        var requiredCapitalBn = Math.Max(
            0m,
            (optimiserInput.TargetCarPercent - projectionInput.CurrentCarPercent) / 100m * projectionInput.CurrentRwaBn);

        if (requiredCapitalBn <= 0m)
        {
            return
            [
                new CapitalStackMixRow
                {
                    Recommendation = "Reserve",
                    Cet1SharePercent = 100m,
                    At1SharePercent = 0m,
                    Tier2SharePercent = 0m,
                    Cet1AmountBn = 0m,
                    At1AmountBn = 0m,
                    Tier2AmountBn = 0m,
                    RequiredCapitalBn = 0m,
                    WeightedAverageCostPercent = 0m,
                    AnnualCarryingCostBn = 0m,
                    TargetCarPercent = projectionInput.CurrentCarPercent,
                    Commentary = "Current CAR already meets or exceeds the target, so no incremental stack is required."
                }
            ];
        }

        var step = optimiserInput.StepPercent <= 0m ? 5m : optimiserInput.StepPercent;
        var rows = new List<CapitalStackMixRow>();

        for (var at1Share = 0m; at1Share <= optimiserInput.MaxAt1SharePercent; at1Share += step)
        {
            for (var tier2Share = 0m; tier2Share <= optimiserInput.MaxTier2SharePercent; tier2Share += step)
            {
                var cet1Share = 100m - at1Share - tier2Share;
                if (cet1Share < 0m)
                {
                    continue;
                }

                var cet1Amount = Math.Round(requiredCapitalBn * cet1Share / 100m, 2);
                var at1Amount = Math.Round(requiredCapitalBn * at1Share / 100m, 2);
                var tier2Amount = Math.Round(requiredCapitalBn * tier2Share / 100m, 2);
                var weightedCost = Math.Round(
                    (cet1Share * optimiserInput.Cet1CostPercent
                     + at1Share * optimiserInput.At1CostPercent
                     + tier2Share * optimiserInput.Tier2CostPercent) / 100m,
                    2);
                var annualCost = Math.Round(requiredCapitalBn * weightedCost / 100m, 2);

                var commentaryParts = new List<string>();
                if (at1Share == optimiserInput.MaxAt1SharePercent)
                {
                    commentaryParts.Add("AT1 capacity fully used");
                }

                if (tier2Share == optimiserInput.MaxTier2SharePercent)
                {
                    commentaryParts.Add("Tier 2 capacity fully used");
                }

                if (cet1Share >= 50m)
                {
                    commentaryParts.Add("common equity remains the dominant layer");
                }

                rows.Add(new CapitalStackMixRow
                {
                    Cet1SharePercent = cet1Share,
                    At1SharePercent = at1Share,
                    Tier2SharePercent = tier2Share,
                    Cet1AmountBn = cet1Amount,
                    At1AmountBn = at1Amount,
                    Tier2AmountBn = tier2Amount,
                    RequiredCapitalBn = Math.Round(requiredCapitalBn, 2),
                    WeightedAverageCostPercent = weightedCost,
                    AnnualCarryingCostBn = annualCost,
                    TargetCarPercent = optimiserInput.TargetCarPercent,
                    Commentary = commentaryParts.Count == 0
                        ? "Feasible mix within the configured regulatory instrument caps."
                        : string.Join("; ", commentaryParts) + "."
                });
            }
        }

        return rows
            .OrderBy(x => x.WeightedAverageCostPercent)
            .ThenBy(x => x.AnnualCarryingCostBn)
            .ThenByDescending(x => x.At1SharePercent + x.Tier2SharePercent)
            .Take(8)
            .Select((row, index) =>
            {
                row.Recommendation = index switch
                {
                    0 => "Optimal",
                    1 or 2 => "Contender",
                    _ => "Reserve"
                };
                return row;
            })
            .ToList();
    }

    private static List<CapitalSupervisoryPackRow> BuildCapitalPackRows(
        IReadOnlyList<CapitalProjectionRow> projectionRows,
        IReadOnlyList<BufferManagementRow> bufferRows,
        IReadOnlyList<CapitalWatchlistRow> watchlistRows,
        IReadOnlyList<CapitalScenarioComparisonRow> rwaOpportunityRows,
        IReadOnlyList<CapitalScenarioComparisonRow> capitalActionRows,
        IReadOnlyList<CapitalStackMixRow> capitalStackRows)
    {
        var rows = new List<CapitalSupervisoryPackRow>();

        var watchlistLeader = watchlistRows
            .OrderByDescending(x => x.CapitalScore)
            .ThenByDescending(x => x.OverallScore)
            .FirstOrDefault();
        var watchlistSignal = watchlistRows.Count switch
        {
            >= 3 => "Critical",
            > 0 => "Watch",
            _ => "Ready"
        };

        rows.Add(new CapitalSupervisoryPackRow(
            "CAP-01",
            "Capital Watchlist & Intervention",
            watchlistRows.Count,
            watchlistSignal,
            $"{watchlistRows.Count} institution(s) on supervisory capital watch",
            watchlistLeader is null
                ? "No live capital watchlist cases are currently open."
                : $"{watchlistLeader.InstitutionName} is the leading intervention case at capital score {watchlistLeader.CapitalScore.ToString("0.0", CultureInfo.InvariantCulture)}.",
            watchlistLeader?.Alert ?? "Maintain current capital surveillance cadence and refresh watchlist triggers weekly."));

        var firstProjectionBreach = projectionRows.FirstOrDefault(x => x.Signal == "Breach");
        var firstProjectionWatch = projectionRows.FirstOrDefault(x => x.Signal == "Watch");
        var projectionSignal = firstProjectionBreach is not null
            ? "Critical"
            : firstProjectionWatch is not null
                ? "Watch"
                : "Ready";

        rows.Add(new CapitalSupervisoryPackRow(
            "CAP-02",
            "CAR Projection Horizon",
            projectionRows.Count,
            projectionSignal,
            $"{projectionRows.Count} quarter(s) projected",
            firstProjectionBreach is not null
                ? $"Projected CAR falls below the stacked prudential threshold in {firstProjectionBreach.Label}."
                : firstProjectionWatch is not null
                    ? $"Projected headroom enters watch range by {firstProjectionWatch.Label}."
                    : "Projected CAR remains above the combined minimum and buffer horizon across the 8-quarter view.",
            firstProjectionBreach is not null
                ? $"Refresh capital actions before {firstProjectionBreach.Label} and escalate to supervisory review."
                : firstProjectionWatch is not null
                    ? $"Pre-position a capital action before {firstProjectionWatch.Label}."
                    : "Maintain the current forecast and refresh assumptions each quarter."));

        var leadingBufferIssue = bufferRows.FirstOrDefault(x => x.Signal == "Breach")
                                 ?? bufferRows.FirstOrDefault(x => x.Signal == "Watch")
                                 ?? bufferRows.FirstOrDefault();
        var bufferSignal = leadingBufferIssue?.Signal switch
        {
            "Breach" => "Critical",
            "Watch" => "Watch",
            _ => "Ready"
        };
        var healthyBufferCount = bufferRows.Count(x => x.Signal == "Healthy");

        rows.Add(new CapitalSupervisoryPackRow(
            "CAP-03",
            "Buffer Stack Readiness",
            bufferRows.Count,
            bufferSignal,
            $"{healthyBufferCount}/{bufferRows.Count} buffer layer(s) above threshold",
            leadingBufferIssue is null
                ? "No buffer-stack evidence is currently available."
                : $"{leadingBufferIssue.Layer} carries the leading signal with projected headroom {leadingBufferIssue.ProjectedHeadroomPercent.ToString("0.0", CultureInfo.InvariantCulture)}%.",
            leadingBufferIssue is null
                ? "Validate layered buffer assumptions before issuing the pack."
                : leadingBufferIssue.Signal == "Breach"
                    ? $"Restore headroom above the {leadingBufferIssue.Layer.ToLowerInvariant()} immediately."
                    : leadingBufferIssue.Signal == "Watch"
                        ? $"Monitor erosion in the {leadingBufferIssue.Layer.ToLowerInvariant()} and stage mitigants."
                        : "Maintain the current stacked buffer posture."));

        var topRwaOpportunity = rwaOpportunityRows.FirstOrDefault();
        var rwaSignal = topRwaOpportunity is null
            ? "Watch"
            : topRwaOpportunity.WorstHeadroomPercent < 0m || topRwaOpportunity.ImprovementBps <= 0m
                ? "Critical"
                : topRwaOpportunity.WorstHeadroomPercent < 1m || topRwaOpportunity.ImprovementBps < 50m
                    ? "Watch"
                    : "Ready";

        rows.Add(new CapitalSupervisoryPackRow(
            "CAP-04",
            "RWA Optimisation",
            rwaOpportunityRows.Count,
            rwaSignal,
            $"{rwaOpportunityRows.Count} ranked RWA lever(s)",
            topRwaOpportunity is null
                ? "No RWA optimisation levers are currently catalogued in the scenario."
                : $"{topRwaOpportunity.Title} leads the RWA queue with {topRwaOpportunity.ImprovementBps.ToString("+0;-0;0", CultureInfo.InvariantCulture)} bps uplift.",
            topRwaOpportunity is null
                ? "Expand the RWA optimisation catalog with collateral, portfolio, and off-balance-sheet actions."
                : $"Prioritize {topRwaOpportunity.Title.ToLowerInvariant()} and validate execution feasibility against the current filing horizon."));

        var topCapitalAction = capitalActionRows.FirstOrDefault();
        var capitalActionSignal = topCapitalAction is null
            ? "Watch"
            : topCapitalAction.WorstHeadroomPercent < 0m || topCapitalAction.Recommendation == "Avoid"
                ? "Critical"
                : topCapitalAction.WorstHeadroomPercent < 1m || topCapitalAction.Recommendation is "Evaluate" or "Optional"
                    ? "Watch"
                    : "Ready";

        rows.Add(new CapitalSupervisoryPackRow(
            "CAP-05",
            "What-If Capital Actions",
            capitalActionRows.Count,
            capitalActionSignal,
            $"{capitalActionRows.Count} scenario action(s)",
            topCapitalAction is null
                ? "No capital actions are currently modeled."
                : $"{topCapitalAction.Title} is the leading action at {topCapitalAction.EndingCarPercent.ToString("0.0", CultureInfo.InvariantCulture)}% Q8 CAR and {topCapitalAction.WorstHeadroomPercent.ToString("0.0", CultureInfo.InvariantCulture)}% worst headroom.",
            topCapitalAction is null
                ? "Add capital actions before sign-off."
                : $"Take {topCapitalAction.Title.ToLowerInvariant()} forward for treasury and supervisory challenge."));

        var bestCapitalStack = capitalStackRows.FirstOrDefault();
        var capitalStackSignal = bestCapitalStack is null
            ? "Watch"
            : bestCapitalStack.RequiredCapitalBn <= 0m
                ? "Ready"
                : bestCapitalStack.RequiredCapitalBn >= 10m || bestCapitalStack.WeightedAverageCostPercent >= 20m
                    ? "Critical"
                    : bestCapitalStack.RequiredCapitalBn >= 3m || bestCapitalStack.WeightedAverageCostPercent >= 16m
                        ? "Watch"
                        : "Ready";

        rows.Add(new CapitalSupervisoryPackRow(
            "CAP-06",
            "Capital Stack Optimiser",
            capitalStackRows.Count,
            capitalStackSignal,
            $"{capitalStackRows.Count} feasible capital mix(es)",
            bestCapitalStack is null
                ? "No compliant capital stack mix is currently available."
                : bestCapitalStack.RequiredCapitalBn <= 0m
                    ? "Current capital already meets the configured target, so new issuance is optional."
                    : $"Best mix reaches {bestCapitalStack.TargetCarPercent.ToString("0.0", CultureInfo.InvariantCulture)}% CAR with {bestCapitalStack.WeightedAverageCostPercent.ToString("0.0", CultureInfo.InvariantCulture)}% weighted cost.",
            bestCapitalStack is null
                ? "Review optimiser constraints and rerun the mix generation."
                : bestCapitalStack.RequiredCapitalBn <= 0m
                    ? "Keep the optimiser as a reserve planning view and revisit if the buffer stack weakens."
                    : $"Evaluate the recommended stack with treasury, focusing on {bestCapitalStack.RequiredCapitalBn.ToString("0.0", CultureInfo.InvariantCulture)} bn incremental capital."));

        return rows;
    }

