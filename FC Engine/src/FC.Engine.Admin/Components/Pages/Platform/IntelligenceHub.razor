                                            </div>
                                            <span class="fc-intel-chip">@SelectedInstitutionProfile.RecentSubmissions.Count row(s)</span>
                                        </header>
                                        <div class="fc-intel-table-wrap">
                                            <table class="fc-intel-table">
                                                <thead>
                                                    <tr>
                                                        <th>Submission</th>
                                                        <th>Status</th>
                                                        <th>Submitted</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var row in SelectedInstitutionProfile.RecentSubmissions)
                                                    {
                                                        <tr>
                                                            <td>
                                                                <strong>#@row.SubmissionId</strong>
