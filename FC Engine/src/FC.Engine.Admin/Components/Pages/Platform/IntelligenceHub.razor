                    new DashboardMetricRow("Pending sanctions reviews", ReviewedTfsPreview.PotentialMatches.ToString(CultureInfo.InvariantCulture), "Screening results still awaiting analyst decisioning.", ReviewedTfsPreview.PotentialMatches > 0 ? "Watch" : "Current"),
