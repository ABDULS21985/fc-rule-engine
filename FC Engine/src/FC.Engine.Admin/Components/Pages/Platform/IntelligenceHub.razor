    private int GetResilienceAssessmentValue(string questionId) =>
        _resilienceAssessmentResponses.TryGetValue(questionId, out var value) ? value : 0;

    private int AnsweredResilienceQuestionCount =>
        _resilienceAssessmentResponses.Count(x => x.Value > 0);

    private decimal ResilienceAssessmentCoveragePercent =>
        ResilienceAssessmentQuestions.Count == 0
            ? 0m
            : Math.Round(AnsweredResilienceQuestionCount * 100m / ResilienceAssessmentQuestions.Count, 1);

    private decimal? ResilienceAssessmentScorePercent =>
        AnsweredResilienceQuestionCount == 0
            ? null
            : Math.Round((decimal)_resilienceAssessmentResponses.Values.Where(x => x > 0).Average() * 20m, 1);

    private decimal ResilienceBlendedScore =>
        _workspace is null
            ? 0m
            : Math.Round(((decimal)_workspace.Resilience.GapScore + (ResilienceAssessmentScorePercent ?? (decimal)_workspace.Resilience.GapScore)) / 2m, 1);

    private IReadOnlyList<ResilienceAssessmentDomainSummaryRow> ResilienceAssessmentDomainRows
    {
        get
        {
            if (_workspace is null)
            {
                return [];
            }

            var groupedResponses = ResilienceAssessmentQuestions
                .GroupBy(x => x.Domain, StringComparer.OrdinalIgnoreCase)
                .ToDictionary(
                    group => group.Key,
                    group =>
                    {
                        var values = group
                            .Select(question => GetResilienceAssessmentValue(question.Id))
                            .Where(value => value > 0)
                            .ToList();
                        return values.Count == 0 ? (decimal?)null : Math.Round((decimal)values.Average() * 20m, 1);
                    },
                    StringComparer.OrdinalIgnoreCase);

            return _workspace.Resilience.GapAnalysis
                .Select(row =>
                {
                    groupedResponses.TryGetValue(row.Domain, out var assessmentScore);
                    var delta = assessmentScore.HasValue ? Math.Round(assessmentScore.Value - row.Score, 1) : (decimal?)null;
                    var signal = assessmentScore.HasValue
                        ? delta switch
                        {
                            >= 15m => "Watch",
                            <= -15m => "Critical",
                            _ => row.Signal
                        }
                        : "Monitor";

                    var commentary = assessmentScore.HasValue
                        ? $"Self score {assessmentScore.Value.ToString("0.0", CultureInfo.InvariantCulture)} versus telemetry-derived {row.Score.ToString("0.0", CultureInfo.InvariantCulture)}."
                        : "Awaiting questionnaire response for this resilience domain.";

                    return new ResilienceAssessmentDomainSummaryRow(
                        row.Domain,
                        row.Score,
                        assessmentScore,
                        delta,
                        signal,
                        commentary,
                        row.NextAction);
                })
                .ToList();
        }
    }

    private async Task UpdateResilienceAssessmentAsync(string questionId, ChangeEventArgs args)
    {
        var value = args.Value?.ToString();
        if (!int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsedValue) || parsedValue < 0 || parsedValue > 5)
        {
            return;
        }

        var question = ResilienceAssessmentQuestions.FirstOrDefault(x => x.Id == questionId);
        if (question is null)
        {
            return;
        }

        await IntelligenceService.RecordResilienceAssessmentResponseAsync(new ResilienceAssessmentResponseCommand
        {
            QuestionId = question.Id,
            Domain = question.Domain,
            Prompt = question.Prompt,
            Score = parsedValue,
            AnsweredAtUtc = DateTime.UtcNow
        });

        await LoadResilienceClientStateAsync();
    }

