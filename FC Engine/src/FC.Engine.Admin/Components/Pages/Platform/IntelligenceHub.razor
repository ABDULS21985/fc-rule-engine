                                                <td>@row.Section</td>
                                                <td><strong>@row.MetricValue</strong></td>
                                                <td><span class="fc-intel-status fc-intel-status--@StatusClass(row.Signal)">@row.Signal</span></td>
                                                <td class="fc-intel-table__sub">@row.Commentary</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </article>
                    </div>

                    <article class="fc-intel-card fc-intel-card--table">
