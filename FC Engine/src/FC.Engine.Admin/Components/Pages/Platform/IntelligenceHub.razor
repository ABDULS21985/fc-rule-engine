    private string ExecutiveBriefHeadline
    {
        get
        {
            if (_workspace is null)
            {
                return "No intelligence snapshot loaded";
            }

            if (_stakeholderLens == "executive")
            {
                var institution = DashboardInstitutionProfile;
                if (institution is null)
                {
                    return "No institution profile is currently available for executive oversight.";
                }

                if (institution.OverdueObligations > 0)
                {
                    return $"{institution.InstitutionName} has {institution.OverdueObligations} overdue filing obligation(s).";
                }

                if (institution.OpenResilienceIncidents > 0)
                {
                    return $"{institution.InstitutionName} has {institution.OpenResilienceIncidents} resilience incident(s) still open.";
                }

                if (institution.ModelReviewItems > 0)
                {
                    return $"{institution.InstitutionName} has {institution.ModelReviewItems} model governance item(s) pending review.";
                }

                return $"{institution.InstitutionName} is currently operating within the active supervisory thresholds tracked in RegOS.";
            }

            var overdue = _workspace.KnowledgeGraph.InstitutionObligations.Count(x => x.Status is "Overdue" or "Attention Required");
            if (overdue > 0)
            {
                return _stakeholderLens switch
                {
                    "governor" => $"{overdue} filing obligation(s) require immediate intervention across the supervised population.",
                    "deputy" => $"{overdue} supervisory filing issues should be escalated through the operating queue.",
                    _ => $"{overdue} filing records need examiner follow-up now."
                };
            }

            if (_workspace.Capital.CapitalWatchlistCount > 0)
            {
                return _stakeholderLens switch
                {
                    "governor" => $"{_workspace.Capital.CapitalWatchlistCount} institutions sit on the capital watchlist.",
                    "deputy" => $"{_workspace.Capital.CapitalWatchlistCount} institutions need prudential intervention planning.",
                    _ => $"{_workspace.Capital.CapitalWatchlistCount} institutions should be assigned for follow-up review."
                };
            }

            if (_workspace.Resilience.OpenIncidentCount > 0)
            {
                return $"{_workspace.Resilience.OpenIncidentCount} resilience incident(s) remain open.";
            }

            return "No cross-track critical signal is currently above threshold.";
        }
    }

    private string ExecutiveBriefNarrative
