                if (institution is null)
                {
                    return "Select an institution to view filing, capital, resilience, and model-governance posture in one place.";
                }

                var topObligation = institution.TopObligations.FirstOrDefault();
                var latestSubmission = institution.RecentSubmissions.FirstOrDefault();
                var peerCount = ExecutivePeerBenchmarks.Count;
                return $"{institution.Summary} Next focus: {(topObligation is null ? "no immediate filing deadline is currently registered." : $"{topObligation.ReturnCode} is {topObligation.Status.ToLowerInvariant()} with a {topObligation.NextDeadline:dd MMM yyyy} deadline.")} Latest submission: {(latestSubmission is null ? "no recent submission captured." : $"{latestSubmission.ReturnCode} {latestSubmission.Status.ToLowerInvariant()} at {FormatTimestamp(latestSubmission.SubmittedAt)}.")} Peer set: {peerCount} comparable institution(s).";
            }

            var bestCapitalAction = _capitalActionRows.FirstOrDefault()?.Title ?? "No capital action comparison available";
            var topHotspot = _workspace.Resilience.Hotspots.FirstOrDefault()?.AssetName ?? "No dependency hotspot registered";
            var dueModels = _workspace.ModelRisk.DueValidationCount;
            return _stakeholderLens switch
            {
                "governor" => $"System signal: prioritize the intervention queue, with {bestCapitalAction} as the strongest current capital lever. Concentration proxy: {topHotspot}. Due model validations: {dueModels}.",
                "deputy" => $"Operational focus should center on filing breaches, capital follow-up, and resilience remediation. Recommended capital lever: {bestCapitalAction}. Key hotspot: {topHotspot}.",
                _ => $"Execution focus: clear the intervention queue, validate remediation evidence, and close due model reviews. Capital action most worth testing: {bestCapitalAction}.",
            };
        }
    }

