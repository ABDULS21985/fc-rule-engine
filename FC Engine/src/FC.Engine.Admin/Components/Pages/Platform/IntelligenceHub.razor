    private void InitializeScreeningDecisions(IReadOnlyList<SanctionsScreeningResultRow> results)
    {
        _screeningDecisions.Clear();
        foreach (var row in results)
        {
            _screeningDecisions[row.Subject] = row.Disposition switch
            {
                "True Match" => "Confirm Match",
                "Potential Match" => "Review",
                _ => "Clear"
            };
        }
    }

    private string GetScreeningDecision(string subject) =>
        _screeningDecisions.TryGetValue(subject, out var decision) ? decision : "Clear";

    private async Task UpdateScreeningDecisionAsync(SanctionsScreeningResultRow row, ChangeEventArgs args)
    {
        var decision = args.Value?.ToString()?.Trim();
        if (string.IsNullOrWhiteSpace(decision))
        {
            return;
        }

        var previousDecision = GetScreeningDecision(row.Subject);
        await IntelligenceService.RecordSanctionsDecisionAsync(new SanctionsWorkflowDecisionCommand
        {
            MatchKey = BuildFalsePositiveMatchKey(row),
            Subject = row.Subject,
            MatchedName = row.MatchedName,
            SourceCode = row.SourceCode,
            RiskLevel = row.RiskLevel,
            PreviousDecision = previousDecision,
            Decision = decision,
            ReviewedAtUtc = DateTime.UtcNow
        });

        _screeningDecisions[row.Subject] = decision;
        await LoadSanctionsWorkflowStateAsync();
        NormalizeSelectedStrDraft();
        RebuildSanctionsPack();
    }

