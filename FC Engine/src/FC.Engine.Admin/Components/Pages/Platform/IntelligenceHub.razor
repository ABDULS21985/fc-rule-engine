                                <span class="fc-intel-chip">@ModelStageCount("Model Risk Committee") committee</span>
                                <span class="fc-intel-chip">@ModelStageCount("Board Review") board</span>
                                <span class="fc-intel-chip">@ModelStageCount("Approved") approved</span>
                            </div>
