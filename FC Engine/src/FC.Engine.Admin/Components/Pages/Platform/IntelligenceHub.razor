                            <p>
                                @if (_workspace.ModelRisk.BreachCount > 0)
                                {
                                    <span>@_workspace.ModelRisk.BreachCount model(s) are outside appetite and require formal reporting escalation.</span>
                                }
                                else if (_workspace.ModelRisk.WatchCount > 0)
                                {
                                    <span>@_workspace.ModelRisk.WatchCount model(s) are on watch and should be highlighted in the next governance pack.</span>
                                }
                                else
                                {
                                    <span>Governed regulatory models are currently operating within the defined appetite and reporting threshold.</span>
                                }
