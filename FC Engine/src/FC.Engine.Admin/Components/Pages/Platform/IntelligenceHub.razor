                                                </tbody>
                                            </table>
                                        </div>
                                    </article>
                                </div>

                                <article class="fc-intel-card fc-intel-card--table">
                                    <header class="fc-intel-card__header">
                                        <div>
                                            <span class="fc-intel-card__label">Recent Activity</span>
                                            <h2>Cross-track events tied to this institution</h2>
                                        </div>
                                        <span class="fc-intel-chip">@SelectedInstitutionProfile.RecentActivity.Count row(s)</span>
                                    </header>
                                    <div class="fc-intel-table-wrap">
                                        <table class="fc-intel-table">
                                            <thead>
                                                <tr>
                                                    <th>Time</th>
                                                    <th>Domain</th>
                                                    <th>Event</th>
                                                    <th>Detail</th>
                                                    <th>Severity</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var row in SelectedInstitutionProfile.RecentActivity)
                                                {
                                                    <tr>
                                                        <td>@FormatTimestamp(row.HappenedAt)</td>
                                                        <td>@row.Domain</td>
                                                        <td>@row.Title</td>
                                                        <td class="fc-intel-table__sub">@row.Detail</td>
                                                        <td><span class="fc-intel-status fc-intel-status--@StatusClass(row.Severity)">@row.Severity</span></td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </article>
                            </div>
                        }
                    </article>
                </section>
                break;
        }
    }
</div>

@code {
    private static readonly IReadOnlyList<(string Id, string Label, string Meta)> Tabs =
    [
        ("overview", "Overview", "cross-track"),
        ("dashboards", "Dashboards", "stakeholder"),
        ("knowledge", "Knowledge Graph", "lineage"),
        ("capital", "Capital", "projection"),
        ("sanctions", "Sanctions", "screening"),
        ("resilience", "Resilience", "operations"),
        ("models", "Model Risk", "governance")
    ];

    private static readonly IReadOnlyList<(string Id, string Label, string Meta)> StakeholderLenses =
    [
        ("governor", "Governor", "systemic view"),
        ("deputy", "Deputy Governor", "oversight"),
        ("director", "Director / Examiner", "execution"),
        ("executive", "Institution Executive", "filing posture")
    ];

    private static readonly IReadOnlyList<ResilienceAssessmentQuestionDefinition> ResilienceAssessmentQuestions =
    [
        new("service-inventory", "Critical Service Mapping", "Important business services are explicitly inventoried, owned, and mapped to supporting assets."),
        new("dependency-mapping", "Critical Service Mapping", "Key service dependencies and single points of failure are documented and current."),
        new("third-party-register", "Third-Party Concentration", "Critical third-party providers are registered, tiered, and monitored for concentration risk."),
        new("third-party-exit", "Third-Party Concentration", "Exit and substitution plans exist for material outsourced providers."),
        new("incident-playbooks", "Incident Response", "Incident playbooks define escalation, communications, containment, and recovery accountability."),
        new("rca-discipline", "Root Cause Discipline", "Material incidents receive root-cause analysis with tracked remediation ownership."),
        new("scenario-testing", "Testing Cadence", "Important services are scenario-tested on a defined cadence with evidence retained."),
        new("recovery-targets", "Testing Cadence", "Recovery-time and impact-tolerance targets are actively tested and challenged."),
        new("board-reporting", "Board Oversight", "Board or risk committee reporting includes resilience metrics, overdue actions, and test outcomes.")
    ];

    private PlatformIntelligenceWorkspace? _workspace;
    private Exception? _error;
    private bool _loading = true;
    private string _activeTab = "overview";
    private string _stakeholderLens = "governor";
    private string _knowledgeQuery = string.Empty;
    private string _selectedInstitutionId = string.Empty;
    private string _selectedNavigatorKey = string.Empty;
    private string _selectedResilienceIncidentKey = string.Empty;
    private int? _selectedProfileInstitutionId;
    private string _selectedStrDraftId = string.Empty;
    private string _screeningInput = string.Empty;
    private double _screeningThreshold = 0.86d;
    private SanctionsScreeningRun? _screeningRun;
    private SanctionsTransactionScreeningRequest _transactionScreeningInput = new();
    private SanctionsTransactionScreeningResult? _transactionScreeningResult;
    private readonly Dictionary<string, string> _screeningDecisions = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, int> _resilienceAssessmentResponses = new(StringComparer.OrdinalIgnoreCase);
    private List<SanctionsFalsePositiveLibraryEntry> _falsePositiveLibrary = [];
    private List<SanctionsDecisionAuditEntry> _screeningAuditTrail = [];
    private List<SanctionsSupervisoryPackRow> _sanctionsPackRows = [];
    private readonly Dictionary<string, string> _modelApprovalStages = new(StringComparer.OrdinalIgnoreCase);
    private List<ModelApprovalAuditEntry> _modelApprovalAuditTrail = [];
    private bool _clientStateLoaded;
    private CapitalProjectionInput _projectionInput = new();
    private CapitalStackOptimiserInput _capitalStackInput = new();
    private List<CapitalProjectionRow> _projectionRows = [];
    private List<BufferManagementRow> _bufferRows = [];
    private List<CapitalScenarioComparisonRow> _capitalActionRows = [];
    private List<CapitalScenarioComparisonRow> _rwaOpportunityRows = [];
    private List<CapitalStackMixRow> _capitalStackRows = [];
    private List<CapitalSupervisoryPackRow> _capitalPackRows = [];

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _workspace = await IntelligenceService.GetWorkspaceAsync();
            InitializeInteractiveState();
            await LoadClientStateAsync();
            await SyncCapitalPackAsync();
        }
        catch (Exception ex)
        {
            _error = ex;
            Toast.Error($"Unable to load intelligence workspace: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void InitializeInteractiveState()
    {
        _selectedInstitutionId = string.Empty;
        _selectedNavigatorKey = _workspace?.KnowledgeGraph.Lineage.FirstOrDefault()?.NavigatorKey ?? string.Empty;
        _selectedResilienceIncidentKey = _workspace?.Resilience.IncidentTimelines.FirstOrDefault()?.IncidentKey ?? string.Empty;
        _selectedProfileInstitutionId = _workspace?.InstitutionScorecards.FirstOrDefault()?.InstitutionId;
        _selectedStrDraftId = string.Empty;
        _screeningDecisions.Clear();
        _screeningInput = string.Join(Environment.NewLine, new[]
        {
            "Sample Bureau De Change Limited FULL",
            "Boko Haram",
            "Central Bank Governor"
        });
        _transactionScreeningInput = new SanctionsTransactionScreeningRequest
        {
            TransactionReference = "TXN-BDC-20260311-001",
            Amount = 12500000m,
            Currency = "NGN",
            Channel = "Wire",
            HighRisk = true,
            OriginatorName = "Sample Bureau De Change Limited FULL",
            BeneficiaryName = "Boko Haram",
            CounterpartyName = "Prime FX Settlement Services"
        };
        _transactionScreeningResult = null;

        _projectionInput = new CapitalProjectionInput
        {
            CurrentCarPercent = 17.5m,
            CurrentRwaBn = 125m,
            QuarterlyRwaGrowthPercent = 4.2m,
            QuarterlyRetainedEarningsBn = 2.5m,
            CapitalActionBn = 8m,
            MinimumRequirementPercent = 10m,
            ConservationBufferPercent = 2.5m,
            CountercyclicalBufferPercent = 0.5m,
            DsibBufferPercent = 1m,
            RwaOptimisationPercent = 3m
        };

        _capitalStackInput = new CapitalStackOptimiserInput
        {
            TargetCarPercent = 19.5m,
            Cet1CostPercent = 18m,
            At1CostPercent = 14m,
            Tier2CostPercent = 11m,
            MaxAt1SharePercent = 30m,
            MaxTier2SharePercent = 35m,
            StepPercent = 5m
        };

        RecalculateProjection();
        RebuildSanctionsPack();
    }

    private async Task RunScreeningAsync()
    {
        var lines = (_screeningInput ?? string.Empty)
            .Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (lines.Length == 0)
        {
            Toast.Warning("Enter one or more names to screen.");
            return;
        }

        _screeningRun = await IntelligenceService.ScreenSubjectsAsync(lines, _screeningThreshold);
        InitializeScreeningDecisions(_screeningRun.Results);
        ApplyPersistedSanctionsDecisions();
        NormalizeSelectedStrDraft();
        RebuildSanctionsPack();
        Toast.Success($"Screening complete: {_screeningRun.MatchCount} match(es) found.");
    }

