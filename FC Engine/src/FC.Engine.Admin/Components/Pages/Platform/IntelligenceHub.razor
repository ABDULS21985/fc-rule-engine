                    new DashboardMetricRow("Due validations", _workspace.ModelRisk.DueValidationCount.ToString(CultureInfo.InvariantCulture), "Regulatory models approaching or exceeding validation due dates.", _workspace.ModelRisk.DueValidationCount > 0 ? "Watch" : "Current"),
                    new DashboardMetricRow("Board-critical resilience issues", _workspace.Resilience.BoardSummary.CriticalIssues.ToString(CultureInfo.InvariantCulture), "Critical resilience items already requiring leadership reporting.", _workspace.Resilience.BoardSummary.CriticalIssues > 0 ? "Critical" : "Current")
