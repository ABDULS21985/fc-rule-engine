                                    <thead>
                                        <tr>
                                            <th>Section</th>
                                            <th>Metric</th>
                                            <th>Signal</th>
                                            <th>Commentary</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _workspace.ModelRisk.ReportingPack)
