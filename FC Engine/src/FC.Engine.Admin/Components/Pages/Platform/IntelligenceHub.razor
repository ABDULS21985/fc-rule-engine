                                                </td>
                                                <td>@row.VarianceText</td>
                                                <td>
                                                    <span class="fc-intel-status fc-intel-status--@PerformanceClass(row.Signal)">@row.Signal</span>
                                                    <div class="fc-intel-table__sub">@row.Commentary</div>
                                                </td>
                                            </tr>
