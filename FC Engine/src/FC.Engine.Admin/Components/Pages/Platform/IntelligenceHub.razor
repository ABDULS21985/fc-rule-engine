                                <span class="fc-intel-chip">@_workspace.ModelRisk.PerformanceAlertCount performance alerts</span>
                                <span class="fc-intel-chip">@_workspace.ModelRisk.ChangeReviewCount material changes</span>
                            </div>
                        </article>

