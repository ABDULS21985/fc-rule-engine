    private int SuppressedFalsePositiveCount =>
        _screeningRun?.Results.Count(row =>
            GetScreeningDecision(row.Subject) == "False Positive"
            && _falsePositiveLibrary.Any(entry => entry.MatchKey == BuildFalsePositiveMatchKey(row))) ?? 0;

    private int SanctionsFalsePositiveLibraryCount =>
        _clientStateLoaded
            ? _falsePositiveLibrary.Count
            : _workspace?.Sanctions.PersistedFalsePositiveCount ?? 0;

    private int SanctionsDecisionAuditCount =>
        _clientStateLoaded
            ? _screeningAuditTrail.Count
            : _workspace?.Sanctions.PersistedReviewAuditCount ?? 0;

    private async Task LoadClientStateAsync()
    {
        await LoadSanctionsWorkflowStateAsync();
        await LoadModelApprovalWorkflowStateAsync();
        await LoadResilienceClientStateAsync();
        _clientStateLoaded = true;
    }

    private async Task LoadSanctionsWorkflowStateAsync()
    {
        try
        {
            var workflowState = await IntelligenceService.GetSanctionsWorkflowStateAsync();

            _falsePositiveLibrary = workflowState.FalsePositiveLibrary
                .Select(x => new SanctionsFalsePositiveLibraryEntry
                {
                    MatchKey = x.MatchKey,
                    Subject = x.Subject,
                    MatchedName = x.MatchedName,
                    SourceCode = x.SourceCode,
                    RiskLevel = x.RiskLevel,
                    ReviewedAtUtc = x.ReviewedAtUtc
                })
                .ToList();

            _screeningAuditTrail = workflowState.AuditTrail
                .Select(x => new SanctionsDecisionAuditEntry
                {
                    ReviewedAtUtc = x.ReviewedAtUtc,
                    Subject = x.Subject,
                    MatchedName = x.MatchedName,
                    SourceCode = x.SourceCode,
                    PreviousDecision = x.PreviousDecision,
                    Decision = x.Decision
                })
                .ToList();

            ApplyPersistedSanctionsDecisions(workflowState.LatestDecisions);
            RebuildSanctionsPack();
        }
        catch
        {
            _falsePositiveLibrary = [];
            _screeningAuditTrail = [];
            RebuildSanctionsPack();
        }
    }

    private async Task LoadModelApprovalWorkflowStateAsync()
    {
        try
        {
            var workflowState = await IntelligenceService.GetModelApprovalWorkflowStateAsync();

            _modelApprovalStages.Clear();
            foreach (var stage in workflowState.Stages)
            {
                _modelApprovalStages[stage.WorkflowKey] = stage.Stage;
            }

            _modelApprovalAuditTrail = workflowState.AuditTrail
                .Select(x => new ModelApprovalAuditEntry
                {
                    ChangedAtUtc = x.ChangedAtUtc,
                    ModelCode = x.ModelCode,
                    ModelName = x.ModelName,
                    Artifact = x.Artifact,
                    PreviousStage = x.PreviousStage,
                    Stage = x.Stage
                })
                .ToList();
        }
        catch
        {
            _modelApprovalStages.Clear();
            _modelApprovalAuditTrail = [];
        }
    }

    private async Task LoadResilienceClientStateAsync()
    {
        try
        {
            var assessmentState = await IntelligenceService.GetResilienceAssessmentStateAsync();
            _resilienceAssessmentResponses.Clear();

            foreach (var response in assessmentState.Responses.Where(x => x.Score is >= 1 and <= 5))
            {
                _resilienceAssessmentResponses[response.QuestionId] = response.Score;
            }

            if (_workspace is not null)
            {
                _workspace.Resilience.PersistedAssessmentResponseCount = assessmentState.Responses.Count;
                _workspace.Resilience.LastAssessmentUpdatedAt = assessmentState.Responses
                    .OrderByDescending(x => x.AnsweredAtUtc)
                    .FirstOrDefault()?.AnsweredAtUtc;
            }
        }
        catch
        {
            _resilienceAssessmentResponses.Clear();

            if (_workspace is not null)
            {
                _workspace.Resilience.PersistedAssessmentResponseCount = 0;
                _workspace.Resilience.LastAssessmentUpdatedAt = null;
            }
        }
    }

    private void ApplyPersistedSanctionsDecisions(IReadOnlyList<SanctionsWorkflowDecisionState>? latestDecisions = null)
    {
        if (_screeningRun is null)
        {
            return;
        }

        var decisions = latestDecisions ?? _screeningAuditTrail
            .GroupBy(BuildPersistedSanctionsMatchKey, StringComparer.OrdinalIgnoreCase)
            .Select(g => new SanctionsWorkflowDecisionState
            {
                MatchKey = g.Key,
                Decision = g.OrderByDescending(x => x.ReviewedAtUtc).First().Decision,
                ReviewedAtUtc = g.Max(x => x.ReviewedAtUtc)
            })
            .ToList();

        var latestDecisionByKey = decisions.ToDictionary(x => x.MatchKey, x => x.Decision, StringComparer.OrdinalIgnoreCase);
        foreach (var row in _screeningRun.Results)
        {
            if (latestDecisionByKey.TryGetValue(BuildFalsePositiveMatchKey(row), out var decision))
            {
                _screeningDecisions[row.Subject] = decision;
            }
        }
    }

    private static string BuildFalsePositiveMatchKey(SanctionsScreeningResultRow row) =>
        $"{NormalizeKeyPart(row.Subject)}|{NormalizeKeyPart(row.SourceCode)}|{NormalizeKeyPart(row.MatchedName)}";

    private static string BuildPersistedSanctionsMatchKey(SanctionsDecisionAuditEntry row) =>
        $"{NormalizeKeyPart(row.Subject)}|{NormalizeKeyPart(row.SourceCode)}|{NormalizeKeyPart(row.MatchedName)}";

    private static string NormalizeKeyPart(string value) =>
        new string((value ?? string.Empty)
            .Trim()
            .ToUpperInvariant()
            .Where(char.IsLetterOrDigit)
            .ToArray());

