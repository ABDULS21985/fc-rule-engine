                    new DashboardMetricRow("Open incidents", _workspace.Resilience.OpenIncidentCount.ToString(CultureInfo.InvariantCulture), "Operational resilience incidents still unresolved in the population.", _workspace.Resilience.OpenIncidentCount > 0 ? "Watch" : "Current")
                ],
                "deputy" =>
                [
                    new DashboardMetricRow("Overdue obligations", _workspace.KnowledgeGraph.InstitutionObligations.Count(x => x.Status is "Overdue" or "Attention Required").ToString(CultureInfo.InvariantCulture), "Filing obligations already requiring supervisory escalation.", _workspace.KnowledgeGraph.InstitutionObligations.Any(x => x.Status is "Overdue" or "Attention Required") ? "Critical" : "Current"),
                    new DashboardMetricRow("Due soon obligations", _workspace.InstitutionScorecards.Sum(x => x.DueSoonObligations).ToString(CultureInfo.InvariantCulture), "Population-wide obligations due inside the short-term attention window.", _workspace.InstitutionScorecards.Sum(x => x.DueSoonObligations) > 0 ? "Watch" : "Current"),
