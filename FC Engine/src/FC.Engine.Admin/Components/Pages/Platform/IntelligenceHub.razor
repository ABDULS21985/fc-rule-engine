    private static TfsReturnPreview BuildTfsPreview(
        IReadOnlyList<SanctionsScreeningResultRow> results,
        Func<string, string> decisionSelector)
    {
        var confirmedRows = results.Where(x => decisionSelector(x.Subject) == "Confirm Match").ToList();
        var falsePositives = results.Count(x => decisionSelector(x.Subject) == "False Positive");
        var escalations = results.Count(x => decisionSelector(x.Subject) is "Review" or "Escalate");
        var reviewedPopulation = confirmedRows.Count + falsePositives;

        return new TfsReturnPreview
        {
            ScreeningCount = results.Count,
            MatchesFound = results.Count(x => x.Disposition != "Clear"),
            PotentialMatches = escalations,
            ConfirmedMatches = confirmedRows.Count,
            FalsePositiveCount = falsePositives,
            AssetsFrozenCount = confirmedRows.Count(x => x.RiskLevel is "critical" or "high"),
            FalsePositiveRatePercent = reviewedPopulation == 0 ? 0d : falsePositives / (double)reviewedPopulation * 100d,
            WatchlistSources = results
                .Where(x => decisionSelector(x.Subject) != "Clear" && !string.Equals(x.SourceCode, "N/A", StringComparison.OrdinalIgnoreCase))
                .Select(x => x.SourceCode)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(x => x, StringComparer.OrdinalIgnoreCase)
                .ToList(),
            StrDraftRequired = confirmedRows.Count > 0,
            Narrative = confirmedRows.Count > 0
                ? $"Confirmed hits remain across {confirmedRows.Count} screened subject(s); compliance escalation and TFS reporting should proceed."
                : escalations > 0
                    ? $"{escalations} screened subject(s) still require analyst review before the TFS return is finalized."
                    : "The current screening run does not contain confirmed sanctions hits."
        };
    }

    private static List<StrDraftRow> BuildStrDrafts(
        IReadOnlyList<SanctionsScreeningResultRow> results,
        DateTime screenedAtUtc,
        Func<string, string> decisionSelector)
    {
        return results
            .Select((row, index) => new { Row = row, Index = index, Decision = decisionSelector(row.Subject) })
            .Where(x => x.Decision is "Confirm Match" or "Escalate")
            .Select(x =>
            {
                var freezeRecommended = x.Row.RiskLevel is "critical" or "high";
                var dueAt = screenedAtUtc.AddHours(freezeRecommended ? 24 : 48);
                var priority = x.Row.RiskLevel switch
                {
                    "critical" => "Critical",
                    "high" => "High",
                    "medium" => "High",
                    _ => "Medium"
                };
                var status = x.Decision == "Escalate" ? "Escalated" : "Ready";
                var narrative = $"Automated sanctions screening on {screenedAtUtc:dd MMM yyyy HH:mm} UTC identified {x.Row.Subject} as a {x.Decision.ToLowerInvariant()} item after matching {x.Row.MatchedName} on {x.Row.SourceName} ({x.Row.SourceCode}) at {x.Row.MatchScore.ToString("0.0", CultureInfo.InvariantCulture)}% confidence. The record is rated {x.Row.RiskLevel} risk and should move to compliance review for STR packaging and goAML decisioning.";

                return new StrDraftRow
                {
                    DraftId = $"STR-{screenedAtUtc:yyyyMMddHHmm}-{x.Index + 1:00}",
                    Subject = x.Row.Subject,
                    MatchedName = x.Row.MatchedName,
                    SourceCode = x.Row.SourceCode,
                    SourceName = x.Row.SourceName,
                    RiskLevel = x.Row.RiskLevel,
                    Decision = x.Decision,
                    Status = status,
                    Priority = priority,
                    ScorePercent = x.Row.MatchScore,
                    FreezeRecommended = freezeRecommended,
                    ScreenedAtUtc = screenedAtUtc,
                    ReviewDueAtUtc = dueAt,
                    SuspicionBasis = $"Match to {x.Row.MatchedName} on {x.Row.SourceName} at {x.Row.MatchScore.ToString("0.0", CultureInfo.InvariantCulture)}% confidence with a {x.Row.RiskLevel} risk rating.",
                    GoAmlPayloadSummary = freezeRecommended
                        ? "Package as urgent STR review with asset-freeze decision, evidence trail, and control-owner escalation."
                        : "Package as STR review with analyst memo, supporting evidence, and enhanced due-diligence recommendation.",
                    Narrative = narrative,
                    RecommendedActions =
                    [
                        freezeRecommended ? "Confirm asset-freeze decision with treasury and operations." : "Escalate to the AML investigations queue.",
                        "Attach screening evidence, analyst review notes, and watchlist provenance.",
                        "Prepare goAML-aligned STR package for compliance officer sign-off."
                    ]
                };
            })
            .OrderByDescending(x => x.Priority == "Critical")
            .ThenByDescending(x => x.Priority == "High")
            .ThenByDescending(x => x.ScorePercent)
            .ThenBy(x => x.Subject, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static List<SanctionsSupervisoryPackRow> BuildSanctionsPackRows(
        IReadOnlyList<SanctionsWatchlistSource> sources,
        DateTime lastUpdatedAt,
        SanctionsScreeningRun? screeningRun,
        TfsReturnPreview tfsPreview,
        IReadOnlyList<StrDraftRow> strDrafts,
        IReadOnlyList<SanctionsFalsePositiveLibraryEntry> falsePositiveLibrary,
        IReadOnlyList<SanctionsDecisionAuditEntry> auditTrail,
        SanctionsTransactionScreeningResult? transactionResult,
        int suppressedFalsePositiveCount)
    {
        var rows = new List<SanctionsSupervisoryPackRow>();

        var syncAgeHours = Math.Max(0d, (DateTime.UtcNow - lastUpdatedAt).TotalHours);
        var integrationSignal = syncAgeHours > 48d
            ? "Critical"
            : syncAgeHours > 24d || sources.Count < 6
                ? "Watch"
                : "Ready";

        rows.Add(new SanctionsSupervisoryPackRow(
            "SAN-01",
            "Watchlist Integration",
            sources.Count,
            integrationSignal,
            $"{sources.Count} source(s) | last sync {lastUpdatedAt:dd MMM HH:mm} UTC",
            syncAgeHours > 48d
                ? "One or more watchlist feeds appear stale for more than 48 hours."
                : syncAgeHours > 24d
                    ? "Watchlist refresh is aging toward the supervisory tolerance window."
                    : "Global and domestic watchlist feeds are within the expected refresh horizon.",
            integrationSignal == "Critical"
                ? "Refresh sanctions feeds immediately and validate parser health."
                : integrationSignal == "Watch"
                    ? "Review feed freshness and confirm the next automated pull."
                    : "Maintain daily watchlist refresh and source reconciliation."));

        var screeningSignal = screeningRun is null
            ? "Watch"
            : screeningRun.MatchCount == 0
                ? "Ready"
                : tfsPreview.PotentialMatches > 0
                    ? "Watch"
                    : "Ready";

        rows.Add(new SanctionsSupervisoryPackRow(
            "SAN-02",
            "Batch Screening Engine",
            screeningRun?.Results.Count ?? 0,
            screeningSignal,
            screeningRun is null
                ? "No screening run currently loaded"
                : $"{screeningRun.MatchCount}/{screeningRun.TotalSubjects} subject(s) flagged at {screeningRun.ThresholdPercent.ToString("0", CultureInfo.InvariantCulture)}% threshold",
            screeningRun is null
                ? "No batch screening evidence is currently available in the workspace."
                : screeningRun.MatchCount == 0
                    ? "The current run cleared all screened subjects at the configured threshold."
                    : "The current run contains sanctions hits requiring workflow review or escalation.",
            screeningRun is null
                ? "Run a fresh sanctions screening pass before finalizing the supervisory pack."
                : tfsPreview.PotentialMatches > 0
                    ? "Complete analyst review for all pending matches."
                    : "Archive the completed screening run with analyst sign-off."));

        var alertSignal = tfsPreview.ConfirmedMatches > 0
            ? "Critical"
            : tfsPreview.PotentialMatches > 0
                ? "Watch"
                : screeningRun is null
                    ? "Watch"
                    : "Ready";

        rows.Add(new SanctionsSupervisoryPackRow(
            "SAN-03",
            "Alert Review Workflow",
            screeningRun?.Results.Count ?? 0,
            alertSignal,
            $"{tfsPreview.ConfirmedMatches} confirmed | {tfsPreview.PotentialMatches} pending | {auditTrail.Count} audit event(s)",
            tfsPreview.ConfirmedMatches > 0
                ? "Confirmed sanctions hits are present and require documented escalation."
                : tfsPreview.PotentialMatches > 0
                    ? "Potential matches remain in analyst review."
                    : screeningRun is null
                        ? "Workflow review has not started because there is no active screening run."
                        : "All reviewed alerts are currently cleared or documented as false positives.",
            tfsPreview.ConfirmedMatches > 0
                ? "Escalate confirmed hits to compliance and freeze-control review."
                : tfsPreview.PotentialMatches > 0
                    ? "Resolve all pending reviews and capture analyst rationale."
                    : "Retain the audit trail and keep review rules current."));

        var falsePositiveSignal = falsePositiveLibrary.Count == 0
            ? "Watch"
            : suppressedFalsePositiveCount > 0
                ? "Ready"
                : "Watch";

        rows.Add(new SanctionsSupervisoryPackRow(
            "SAN-04",
            "False-Positive Control",
            falsePositiveLibrary.Count,
            falsePositiveSignal,
            $"{falsePositiveLibrary.Count} library entry(ies) | {suppressedFalsePositiveCount} suppressed in current run",
            falsePositiveLibrary.Count == 0
                ? "No false-positive memory has been established yet."
                : suppressedFalsePositiveCount > 0
                    ? "Known false positives were successfully suppressed in the active screening flow."
                    : "False-positive decisions exist, but none were exercised in the active run.",
            falsePositiveLibrary.Count == 0
                ? "Begin curating dismissed matches to reduce repeat alert noise."
                : "Review library hygiene and remove stale dismissals during periodic QA."));

        var tfsSignal = tfsPreview.ConfirmedMatches > 0
            ? "Critical"
            : tfsPreview.PotentialMatches > 0
                ? "Watch"
                : screeningRun is null
                    ? "Watch"
                    : "Ready";

        rows.Add(new SanctionsSupervisoryPackRow(
            "SAN-05",
            "TFS Return Readiness",
            tfsPreview.ScreeningCount,
            tfsSignal,
            $"{tfsPreview.ScreeningCount} screened | {tfsPreview.MatchesFound} flagged | {tfsPreview.WatchlistSources.Count} source(s)",
            tfsPreview.Narrative,
            tfsPreview.ConfirmedMatches > 0
                ? "Prepare the NFIU_TFS return with confirmed-hit evidence and asset-freeze controls."
                : tfsPreview.PotentialMatches > 0
                    ? "Close pending reviews before finalizing the TFS metrics."
                    : screeningRun is null
                        ? "Run screening before issuing the TFS readiness view."
                        : "TFS metrics are in a clear posture for the current reviewed run."));

        var criticalDrafts = strDrafts.Count(x => x.Priority == "Critical");
        var draftSignal = criticalDrafts > 0
            ? "Critical"
            : strDrafts.Count > 0
                ? "Watch"
                : screeningRun is null
                    ? "Watch"
                    : "Ready";

        rows.Add(new SanctionsSupervisoryPackRow(
            "SAN-06",
            "STR Draft Centre",
            strDrafts.Count,
            draftSignal,
            $"{strDrafts.Count} draft(s) | {criticalDrafts} critical | {strDrafts.Count(x => x.Status == "Escalated")} escalated",
            strDrafts.Count == 0
                ? "No STR packets are currently open."
                : $"{strDrafts.First().Subject} leads the current STR queue at {strDrafts.First().Priority.ToLowerInvariant()} priority.",
            criticalDrafts > 0
                ? "Advance critical STR drafts to compliance sign-off immediately."
                : strDrafts.Count > 0
                    ? "Complete analyst packaging and goAML review for all open drafts."
                    : "Maintain the STR queue in reserve until new confirmed hits appear."));

        var transactionSignal = transactionResult is null
            ? "Watch"
            : transactionResult.ControlDecision.Equals("Block", StringComparison.OrdinalIgnoreCase)
                ? "Critical"
                : transactionResult.ControlDecision.Equals("Escalate", StringComparison.OrdinalIgnoreCase)
                  || transactionResult.ControlDecision.Equals("Hold", StringComparison.OrdinalIgnoreCase)
                    ? "Watch"
                    : "Ready";

        rows.Add(new SanctionsSupervisoryPackRow(
            "SAN-07",
            "Transaction Screening Control",
            transactionResult?.PartyResults.Count ?? 0,
            transactionSignal,
            transactionResult is null
                ? "No live transaction-screening decision is loaded"
                : $"{transactionResult.ControlDecision} | {transactionResult.PartyResults.Count} screened party result(s)",
            transactionResult is null
                ? "No transaction-level control decision is currently available."
                : transactionResult.Narrative,
            transactionResult is null
                ? "Run a transaction screening check for the current case mix."
                : transactionResult.ControlDecision.Equals("Block", StringComparison.OrdinalIgnoreCase)
                    ? "Block the payment path and escalate to sanctions operations."
                    : transactionResult.ControlDecision.Equals("Escalate", StringComparison.OrdinalIgnoreCase)
                      || transactionResult.ControlDecision.Equals("Hold", StringComparison.OrdinalIgnoreCase)
                        ? "Escalate the payment for enhanced review before release."
                        : "Record the clear decision and retain the screening evidence."));

        return rows;
    }

    private string GetModelApprovalStage(ModelApprovalQueueRow row) =>
        _modelApprovalStages.TryGetValue(row.WorkflowKey, out var stage) ? stage : row.CurrentStage;

    private async Task UpdateModelApprovalStageAsync(ModelApprovalQueueRow row, ChangeEventArgs args)
    {
        var stage = args.Value?.ToString()?.Trim();
        if (string.IsNullOrWhiteSpace(stage))
        {
            return;
        }

        var previousStage = GetModelApprovalStage(row);
        await IntelligenceService.RecordModelApprovalStageAsync(new ModelApprovalWorkflowCommand
        {
            WorkflowKey = row.WorkflowKey,
            ModelCode = row.ModelCode,
            ModelName = row.ModelName,
            Artifact = row.Artifact,
            PreviousStage = previousStage,
            Stage = stage,
            ChangedAtUtc = DateTime.UtcNow
        });

        _modelApprovalStages[row.WorkflowKey] = stage;
        await LoadModelApprovalWorkflowStateAsync();
    }

    private string ModelWorkflowHeadline =>
        _workspace is null || _workspace.ModelRisk.ApprovalQueue.Count == 0
            ? "No material model changes currently require staged approval."
            : $"{ModelStageCount("Validation Team")} item(s) sit with validation and {ModelStageCount("Board Review")} await board attention.";

    private string ModelWorkflowNarrative =>
        _workspace is null || _workspace.ModelRisk.ApprovalQueue.Count == 0
            ? "Approval routing will appear when material model changes enter the governance flow."
            : $"{ModelStageCount("Model Owner")} item(s) remain with model owners, {ModelStageCount("Model Risk Committee")} require committee challenge, and {ModelStageCount("Approved")} have already cleared the workflow.";

    private int ModelStageCount(string stage) =>
        _workspace?.ModelRisk.ApprovalQueue.Count(row => GetModelApprovalStage(row) == stage) ?? 0;

    private int ModelApprovalAuditCount =>
        _clientStateLoaded
            ? _modelApprovalAuditTrail.Count
            : _workspace?.ModelRisk.PersistedApprovalAuditCount ?? 0;

    private static string FormatTimestamp(DateTime value) => value.ToString("dd MMM yyyy, HH:mm", CultureInfo.InvariantCulture);

    private static string FormatMinuteVariance(int? varianceMinutes) =>
        varianceMinutes.HasValue
            ? varianceMinutes.Value == 0
                ? "On target"
                : varianceMinutes.Value > 0
                    ? $"+{varianceMinutes.Value} mins vs target"
                    : $"{varianceMinutes.Value} mins vs target"
            : "Awaiting recovery evidence";

