@page "/dashboard/platform"
@attribute [Authorize(Policy = "PlatformAdmin")]
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Models
@using FC.Engine.Infrastructure.Charts
@inject IDashboardService DashboardService
@inject ChartJsInterop Charts

<PageTitle>Platform Dashboard</PageTitle>

<div class="fc-platform37-shell">
    <PageHeader Title="Platform Dashboard"
                Subtitle="Commercial pulse, tenant adoption, and filing reliability across the live portfolio"
                CountBadge="@(_data?.TenantStats.TotalActiveTenants)"
                StatusBadge="@ResolveStatusBadge()"
                StatusVariant="@ResolveStatusVariant()">
        <PrimaryAction>
            <div class="fc-platform37-header-actions">
                <span class="fc-platform37-header-chip">
                    <span class="fc-platform37-header-chip-label">Snapshot</span>
                    <strong>@(_data?.GeneratedAt.ToString("dd MMM yyyy · HH:mm 'UTC'") ?? "Refreshing live view")</strong>
                </span>
                <a href="/platform/health" class="fc-platform37-header-link">Platform Health</a>
                <a href="/platform/tenants" class="fc-platform37-header-link">Tenant Portfolio</a>
                <a href="/billing/revenue" class="fc-platform37-header-link fc-platform37-header-link--accent">Revenue</a>
            </div>
        </PrimaryAction>
    </PageHeader>

    @if (_loading)
    {
        <section class="fc-platform37-loading" role="status" aria-label="Loading platform dashboard">
            <div class="fc-platform37-loading-hero"></div>
            <div class="fc-platform37-loading-grid">
                @for (var i = 0; i < 6; i++)
                {
                    <div class="fc-platform37-loading-card"></div>
                }
            </div>
            <div class="fc-platform37-loading-panels">
                @for (var i = 0; i < 5; i++)
                {
                    <div class="fc-platform37-loading-panel"></div>
                }
            </div>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="fc-platform37-error-card" role="alert">
            <div class="fc-platform37-error-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" width="26" height="26">
                    <circle cx="12" cy="12" r="9"></circle>
                    <path d="M12 8v5"></path>
                    <path d="M12 16h.01"></path>
                </svg>
            </div>
            <div class="fc-platform37-error-copy">
                <span class="fc-platform37-section-kicker">Platform data unavailable</span>
                <h2>We could not materialise the control-room snapshot.</h2>
                <p>@_error</p>
            </div>
            <div class="fc-platform37-error-actions">
                <a href="/platform/health" class="fc-platform37-btn fc-platform37-btn--ghost">Review platform health</a>
                <a href="/billing/revenue" class="fc-platform37-btn">Open revenue cockpit</a>
            </div>
        </section>
    }
    else if (_data is not null)
    {
        var attentionSignals = BuildAttentionSignals(_data);
        var bannerTone = ResolveBannerTone(attentionSignals);
        var controlScore = ComputeControlScore(_data);
        var topPlan = _data.Revenue.RevenueByPlan.FirstOrDefault();
        var topModule = _data.ModuleAdoption.FirstOrDefault();
        var topTenant = _data.TopTenantsByUsage.FirstOrDefault();
        var totalModuleRevenue = _data.Revenue.RevenueByModule.Sum(x => x.Amount);
        var totalUsage = Math.Max(1, _data.FilingAnalytics.TotalReturnsSubmittedThisPeriod);
        var validationTotal = _data.FilingAnalytics.TopValidationErrors.Sum(x => x.Count);

        <section class="fc-platform37-alertbar fc-platform37-alertbar--@bannerTone">
            <div class="fc-platform37-alert-copy">
                <span class="fc-platform37-section-kicker">Control pulse</span>
                <h2>@BuildBannerHeadline(attentionSignals, _data)</h2>
                <p>@BuildBannerDetail(attentionSignals, _data)</p>
            </div>
            <div class="fc-platform37-alert-pills">
                @foreach (var signal in attentionSignals.Take(3))
                {
                    <a href="@signal.Href" class="fc-platform37-alert-pill fc-platform37-alert-pill--@signal.Tone">
                        <span class="fc-platform37-alert-pill-dot" aria-hidden="true"></span>
                        <span>@signal.Title</span>
                    </a>
                }
            </div>
        </section>

        <section class="fc-platform37-overview">
            <article class="fc-platform37-hero-card" style="--stagger: 0;">
                <div class="fc-platform37-hero-kicker">
                    <span class="fc-platform37-hero-kicker-dot" aria-hidden="true"></span>
                    Platform command center
                </div>

                <div class="fc-platform37-hero-topline">
                    <div class="fc-platform37-hero-copy">
                        <h2>Revenue, reliability, and tenant momentum in one live cockpit.</h2>
                        <p>
                            The platform is currently carrying <strong>@FormatCurrencyCompact(_data.Revenue.Mrr)</strong> in monthly run-rate
                            across <strong>@_data.TenantStats.TotalActiveTenants active tenants</strong>, with
                            <strong> @FormatPercentage(_data.FilingAnalytics.OnTimeRatePercent)</strong> on-time filing performance this period.
                        </p>
                    </div>
                    <div class="fc-platform37-control-score">
                        <span>Control score</span>
                        <strong>@controlScore.ToString("0")</strong>
                        <small>@BuildControlNarrative(controlScore)</small>
                    </div>
                </div>

                <div class="fc-platform37-hero-metrics">
                    <div class="fc-platform37-hero-metric">
                        <span class="fc-platform37-hero-metric-label">Monthly recurring revenue</span>
                        <strong>@FormatCurrencyCompact(_data.Revenue.Mrr)</strong>
                        <small>@topPlan?.Label contributing most to the run-rate</small>
                    </div>
                    <div class="fc-platform37-hero-metric">
                        <span class="fc-platform37-hero-metric-label">Annualised run-rate</span>
                        <strong>@FormatCurrencyCompact(_data.Revenue.Arr)</strong>
                        <small>Current contract mix extrapolated over 12 months</small>
                    </div>
                    <div class="fc-platform37-hero-metric">
                        <span class="fc-platform37-hero-metric-label">Submission throughput</span>
                        <strong>@_data.FilingAnalytics.TotalReturnsSubmittedThisPeriod.ToString("N0")</strong>
                        <small>@FormatPercentage(_data.FilingAnalytics.OnTimeRatePercent) filed on time this period</small>
                    </div>
                </div>

                <div class="fc-platform37-story-pills">
                    <span class="fc-platform37-story-pill">Lead plan: @(topPlan?.Label ?? "No plan revenue yet")</span>
                    <span class="fc-platform37-story-pill">Top module: @(topModule?.ModuleName ?? "No module adoption yet")</span>
                    <span class="fc-platform37-story-pill">Lead tenant: @(topTenant?.TenantName ?? "No tenant activity yet")</span>
                    <span class="fc-platform37-story-pill fc-platform37-story-pill--accent">@BuildNetMovementLabel(_data.TenantStats)</span>
                </div>

                <div class="fc-platform37-hero-actions">
                    <a href="/platform/tenants" class="fc-platform37-btn">Explore tenant portfolio</a>
                    <a href="/platform/module-analytics" class="fc-platform37-btn fc-platform37-btn--ghost">Module analytics</a>
                    <a href="/platform/billing-ops" class="fc-platform37-btn fc-platform37-btn--ghost">Billing operations</a>
                </div>
            </article>

            <div class="fc-platform37-kpi-bento">
                <article class="fc-platform37-kpi-card fc-platform37-kpi-card--emerald" style="--stagger: 1;">
                    <span class="fc-platform37-kpi-label">Active tenants</span>
                    <strong>@_data.TenantStats.TotalActiveTenants.ToString("N0")</strong>
                    <p>@_data.TenantStats.NewThisMonth.ToString("N0") new this month</p>
                </article>
                <article class="fc-platform37-kpi-card fc-platform37-kpi-card--gold" style="--stagger: 2;">
                    <span class="fc-platform37-kpi-label">Net movement</span>
                    <strong>@BuildNetMovementNumber(_data.TenantStats)</strong>
                    <p>@_data.TenantStats.ChurnedThisMonth.ToString("N0") churned this month</p>
                </article>
                <article class="fc-platform37-kpi-card fc-platform37-kpi-card--teal" style="--stagger: 3;">
                    <span class="fc-platform37-kpi-label">Active sessions</span>
                    <strong>@_data.PlatformHealth.ActiveSessions.ToString("N0")</strong>
                    <p>Institution and portal users active in the last 30 minutes</p>
                </article>
                <article class="fc-platform37-kpi-card fc-platform37-kpi-card--blue" style="--stagger: 4;">
                    <span class="fc-platform37-kpi-label">P95 latency</span>
                    <strong>@FormatMilliseconds(_data.PlatformHealth.ApiLatencyP95Ms)</strong>
                    <p>P99 tail at @FormatMilliseconds(_data.PlatformHealth.ApiLatencyP99Ms)</p>
                </article>
                <article class="fc-platform37-kpi-card fc-platform37-kpi-card--coral" style="--stagger: 5;">
                    <span class="fc-platform37-kpi-label">Error rate</span>
                    <strong>@FormatPercentage(_data.PlatformHealth.ErrorRatePercent)</strong>
                    <p>Rejected or failed submissions within the 30-day operating window</p>
                </article>
                <article class="fc-platform37-kpi-card fc-platform37-kpi-card--sage" style="--stagger: 6;">
                    <span class="fc-platform37-kpi-label">Validation volume</span>
                    <strong>@validationTotal.ToString("N0")</strong>
                    <p>@_data.FilingAnalytics.TopValidationErrors.Count hotspot rules surfaced in the latest analysis</p>
                </article>
            </div>
        </section>

        <section class="fc-platform37-grid">
            <article class="fc-platform37-panel fc-platform37-panel--span-5" style="--stagger: 7;">
                <div class="fc-platform37-panel-head">
                    <div>
                        <span class="fc-platform37-section-kicker">Revenue architecture</span>
                        <h3>Plan mix and commercial concentration</h3>
                    </div>
                    <span class="fc-platform37-panel-pill">@FormatCurrencyCompact(_data.Revenue.Mrr) MRR</span>
                </div>
                <p class="fc-platform37-panel-copy">The doughnut shows where monthly revenue is concentrated across subscription plans.</p>

                <div class="fc-platform37-plan-layout">
                    @if (_data.Revenue.RevenueByPlan.Count > 0)
                    {
                        <div class="fc-platform37-chart-wrap fc-platform37-chart-wrap--compact">
                            <canvas id="platformRevenuePlanChart"></canvas>
                        </div>
                    }
                    else
                    {
                        <div class="fc-platform37-empty">No active subscription revenue has been recorded yet.</div>
                    }

                    <div class="fc-platform37-ranking-list">
                        @foreach (var row in _data.Revenue.RevenueByPlan.Take(5))
                        {
                            <div class="fc-platform37-ranking-row">
                                <div>
                                    <strong>@row.Label</strong>
                                    <span>@BuildShareLabel(row.Amount, _data.Revenue.Mrr) of MRR</span>
                                </div>
                                <span class="fc-platform37-ranking-value">@FormatCurrencyCompact(row.Amount)</span>
                            </div>
                        }
                    </div>
                </div>
            </article>

            <article class="fc-platform37-panel fc-platform37-panel--span-7" style="--stagger: 8;">
                <div class="fc-platform37-panel-head">
                    <div>
                        <span class="fc-platform37-section-kicker">Tenant momentum</span>
                        <h3>Who is driving filing activity right now</h3>
                    </div>
                    <span class="fc-platform37-panel-pill">@_data.TopTenantsByUsage.Count active leaders</span>
                </div>
                <p class="fc-platform37-panel-copy">Ranked by submitted returns in the current reporting window.</p>

                @if (_data.TopTenantsByUsage.Count == 0)
                {
                    <div class="fc-platform37-empty">Tenant activity will appear here once submissions begin flowing this period.</div>
                }
                else
                {
                    <div class="fc-platform37-tenant-stack">
                        @foreach (var entry in _data.TopTenantsByUsage.Take(6).Select((tenant, index) => new { tenant, index }))
                        {
                            var share = BuildSharePercent(entry.tenant.ReturnsSubmitted, totalUsage);
                            <a href="/platform/tenants/@entry.tenant.TenantId" class="fc-platform37-tenant-row">
                                <div class="fc-platform37-rank">@((entry.index + 1).ToString("00"))</div>
                                <div class="fc-platform37-tenant-main">
                                    <strong>@entry.tenant.TenantName</strong>
                                    <span>@entry.tenant.ReturnsSubmitted.ToString("N0") returns submitted</span>
                                </div>
                                <div class="fc-platform37-tenant-meter" aria-hidden="true">
                                    <span style="width: @share.ToString("0.##")%;"></span>
                                </div>
                                <div class="fc-platform37-tenant-share">@share.ToString("0.#")%</div>
                            </a>
                        }
                    </div>
                }
            </article>

            <article class="fc-platform37-panel fc-platform37-panel--span-4" style="--stagger: 9;">
                <div class="fc-platform37-panel-head">
                    <div>
                        <span class="fc-platform37-section-kicker">Latency profile</span>
                        <h3>Processing tail under the microscope</h3>
                    </div>
                    <span class="fc-platform37-panel-pill">@FormatMilliseconds(_data.PlatformHealth.ApiLatencyP95Ms)</span>
                </div>
                <p class="fc-platform37-panel-copy">P50, P95, and P99 submission processing speeds over the rolling 30-day window.</p>

                <div class="fc-platform37-chart-wrap">
                    <canvas id="platformLatencyChart"></canvas>
                </div>

                <div class="fc-platform37-inline-metrics">
                    <div class="fc-platform37-inline-metric">
                        <span>P50</span>
                        <strong>@FormatMilliseconds(_data.PlatformHealth.ApiLatencyP50Ms)</strong>
                    </div>
                    <div class="fc-platform37-inline-metric">
                        <span>P95</span>
                        <strong>@FormatMilliseconds(_data.PlatformHealth.ApiLatencyP95Ms)</strong>
                    </div>
                    <div class="fc-platform37-inline-metric">
                        <span>P99</span>
                        <strong>@FormatMilliseconds(_data.PlatformHealth.ApiLatencyP99Ms)</strong>
                    </div>
                </div>
            </article>

            <article class="fc-platform37-panel fc-platform37-panel--span-4" style="--stagger: 10;">
                <div class="fc-platform37-panel-head">
                    <div>
                        <span class="fc-platform37-section-kicker">Attention queue</span>
                        <h3>Signals requiring operator judgment</h3>
                    </div>
                    <span class="fc-platform37-panel-pill">@attentionSignals.Count signal@(attentionSignals.Count == 1 ? string.Empty : "s")</span>
                </div>
                <p class="fc-platform37-panel-copy">Advisory only. These are platform signals, not automated actions.</p>

                <div class="fc-platform37-signal-stack">
                    @foreach (var signal in attentionSignals.Take(4))
                    {
                        <a href="@signal.Href" class="fc-platform37-signal-row fc-platform37-signal-row--@signal.Tone">
                            <div class="fc-platform37-signal-marker" aria-hidden="true"></div>
                            <div class="fc-platform37-signal-copy">
                                <strong>@signal.Title</strong>
                                <span>@signal.Detail</span>
                            </div>
                            <span class="fc-platform37-signal-link">@signal.LinkLabel</span>
                        </a>
                    }
                </div>
            </article>

            <article class="fc-platform37-panel fc-platform37-panel--span-4" style="--stagger: 11;">
                <div class="fc-platform37-panel-head">
                    <div>
                        <span class="fc-platform37-section-kicker">Validation hotspots</span>
                        <h3>Where filing friction is concentrating</h3>
                    </div>
                    <span class="fc-platform37-panel-pill">@validationTotal.ToString("N0") findings</span>
                </div>
                <p class="fc-platform37-panel-copy">The heaviest validation failures over the last 90 days.</p>

                @if (_data.FilingAnalytics.TopValidationErrors.Count > 0)
                {
                    <div class="fc-platform37-chart-wrap">
                        <canvas id="platformValidationChart"></canvas>
                    </div>
                    var leadValidation = _data.FilingAnalytics.TopValidationErrors[0];
                    <div class="fc-platform37-footnote">
                        Lead hotspot: <strong>@leadValidation.RuleId</strong> on <strong>@leadValidation.Field</strong> with
                        <strong> @leadValidation.Count.ToString("N0")</strong> occurrences.
                    </div>
                }
                else
                {
                    <div class="fc-platform37-empty">No recurring validation hotspots are recorded in the current lookback window.</div>
                }
            </article>

            <article class="fc-platform37-panel fc-platform37-panel--span-6" style="--stagger: 12;">
                <div class="fc-platform37-panel-head">
                    <div>
                        <span class="fc-platform37-section-kicker">Adoption velocity</span>
                        <h3>Which modules are becoming portfolio defaults</h3>
                    </div>
                    <span class="fc-platform37-panel-pill">@_data.ModuleAdoption.Count modules</span>
                </div>
                <p class="fc-platform37-panel-copy">Adoption rate is measured as the percentage of active tenants with the module enabled.</p>

                @if (_data.ModuleAdoption.Count > 0)
                {
                    <div class="fc-platform37-chart-wrap">
                        <canvas id="platformAdoptionChart"></canvas>
                    </div>

                    <div class="fc-platform37-ranking-list fc-platform37-ranking-list--spaced">
                        @foreach (var module in _data.ModuleAdoption.Take(5))
                        {
                            var share = BuildSharePercent(module.AdoptionRate, 100m);
                            <div class="fc-platform37-ranking-row">
                                <div class="fc-platform37-ranking-main">
                                    <strong>@module.ModuleName</strong>
                                    <span>@module.ActiveTenants.ToString("N0") active tenants</span>
                                </div>
                                <div class="fc-platform37-progress-track" aria-hidden="true">
                                    <span style="width: @share.ToString("0.##")%;"></span>
                                </div>
                                <span class="fc-platform37-ranking-value">@FormatPercentage(module.AdoptionRate)</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="fc-platform37-empty">Module adoption will populate once subscriptions and active modules are provisioned.</div>
                }
            </article>

            <article class="fc-platform37-panel fc-platform37-panel--span-6" style="--stagger: 13;">
                <div class="fc-platform37-panel-head">
                    <div>
                        <span class="fc-platform37-section-kicker">Module monetisation</span>
                        <h3>Revenue concentration across active module catalog</h3>
                    </div>
                    <span class="fc-platform37-panel-pill">@FormatCurrencyCompact(totalModuleRevenue) module billings</span>
                </div>
                <p class="fc-platform37-panel-copy">Shows which optional modules are driving recurring commercial uplift.</p>

                @if (_data.Revenue.RevenueByModule.Count > 0)
                {
                    <div class="fc-platform37-chart-wrap">
                        <canvas id="platformRevenueModuleChart"></canvas>
                    </div>

                    <div class="fc-platform37-ranking-list fc-platform37-ranking-list--spaced">
                        @foreach (var row in _data.Revenue.RevenueByModule.Take(5))
                        {
                            <div class="fc-platform37-ranking-row">
                                <div class="fc-platform37-ranking-main">
                                    <strong>@row.Label</strong>
                                    <span>@BuildShareLabel(row.Amount, totalModuleRevenue) of module revenue</span>
                                </div>
                                <span class="fc-platform37-ranking-value">@FormatCurrencyCompact(row.Amount)</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="fc-platform37-empty">No module-specific recurring revenue has been booked yet.</div>
                }
            </article>
        </section>
    }
</div>

<style>
    .fc-platform37-shell {
        display: grid;
        gap: 1.5rem;
    }

    .fc-platform37-header-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 0.75rem;
        align-items: center;
    }

    .fc-platform37-header-chip,
    .fc-platform37-header-link {
        border-radius: 999px;
        border: 1px solid rgba(0, 107, 63, 0.12);
        background: rgba(255, 255, 255, 0.85);
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.06);
        backdrop-filter: blur(18px);
        color: #17324d;
    }

    .fc-platform37-header-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.72rem 1rem;
        font-size: 0.88rem;
    }

    .fc-platform37-header-chip-label {
        color: #6a7280;
        text-transform: uppercase;
        letter-spacing: 0.11em;
        font-size: 0.68rem;
        font-weight: 700;
    }

    .fc-platform37-header-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.72rem 1rem;
        text-decoration: none;
        font-weight: 700;
        transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
    }

    .fc-platform37-header-link:hover {
        transform: translateY(-1px);
        border-color: rgba(0, 107, 63, 0.2);
        box-shadow: 0 22px 48px rgba(15, 23, 42, 0.09);
        color: #17324d;
    }

    .fc-platform37-header-link--accent {
        background: linear-gradient(135deg, rgba(200, 164, 21, 0.16), rgba(255, 255, 255, 0.96));
    }

    .fc-platform37-loading {
        display: grid;
        gap: 1rem;
        min-height: 60vh;
    }

    .fc-platform37-loading-hero,
    .fc-platform37-loading-card,
    .fc-platform37-loading-panel {
        position: relative;
        overflow: hidden;
        border-radius: 28px;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(245, 248, 242, 0.96));
        border: 1px solid rgba(226, 232, 240, 0.9);
        box-shadow: 0 18px 44px rgba(15, 23, 42, 0.05);
    }

    .fc-platform37-loading-hero::after,
    .fc-platform37-loading-card::after,
    .fc-platform37-loading-panel::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(110deg, transparent 8%, rgba(255, 255, 255, 0.78) 30%, transparent 52%);
        transform: translateX(-100%);
        animation: fc-platform37-shimmer 1.4s infinite;
    }

    .fc-platform37-loading-hero {
        min-height: 260px;
    }

    .fc-platform37-loading-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: 1rem;
    }

    .fc-platform37-loading-card {
        min-height: 150px;
    }

    .fc-platform37-loading-panels {
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 1rem;
    }

    .fc-platform37-loading-panel {
        min-height: 320px;
        grid-column: span 4;
    }

    .fc-platform37-error-card,
    .fc-platform37-alertbar,
    .fc-platform37-hero-card,
    .fc-platform37-kpi-card,
    .fc-platform37-panel {
        position: relative;
        overflow: hidden;
        border-radius: 28px;
        border: 1px solid rgba(226, 232, 240, 0.92);
        background: rgba(255, 255, 255, 0.94);
        box-shadow: 0 22px 60px rgba(15, 23, 42, 0.06);
        backdrop-filter: blur(18px);
        animation: fc-platform37-rise 620ms cubic-bezier(.2, .75, .25, 1) both;
        animation-delay: calc(var(--stagger, 0) * 70ms);
    }

    .fc-platform37-error-card {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 1.25rem;
        padding: 1.5rem;
        align-items: center;
    }

    .fc-platform37-error-icon {
        width: 64px;
        height: 64px;
        border-radius: 22px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, rgba(185, 28, 28, 0.12), rgba(251, 191, 36, 0.1));
        color: #b91c1c;
    }

    .fc-platform37-error-copy h2 {
        margin: 0.3rem 0 0.55rem;
        font-size: clamp(1.5rem, 2vw, 2rem);
        color: #142033;
    }

    .fc-platform37-error-copy p {
        margin: 0;
        color: #5f6877;
        max-width: 58ch;
    }

    .fc-platform37-error-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 0.75rem;
    }

    .fc-platform37-alertbar {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) auto;
        gap: 1.5rem;
        padding: 1.45rem 1.55rem;
        align-items: center;
    }

    .fc-platform37-alertbar::before,
    .fc-platform37-hero-card::before,
    .fc-platform37-panel::before {
        content: "";
        position: absolute;
        inset: -25% auto auto -10%;
        width: 240px;
        height: 240px;
        border-radius: 50%;
