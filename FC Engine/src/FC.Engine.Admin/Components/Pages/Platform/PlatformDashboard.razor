@page "/dashboard/platform"
@attribute [Authorize(Policy = "PlatformAdmin")]
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Models
@using FC.Engine.Infrastructure.Charts
@inject IDashboardService DashboardService
@inject ChartJsInterop Charts

<PageTitle>Platform Dashboard</PageTitle>

@if (_loading)
{
    <div class="fc-dash17-loading">Loading platform dashboard...</div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="fc-dash17-error">@_error</div>
}
else if (_data is not null)
{
    <div class="fc-dash17-platform">
        <header class="fc-dash17-header">
            <div>
                <h1>Platform Dashboard</h1>
                <p>Revenue, adoption, health, and filing analytics across tenants</p>
            </div>
            <div class="fc-dash17-score-chip">Updated @_data.GeneratedAt.ToString("dd MMM yyyy HH:mm")</div>
        </header>

        <section class="fc-dash17-kpi-grid">
            <article class="fc-dash17-kpi-card">
                <h3>Active Tenants</h3>
                <div class="fc-dash17-kpi-value">@_data.TenantStats.TotalActiveTenants</div>
                <p>@_data.TenantStats.NewThisMonth new · @_data.TenantStats.ChurnedThisMonth churned</p>
            </article>
            <article class="fc-dash17-kpi-card">
                <h3>MRR</h3>
                <div class="fc-dash17-kpi-value">NGN @_data.Revenue.Mrr.ToString("N2")</div>
                <p>ARR: NGN @_data.Revenue.Arr.ToString("N2")</p>
            </article>
            <article class="fc-dash17-kpi-card">
                <h3>API Latency</h3>
                <div class="fc-dash17-kpi-value">p95 @_data.PlatformHealth.ApiLatencyP95Ms.ToString("0") ms</div>
                <p>p50 @_data.PlatformHealth.ApiLatencyP50Ms.ToString("0") · p99 @_data.PlatformHealth.ApiLatencyP99Ms.ToString("0")</p>
            </article>
            <article class="fc-dash17-kpi-card">
                <h3>On-Time Filing Rate</h3>
                <div class="fc-dash17-kpi-value">@_data.FilingAnalytics.OnTimeRatePercent.ToString("0.##")%</div>
                <p>@_data.FilingAnalytics.TotalReturnsSubmittedThisPeriod returns this period</p>
            </article>
        </section>

        <section class="fc-dash17-chart-grid">
            <article class="fc-dash17-chart-card">
                <h3>Revenue by Plan</h3>
                <div class="fc-dash17-chart-wrap"><canvas id="platformRevenuePlanChart"></canvas></div>
            </article>
            <article class="fc-dash17-chart-card">
                <h3>Revenue by Module</h3>
                <div class="fc-dash17-chart-wrap"><canvas id="platformRevenueModuleChart"></canvas></div>
            </article>
            <article class="fc-dash17-chart-card">
                <h3>Module Adoption</h3>
                <div class="fc-dash17-chart-wrap"><canvas id="platformAdoptionChart"></canvas></div>
            </article>
            <article class="fc-dash17-chart-card">
                <h3>Platform Health</h3>
                <div class="fc-dash17-chart-wrap"><canvas id="platformHealthChart"></canvas></div>
            </article>
        </section>

        <section class="fc-dash17-table-wrap">
            <h3>Top Tenants by Usage</h3>
            <table class="fc-dash17-table" aria-label="Top tenants by usage">
                <thead>
                    <tr>
                        <th>Tenant</th>
                        <th>Returns Submitted</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tenant in _data.TopTenantsByUsage)
                    {
                        <tr>
                            <td>@tenant.TenantName</td>
                            <td>@tenant.ReturnsSubmitted</td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>

        <section class="fc-dash17-table-wrap">
            <h3>Top Validation Errors</h3>
            <table class="fc-dash17-table" aria-label="Top validation errors">
                <thead>
                    <tr>
                        <th>Rule</th>
                        <th>Field</th>
                        <th>Count</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _data.FilingAnalytics.TopValidationErrors)
                    {
                        <tr>
                            <td>@item.RuleId</td>
                            <td>@item.Field</td>
                            <td>@item.Count</td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    </div>
}

@code {
    private PlatformDashboardData? _data;
    private bool _loading = true;
    private bool _chartsRendered;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _data = await DashboardService.GetPlatformDashboard();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_data is null || _chartsRendered)
        {
            return;
        }

        await Charts.RenderBarChart("platformRevenuePlanChart", BuildRevenueTrend(_data.Revenue.RevenueByPlan, "MRR by Plan"));
        await Charts.RenderBarChart("platformRevenueModuleChart", BuildRevenueTrend(_data.Revenue.RevenueByModule, "MRR by Module"));
        await Charts.RenderBarChart("platformAdoptionChart", BuildAdoptionTrend(_data.ModuleAdoption));
        await Charts.RenderDoughnutChart("platformHealthChart", BuildHealthTrend(_data.PlatformHealth));

        _chartsRendered = true;
    }

    private static TrendData BuildRevenueTrend(List<RevenueBreakdownItem> rows, string title)
    {
        return new TrendData
        {
            Title = title,
            Labels = rows.Select(r => r.Label).ToList(),
            Datasets =
            {
                new TrendDataset
                {
                    Label = "Amount",
                    Data = rows.Select(r => r.Amount).ToList(),
                    BackgroundColor = "#1d4ed8",
                    BorderColor = "#1d4ed8"
                }
            }
        };
    }

    private static TrendData BuildAdoptionTrend(List<ModuleAdoptionItem> rows)
    {
        return new TrendData
        {
            Title = "Module Adoption",
            Labels = rows.Select(r => r.ModuleCode).ToList(),
            Datasets =
            {
                new TrendDataset
                {
                    Label = "Adoption %",
                    Data = rows.Select(r => r.AdoptionRate).ToList(),
                    BackgroundColor = "#0f766e",
                    BorderColor = "#0f766e"
                }
            }
        };
    }

    private static TrendData BuildHealthTrend(PlatformHealthMetrics health)
    {
        return new TrendData
        {
            Title = "Platform Health",
            Labels = new List<string> { "Active Sessions", "Error Rate %" },
            Datasets =
            {
                new TrendDataset
                {
                    Label = "Health",
                    Data = new List<decimal> { health.ActiveSessions, health.ErrorRatePercent },
                    BackgroundColor = "#d97706",
                    BorderColor = "#d97706"
                }
            }
        };
    }
}
