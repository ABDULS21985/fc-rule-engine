@code {
    private PlatformDashboardData? _data;
    private bool _loading = true;
    private bool _chartsRendered;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _data = await DashboardService.GetPlatformDashboard();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_data is null || _chartsRendered)
        {
            return;
        }

        if (_data.Revenue.RevenueByPlan.Count > 0)
        {
            await Charts.InitChart("platformRevenuePlanChart", BuildRevenuePlanSpec(_data.Revenue.RevenueByPlan));
        }

        if (_data.Revenue.RevenueByModule.Count > 0)
        {
            await Charts.InitChart("platformRevenueModuleChart", BuildRevenueModuleSpec(_data.Revenue.RevenueByModule));
        }

        if (_data.ModuleAdoption.Count > 0)
        {
            await Charts.InitChart("platformAdoptionChart", BuildAdoptionSpec(_data.ModuleAdoption));
        }

        await Charts.InitChart("platformLatencyChart", BuildLatencySpec(_data.PlatformHealth));

        if (_data.FilingAnalytics.TopValidationErrors.Count > 0)
        {
            await Charts.InitChart("platformValidationChart", BuildValidationSpec(_data.FilingAnalytics.TopValidationErrors));
        }

        _chartsRendered = true;
    }

    private string ResolveStatusBadge()
    {
        if (_loading)
        {
            return "Refreshing snapshot";
        }

        if (!string.IsNullOrWhiteSpace(_error))
        {
            return "Data unavailable";
        }

        if (_data is null)
        {
            return "Awaiting snapshot";
        }

        var score = ComputeControlScore(_data);
        return score >= 85m
            ? "Operationally live"
            : score >= 70m
                ? "Monitoring closely"
                : "Attention required";
    }

    private string ResolveStatusVariant()
    {
        if (_loading)
        {
            return "info";
        }

        if (!string.IsNullOrWhiteSpace(_error))
        {
            return "danger";
        }

        if (_data is null)
        {
            return "neutral";
        }

        var score = ComputeControlScore(_data);
        return score >= 85m
            ? "success"
            : score >= 70m
                ? "warning"
                : "danger";
    }

    private static object BuildRevenuePlanSpec(List<RevenueBreakdownItem> rows)
    {
        return new
        {
            type = "doughnut",
            labels = rows.Select(r => r.Label).ToArray(),
            datasets = new[]
            {
                new
                {
                    label = "Plan mix",
                    data = rows.Select(r => r.Amount).ToArray()
                }
            }
        };
    }

    private static object BuildRevenueModuleSpec(List<RevenueBreakdownItem> rows)
    {
        return new
        {
            type = "bar",
            yFormat = "currency",
            tooltipFormat = "currency",
            labels = rows.Select(r => r.Label).ToArray(),
            datasets = new[]
            {
                new
                {
                    label = "Monthly revenue",
                    data = rows.Select(r => r.Amount).ToArray(),
                    color = "primary"
                }
            }
        };
    }

    private static object BuildAdoptionSpec(List<ModuleAdoptionItem> rows)
    {
        return new
        {
            type = "bar",
            yFormat = "percent",
            labels = rows.Select(r => BuildModuleAxisLabel(r)).ToArray(),
            datasets = new[]
            {
                new
                {
                    label = "Adoption %",
                    data = rows.Select(r => r.AdoptionRate).ToArray(),
                    color = "success"
                }
            }
        };
    }

    private static object BuildLatencySpec(PlatformHealthMetrics health)
    {
        return new
        {
            type = "line",
            yLabel = "Milliseconds",
            labels = new[] { "P50", "P95", "P99" },
            datasets = new[]
            {
                new
                {
                    label = "Latency",
                    data = new[] { health.ApiLatencyP50Ms, health.ApiLatencyP95Ms, health.ApiLatencyP99Ms },
                    color = "info",
                    fill = false
                }
            }
        };
    }

    private static object BuildValidationSpec(List<ValidationErrorAggregate> rows)
    {
        var displayRows = rows.Take(6).ToList();

        return new
        {
            type = "bar",
            yFormat = "compact",
            labels = displayRows.Select(BuildValidationAxisLabel).ToArray(),
            datasets = new[]
            {
                new
                {
                    label = "Occurrences",
                    data = displayRows.Select(r => (decimal)r.Count).ToArray(),
                    color = "warning"
                }
            }
        };
    }

    private static decimal ComputeControlScore(PlatformDashboardData data)
    {
        var latencyScore = ComputeLatencyScore(data.PlatformHealth.ApiLatencyP95Ms);
        var reliabilityScore = ComputeReliabilityScore(data.PlatformHealth.ErrorRatePercent);
        return Math.Round((latencyScore + reliabilityScore + data.FilingAnalytics.OnTimeRatePercent) / 3m, 1);
    }

    private static decimal ComputeLatencyScore(decimal p95Ms)
    {
        return p95Ms switch
        {
            <= 500m => 100m,
            <= 900m => 92m,
            <= 1500m => 82m,
            <= 2200m => 70m,
            <= 3200m => 56m,
            <= 4500m => 42m,
            _ => 28m
        };
    }

    private static decimal ComputeReliabilityScore(decimal errorRatePercent)
    {
        return Math.Max(0m, Math.Min(100m, 100m - (errorRatePercent * 12m)));
    }

    private static string BuildControlNarrative(decimal score)
    {
        return score switch
        {
            >= 90m => "Strong posture across revenue, reliability, and filing discipline.",
            >= 80m => "Healthy operating state with only light friction pockets.",
            >= 70m => "Stable overall, but several signals deserve operator attention.",
            >= 60m => "Mixed posture. Reliability or filing pressure is softening the portfolio.",
            _ => "Fragile posture. Escalate operating issues before the platform absorbs more drag."
        };
    }

    private static List<AttentionSignal> BuildAttentionSignals(PlatformDashboardData data)
    {
        var signals = new List<AttentionSignal>();

        if (data.PlatformHealth.ErrorRatePercent >= 2m)
        {
            signals.Add(new AttentionSignal(
                "critical",
                "Reliability slippage",
                $"{FormatPercentage(data.PlatformHealth.ErrorRatePercent)} of processed submissions were rejected or failed in the rolling 30-day window.",
                "/platform/health",
                "Health center"));
        }

        if (data.PlatformHealth.ApiLatencyP95Ms >= 1800m)
        {
            signals.Add(new AttentionSignal(
                "warning",
                "Latency pressure",
                $"P95 processing is at {FormatMilliseconds(data.PlatformHealth.ApiLatencyP95Ms)} and the long tail is stretching to {FormatMilliseconds(data.PlatformHealth.ApiLatencyP99Ms)}.",
                "/platform/health",
                "Inspect latency"));
        }

        if (data.FilingAnalytics.OnTimeRatePercent < 95m)
        {
            signals.Add(new AttentionSignal(
                "warning",
                "Timeliness softening",
                $"{FormatPercentage(data.FilingAnalytics.OnTimeRatePercent)} of returns are arriving on time this period.",
                "/platform/compliance-health",
                "Review filing health"));
        }

        if (data.TenantStats.ChurnedThisMonth > 0)
        {
            var tone = data.TenantStats.ChurnedThisMonth > data.TenantStats.NewThisMonth ? "critical" : "warning";
            signals.Add(new AttentionSignal(
                tone,
                "Tenant churn watch",
                $"{data.TenantStats.ChurnedThisMonth.ToString("N0")} tenants churned this month against {data.TenantStats.NewThisMonth.ToString("N0")} new logos added.",
                "/platform/foresight/churn-risk",
                "Churn dashboard"));
        }

        var leadValidation = data.FilingAnalytics.TopValidationErrors.FirstOrDefault();
        if (leadValidation is not null && leadValidation.Count >= 5)
        {
            signals.Add(new AttentionSignal(
                "info",
                "Validation hotspot",
                $"{leadValidation.RuleId} on {leadValidation.Field} is the dominant recurring failure pattern.",
                "/platform/module-analytics",
                "Analyze modules"));
        }

        if (signals.Count == 0)
        {
            signals.Add(new AttentionSignal(
                "success",
                "Platform operating within expected thresholds",
                "Commercial, reliability, and filing indicators are all currently inside their normal operating bands.",
                "/platform/health",
                "View health"));
        }

        return signals
            .OrderBy(s => ToneRank(s.Tone))
            .ThenBy(s => s.Title)
            .ToList();
    }

    private static int ToneRank(string tone)
    {
        return tone switch
        {
            "critical" => 0,
            "warning" => 1,
            "info" => 2,
            "success" => 3,
            _ => 4
        };
    }

    private static string ResolveBannerTone(IReadOnlyList<AttentionSignal> signals)
    {
        return signals.FirstOrDefault()?.Tone ?? "info";
    }

    private static string BuildBannerHeadline(IReadOnlyList<AttentionSignal> signals, PlatformDashboardData data)
    {
        var lead = signals.FirstOrDefault();
        if (lead is null)
        {
            return "Platform pulse unavailable";
        }

        if (lead.Tone == "success")
        {
            return "The platform is running inside expected control bands.";
        }

        return $"{signals.Count} live signal{(signals.Count == 1 ? string.Empty : "s")} surfaced across tenants, filing reliability, and platform health.";
    }

    private static string BuildBannerDetail(IReadOnlyList<AttentionSignal> signals, PlatformDashboardData data)
    {
        var lead = signals.FirstOrDefault();
        if (lead is null)
        {
            return "Refresh the dashboard to regenerate the control-room snapshot.";
        }

        if (lead.Tone == "success")
        {
            return $"Current view: {FormatCurrencyCompact(data.Revenue.Mrr)} MRR, {FormatPercentage(data.FilingAnalytics.OnTimeRatePercent)} on-time filings, and {data.PlatformHealth.ActiveSessions.ToString("N0")} active sessions.";
        }

        return lead.Detail;
    }

    private static string BuildNetMovementLabel(PlatformTenantStats stats)
    {
        var net = stats.NewThisMonth - stats.ChurnedThisMonth;
        return net switch
        {
            > 0 => $"+{net} net tenant movement",
            < 0 => $"{net} net tenant movement",
            _ => "Flat tenant movement"
        };
    }

    private static string BuildNetMovementNumber(PlatformTenantStats stats)
    {
        var net = stats.NewThisMonth - stats.ChurnedThisMonth;
        return net >= 0 ? $"+{net}" : net.ToString();
    }

    private static string BuildShareLabel(decimal value, decimal total)
    {
        return $"{BuildSharePercent(value, total).ToString("0.#")}%";
    }

    private static decimal BuildSharePercent(decimal value, decimal total)
    {
        if (total <= 0)
        {
            return 0m;
        }

        return Math.Round(value * 100m / total, 2);
    }

    private static string FormatCurrencyCompact(decimal value)
    {
        var abs = Math.Abs(value);

        if (abs >= 1_000_000_000m)
        {
            return $"NGN {(value / 1_000_000_000m):0.##}B";
        }

        if (abs >= 1_000_000m)
        {
            return $"NGN {(value / 1_000_000m):0.##}M";
        }

        if (abs >= 1_000m)
        {
            return $"NGN {(value / 1_000m):0.#}K";
        }

        return $"NGN {value:0.##}";
    }

    private static string FormatPercentage(decimal value)
    {
        return $"{value:0.##}%";
    }

    private static string FormatMilliseconds(decimal value)
    {
        return $"{value:0} ms";
    }

    private static string BuildModuleAxisLabel(ModuleAdoptionItem row)
    {
        if (!string.IsNullOrWhiteSpace(row.ModuleCode) && row.ModuleCode.Length <= 14)
        {
            return row.ModuleCode;
        }

        return row.ModuleName.Length > 16
            ? row.ModuleName[..16] + "..."
            : row.ModuleName;
    }

    private static string BuildValidationAxisLabel(ValidationErrorAggregate row)
    {
        var field = row.Field.Length > 12 ? row.Field[..12] + "..." : row.Field;
        return $"{row.RuleId}/{field}";
    }

    private sealed record AttentionSignal(string Tone, string Title, string Detail, string Href, string LinkLabel);
}
