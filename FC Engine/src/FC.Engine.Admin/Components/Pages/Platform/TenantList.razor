@page "/platform/tenants"
@attribute [Authorize(Policy = "PlatformAdmin")]
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using FC.Engine.Admin.Services
@using FC.Engine.Domain.Enums
@inject PlatformAdminService PlatformService
@inject NavigationManager Navigation

<PageTitle>Tenant List</PageTitle>

<PageHeader Title="Global Tenant List"
            Subtitle="Search, filter, sort, export, and take quick tenant actions." />

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="fc-alert fc-alert--inline fc-alert--success">@_message</div>
}
@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="fc-alert fc-alert--inline fc-alert--error">@_error</div>
}

<div class="fc-card" style="margin-bottom:1rem;">
    <div class="fc-card__body">
        <div class="fc-grid fc-grid-3">
            <div class="fc-form-row">
                <label>Search</label>
                <input class="fc-input" @bind="_query.Search" placeholder="Tenant, slug, email" />
            </div>
            <div class="fc-form-row">
                <label>Status</label>
                <select class="fc-input" @bind="_query.Status">
                    <option value="">All</option>
                    @foreach (var status in Enum.GetNames<TenantStatus>())
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>
            <div class="fc-form-row">
                <label>Plan</label>
                <select class="fc-input" @bind="_query.PlanCode">
                    <option value="">All</option>
                    @foreach (var plan in _data.PlanOptions)
                    {
                        <option value="@plan">@plan</option>
                    }
                </select>
            </div>
            <div class="fc-form-row">
                <label>Licence Type</label>
                <select class="fc-input" @bind="_query.LicenceType">
                    <option value="">All</option>
                    @foreach (var licence in _data.LicenceOptions)
                    {
                        <option value="@licence">@licence</option>
                    }
                </select>
            </div>
            <div class="fc-form-row">
                <label>Min Modules</label>
                <input class="fc-input" type="number" min="0" @bind="_query.MinModuleCount" />
            </div>
            <div class="fc-form-row">
                <label>Sort By</label>
                <select class="fc-input" @bind="_query.SortBy">
                    <option value="name">Name</option>
                    <option value="status">Status</option>
                    <option value="plan">Plan</option>
                    <option value="modules">Modules</option>
                    <option value="users">Users</option>
                    <option value="entities">Entities</option>
                    <option value="mrr">MRR</option>
                    <option value="created">Created</option>
                </select>
            </div>
        </div>

        <div style="display:flex; gap:0.5rem; margin-top:1rem; flex-wrap:wrap; align-items:center;">
            <label style="display:flex; gap:0.35rem; align-items:center; font-size:0.9rem; color:#475569;">
                <input type="checkbox" @bind="_query.SortDescending" />
                Descending
            </label>
            <button class="fc-btn fc-btn--primary" @onclick="LoadAsync" disabled="@_loading">Apply</button>
            <button class="fc-btn fc-btn--outline" @onclick="ResetFilters" disabled="@_loading">Reset</button>
            <button class="fc-btn fc-btn--outline" @onclick="Export" disabled="@_loading">Export Excel</button>
            <span style="margin-left:auto; color:#64748b; font-size:0.9rem;">@_data.Tenants.Count tenant(s)</span>
        </div>
    </div>
</div>

<DataTable TItem="PlatformTenantListItem"
           Items="@_data.Tenants"
           Loading="_loading"
           Sortable="false"
           ShowPagination="true"
           PageSize="25"
           EmptyTitle="No tenants found"
           EmptyText="Try adjusting your search or filters and click Apply."
           SkeletonRows="5">
    <ChildContent>
        <DataColumn TItem="PlatformTenantListItem" Title="Tenant Name" Width="200px">
            <CellTemplate>
                <div style="font-weight:600;">@context.TenantName</div>
                <small style="color:#64748b;">@(context.ContactEmail ?? "-")</small>
            </CellTemplate>
        </DataColumn>
        <DataColumn TItem="PlatformTenantListItem" Title="Slug" Width="140px">
            <CellTemplate><code>@context.TenantSlug</code></CellTemplate>
        </DataColumn>
        <DataColumn TItem="PlatformTenantListItem" Title="Status" Width="120px">
            <CellTemplate>
                <span class="fc-badge @GetStatusBadge(context.Status)">@context.Status</span>
            </CellTemplate>
        </DataColumn>
        <DataColumn TItem="PlatformTenantListItem" Title="Plan" Width="120px">
            <CellTemplate>@context.PlanName</CellTemplate>
        </DataColumn>
        <DataColumn TItem="PlatformTenantListItem" Title="Active Modules" Width="120px">
            <CellTemplate>@context.ActiveModules</CellTemplate>
        </DataColumn>
        <DataColumn TItem="PlatformTenantListItem" Title="Users" Width="80px">
            <CellTemplate>@context.Users</CellTemplate>
        </DataColumn>
        <DataColumn TItem="PlatformTenantListItem" Title="Entities" Width="80px">
            <CellTemplate>@context.Entities</CellTemplate>
        </DataColumn>
        <DataColumn TItem="PlatformTenantListItem" Title="MRR" Width="120px">
            <CellTemplate>NGN @context.Mrr.ToString("N2")</CellTemplate>
        </DataColumn>
        <DataColumn TItem="PlatformTenantListItem" Title="Created" Width="120px">
            <CellTemplate>@context.CreatedAt.ToString("dd MMM yyyy")</CellTemplate>
        </DataColumn>
        <DataColumn TItem="PlatformTenantListItem" Title="Actions" Align="right" Width="220px">
            <CellTemplate>
                <div style="display:flex; gap:0.35rem; flex-wrap:wrap; justify-content:flex-end;">
                    <button class="fc-btn fc-btn--outline fc-btn--xs" @onclick="() => OpenTenant(context.TenantId)" @onclick:stopPropagation="true">View</button>
                    <button class="fc-btn fc-btn--outline fc-btn--xs" @onclick="() => ImpersonateTenant(context.TenantId)" @onclick:stopPropagation="true">Impersonate</button>
                    @if (context.Status == TenantStatus.Active)
                    {
                        <button class="fc-btn fc-btn--xs" style="background:#b91c1c;color:#fff;" @onclick="() => SuspendTenant(context.TenantId)" @onclick:stopPropagation="true">Suspend</button>
                    }
                    else if (context.Status == TenantStatus.PendingActivation || context.Status == TenantStatus.Suspended)
                    {
                        <button class="fc-btn fc-btn--xs" style="background:#166534;color:#fff;" @onclick="() => ActivateTenant(context.TenantId)" @onclick:stopPropagation="true">Activate</button>
                    }
                </div>
            </CellTemplate>
        </DataColumn>
    </ChildContent>
</DataTable>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private PlatformTenantListQuery _query = new();
    private PlatformTenantListResult _data = new();
    private bool _loading = true;
    private string? _error;
    private string? _message;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        _message = null;

        try
        {
            _data = await PlatformService.GetTenantList(_query);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ActivateTenant(Guid tenantId)
    {
        await ExecuteAction(async actor =>
        {
            await PlatformService.ActivateTenant(tenantId, actor);
            _message = "Tenant activated.";
        });
    }

    private async Task SuspendTenant(Guid tenantId)
    {
        await ExecuteAction(async actor =>
        {
            await PlatformService.SuspendTenant(tenantId, actor);
            _message = "Tenant suspended.";
        });
    }

    private void OpenTenant(Guid tenantId)
        => Navigation.NavigateTo($"/platform/tenants/{tenantId}");

    private void ImpersonateTenant(Guid tenantId)
        => Navigation.NavigateTo($"/platform/impersonate?tenantId={tenantId}", forceLoad: true);

    private async Task ResetFilters()
    {
        _query = new PlatformTenantListQuery();
        await LoadAsync();
    }

    private void Export()
    {
        var query = new List<string>();
        AddQuery(query, "search", _query.Search);
        AddQuery(query, "status", _query.Status);
        AddQuery(query, "plan", _query.PlanCode);
        AddQuery(query, "licence", _query.LicenceType);
        AddQuery(query, "sortBy", _query.SortBy);
        AddQuery(query, "sortDesc", _query.SortDescending ? "true" : "false");
        AddQuery(query, "minModules", _query.MinModuleCount?.ToString());

        var qs = query.Count > 0 ? "?" + string.Join("&", query) : string.Empty;
        Navigation.NavigateTo($"/platform/tenants/export{qs}", forceLoad: true);
    }

    private async Task ExecuteAction(Func<string, Task> action)
    {
        _error = null;
        _message = null;
        try
        {
            var actor = await GetActor();
            await action(actor);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task<string> GetActor()
    {
        var state = AuthState is null ? null : await AuthState;
        return state?.User.FindFirst(ClaimTypes.NameIdentifier)?.Value
               ?? state?.User.Identity?.Name
               ?? "platform-admin";
    }

    private static void AddQuery(List<string> list, string key, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            list.Add($"{Uri.EscapeDataString(key)}={Uri.EscapeDataString(value)}");
        }
    }

    private static string GetStatusBadge(TenantStatus status) => status switch
    {
        TenantStatus.Active => "fc-badge--success",
        TenantStatus.PendingActivation => "fc-badge--warning",
        TenantStatus.Suspended => "fc-badge--danger",
        TenantStatus.Deactivated => "fc-badge--neutral",
        _ => "fc-badge--neutral"
    };
}
