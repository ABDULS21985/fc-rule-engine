@page "/platform/health"
@attribute [Authorize(Policy = "PlatformAdmin")]
@using FC.Engine.Admin.Services
@using FC.Engine.Domain.Models
@using FC.Engine.Infrastructure.Charts
@inject PlatformAdminService PlatformService
@inject ChartJsInterop Charts
@implements IDisposable

<PageTitle>Platform Health</PageTitle>

<div class="admin-page">

    <!-- Breadcrumb -->
    <nav class="detail-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Dashboard</a>
        <span class="detail-breadcrumb-sep" aria-hidden="true">/</span>
        <a href="/platform">Platform</a>
        <span class="detail-breadcrumb-sep" aria-hidden="true">/</span>
        <span class="detail-breadcrumb-current">Health</span>
    </nav>

    <!-- Page Header -->
    <div class="admin-header">
        <div class="admin-header-top">
            <div>
                <h1>Platform Health</h1>
                <p class="admin-header-subtitle">Latency, error rate, sessions, queue depth, database, and cache telemetry.</p>
            </div>
        </div>

        @if (_data is not null)
        {
            <div class="fc-chip-group">
                <span class="fc-chip"><span class="fc-chip__count">@_data.ApiLatencyP50Ms.ToString("0") ms</span> Latency p50</span>
                <span class="fc-chip"><span class="fc-chip__count">@_data.ErrorRatePercent.ToString("0.##")%</span> Error Rate</span>
                <span class="fc-chip"><span class="fc-chip__count">@_data.ActiveSessions</span> Active Sessions</span>
                <span class="fc-chip"><span class="fc-chip__count">@_data.QueueDepth</span> Queue Depth</span>
            </div>
        }
    </div>

    <!-- Error Display -->
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="fc-alert fc-alert--inline fc-alert--error">@_error</div>
    }

    <!-- Content -->
    @if (_loading)
    {
        <!-- Skeleton: KPI cards -->
        <div class="portal-grid portal-grid-4" style="margin-bottom:1rem;">
            @for (var i = 0; i < 4; i++)
            {
                <div class="fc-card">
                    <div class="fc-card__body">
                        <div class="skel skel-text" style="width:80px; margin-bottom:0.5rem;"></div>
                        <div class="skel skel-text" style="width:60px; height:1.5rem;"></div>
                    </div>
                </div>
            }
        </div>

        <!-- Skeleton: Infrastructure metrics -->
        <div class="portal-grid portal-grid-3" style="margin-bottom:1rem;">
            @for (var i = 0; i < 3; i++)
            {
                <div class="fc-card">
                    <div class="fc-card__body">
                        <div class="skel skel-text" style="width:120px; margin-bottom:0.75rem;"></div>
                        <div class="skel skel-text" style="width:90px; margin-bottom:0.5rem;"></div>
                        <div class="skel skel-text" style="width:100px;"></div>
                    </div>
                </div>
            }
        </div>

        <!-- Skeleton: Charts -->
        <div class="portal-grid portal-grid-2">
            @for (var i = 0; i < 2; i++)
            {
                <div class="fc-card">
                    <div class="fc-card__header">
                        <div class="skel skel-text" style="width:160px;"></div>
                    </div>
                    <div class="fc-card__body" style="height:320px;">
                        <div class="skel" style="width:100%; height:100%; border-radius:6px;"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (_data is not null)
    {
        <!-- KPI Cards -->
        <div class="portal-grid portal-grid-4" style="margin-bottom:1rem;">
            <div class="fc-card">
                <div class="fc-card__body">
                    <div class="portal-stat-label">Latency p50</div>
                    <div class="portal-stat-value">@_data.ApiLatencyP50Ms.ToString("0") ms</div>
                </div>
            </div>
            <div class="fc-card">
                <div class="fc-card__body">
                    <div class="portal-stat-label">Latency p95</div>
                    <div class="portal-stat-value">@_data.ApiLatencyP95Ms.ToString("0") ms</div>
                </div>
            </div>
            <div class="fc-card">
                <div class="fc-card__body">
                    <div class="portal-stat-label">Latency p99</div>
                    <div class="portal-stat-value">@_data.ApiLatencyP99Ms.ToString("0") ms</div>
                </div>
            </div>
            <div class="fc-card">
                <div class="fc-card__body">
                    <div class="portal-stat-label">Error Rate</div>
                    <div class="portal-stat-value">@_data.ErrorRatePercent.ToString("0.##")%</div>
                </div>
            </div>
        </div>

        <!-- Infrastructure Metrics -->
        <div class="portal-grid portal-grid-3" style="margin-bottom:1rem;">
            <div class="fc-card">
                <div class="fc-card__body">
                    <div class="portal-kv"><span>Active Sessions</span><strong>@_data.ActiveSessions</strong></div>
                    <div class="portal-kv"><span>Queue Depth</span><strong>@_data.QueueDepth</strong></div>
                    <div class="portal-kv"><span>RabbitMQ Pending</span><strong>@_data.RabbitMqPending</strong></div>
                </div>
            </div>
            <div class="fc-card">
                <div class="fc-card__body">
                    <div class="portal-kv"><span>DB Query Duration</span><strong>@_data.DatabaseQueryDurationMs ms</strong></div>
                    <div class="portal-kv"><span>DB Pool Utilisation</span><strong>@_data.DatabasePoolUtilisationPercent.ToString("0.##")%</strong></div>
                </div>
            </div>
            <div class="fc-card">
                <div class="fc-card__body">
                    <div class="portal-kv"><span>Redis Hit Ratio</span><strong>@_data.RedisCacheHitRatioPercent.ToString("0.##")%</strong></div>
                    <div class="portal-kv"><span>Redis Memory</span><strong>@_data.RedisMemoryUsageMb.ToString("0.##") MB</strong></div>
                </div>
            </div>
        </div>

        <!-- Charts -->
        <div class="portal-grid portal-grid-2">
            <div class="fc-card">
                <div class="fc-card__header"><h2 class="fc-card__title">Latency Percentiles</h2></div>
                <div class="fc-card__body" style="height:320px;"><canvas id="healthLatencyChart"></canvas></div>
            </div>
            <div class="fc-card">
                <div class="fc-card__header"><h2 class="fc-card__title">Error Rate (Live Samples)</h2></div>
                <div class="fc-card__body" style="height:320px;"><canvas id="healthErrorTrendChart"></canvas></div>
            </div>
        </div>

        <!-- Auto-refresh indicator -->
        <div style="margin-top:0.75rem; display:flex; align-items:center; gap:0.5rem;">
            <span class="fc-badge fc-badge--success">Auto-refresh</span>
            <span style="color:#64748b; font-size:0.85rem;">Every 30 seconds &middot; Last update: @_lastUpdated.ToString("dd MMM yyyy HH:mm:ss")</span>
        </div>
    }

</div>

@code {
    private PlatformHealthData? _data;
    private bool _loading = true;
    private string? _error;
    private bool _chartDirty;
    private Timer? _refreshTimer;
    private DateTime _lastUpdated = DateTime.UtcNow;
    private readonly Queue<decimal> _errorSamples = new();
    private readonly Queue<string> _errorLabels = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();

        _refreshTimer = new Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadAsync(silent: true);
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_data is null || !_chartDirty)
        {
            return;
        }

        await Charts.RenderBarChart("healthLatencyChart", BuildLatencyChart(_data));
        await Charts.RenderLineChart("healthErrorTrendChart", BuildErrorTrendChart());
        _chartDirty = false;
    }

    private async Task LoadAsync(bool silent = false)
    {
        if (!silent)
        {
            _loading = true;
            _error = null;
        }

        try
        {
            _data = await PlatformService.GetPlatformHealth();
            _lastUpdated = DateTime.UtcNow;

            EnqueueSample(_errorSamples, _data.ErrorRatePercent, 24);
            EnqueueSample(_errorLabels, _lastUpdated.ToString("HH:mm:ss"), 24);

            _chartDirty = true;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            if (!silent)
            {
                _loading = false;
            }
        }
    }

    private static void EnqueueSample<T>(Queue<T> queue, T value, int max)
    {
        queue.Enqueue(value);
        while (queue.Count > max)
        {
            queue.Dequeue();
        }
    }

    private static TrendData BuildLatencyChart(PlatformHealthData data)
    {
        return new TrendData
        {
            Title = "API Latency",
            Labels = new List<string> { "p50", "p95", "p99" },
            Datasets =
            {
                new TrendDataset
                {
                    Label = "Milliseconds",
                    Data = new List<decimal> { data.ApiLatencyP50Ms, data.ApiLatencyP95Ms, data.ApiLatencyP99Ms },
                    BackgroundColor = "#0f766e",
                    BorderColor = "#0f766e"
                }
            }
        };
    }

    private TrendData BuildErrorTrendChart()
    {
        return new TrendData
        {
            Title = "Error Rate Trend",
            Labels = _errorLabels.ToList(),
            Datasets =
            {
                new TrendDataset
                {
                    Label = "5xx Error Rate %",
                    Data = _errorSamples.ToList(),
                    BackgroundColor = "#b91c1c",
                    BorderColor = "#b91c1c"
                }
            }
        };
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
