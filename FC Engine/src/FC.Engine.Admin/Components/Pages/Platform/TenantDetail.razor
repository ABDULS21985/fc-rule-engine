@page "/platform/tenants/{TenantId:guid}"
@attribute [Authorize(Policy = "PlatformAdmin")]
@using FC.Engine.Admin.Services
@using FC.Engine.Domain.Enums
@inject PlatformAdminService PlatformService
@inject NavigationManager Navigation
@inject ToastService Toast

<PageTitle>Tenant Detail</PageTitle>

<PageHeader Title="@(_data?.TenantName ?? "Tenant Detail")"
            BackUrl="/platform/tenants">
    <PrimaryAction>
        @if (_data is not null)
        {
            <button class="fc-btn fc-btn--primary" @onclick="Impersonate" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Impersonate
            </button>
        }
    </PrimaryAction>
</PageHeader>

<div class="fc-page">

    @if (_loading)
    {

        <!-- Skeleton Tabs -->
        <div class="fc-tabs">
            @for (var i = 0; i < 7; i++)
            {
                <div class="fc-skel" style="width:80px;height:32px;border-radius:6px;"></div>
            }
        </div>

        <!-- Skeleton Content Cards -->
        <div class="fc-grid fc-grid-3">
            @for (var i = 0; i < 3; i++)
            {
                <div class="fc-card">
                    <div class="fc-card__body">
                        <div class="fc-skel fc-skel-text" style="width:100%;height:14px;margin-bottom:0.75rem;"></div>
                        <div class="fc-skel fc-skel-text" style="width:70%;height:14px;"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (_data is null)
    {
        <!-- Empty State -->
        <div class="fc-empty">
            <div class="fc-empty-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            <h3 class="fc-empty-title">Tenant not found</h3>
            <p class="fc-empty-text">The requested tenant could not be located. It may have been removed or the ID is invalid.</p>
            <button class="fc-btn fc-btn--outline" @onclick="Back" type="button">Back to Tenants</button>
        </div>
    }
    else
    {
        <!-- Tabs -->
        <div class="fc-tabs">
            <button class="fc-tab @(_tab == "overview" ? "fc-tab-active" : "")" @onclick='() => SetTab("overview")'>Overview</button>
            <button class="fc-tab @(_tab == "subscription" ? "fc-tab-active" : "")" @onclick='() => SetTab("subscription")'>Subscription</button>
            <button class="fc-tab @(_tab == "users" ? "fc-tab-active" : "")" @onclick='() => SetTab("users")'>Users</button>
            <button class="fc-tab @(_tab == "entities" ? "fc-tab-active" : "")" @onclick='() => SetTab("entities")'>Entities</button>
            <button class="fc-tab @(_tab == "filings" ? "fc-tab-active" : "")" @onclick='() => SetTab("filings")'>Filings</button>
            <button class="fc-tab @(_tab == "audit" ? "fc-tab-active" : "")" @onclick='() => SetTab("audit")'>Audit</button>
            <button class="fc-tab @(_tab == "support" ? "fc-tab-active" : "")" @onclick='() => SetTab("support")'>Support</button>
        </div>

        <!-- Overview Tab -->
        @if (_tab == "overview")
        {
            <div class="fc-grid fc-grid-3" style="margin-bottom:1rem;">
                <div class="fc-card">
                    <div class="fc-card__body">
                        <div class="fc-kv"><span>Status</span><strong>
                            @if (_data.Status == TenantStatus.Active)
                            {
                                <span class="fc-badge fc-badge--success">@_data.Status</span>
                            }
                            else
                            {
                                <span class="fc-badge fc-badge--danger">@_data.Status</span>
                            }
                        </strong></div>
                        <div class="fc-kv"><span>Created</span><strong>@_data.CreatedAt.ToString("dd MMM yyyy")</strong></div>
                    </div>
                </div>
                <div class="fc-card">
                    <div class="fc-card__body">
                        <div class="fc-kv"><span>Timezone</span><strong>@_data.Timezone</strong></div>
                        <div class="fc-kv"><span>Currency</span><strong>@_data.DefaultCurrency</strong></div>
                    </div>
                </div>
                <div class="fc-card">
                    <div class="fc-card__body">
                        <div class="fc-kv"><span>Users</span><strong>@_data.Usage.UsersUsed / @_data.Usage.UsersLimit</strong></div>
                        <div class="fc-kv"><span>Modules</span><strong>@_data.Usage.ModulesUsed / @_data.Usage.ModulesLimit</strong></div>
                    </div>
                </div>
            </div>

            <div class="fc-card">
                <div class="fc-card__header"><h2 class="fc-card__title">Contact</h2></div>
                <div class="fc-card__body">
                    <div class="fc-kv"><span>Email</span><strong>@(_data.ContactEmail ?? "-")</strong></div>
                    <div class="fc-kv"><span>Phone</span><strong>@(_data.ContactPhone ?? "-")</strong></div>
                    <div class="fc-kv"><span>Address</span><strong>@(_data.Address ?? "-")</strong></div>
                </div>
            </div>
        }

        <!-- Subscription Tab -->
        @if (_tab == "subscription")
        {
            <div class="fc-card" style="margin-bottom:1rem;">
                <div class="fc-card__header"><h2 class="fc-card__title">Subscription History</h2></div>
                <div class="fc-card__body" style="padding:0;overflow:auto;">
                    <table class="fc-table">
                        <thead>
                            <tr>
                                <th>Plan</th>
                                <th>Status</th>
                                <th>Billing</th>
                                <th>Period</th>
                                <th>Modules</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _data.SubscriptionHistory)
                            {
                                <tr>
                                    <td>@row.PlanName (@row.PlanCode)</td>
                                    <td>
                                        <span class="fc-badge @(row.Status == "Active" ? "fc-badge--success" : row.Status == "Cancelled" ? "fc-badge--danger" : "fc-badge--neutral")">
                                            @row.Status
                                        </span>
                                    </td>
                                    <td>@row.BillingFrequency</td>
                                    <td>@row.CurrentPeriodStart.ToString("dd MMM yyyy") - @row.CurrentPeriodEnd.ToString("dd MMM yyyy")</td>
                                    <td>@string.Join(", ", row.Modules)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="fc-grid fc-grid-2">
                <div class="fc-card">
                    <div class="fc-card__header"><h2 class="fc-card__title">Invoices</h2></div>
                    <div class="fc-card__body" style="padding:0;overflow:auto;max-height:420px;">
                        <table class="fc-table">
                            <thead>
                                <tr>
                                    <th>Invoice</th>
                                    <th>Status</th>
                                    <th>Amount</th>
                                    <th>Due</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in _data.Invoices)
                                {
                                    <tr>
                                        <td>@row.InvoiceNumber</td>
                                        <td>
                                            <span class="fc-badge @(row.Status == "Paid" ? "fc-badge--success" : row.Status == "Overdue" ? "fc-badge--danger" : "fc-badge--warning")">
                                                @row.Status
                                            </span>
                                        </td>
                                        <td>@row.Currency @row.TotalAmount.ToString("N2")</td>
                                        <td>@(row.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="fc-card">
                    <div class="fc-card__header"><h2 class="fc-card__title">Payments</h2></div>
                    <div class="fc-card__body" style="padding:0;overflow:auto;max-height:420px;">
                        <table class="fc-table">
                            <thead>
                                <tr>
                                    <th>Payment</th>
                                    <th>InvoiceId</th>
                                    <th>Status</th>
                                    <th>Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in _data.Payments)
                                {
                                    <tr>
                                        <td>#@row.PaymentId</td>
                                        <td>#@row.InvoiceId</td>
                                        <td>
                                            <span class="fc-badge @(row.Status == "Completed" || row.Status == "Succeeded" ? "fc-badge--success" : row.Status == "Failed" ? "fc-badge--danger" : "fc-badge--warning")">
                                                @row.Status
                                            </span>
                                        </td>
                                        <td>@row.Currency @row.Amount.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Users Tab -->
        @if (_tab == "users")
        {
            <div class="fc-card">
                <div class="fc-card__header"><h2 class="fc-card__title">Users</h2></div>
                <div class="fc-card__body" style="padding:0;overflow:auto;">
                    <table class="fc-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>MFA</th>
                                <th>Last Login</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in _data.Users)
                            {
                                <tr>
                                    <td>@user.DisplayName</td>
                                    <td>@user.Email</td>
                                    <td><span class="fc-badge fc-badge--neutral">@user.Role</span></td>
                                    <td>
                                        @if (user.MfaEnabled)
                                        {
                                            <span class="fc-badge fc-badge--success">Enabled</span>
                                        }
                                        else
                                        {
                                            <span class="fc-badge fc-badge--warning">Disabled</span>
                                        }
                                    </td>
                                    <td>@(user.LastLoginAt?.ToString("dd MMM yyyy HH:mm") ?? "Never")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- Entities Tab -->
        @if (_tab == "entities")
        {
            <div class="fc-card">
                <div class="fc-card__header"><h2 class="fc-card__title">Entities</h2></div>
                <div class="fc-card__body" style="padding:0;overflow:auto;">
                    <table class="fc-table">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Name</th>
                                <th>Type</th>
                                <th>Parent</th>
                                <th>Branches</th>
                                <th>Status</th>
                                <th>Contact</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _data.Entities)
                            {
                                <tr>
                                    <td><code>@row.InstitutionCode</code></td>
                                    <td>@row.InstitutionName</td>
                                    <td><span class="fc-badge fc-badge--neutral">@row.EntityType</span></td>
                                    <td>@(row.ParentInstitutionName ?? "-")</td>
                                    <td>@row.BranchCount</td>
                                    <td>
                                        @if (row.IsActive)
                                        {
                                            <span class="fc-badge fc-badge--success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="fc-badge fc-badge--danger">Inactive</span>
                                        }
                                    </td>
                                    <td>@(row.ContactEmail ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- Filings Tab -->
        @if (_tab == "filings")
        {
            <div class="fc-card">
                <div class="fc-card__header"><h2 class="fc-card__title">Filing Matrix</h2></div>
                <div class="fc-card__body" style="padding:0;overflow:auto;">
                    <table class="fc-table">
                        <thead>
                            <tr>
                                <th>Module</th>
                                <th>Period</th>
                                <th>Deadline</th>
                                <th>RAG</th>
                                <th>Submission</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _data.FilingMatrix)
                            {
                                <tr>
                                    <td>@row.ModuleName</td>
                                    <td>@row.PeriodLabel</td>
                                    <td>@row.Deadline.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <span class="fc-badge @(row.RagStatus == "Red" ? "fc-badge--danger" : row.RagStatus == "Amber" ? "fc-badge--warning" : "fc-badge--success")">
                                            @row.RagStatus
                                        </span>
                                    </td>
                                    <td>
                                        <span class="fc-badge @(row.SubmissionStatus == "Submitted" ? "fc-badge--success" : row.SubmissionStatus == "Overdue" ? "fc-badge--danger" : "fc-badge--neutral")">
                                            @row.SubmissionStatus
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- Audit Tab -->
        @if (_tab == "audit")
        {
            <div class="fc-card">
                <div class="fc-card__header"><h2 class="fc-card__title">Audit Log</h2></div>
                <div class="fc-card__body" style="padding:0;overflow:auto;max-height:560px;">
                    <table class="fc-table">
                        <thead>
                            <tr>
                                <th>When</th>
                                <th>Action</th>
                                <th>Entity</th>
                                <th>Actor</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _data.AuditEntries)
                            {
                                <tr>
                                    <td>@row.PerformedAt.ToString("dd MMM yyyy HH:mm")</td>
                                    <td>@row.Action</td>
                                    <td>@row.EntityType #@row.EntityId</td>
                                    <td>@row.PerformedBy</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- Support Tab -->
        @if (_tab == "support")
        {
            <div class="fc-card">
                <div class="fc-card__header"><h2 class="fc-card__title">Support Tickets</h2></div>
                <div class="fc-card__body" style="padding:0;overflow:auto;">
                    <table class="fc-table">
                        <thead>
                            <tr>
                                <th>Ticket</th>
                                <th>Title</th>
                                <th>Priority</th>
                                <th>Status</th>
                                <th>SLA Due</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _data.SupportTickets)
                            {
                                <tr>
                                    <td>#@row.TicketId</td>
                                    <td>@row.Title</td>
                                    <td>
                                        <span class="fc-badge @(row.Priority == "High" || row.Priority == "Critical" ? "fc-badge--danger" : row.Priority == "Medium" ? "fc-badge--warning" : "fc-badge--neutral")">
                                            @row.Priority
                                        </span>
                                    </td>
                                    <td>
                                        <span class="fc-badge @(row.Status == "Resolved" || row.Status == "Closed" ? "fc-badge--success" : row.Status == "Open" ? "fc-badge--warning" : "fc-badge--neutral")">
                                            @row.Status
                                        </span>
                                    </td>
                                    <td>@row.SlaDueAt.ToString("dd MMM yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public Guid TenantId { get; set; }

    private PlatformTenantDetailData? _data;
    private bool _loading = true;
    private string? _error;
    private string _tab = "overview";

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _data = await PlatformService.GetTenantDetail(TenantId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void SetTab(string tab) => _tab = tab;

    private string TabClass(string tab)
        => _tab == tab ? "fc-btn--primary" : "fc-btn--outline";

    private void Back() => Navigation.NavigateTo("/platform/tenants");

    private void Impersonate()
        => Navigation.NavigateTo($"/platform/impersonate?tenantId={TenantId}", forceLoad: true);
}
