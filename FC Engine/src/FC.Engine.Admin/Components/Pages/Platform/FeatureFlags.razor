@page "/platform/feature-flags"
@attribute [Authorize(Policy = "PlatformAdmin")]
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using FC.Engine.Admin.Services
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Entities
@inject PlatformAdminService PlatformService
@inject IFeatureFlagService FeatureFlagService

<PageTitle>Feature Flags</PageTitle>

<header class="dash-header" role="banner">
    <div class="dash-header-text">
        <h1>Feature Flags</h1>
        <p>Global toggles, gradual rollout, and tenant/plan targeting with audit logging.</p>
    </div>
</header>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="fc-alert fc-alert--inline fc-alert--success">@_message</div>
}
@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="fc-alert fc-alert--inline fc-alert--error">@_error</div>
}

@if (_loading)
{
    <div class="fc-card"><div class="fc-card__body">Loading feature flags...</div></div>
}
else
{
    <div class="portal-grid portal-grid-2" style="margin-bottom:1rem;">
        <section class="fc-card">
            <div class="fc-card__header"><h2 class="fc-card__title">Create / Update Flag</h2></div>
            <div class="fc-card__body">
                <div class="portal-form-row"><label>Flag Code</label><input class="portal-input" @bind="_edit.FlagCode" placeholder="e.g. rg28_beta_console" /></div>
                <div class="portal-form-row"><label>Description</label><input class="portal-input" @bind="_edit.Description" /></div>
                <div class="portal-form-row"><label>Rollout Percent (0-100)</label><input class="portal-input" type="number" min="0" max="100" @bind="_edit.RolloutPercent" /></div>
                <div class="portal-form-row"><label>Allowed Tenants (CSV or JSON array)</label><textarea class="portal-input" rows="3" @bind="_edit.AllowedTenants"></textarea></div>
                <div class="portal-form-row"><label>Allowed Plans (CSV or JSON array)</label><textarea class="portal-input" rows="3" @bind="_edit.AllowedPlans"></textarea></div>
                <div class="portal-form-row" style="display:flex; gap:0.5rem; align-items:center;">
                    <input type="checkbox" @bind="_edit.IsEnabled" /> <label style="margin:0;">Globally Enabled</label>
                </div>
                <div style="display:flex; gap:0.5rem; margin-top:1rem;">
                    <button class="fc-btn fc-btn--primary" @onclick="Save">Save</button>
                    <button class="fc-btn fc-btn--outline" @onclick="ResetForm">Reset</button>
                </div>
            </div>
        </section>

        <section class="fc-card">
            <div class="fc-card__header"><h2 class="fc-card__title">Quick Evaluation</h2></div>
            <div class="fc-card__body">
                <div class="portal-form-row"><label>Flag Code</label><input class="portal-input" @bind="_evalFlagCode" /></div>
                <div class="portal-form-row"><label>Tenant Id (optional)</label><input class="portal-input" @bind="_evalTenantId" placeholder="GUID" /></div>
                <button class="fc-btn fc-btn--outline" @onclick="Evaluate">Evaluate</button>
                @if (_evalResult.HasValue)
                {
                    <div style="margin-top:0.75rem; font-weight:600; color:@(_evalResult.Value ? "#166534" : "#991b1b");">
                        Result: @(_evalResult.Value ? "Enabled" : "Disabled")
                    </div>
                }
            </div>
        </section>
    </div>

    <div class="fc-card">
        <div class="fc-card__header"><h2 class="fc-card__title">Existing Flags</h2></div>
        <div class="fc-card__body" style="padding:0; overflow:auto;">
            <table class="portal-table">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Description</th>
                        <th>Enabled</th>
                        <th>Rollout %</th>
                        <th>Allowed Tenants</th>
                        <th>Allowed Plans</th>
                        <th>Updated</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var flag in _flags)
                    {
                        <tr>
                            <td><code>@flag.FlagCode</code></td>
                            <td>@flag.Description</td>
                            <td>
                                <span class="fc-badge @(flag.IsEnabled ? "fc-badge--success" : "fc-badge--muted")">
                                    @(flag.IsEnabled ? "Enabled" : "Disabled")
                                </span>
                            </td>
                            <td>@flag.RolloutPercent</td>
                            <td style="max-width:200px; overflow:hidden; text-overflow:ellipsis;">@(flag.AllowedTenants ?? "-")</td>
                            <td style="max-width:200px; overflow:hidden; text-overflow:ellipsis;">@(flag.AllowedPlans ?? "-")</td>
                            <td>@flag.UpdatedAt.ToString("dd MMM yyyy HH:mm")</td>
                            <td>
                                <div style="display:flex; gap:0.35rem; flex-wrap:wrap;">
                                    <button class="fc-btn fc-btn--outline fc-btn--xs" @onclick="() => Edit(flag)">Edit</button>
                                    <button class="fc-btn fc-btn--primary fc-btn--xs" @onclick="() => Toggle(flag)">
                                        @(flag.IsEnabled ? "Disable" : "Enable")
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private List<FeatureFlag> _flags = new();
    private UpdateFeatureFlagRequest _edit = new();
    private bool _loading = true;
    private string? _error;
    private string? _message;
    private string _evalFlagCode = string.Empty;
    private string _evalTenantId = string.Empty;
    private bool? _evalResult;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        _message = null;

        try
        {
            _flags = (await PlatformService.GetFeatureFlags()).ToList();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void Edit(FeatureFlag flag)
    {
        _edit = new UpdateFeatureFlagRequest
        {
            FlagCode = flag.FlagCode,
            Description = flag.Description,
            IsEnabled = flag.IsEnabled,
            RolloutPercent = flag.RolloutPercent,
            AllowedTenants = flag.AllowedTenants,
            AllowedPlans = flag.AllowedPlans
        };
    }

    private async Task Save()
    {
        _error = null;
        _message = null;

        if (string.IsNullOrWhiteSpace(_edit.FlagCode) || string.IsNullOrWhiteSpace(_edit.Description))
        {
            _error = "Flag code and description are required.";
            return;
        }

        try
        {
            var actor = await GetActor();
            await PlatformService.UpsertFeatureFlag(_edit, actor);
            _message = "Feature flag saved.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task Toggle(FeatureFlag flag)
    {
        _error = null;
        _message = null;
        try
        {
            var actor = await GetActor();
            await PlatformService.UpsertFeatureFlag(new UpdateFeatureFlagRequest
            {
                FlagCode = flag.FlagCode,
                Description = flag.Description,
                IsEnabled = !flag.IsEnabled,
                RolloutPercent = flag.RolloutPercent,
                AllowedTenants = flag.AllowedTenants,
                AllowedPlans = flag.AllowedPlans
            }, actor);

            _message = $"Flag '{flag.FlagCode}' {(!flag.IsEnabled ? "enabled" : "disabled")}.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void ResetForm()
    {
        _edit = new UpdateFeatureFlagRequest();
        _evalResult = null;
    }

    private async Task Evaluate()
    {
        _error = null;
        _evalResult = null;

        try
        {
            Guid? tenantId = null;
            if (!string.IsNullOrWhiteSpace(_evalTenantId))
            {
                tenantId = Guid.Parse(_evalTenantId.Trim());
            }

            _evalResult = await FeatureFlagService.IsEnabled(_evalFlagCode, tenantId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task<string> GetActor()
    {
        var state = AuthState is null ? null : await AuthState;
        return state?.User.FindFirst(ClaimTypes.NameIdentifier)?.Value
               ?? state?.User.Identity?.Name
               ?? "platform-admin";
    }
}
