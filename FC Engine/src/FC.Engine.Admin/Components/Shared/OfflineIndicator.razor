@*
    OfflineIndicator — Fixed banner that slides down from the top when the browser
    loses internet connectivity, and automatically disappears when the connection returns.
    The actual show/hide logic lives in mobile.js (fcMobile.initOfflineDetection).
*@

<div id="fc-offline-banner"
     class="fc-offline-banner"
     role="alert"
     aria-live="assertive"
     aria-atomic="true">
    <span class="fc-offline-dot" aria-hidden="true"></span>
    <span class="fc-offline-text">No internet connection &mdash; showing cached data</span>
    <span class="fc-offline-cached">Offline</span>
</div>
