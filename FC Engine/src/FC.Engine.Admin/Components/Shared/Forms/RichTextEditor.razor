@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="fc-rte">
    <!-- Toolbar -->
    <div class="fc-rte__toolbar" role="toolbar" aria-label="Text formatting">
        <button class="fc-rte__toolbar-btn" type="button" title="Bold (Ctrl+B)" @onclick='() => ExecCommand("bold")' aria-label="Bold">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h8a4 4 0 014 4 4 4 0 01-4 4H6z" /><path d="M6 12h9a4 4 0 014 4 4 4 0 01-4 4H6z" /></svg>
        </button>
        <button class="fc-rte__toolbar-btn" type="button" title="Italic (Ctrl+I)" @onclick='() => ExecCommand("italic")' aria-label="Italic">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="4" x2="10" y2="4" /><line x1="14" y1="20" x2="5" y2="20" /><line x1="15" y1="4" x2="9" y2="20" /></svg>
        </button>
        <button class="fc-rte__toolbar-btn" type="button" title="Underline (Ctrl+U)" @onclick='() => ExecCommand("underline")' aria-label="Underline">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3v7a6 6 0 006 6 6 6 0 006-6V3" /><line x1="4" y1="21" x2="20" y2="21" /></svg>
        </button>

        <div class="fc-rte__toolbar-sep" aria-hidden="true"></div>

        <button class="fc-rte__toolbar-btn" type="button" title="Bulleted list" @onclick='() => ExecCommand("insertUnorderedList")' aria-label="Bulleted list">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6" /><line x1="8" y1="12" x2="21" y2="12" /><line x1="8" y1="18" x2="21" y2="18" /><line x1="3" y1="6" x2="3.01" y2="6" /><line x1="3" y1="12" x2="3.01" y2="12" /><line x1="3" y1="18" x2="3.01" y2="18" /></svg>
        </button>
        <button class="fc-rte__toolbar-btn" type="button" title="Numbered list" @onclick='() => ExecCommand("insertOrderedList")' aria-label="Numbered list">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="10" y1="6" x2="21" y2="6" /><line x1="10" y1="12" x2="21" y2="12" /><line x1="10" y1="18" x2="21" y2="18" /><path d="M4 6h1v4" /><path d="M4 10h2" /><path d="M6 18H4c0-1 2-2 2-3s-1-1.5-2-1" /></svg>
        </button>

        <div class="fc-rte__toolbar-sep" aria-hidden="true"></div>

        <button class="fc-rte__toolbar-btn" type="button" title="Insert link" @onclick="InsertLink" aria-label="Insert link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71" /><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71" /></svg>
        </button>
        <button class="fc-rte__toolbar-btn" type="button" title="Remove formatting" @onclick='() => ExecCommand("removeFormat")' aria-label="Remove formatting">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 10H3M21 6H3M21 14H3M17 18H3" /></svg>
        </button>
    </div>

    <!-- Editor -->
    <div id="@_editorId"
         class="fc-rte__editor"
         contenteditable="true"
         role="textbox"
         aria-multiline="true"
         aria-label="@(string.IsNullOrEmpty(AriaLabel) ? "Rich text editor" : AriaLabel)"
         data-placeholder="@Placeholder"
         spellcheck="true">
    </div>

    <!-- Footer -->
    @if (MaxLength > 0)
    {
        var charCount = _charCount;
        var isOver = charCount > MaxLength;
        <div class="fc-rte__footer">
            <span class="fc-rte__char-count @(isOver ? "fc-rte__char-count--over" : "")">
                @charCount / @MaxLength
            </span>
        </div>
    }
</div>

@code {
    private string _editorId = $"fc-rte-{Guid.NewGuid():N}";
    private DotNetObjectReference<RichTextEditor>? _dotnetRef;
    private int _charCount;
    private string _currentValue = "";

    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Start typing...";
    [Parameter] public int MaxLength { get; set; }
    [Parameter] public string? AriaLabel { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotnetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("FCForms.initEditor", _editorId, _dotnetRef);

            if (!string.IsNullOrEmpty(Value))
            {
                await JS.InvokeVoidAsync("FCForms.setEditorHtml", _editorId, Value);
                _currentValue = Value;
                _charCount = StripHtml(Value).Length;
            }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_dotnetRef != null && Value != _currentValue)
        {
            _currentValue = Value;
            _charCount = StripHtml(Value).Length;
            try { await JS.InvokeVoidAsync("FCForms.setEditorHtml", _editorId, Value); }
            catch (JSDisconnectedException) { }
        }
    }

    [JSInvokable]
    public async Task OnContentChanged(string html)
    {
        _currentValue = html;
        _charCount = StripHtml(html).Length;
        await ValueChanged.InvokeAsync(html);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ExecCommand(string command)
    {
        try { await JS.InvokeVoidAsync("FCForms.execCommand", _editorId, command, null); }
        catch (JSDisconnectedException) { }
    }

    private async Task InsertLink()
    {
        // Simple prompt-based link insertion
        try
        {
            await JS.InvokeVoidAsync("eval", $@"
                var url = prompt('Enter URL:', 'https://');
                if (url) {{
                    var el = document.getElementById('{_editorId}');
                    if (el) {{ el.focus(); document.execCommand('createLink', false, url); }}
                }}");
        }
        catch (JSDisconnectedException) { }
    }

    private static string StripHtml(string html)
    {
        if (string.IsNullOrEmpty(html)) return "";
        return System.Text.RegularExpressions.Regex.Replace(html, "<[^>]*>", "").Trim();
    }

    public async ValueTask DisposeAsync()
    {
        _dotnetRef?.Dispose();
        await ValueTask.CompletedTask;
    }
}
