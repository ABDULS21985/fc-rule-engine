@inject HelpService Help
@inject IJSRuntime JS
@implements IAsyncDisposable

@* ── Keyboard Shortcut Overlay ────────────────────────────────────────────── *@
@* Registers the "?" key listener via help.js on first render.                *@
@* Also renders the shortcut modal when HelpService.IsShortcutOverlayOpen.   *@

@if (Help.IsShortcutOverlayOpen)
{
    <div class="fc-kbd-overlay-backdrop"
         @onclick="Help.CloseShortcutOverlay"
         role="presentation"
         aria-hidden="true"></div>

    <div class="fc-kbd-overlay"
         role="dialog"
         aria-modal="true"
         aria-label="Keyboard shortcuts"
         @onkeydown="HandleKey">

        <div class="fc-kbd-overlay__header">
            <div class="fc-kbd-overlay__header-left">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                    <rect x="2" y="4" width="20" height="16" rx="2"/>
                    <path d="M8 10h.01M12 10h.01M16 10h.01M8 14h8"/>
                </svg>
                <h2 class="fc-kbd-overlay__title">Keyboard Shortcuts</h2>
            </div>
            <button class="fc-kbd-overlay__close"
                    @onclick="Help.CloseShortcutOverlay"
                    aria-label="Close keyboard shortcuts">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>

        <div class="fc-kbd-overlay__body">
            @foreach (var group in Help.GetShortcuts())
            {
                <div class="fc-kbd-group">
                    <div class="fc-kbd-group__label">@group.Category</div>
                    @foreach (var sc in group.Shortcuts)
                    {
                        <div class="fc-kbd-row">
                            <div class="fc-kbd-keys">
                                @foreach (var key in sc.Keys.Split('/'))
                                {
                                    <kbd class="fc-kbd-badge">@key.Trim()</kbd>
                                }
                            </div>
                            <span class="fc-kbd-desc">@sc.Description</span>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="fc-kbd-overlay__footer">
            Press <kbd class="fc-kbd-badge">?</kbd> to toggle &nbsp;·&nbsp;
            Press <kbd class="fc-kbd-badge">Esc</kbd> to close
        </div>
    </div>
}

@code {
    private DotNetObjectReference<KeyboardShortcutOverlay>? _dotNetRef;

    protected override void OnInitialized() => Help.OnChanged += OnHelpChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("fcHelp.init", _dotNetRef);
        }
    }

    [JSInvokable("OpenShortcutOverlay")]
    public void OpenShortcutOverlay()
    {
        Help.OpenShortcutOverlay();
        InvokeAsync(StateHasChanged);
    }

    private void HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            Help.CloseShortcutOverlay();
    }

    private void OnHelpChanged() => InvokeAsync(StateHasChanged);

    public async ValueTask DisposeAsync()
    {
        Help.OnChanged -= OnHelpChanged;
        try { await JS.InvokeVoidAsync("fcHelp.destroy"); } catch { }
        _dotNetRef?.Dispose();
    }
}
