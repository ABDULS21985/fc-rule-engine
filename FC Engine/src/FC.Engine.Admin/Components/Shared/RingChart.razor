@* CSS-only donut/ring chart component for executive metrics visualization *@

<div class="fc-ia-ring" style="--ring-size: @(Size)px; --ring-value: @ValueClamped; --ring-color: @ColorVar;" role="img" aria-label="@Label: @Value percent">
    <div class="fc-ia-ring-track">
        <div class="fc-ia-ring-fill" aria-hidden="true"></div>
    </div>
    <div class="fc-ia-ring-center">
        <span class="fc-ia-ring-pct">@Value<span class="fc-ia-ring-pct-sign">%</span></span>
        <span class="fc-ia-ring-label">@Label</span>
    </div>
</div>

@code {
    [Parameter] public int Value { get; set; }
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Variant { get; set; } = "green";
    [Parameter] public int Size { get; set; } = 140;

    private int ValueClamped => Math.Clamp(Value, 0, 100);

    private string ColorVar => Variant switch
    {
        "gold" => "var(--cbn-accent)",
        "red" => "var(--cbn-danger)",
        "blue" => "var(--cbn-info)",
        _ => "var(--cbn-success)"
    };
}
