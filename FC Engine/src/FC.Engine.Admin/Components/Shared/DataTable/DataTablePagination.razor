@* Pagination footer bar used by DataTable. *@

<div class="fc-list-footer">
    <div class="fc-list-footer-summary">
        @if (TotalCount == FilteredCount)
        {
            <span>Showing <strong>@StartItem–@EndItem</strong> of <strong>@FilteredCount</strong></span>
        }
        else
        {
            <span>Showing <strong>@StartItem–@EndItem</strong> of <strong>@FilteredCount</strong> <span class="fc-list-footer-filtered">(filtered from @TotalCount)</span></span>
        }
    </div>

    <div class="fc-list-pagination-wrap">
        @if (ShowPageSizeSelector)
        {
            <select class="fc-list-filter-select fc-dt-page-size-select"
                    value="@PageSize"
                    @onchange="OnPageSizeSelectChange"
                    aria-label="Rows per page">
                @foreach (var opt in PageSizeOptions)
                {
                    <option value="@opt">@opt / page</option>
                }
            </select>
        }

        @if (TotalPages > 1)
        {
            <div class="fc-list-pagination" role="navigation" aria-label="Pagination">
                <button class="fc-list-page-btn" disabled="@(CurrentPage == 1)"
                        @onclick="() => OnPageChanged.InvokeAsync(1)"
                        title="First page" aria-label="First page">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="11 17 6 12 11 7"/><polyline points="18 17 13 12 18 7"/>
                    </svg>
                </button>
                <button class="fc-list-page-btn" disabled="@(CurrentPage == 1)"
                        @onclick="() => OnPageChanged.InvokeAsync(CurrentPage - 1)"
                        title="Previous page" aria-label="Previous page">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="15 18 9 12 15 6"/>
                    </svg>
                </button>

                @foreach (var p in VisiblePages)
                {
                    @if (p == -1)
                    {
                        <span class="fc-list-page-btn fc-list-page-btn--ellipsis" aria-hidden="true">…</span>
                    }
                    else
                    {
                        var page = p;
                        <button class="fc-list-page-btn @(page == CurrentPage ? "fc-list-page-btn-active" : "")"
                                @onclick="() => OnPageChanged.InvokeAsync(page)"
                                aria-label="Page @page"
                                aria-current="@(page == CurrentPage ? "page" : null)">
                            @page
                        </button>
                    }
                }

                <button class="fc-list-page-btn" disabled="@(CurrentPage == TotalPages)"
                        @onclick="() => OnPageChanged.InvokeAsync(CurrentPage + 1)"
                        title="Next page" aria-label="Next page">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="9 18 15 12 9 6"/>
                    </svg>
                </button>
                <button class="fc-list-page-btn" disabled="@(CurrentPage == TotalPages)"
                        @onclick="() => OnPageChanged.InvokeAsync(TotalPages)"
                        title="Last page" aria-label="Last page">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/>
                    </svg>
                </button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public int CurrentPage { get; set; }
    [Parameter] public int TotalPages { get; set; }
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public int FilteredCount { get; set; }
    [Parameter] public int PageSize { get; set; }
    [Parameter] public int[] PageSizeOptions { get; set; } = [10, 25, 50, 100];
    [Parameter] public bool ShowPageSizeSelector { get; set; } = true;
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }
    [Parameter] public EventCallback<int> OnPageSizeChanged { get; set; }

    private int StartItem => FilteredCount == 0 ? 0 : (CurrentPage - 1) * PageSize + 1;
    private int EndItem => Math.Min(CurrentPage * PageSize, FilteredCount);

    private IEnumerable<int> VisiblePages
    {
        get
        {
            var total = TotalPages;
            var cur = CurrentPage;
            var pages = new List<int>();

            if (total <= 7)
            {
                for (var i = 1; i <= total; i++) pages.Add(i);
            }
            else
            {
                pages.Add(1);
                if (cur > 3) pages.Add(-1); // ellipsis
                for (var i = Math.Max(2, cur - 1); i <= Math.Min(total - 1, cur + 1); i++)
                    pages.Add(i);
                if (cur < total - 2) pages.Add(-1); // ellipsis
                pages.Add(total);
            }
            return pages;
        }
    }

    private async Task OnPageSizeSelectChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size))
            await OnPageSizeChanged.InvokeAsync(size);
    }
}
