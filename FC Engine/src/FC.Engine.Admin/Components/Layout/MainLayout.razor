@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<div class="admin-layout">
    <nav class="sidebar">
        <div class="sidebar-header">
            <h3>FC Engine</h3>
            <span class="subtitle">Admin Portal</span>
        </div>
        <NavMenu />
        <div class="sidebar-footer">
            <AuthorizeView>
                <Authorized Context="authState">
                    <div class="user-info">
                        <span class="user-name">@authState.User.Identity?.Name</span>
                        <span class="user-role">@authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                    </div>
                    <a href="/account/logout" class="logout-link">Sign Out</a>
                </Authorized>
            </AuthorizeView>
        </div>
    </nav>
    <main class="main-content">
        <header class="top-bar">
            <div class="breadcrumb-area">
                @Body
            </div>
        </header>
    </main>
</div>
