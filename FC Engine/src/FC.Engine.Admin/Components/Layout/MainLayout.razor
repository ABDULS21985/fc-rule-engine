@inherits LayoutComponentBase
@using System.Security.Claims
@inject NavigationManager Navigation
@implements IDisposable

<!-- Skip to content link for accessibility -->
<a href="#main-content" class="skip-link">Skip to main content</a>

<!-- Global progress bar -->
<div class="global-progress @(_navigating ? "is-loading" : (_progressComplete ? "is-complete" : ""))" aria-hidden="true">
    <div class="global-progress-bar"></div>
</div>

<div class="app-shell @(_sidebarOpen ? "sidebar-open" : "")">
    <!-- Sidebar -->
    <aside class="shell-sidebar" aria-label="Main navigation" @onkeydown="HandleSidebarKeyDown">
        <div class="sidebar-brand">
            <img src="images/cbn-logo.svg" alt="Central Bank of Nigeria" class="sidebar-brand-logo" width="40" height="33" />
            <div class="sidebar-brand-text">
                <span class="sidebar-brand-name">FC Engine</span>
                <span class="sidebar-brand-sub">Admin Portal</span>
            </div>
        </div>

        <NavMenu />

        <div class="sidebar-user">
            <AuthorizeView>
                <Authorized Context="authState">
                    @{
                        var displayName = authState.User.FindFirst("DisplayName")?.Value
                            ?? authState.User.Identity?.Name
                            ?? "User";
                        var userRole = authState.User.FindFirst(ClaimTypes.Role)?.Value ?? "Viewer";
                        var initials = GetInitials(displayName);
                    }
                    <div class="sidebar-user-info">
                        <div class="sidebar-user-avatar" aria-hidden="true">
                            <span>@initials</span>
                        </div>
                        <div class="sidebar-user-details">
                            <span class="sidebar-user-name">@displayName</span>
                            <span class="sidebar-user-role">@userRole</span>
                        </div>
                    </div>
                    <a href="/account/logout" class="sidebar-signout" aria-label="Sign out">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true">
                            <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                            <polyline points="16 17 21 12 16 7"/>
                            <line x1="21" y1="12" x2="9" y2="12"/>
                        </svg>
                        <span>Sign Out</span>
                    </a>
                </Authorized>
            </AuthorizeView>
        </div>
    </aside>

    <!-- Sidebar overlay for mobile -->
    <div class="sidebar-overlay" @onclick="CloseSidebar" role="presentation" aria-hidden="true"></div>

    <!-- Main Area -->
    <div class="shell-main">
        <header class="shell-topbar" role="banner">
            <div class="topbar-left">
                <button class="topbar-toggle" @onclick="ToggleSidebar" aria-label="@(_sidebarOpen ? "Close navigation" : "Open navigation")" aria-expanded="@_sidebarOpen">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true">
                        @if (_sidebarOpen)
                        {
                            <line x1="18" y1="6" x2="6" y2="18"/>
                            <line x1="6" y1="6" x2="18" y2="18"/>
                        }
                        else
                        {
                            <line x1="3" y1="12" x2="21" y2="12"/>
                            <line x1="3" y1="6" x2="21" y2="6"/>
                            <line x1="3" y1="18" x2="21" y2="18"/>
                        }
                    </svg>
                </button>
                <nav class="topbar-breadcrumb" aria-label="Breadcrumb">
                    <ol>
                        <li><a href="/">Home</a></li>
                        @if (_currentPageName != "Dashboard")
                        {
                            <li aria-current="page">@_currentPageName</li>
                        }
                    </ol>
                </nav>
            </div>

            <div class="topbar-right">
                <div class="topbar-search">
                    <svg class="topbar-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true">
                        <circle cx="11" cy="11" r="8"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <input type="text" class="topbar-search-input" placeholder="Search templates, rules..." aria-label="Search" />
                </div>
                <button class="topbar-notification" aria-label="Notifications">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                        <path d="M13.73 21a2 2 0 01-3.46 0"/>
                    </svg>
                </button>
            </div>
        </header>

        <main id="main-content" class="shell-content" role="main">
            <!-- Print letterhead (visible only in print) -->
            <div class="print-letterhead" aria-hidden="true">
                <div class="print-letterhead-title">Central Bank of Nigeria</div>
                <div class="print-letterhead-sub">FC Engine &mdash; @_currentPageName</div>
                <span class="print-letterhead-accent"></span>
            </div>

            @Body

            <!-- Print footer (visible only in print) -->
            <div class="print-footer" aria-hidden="true">
                FC Engine Admin Portal &bull; Central Bank of Nigeria &bull; Printed @DateTime.UtcNow.ToString("dd MMM yyyy HH:mm") UTC
            </div>
        </main>
    </div>
</div>

<!-- Global notification overlays -->
<ToastContainer />
<ConfirmDialog />

@code {
    private bool _sidebarOpen;
    private bool _navigating;
    private bool _progressComplete;
    private string _currentPageName = "Dashboard";

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        UpdatePageName(Navigation.Uri);
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _navigating = true;
        _progressComplete = false;
        UpdatePageName(e.Location);
        _sidebarOpen = false;
        StateHasChanged();

        await Task.Delay(300);
        _navigating = false;
        _progressComplete = true;
        StateHasChanged();

        await Task.Delay(500);
        _progressComplete = false;
        StateHasChanged();
    }

    private void UpdatePageName(string uri)
    {
        var path = new Uri(uri).AbsolutePath.TrimStart('/').ToLowerInvariant();
        _currentPageName = path switch
        {
            "" or "/" => "Dashboard",
            "templates" => "Templates",
            var p when p.StartsWith("templates/") => "Template Detail",
            "formulas" => "Formulas",
            "cross-sheet-rules" => "Cross-Sheet Rules",
            var p when p.StartsWith("cross-sheet-rules/") => "Cross-Sheet Rule Detail",
            "business-rules" => "Business Rules",
            "submissions" => "Submissions",
            var p when p.StartsWith("submissions/") => "Submission Detail",
            "impact-analysis" => "Impact Analysis",
            "audit" => "Audit Log",
            "users" => "User Management",
            _ => "Page"
        };
    }

    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;
    private void CloseSidebar() => _sidebarOpen = false;

    private void HandleSidebarKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" && _sidebarOpen)
            _sidebarOpen = false;
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
        return name[..Math.Min(2, name.Length)].ToUpperInvariant();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
