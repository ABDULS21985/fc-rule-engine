</AuthorizeView>

@code {
    private bool _isPlatformAdmin;
    private HashSet<string> _activeModules = new(StringComparer.OrdinalIgnoreCase);
    private BrandingConfig _branding = BrandingConfig.WithDefaults();

    protected override async Task OnInitializedAsync()
    {
        _isPlatformAdmin = TenantContext.IsPlatformAdmin;

        if (_isPlatformAdmin)
        {
            return;
        }

        if (TenantContext.CurrentTenantId is { } tenantId)
        {
            _branding = await BrandingService.GetBrandingConfig(tenantId);

            try
            {
                var entitlement = await EntitlementSvc.ResolveEntitlements(tenantId);
                _activeModules = entitlement.ActiveModules
                    .Select(m => m.ModuleCode)
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);
            }
            catch
            {
                _activeModules = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            }
        }
    }

    private bool CanAccessModulePages() => _isPlatformAdmin || _activeModules.Count > 0;
}
