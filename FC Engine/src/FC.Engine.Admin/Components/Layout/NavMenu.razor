                            </NavLink>
                        </li>
                        <li>
                            <NavLink href="/licence-types" class="nav-item">
                                <svg class="nav-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                    <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                                    <polyline points="16 17 21 12 16 7"/>
                                    <line x1="21" y1="12" x2="9" y2="12"/>
                                </svg>
                                <span class="nav-item-label">Licence Types</span>
                            </NavLink>
                        </li>
                        <li>
                            <NavLink href="/billing/plans" class="nav-item">
                                <svg class="nav-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                    <rect x="2" y="6" width="20" height="12" rx="2"/>
                                    <line x1="2" y1="10" x2="22" y2="10"/>
                                </svg>
                                <span class="nav-item-label">Billing Plans</span>
                            </NavLink>
                        </li>
                        <li>
                            <NavLink href="/billing/subscriptions" class="nav-item">
                                <svg class="nav-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                    <path d="M16 3h5v5"/>
                                    <path d="M4 20L21 3"/>
                                    <path d="M21 16v5h-5"/>
                                    <path d="M15 21L3 9"/>
                                </svg>
                                <span class="nav-item-label">Subscriptions</span>
                            </NavLink>
                        </li>
                        <li>
                            <NavLink href="/billing/invoices" class="nav-item">
                                <svg class="nav-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                                    <polyline points="14 2 14 8 20 8"/>
                                    <line x1="8" y1="13" x2="16" y2="13"/>
                                </svg>
                                <span class="nav-item-label">Invoices</span>
                            </NavLink>
                        </li>
                        <li>
                            <NavLink href="/billing/revenue" class="nav-item">
                                <svg class="nav-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                                    <line x1="12" y1="20" x2="12" y2="10"/>
                                    <line x1="18" y1="20" x2="18" y2="4"/>
                                    <line x1="6" y1="20" x2="6" y2="14"/>
                                </svg>
                                <span class="nav-item-label">Revenue</span>
                            </NavLink>
                        </li>
                    </ul>
                </div>
            }

        </nav>
