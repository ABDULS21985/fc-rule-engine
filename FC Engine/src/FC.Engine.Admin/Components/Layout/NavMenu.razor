@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Enums
@using FC.Engine.Infrastructure.Services
@using FC.Engine.Admin.Services
@inject IEntitlementService EntitlementSvc
@inject ITenantContext TenantContext
@inject ITenantAccessContextResolver TenantAccessContextResolver
@inject IPlatformRegulatorTenantResolver PlatformRegulatorTenantResolver
@inject SidebarStateService SidebarState
@inject NavigationManager Navigation
@inject ToastService Toast
@inject IJSRuntime JS
@inject DataCacheService DataCache
@implements IAsyncDisposable

<AuthorizeView>
    <Authorized Context="navAuth">

        @* ── Search ─────────────────────────────────────────────────── *@
        <div class="fc-nav__search-wrap @(SidebarState.IsCollapsed ? "fc-nav__search-wrap--collapsed" : "")">
            @if (!SidebarState.IsCollapsed)
            {
                <div class="fc-nav__search">
                    <svg class="fc-nav__search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13" aria-hidden="true">
                        <circle cx="11" cy="11" r="8"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <input class="fc-nav__search-input"
                           type="search"
                           placeholder="Search navigation…"
                           aria-label="Search navigation"
                           autocomplete="off"
                           @bind="_searchQuery"
                           @bind:event="oninput"
                           @ref="_searchInputRef" />
                    @if (!string.IsNullOrEmpty(_searchQuery))
                    {
                        <button class="fc-nav__search-clear" @onclick="ClearSearch" aria-label="Clear search" tabindex="-1">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="11" height="11" aria-hidden="true">
                                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                            </svg>
                        </button>
                    }
                </div>
            }
            else
            {
                <button class="fc-nav__search-icon-btn" @onclick="ExpandAndFocusSearch" aria-label="Search navigation (expand sidebar)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true">
                        <circle cx="11" cy="11" r="8"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                </button>
            }
        </div>


        <nav class="fc-nav" aria-label="Primary navigation">

            @* ── Search results (flat, ungrouped) ────────────────────── *@
            @if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                var results = GetSearchResults();
                if (results.Count > 0)
                {
                    <div class="fc-nav__group">
                        <h3 class="fc-nav__group-label">Results</h3>
                        <ul class="fc-nav__group-items-inner">
                            @foreach (var item in results)
                            {
                                @RenderNavItem(item, false)
                            }
                        </ul>
                    </div>
                }
                else
                {
                    <div class="fc-nav__empty-search">
                        <span>No matches for "@_searchQuery"</span>
                    </div>
                }
            }
            else
            {
                @* ── Favorites ─────────────────────────────────────────── *@
                @if (SidebarState.Favorites.Count > 0)
                {
                    <div class="fc-nav__group @(SidebarState.IsGroupCollapsed("favorites") ? "is-collapsed" : "")">
                        <button class="fc-nav__group-header"
                                @onclick='() => ToggleGroup("favorites")'
                                aria-expanded="@(!SidebarState.IsGroupCollapsed("favorites"))"
                                aria-label="Favorites section">
                            <span class="fc-nav__group-header-inner">
                                <svg class="fc-nav__group-header-icon" viewBox="0 0 24 24" fill="currentColor" stroke="none" width="11" height="11" aria-hidden="true">
                                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                </svg>
                                @if (!SidebarState.IsCollapsed)
                                {
                                    <span class="fc-nav__group-label-text">Favorites</span>
                                }
                            </span>
                            @if (!SidebarState.IsCollapsed)
                            {
                                <svg class="fc-nav__group-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="12" height="12" aria-hidden="true">
                                    <polyline points="6 9 12 15 18 9"/>
                                </svg>
                            }
                        </button>
                        <div class="fc-nav__group-items">
                            <ul class="fc-nav__group-items-inner">
                                @foreach (var fav in SidebarState.Favorites)
                                {
                                    @RenderNavItem(new NavItemModel(fav.Label, fav.Href, fav.IconPath, 0, false, [], "favorites"), true)
                                }
                            </ul>
                        </div>
                    </div>
                }

                @* ── Recent ────────────────────────────────────────────── *@
                @if (SidebarState.RecentPages.Count > 0)
                {
                    <div class="fc-nav__group @(SidebarState.IsGroupCollapsed("recent") ? "is-collapsed" : "")">
                        <button class="fc-nav__group-header"
                                @onclick='() => ToggleGroup("recent")'
                                aria-expanded="@(!SidebarState.IsGroupCollapsed("recent"))"
                                aria-label="Recent pages section">
                            <span class="fc-nav__group-header-inner">
                                <svg class="fc-nav__group-header-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="11" height="11" aria-hidden="true">
                                    <circle cx="12" cy="12" r="10"/>
                                    <polyline points="12 6 12 12 16 14"/>
                                </svg>
                                @if (!SidebarState.IsCollapsed)
                                {
                                    <span class="fc-nav__group-label-text">Recent</span>
                                }
                            </span>
                            @if (!SidebarState.IsCollapsed)
                            {
                                <svg class="fc-nav__group-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="12" height="12" aria-hidden="true">
                                    <polyline points="6 9 12 15 18 9"/>
                                </svg>
                            }
                        </button>
                        <div class="fc-nav__group-items">
                            <ul class="fc-nav__group-items-inner">
                                @foreach (var recent in SidebarState.RecentPages)
                                {
                                    @RenderNavItem(new NavItemModel(recent.Label, recent.Href, recent.IconPath, 0, false, [], "recent"), false)
                                }
                            </ul>
                        </div>
                    </div>
                }

                @* ── Regular groups ────────────────────────────────────── *@
                @foreach (var group in GetVisibleGroups())
                {
                    <div class="fc-nav__group @(SidebarState.IsGroupCollapsed(group.Id) ? "is-collapsed" : "")">
                        <button class="fc-nav__group-header"
                                @onclick="() => ToggleGroup(group.Id)"
                                aria-expanded="@(!SidebarState.IsGroupCollapsed(group.Id))"
                                aria-label="@group.Label section">
                            <span class="fc-nav__group-header-inner">
                                @if (!SidebarState.IsCollapsed)
                                {
                                    <span class="fc-nav__group-label-text">@group.Label</span>
                                }
                            </span>
                            @if (!SidebarState.IsCollapsed)
                            {
                                <svg class="fc-nav__group-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="12" height="12" aria-hidden="true">
                                    <polyline points="6 9 12 15 18 9"/>
                                </svg>
                            }
                        </button>
                        <div class="fc-nav__group-items">
                            <ul class="fc-nav__group-items-inner">
                                @foreach (var item in group.Items)
                                {
                                    @RenderNavItem(item, false)
                                }
                            </ul>
                        </div>
                    </div>
                }
            }

        </nav>

        @* ── Context menu (single shared instance) ───────────────────── *@
        <NavContextMenu @ref="_contextMenu" OnFavoriteToggled="HandleContextAction" />

    </Authorized>
</AuthorizeView>

@* ── Nav item render helper ─────────────────────────────────────────── *@
@code {

    private RenderFragment RenderNavItem(NavItemModel item, bool alwaysActive) =>
        @<li @key="item.Href">
            @if (item.IsLocked)
            {
                <div class="fc-nav__item fc-nav__item--locked"
                     @onmouseenter="() => ShowTooltip(item)"
                     @onmouseleave="HideTooltip"
                     title="@(SidebarState.IsCollapsed ? item.Label : null)"
                     aria-label="@item.Label — module not active">
                    <svg class="fc-nav__item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                        @((MarkupString)item.IconPath)
                    </svg>
                    @if (!SidebarState.IsCollapsed)
                    {
                        <span class="fc-nav__item-label">@item.Label</span>
                        <svg class="fc-nav__lock-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-label="Module not active">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0110 0v4"/>
                        </svg>
                    }
                </div>
            }
            else
            {
                <NavLink href="@item.Href"
                         Match="@(item.Href == "/" ? NavLinkMatch.All : NavLinkMatch.Prefix)"
                         class="fc-nav__item"
                         @oncontextmenu="(e) => OnRightClick(e, item)"
                         @onmouseenter="() => OnNavItemHover(item)"
                         @onmouseleave="HideTooltip"
                         aria-label="@item.Label">
                    <svg class="fc-nav__item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                        @((MarkupString)item.IconPath)
                    </svg>
                    @if (!SidebarState.IsCollapsed)
                    {
                        <span class="fc-nav__item-label">@item.Label</span>
                        @if (item.BadgeCount > 0)
                        {
                            <span class="fc-nav__badge" aria-label="@item.BadgeCount pending">
                                @(item.BadgeCount > 99 ? "99+" : item.BadgeCount.ToString())
                            </span>
                        }
                    }
                    else if (item.BadgeCount > 0)
                    {
                        <span class="fc-nav__badge fc-nav__badge--dot" aria-label="@item.BadgeCount pending"></span>
                    }
                </NavLink>
            }
        </li>;

}

@code {
    // ── Injected refs ────────────────────────────────────────────────
    private NavContextMenu? _contextMenu;
    private ElementReference _searchInputRef;
    private DotNetObjectReference<NavMenu>? _dotNetRef;

    // ── State ────────────────────────────────────────────────────────
    private bool _isPlatformAdmin;
    private bool _hasRegulatorPortalAccess;
    private HashSet<string> _activeModules = new(StringComparer.OrdinalIgnoreCase);
    private string _searchQuery = string.Empty;

    // ── Lifecycle ────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _isPlatformAdmin = TenantContext.IsPlatformAdmin;
        await ResolveRegulatorPortalAccessAsync();

        if (!_isPlatformAdmin && TenantContext.CurrentTenantId is { } tenantId)
        {
            try
            {
                var entitlement = await EntitlementSvc.ResolveEntitlements(tenantId);
                _activeModules = entitlement.ActiveModules
                    .Select(m => m.ModuleCode)
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);
            }
            catch
            {
                _activeModules = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            }
        }

        SidebarState.OnStateChanged += OnSidebarStateChanged;
        Navigation.LocationChanged  += OnLocationChanged;
    }

    private async Task ResolveRegulatorPortalAccessAsync()
    {
        _hasRegulatorPortalAccess = false;

        if (TenantContext.CurrentTenantId.HasValue)
        {
            try
            {
                var accessContext = await TenantAccessContextResolver.TryResolveAsync(TenantContext.CurrentTenantId.Value);
                _hasRegulatorPortalAccess = accessContext?.TenantType == TenantType.Regulator;
            }
            catch
            {
                _hasRegulatorPortalAccess = false;
            }
        }

        if (_hasRegulatorPortalAccess || !_isPlatformAdmin)
        {
            return;
        }

        try
        {
            _hasRegulatorPortalAccess = await PlatformRegulatorTenantResolver.TryResolveAsync() is not null;
        }
        catch
        {
            _hasRegulatorPortalAccess = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SidebarState.InitializeAsync();
            _dotNetRef = DotNetObjectReference.Create(this);
            StateHasChanged();
        }
    }

    private void OnSidebarStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            // Track the visited page in the Recent section
            var item = FindNavItemByHref(e.Location);
            if (item != null)
            {
                await SidebarState.AddRecentPageAsync(
                    new SidebarNavItem(item.Label, item.Href, item.IconPath));
            }
        });
    }

    // ── Navigation model ─────────────────────────────────────────────

    private NavItemModel? FindNavItemByHref(string uri)
    {
        var path = "/" + new Uri(uri).AbsolutePath.TrimStart('/');
        foreach (var group in GetVisibleGroups())
        {
            var match = group.Items.FirstOrDefault(i =>
                string.Equals(i.Href, path, StringComparison.OrdinalIgnoreCase));
            if (match != null) return match;
        }
        return null;
    }

    private bool HasModules() => _isPlatformAdmin || _activeModules.Count > 0;

    private bool IsModuleActive(string moduleCode) =>
        _isPlatformAdmin || _activeModules.Contains(moduleCode);

    private List<NavGroup> GetVisibleGroups()
