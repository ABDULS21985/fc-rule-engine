    // ── Search ───────────────────────────────────────────────────────

    private List<NavItemModel> GetSearchResults()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery)) return [];
        var q = _searchQuery.Trim();
        return GetVisibleGroups()
            .SelectMany(g => g.Items)
            .Where(i => i.Label.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                        i.Href.Contains(q, StringComparison.OrdinalIgnoreCase))
            .Take(10)
            .ToList();
    }

    private void ClearSearch() => _searchQuery = string.Empty;

    private async Task ExpandAndFocusSearch()
    {
        await SidebarState.SetCollapsedAsync(false);
        await Task.Yield();
        await JS.InvokeVoidAsync("FCSidebar.focusNavSearch");
    }

    // ── Group accordion ──────────────────────────────────────────────

    private Task ToggleGroup(string groupId) => SidebarState.ToggleGroupAsync(groupId);

    // ── Context menu ─────────────────────────────────────────────────

    private async Task OnRightClick(MouseEventArgs e, NavItemModel item)
    {
        if (_contextMenu == null) return;
        var ctxItem = new NavContextMenu.NavContextItem(item.Label, item.Href, item.IconPath, item.QuickActions);
        await _contextMenu.ShowAsync(e.ClientX, e.ClientY, ctxItem,
            SidebarState.IsFavorite(item.Href));
    }

    private async Task HandleContextAction(string href)
    {
        if (href.StartsWith("__action__"))
        {
            var target = href["__action__".Length..];
            Navigation.NavigateTo(target);
            return;
        }

        // Toggle favorite
        var item = FindNavItemByHref(href) ??
                   GetVisibleGroups().SelectMany(g => g.Items)
                       .FirstOrDefault(i => i.Href == href);

        if (item != null)
        {
            await SidebarState.ToggleFavoriteAsync(
                new SidebarNavItem(item.Label, item.Href, item.IconPath));
            var pinned = SidebarState.IsFavorite(item.Href);
            if (pinned)
                Toast.Success($"\u201c{item.Label}\u201d pinned to Favorites");
            else
                Toast.Info($"\u201c{item.Label}\u201d unpinned");
        }
    }

    // ── Tooltip (collapsed mode) ──────────────────────────────────────

    private void OnNavItemHover(NavItemModel item)
    {
        ShowTooltip(item);
        PrefetchRoute(item.Href);
    }

    private void ShowTooltip(NavItemModel item)
    {
        // tooltip is positioned by CSS :after in collapsed mode; JS as fallback
    }

    private Task HideTooltip() => Task.CompletedTask;

    // ── Hover prefetch ────────────────────────────────────────────────

    private CancellationTokenSource? _prefetchCts;

    private async void PrefetchRoute(string route)
    {
        _prefetchCts?.Cancel();
        _prefetchCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(250, _prefetchCts.Token);
            await DataCache.PrefetchAsync(route);
        }
        catch (TaskCanceledException) { }
    }

    // ── Dispose ──────────────────────────────────────────────────────

    public ValueTask DisposeAsync()
    {
        SidebarState.OnStateChanged -= OnSidebarStateChanged;
        Navigation.LocationChanged  -= OnLocationChanged;
        _dotNetRef?.Dispose();
        _prefetchCts?.Dispose();
        return ValueTask.CompletedTask;
    }
}

