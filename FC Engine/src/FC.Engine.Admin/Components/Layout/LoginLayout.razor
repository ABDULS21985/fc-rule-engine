@inherits LayoutComponentBase

<div class="login-layout" style="display:flex;min-height:100vh;">
    <!-- Left Brand Panel -->
    <aside class="login-brand-panel" aria-hidden="true" style="position:relative;overflow:hidden;background:#003320;">
        <div class="brand-bg-layer"></div>
        <div class="brand-bg-accent"></div>

        <div class="brand-content">
            <div class="brand-logo-wrapper">
                <img src="images/cbn-logo.svg" alt="" class="brand-logo" width="130" height="108" style="width:130px;height:auto;" />
            </div>

            <h1 class="brand-name">Central Bank of Nigeria</h1>

            <div class="brand-separator" role="presentation">
                <span class="separator-line"></span>
            </div>

            <p class="brand-tagline">Financial Returns Collection &amp; Analysis System</p>
        </div>

        <div class="brand-panel-footer">
            <span>Secure Regulatory Platform</span>
        </div>
    </aside>

    <!-- Right Content Panel -->
    <main class="login-content-panel" style="flex:1;display:flex;align-items:center;justify-content:center;">
        @Body
    </main>
</div>
