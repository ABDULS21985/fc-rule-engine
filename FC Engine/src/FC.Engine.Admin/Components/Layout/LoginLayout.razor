@inherits LayoutComponentBase

<div class="login-layout">
    <!-- Left Brand Panel -->
    <aside class="login-brand-panel" aria-hidden="true">
        <div class="brand-bg-layer"></div>
        <div class="brand-bg-accent"></div>

        <div class="brand-content">
            <div class="brand-logo-wrapper">
                <img src="images/cbn-logo.svg" alt="" class="brand-logo" />
            </div>

            <h1 class="brand-name">Central Bank of Nigeria</h1>

            <div class="brand-separator" role="presentation">
                <span class="separator-line"></span>
            </div>

            <p class="brand-tagline">Financial Returns Collection &amp; Analysis System</p>
        </div>

        <div class="brand-panel-footer">
            <span>Secure Regulatory Platform</span>
        </div>
    </aside>

    <!-- Right Content Panel -->
    <main class="login-content-panel">
        @Body
    </main>
</div>
