{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "ConnectionStrings": {
    "FcEngine": "Server=(localdb)\\mssqllocaldb;Database=FcEngine;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "EWIEngine": {
    "CycleIntervalMinutes": 60,
    "DefaultRegulatorCode": "CBN",
    "AutoGenerateActions": true,
    "RunContagionAnalysis": true
  },
  "DataResidency": {
    "DefaultRegion": "SouthAfricaNorth",
    "MultiJurisdictionRegion": "WestEurope",
    "RegionConnectionStrings": {
      "SouthAfricaNorth": "FcEngine",
      "WestEurope": "FcEngine",
      "UAE North": "FcEngine",
      "UAENorth": "FcEngine"
    }
  }
}
