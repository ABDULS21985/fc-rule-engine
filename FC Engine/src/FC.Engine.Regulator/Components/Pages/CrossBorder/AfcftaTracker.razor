@page "/cross-border/afcfta"
@attribute [Authorize(Policy = "RegulatorOnly")]
@inject IAfcftaTrackingService AfcftaService
@inject NavigationManager Nav

<PageTitle>AfCFTA Protocol Tracker — RegOS™</PageTitle>

<div class="rg-cb-hero">
    <div class="rg-cb-hero-text">
        <div class="rg-cb-kicker">Cross-Border Harmonisation</div>
        <h1 class="rg-cb-hero-title">AfCFTA Protocol Tracker</h1>
        <p class="rg-cb-hero-sub">
            Track the African Continental Free Trade Area financial services protocols
            and their impact on RegOS™ regulatory compliance.
        </p>
    </div>
</div>

@* ── Summary KPIs ── *@
@if (_protocols.Count > 0)
{
    <div class="rg-cb-kpis" style="margin-bottom:1rem;">
        <div class="rg-card rg-cb-kpi rg-cb-kpi--success">
            <div class="rg-cb-kpi-value rg-cb-kpi-value--success">@_protocols.Count(p => p.Status == AfcftaProtocolStatus.Effective)</div>
            <div class="rg-cb-kpi-label">Effective</div>
        </div>
        <div class="rg-card rg-cb-kpi rg-cb-kpi--info">
            <div class="rg-cb-kpi-value rg-cb-kpi-value--info">@_protocols.Count(p => p.Status == AfcftaProtocolStatus.Enacted)</div>
            <div class="rg-cb-kpi-label">Enacted</div>
        </div>
        <div class="rg-card rg-cb-kpi rg-cb-kpi--warning">
            <div class="rg-cb-kpi-value rg-cb-kpi-value--warning">@_protocols.Count(p => p.Status == AfcftaProtocolStatus.Negotiating || p.Status == AfcftaProtocolStatus.Agreed)</div>
            <div class="rg-cb-kpi-label">In Progress</div>
        </div>
        <div class="rg-card rg-cb-kpi rg-cb-kpi--info">
            <div class="rg-cb-kpi-value rg-cb-kpi-value--info">@_protocols.Count(p => p.Status == AfcftaProtocolStatus.Proposed)</div>
            <div class="rg-cb-kpi-label">Proposed</div>
        </div>
    </div>
}

@* ── Tabs ── *@
<div class="rg-cb-tabs">
    <button class="rg-cb-tab @(_view == "timeline" ? "rg-cb-tab--active" : "")" @onclick='() => _view = "timeline"'>Timeline</button>
    <button class="rg-cb-tab @(_view == "table" ? "rg-cb-tab--active" : "")" @onclick='() => _view = "table"'>Table</button>
</div>

@if (_loading)
{
    <p class="rg-muted">Loading protocols…</p>
}
else if (_protocols.Count == 0)
{
    <div class="rg-cb-empty">
        <div class="rg-cb-empty-icon">🌍</div>
        <div class="rg-cb-empty-title">No Protocols Tracked</div>
        <div class="rg-cb-empty-desc">No AfCFTA financial services protocols are being tracked yet.</div>
    </div>
}
else if (_view == "timeline")
{
    @* ── Timeline View ── *@
    <div class="rg-cb-protocol-timeline">
        @foreach (var p in _protocols.OrderByDescending(p => p.Status).ThenBy(p => p.TargetEffectiveDate))
        {
            var cardClass = p.Status switch
            {
                AfcftaProtocolStatus.Effective => "rg-cb-proto-card--effective",
                AfcftaProtocolStatus.Enacted => "rg-cb-proto-card--enacted",
                _ => ""
            };

            <div class="rg-card rg-cb-proto-card @cardClass">
                <div class="rg-cb-proto-head">
                    <span class="rg-cb-proto-name">@p.ProtocolName</span>
                    <StatusPill Label="@p.Status.ToString()" Variant="@GetStatusVariant(p.Status)" />
                </div>
                @if (!string.IsNullOrEmpty(p.Description))
                {
                    <div class="rg-cb-proto-desc">@p.Description</div>
                }
                <div class="rg-cb-proto-meta">
                    <span>📋 @p.Category</span>
                    <span>🔖 @p.ProtocolCode</span>
                    @if (p.TargetEffectiveDate.HasValue)
                    {
                        <span>🎯 Target: @p.TargetEffectiveDate.Value.ToString("dd MMM yyyy")</span>
                    }
                    @if (p.ActualEffectiveDate.HasValue)
                    {
                        <span>✓ Effective: @p.ActualEffectiveDate.Value.ToString("dd MMM yyyy")</span>
                    }
                </div>
                @if (p.ParticipatingJurisdictions.Count > 0)
                {
                    <div class="rg-cb-proto-flags">
                        @foreach (var j in p.ParticipatingJurisdictions)
                        {
                            <span title="@j">@GetFlag(j)</span>
                        }
                    </div>
                }
                @if (!string.IsNullOrEmpty(p.ImpactOnRegOS))
                {
                    <div style="margin-top:0.4rem;padding:0.4rem 0.6rem;border-radius:6px;background:#fffbeb;border:1px solid #fde68a;font-size:0.78rem;color:#92400e;">
                        <strong>RegOS™ Impact:</strong> @p.ImpactOnRegOS
                    </div>
                }

                @* ── Progress Steps ── *@
                <div style="display:flex;gap:0.25rem;margin-top:0.5rem;">
                    @{
                        var allStatuses = new[] { AfcftaProtocolStatus.Proposed, AfcftaProtocolStatus.Negotiating, AfcftaProtocolStatus.Agreed, AfcftaProtocolStatus.Enacted, AfcftaProtocolStatus.Effective };
                    }
                    @foreach (var s in allStatuses)
                    {
                        var isDone = p.Status >= s;
                        <div style="flex:1;height:4px;border-radius:2px;background:@(isDone ? "var(--rg-primary)" : "#e2e8f0");transition:background 0.3s;"></div>
                    }
                </div>
            </div>
        }
    </div>
}
else
{
    @* ── Table View ── *@
    <div class="rg-table-wrap">
        <table class="rg-table">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Protocol</th>
                    <th>Category</th>
                    <th>Status</th>
                    <th>Jurisdictions</th>
                    <th>Target Date</th>
                    <th>Impact</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in _protocols)
                {
                    <tr>
                        <td><code style="font-size:0.78rem;">@p.ProtocolCode</code></td>
                        <td>
                            <div><strong>@p.ProtocolName</strong></div>
                            @if (!string.IsNullOrEmpty(p.Description))
                            {
                                <div style="font-size:0.72rem;color:var(--rg-muted);max-width:300px;">@p.Description</div>
                            }
                        </td>
                        <td>@p.Category</td>
                        <td><StatusPill Label="@p.Status.ToString()" Variant="@GetStatusVariant(p.Status)" /></td>
                        <td>
                            <div style="display:flex;gap:0.15rem;">
                                @foreach (var j in p.ParticipatingJurisdictions)
                                {
                                    <span title="@j" style="font-size:0.9rem;">@GetFlag(j)</span>
                                }
                            </div>
                        </td>
                        <td>@(p.TargetEffectiveDate?.ToString("dd MMM yyyy") ?? "—")</td>
                        <td style="font-size:0.78rem;max-width:200px;">@(p.ImpactOnRegOS ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private bool _loading = true;
    private string _view = "timeline";
    private List<AfcftaProtocolDto> _protocols = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await AfcftaService.ListProtocolsAsync();
            _protocols = result.ToList();
        }
        catch { _protocols = []; }
        finally { _loading = false; }
    }

    private static string GetStatusVariant(AfcftaProtocolStatus status) => status switch
    {
        AfcftaProtocolStatus.Effective => "success",
        AfcftaProtocolStatus.Enacted => "primary",
        AfcftaProtocolStatus.Agreed => "info",
        AfcftaProtocolStatus.Negotiating => "warning",
        AfcftaProtocolStatus.Proposed => "default",
        _ => "default"
    };

    private static string GetFlag(string isoCode)
    {
        if (string.IsNullOrEmpty(isoCode) || isoCode.Length < 2) return "🏳";
        var upper = isoCode[..2].ToUpperInvariant();
        return string.Concat(upper.Select(c => char.ConvertFromUtf32(0x1F1E6 + c - 'A')));
    }
}
