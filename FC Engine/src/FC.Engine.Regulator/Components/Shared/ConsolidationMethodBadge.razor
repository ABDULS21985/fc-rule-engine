@* Consolidation method badge *@

<span class="rg-cb-pill rg-cb-pill--@GetVariant(Method)">@Method</span>

@code {
    [Parameter] public ConsolidationMethod Method { get; set; }

    private static string GetVariant(ConsolidationMethod m) => m switch
    {
        ConsolidationMethod.Full => "primary",
        ConsolidationMethod.Proportional => "warning",
        ConsolidationMethod.Equity => "info",
        _ => "default"
    };
}
