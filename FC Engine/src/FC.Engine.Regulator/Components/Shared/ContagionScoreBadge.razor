<span class="rg-badge rg-badge-@_bandClass" title="Contagion Risk Score: @Score.ToString("F1")">
    @Score.ToString("F0")
</span>

@code {
    [Parameter, EditorRequired] public double Score { get; set; }

    private string _bandClass => Score switch
    {
        >= 70 => "critical",
        >= 50 => "red",
        >= 30 => "amber",
        _     => "green"
    };
}
